Object oImportContacts is a cWEsWebView

    { WebProperty=Server }
    Property tImportDynamicColumns[] paImportDynamicColumns
    { WebProperty=Server }
    Property tImportFileSpects pImportFileSpects
    
    { DesignTime = False }
    Property Handle phoImportFirst
    { DesignTime = False }
    Property Handle phoEmployee
    { DesignTime = False }
    Property Handle phoHotContacts
    { DesignTime = False }
    Property Handle phoColumnMatches
    { DesignTime = False }
    Property Handle phoPreview

//    Object oCustType_DD is a Custtype_DataDictionary
