    Object oChangeCharacterCommandToFunction is a cTestFixture
        Set psFunctionName to "ChangeCharacterCommandToFunction"

        // Character {ascii} to {dest} -> Move (Character(ascii)) to dest
        { Published = True }
        Procedure ChangeCharacterCommandToFunction_NumericArg
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Character 13 to CR' to sLine
            Move 'Move (Character(13)) to CR' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeCharacterCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // A pre-parenthesised argument must NOT be double-wrapped: (9) -> Character(9), not ((9)).
        { Published = True }
        Procedure ChangeCharacterCommandToFunction_ParenArg
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Character (9) to iInt' to sLine
            Move 'Move (Character(9)) to iInt' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeCharacterCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Leading indentation is preserved.
        { Published = True }
        Procedure ChangeCharacterCommandToFunction_PreservesIndent
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Character 10 to LF' to sLine
            Move '    Move (Character(10)) to LF' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeCharacterCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // A line with no Character command is unchanged and reports no change.
        { Published = True }
        Procedure ChangeCharacterCommandToFunction_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move x to y' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeCharacterCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Move x to y' sLine
        End_Procedure

    End_Object
