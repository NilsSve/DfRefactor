    // Unit tests for the UnicodePointerToString refactoring function (the public
    // wrapper on ghoFuncLib, which drives the cUnicodePointerToString class).
    // It wraps a bare  Move <Pointer/Address local> to <String local>  with
    // PointerToString() and ONLY that, leaving every other Move untouched.
    //
    // Each test feeds a small synthetic source file as a String array, resets the
    // lexer state first (ClearFuncLibProperties, as the engine does per file), then
    // checks the returned rewrite count and the affected line.
    Object oUnicodePointerToString is a cTestFixture
        Set psFunctionName to "UnicodePointerToString"

        // A declared Address source + String dest -> wrapped.
        {Published = True}
        Procedure UnicodePointerToString_Address_Wrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function Foo Global Returns String" to asCode[0]
            Move "    String sStr"             to asCode[1]
            Move "    Address aPtr"            to asCode[2]
            Move "    Move aPtr to sStr"       to asCode[3]
            Move "    Function_Return sStr"    to asCode[4]
            Move "End_Function"                to asCode[5]
            Get UnicodePointerToString of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "    Move (PointerToString(aPtr)) to sStr" asCode[3]
        End_Procedure

        // A declared Pointer source also qualifies (same 4539).
        {Published = True}
        Procedure UnicodePointerToString_Pointer_Wrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function Foo Global Returns String" to asCode[0]
            Move "    String sData"            to asCode[1]
            Move "    Pointer pData"           to asCode[2]
            Move "    Move pData to sData"     to asCode[3]
            Move "End_Function"                to asCode[4]
            Get UnicodePointerToString of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "    Move (PointerToString(pData)) to sData" asCode[3]
        End_Procedure

        // REGRESSION: an early Function_Return BEFORE the Move must NOT wipe the
        // per-method type map (the bug the class first shipped with - _IsFunction-
        // Declaration matched "Function_Return", resetting the pointer/string sets).
        {Published = True}
        Procedure UnicodePointerToString_FunctionReturnBeforeMove_Wrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function Bar Global Integer iIn Returns String" to asCode[0]
            Move "    String sResult"          to asCode[1]
            Move "    Address aResult"         to asCode[2]
            Move "    If (iIn = 0) Begin"      to asCode[3]
            Move "        Function_Return sResult" to asCode[4]
            Move "    End"                     to asCode[5]
            Move "    Move aResult to sResult" to asCode[6]
            Move "    Function_Return sResult" to asCode[7]
            Move "End_Function"                to asCode[8]
            Get UnicodePointerToString of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "    Move (PointerToString(aResult)) to sResult" asCode[6]
        End_Procedure

        // Integer -> Integer is untouched (count 0, line unchanged).
        {Published = True}
        Procedure UnicodePointerToString_IntegerMove_NotWrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function Foo Global Returns Integer" to asCode[0]
            Move "    Integer iA iB"           to asCode[1]
            Move "    Move iA to iB"           to asCode[2]
            Move "End_Function"                to asCode[3]
            Get UnicodePointerToString of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 0)
            Send AssertSAreEqual "    Move iA to iB" asCode[2]
        End_Procedure

        // String -> Address (the reverse direction) is OUT OF SCOPE - untouched.
        {Published = True}
        Procedure UnicodePointerToString_StringToAddress_NotWrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function Foo Global Returns Integer" to asCode[0]
            Move "    String sX"               to asCode[1]
            Move "    Address aY"              to asCode[2]
            Move "    Move sX to aY"           to asCode[3]
            Move "End_Function"                to asCode[4]
            Get UnicodePointerToString of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 0)
            Send AssertSAreEqual "    Move sX to aY" asCode[3]
        End_Procedure

        // Per-method scope: a Pointer/Address declared in one method must not
        // license a Move in another method (guards the per-method scope reset).
        {Published = True}
        Procedure UnicodePointerToString_ScopeIsolation_NotWrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function A Global Returns Integer" to asCode[0]
            Move "    Address aPtr"            to asCode[1]
            Move "End_Function"                to asCode[2]
            Move "Function B Global Returns String" to asCode[3]
            Move "    String sStr"             to asCode[4]
            Move "    Move aPtr to sStr"       to asCode[5]
            Move "End_Function"                to asCode[6]
            Get UnicodePointerToString of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 0)
            Send AssertSAreEqual "    Move aPtr to sStr" asCode[5]
        End_Procedure

    End_Object
