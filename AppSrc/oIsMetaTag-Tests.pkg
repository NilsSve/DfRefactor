    Object oIsMetaTag is a cTestFixture
        Set psFunctionName to "IsMetaTag"

        {Published = True}
        Procedure IsMetaTag_1
            // Detects {MethodType=...} tag.
            Send Assert (IsMetaTag("{ MethodType = eStandardFunction }", eMethodType))
        End_Procedure

        {Published = True}
        Procedure IsMetaTag_2
            // Detects {SummaryText=...} tag.
            Send Assert (IsMetaTag("{ SummaryText = Does something }", eSummaryText))
        End_Procedure

        {Published = True}
        Procedure IsMetaTag_3
            // Detects {EnumList=...} tag.
            Send Assert (IsMetaTag("{ EnumList = eSomeEnum }", eEnumList))
        End_Procedure

        {Published = True}
        Procedure IsMetaTag_4
            // Detects {InitialValue=...} tag.
            Send Assert (IsMetaTag("{ InitialValue = 0 }", eInitValue))
        End_Procedure

        {Published = True}
        Procedure IsMetaTag_5
            // Detects {ParamHelp=...} tag (eHelpTopic enum kept its name; tag string renamed).
            Send Assert (IsMetaTag("{ ParamHelp = See manual }", eHelpTopic))
        End_Procedure

        {Published = True}
        Procedure IsMetaTag_6
            // Wrong tag type: tag is present but queried as a different type.
            Send AssertFalse (IsMetaTag("{ MethodType = eStandardFunction }", eSummaryText))
        End_Procedure

        {Published = True}
        Procedure IsMetaTag_7
            // Empty string returns False for any tag type.
            Send AssertFalse (IsMetaTag("", eMethodType))
        End_Procedure

        {Published = True}
        Procedure IsMetaTag_8
            // Unknown eTagType (else branch) returns False.
            Send AssertFalse (IsMetaTag("{ MethodType = eStandardFunction }", 99))
        End_Procedure

        {Published = True}
        Procedure IsMetaTag_9
            // Spaces inside the tag string are stripped before matching.
            Send Assert (IsMetaTag("{  MethodType  =  eStandardFunction  }", eMethodType))
        End_Procedure

    End_Object
