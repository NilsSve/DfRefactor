    Object oIsFileInFilter is a cTestFixture
        Set psFunctionName to "IsFileInFilter"

        {Published = True}
        Procedure IsFileInFilter_1
            // Single filter, matching extension.
            Boolean bResult
            Get IsFileInFilter of ghoRefactorFuncLib "myfile.pkg" "*.pkg" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        Procedure IsFileInFilter_2
            // Single filter, extension does not match.
            Boolean bResult
            Get IsFileInFilter of ghoRefactorFuncLib "myfile.pkg" "*.dd" to bResult
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        Procedure IsFileInFilter_3
            // Multiple semicolon-separated filters, matches the first one.
            Boolean bResult
            Get IsFileInFilter of ghoRefactorFuncLib "myfile.src" "*.src;*.pkg" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        Procedure IsFileInFilter_4
            // Multiple semicolon-separated filters, matches the second one.
            Boolean bResult
            Get IsFileInFilter of ghoRefactorFuncLib "myfile.pkg" "*.src;*.pkg" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        Procedure IsFileInFilter_5
            // Multiple filters, extension present in neither.
            Boolean bResult
            Get IsFileInFilter of ghoRefactorFuncLib "myfile.vw" "*.src;*.pkg" to bResult
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        Procedure IsFileInFilter_6
            // LoginEncryptionKey.inc is always excluded regardless of filter.
            Boolean bResult
            Get IsFileInFilter of ghoRefactorFuncLib "LoginEncryptionKey.inc" "*.inc" to bResult
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        Procedure IsFileInFilter_7
            // Filename extension comparison is case-insensitive.
            Boolean bResult
            Get IsFileInFilter of ghoRefactorFuncLib "myfile.PKG" "*.pkg" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        Procedure IsFileInFilter_8
            // Filter comparison is case-insensitive.
            Boolean bResult
            Get IsFileInFilter of ghoRefactorFuncLib "myfile.pkg" "*.PKG" to bResult
            Send Assert bResult
        End_Procedure

    End_Object
