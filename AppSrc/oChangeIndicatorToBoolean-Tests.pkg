    // Unit tests for ChangeIndicatorToBoolean - modernises a legacy GLOBAL "Indicator <name>"
    // declaration to "Global_Variable Boolean <name>". Indicator declarations are always global,
    // so there is no scope-dependent variant. Owns the 4538 "Obsolete command: Indicator" warning.
    Object oChangeIndicatorToBoolean is a cTestFixture
        Set psFunctionName to "ChangeIndicatorToBoolean"

        {Published = True}
        Procedure ChangeIndicatorToBoolean_Single
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Indicator User" to sLine
            Move "Global_Variable Boolean User" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndicatorToBoolean of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // Multiple names on one line are all kept (mirrors Global_Variable String a b c).
        Procedure ChangeIndicatorToBoolean_MultipleNames
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Indicator Boss_Avd Boss_Form Boss_Hkst" to sLine
            Move "Global_Variable Boolean Boss_Avd Boss_Form Boss_Hkst" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndicatorToBoolean of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // Indentation and a trailing comment are preserved verbatim.
        Procedure ChangeIndicatorToBoolean_IndentAndComment
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    Indicator Boss_Avd  // a flag" to sLine
            Move "    Global_Variable Boolean Boss_Avd  // a flag" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndicatorToBoolean of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // An identifier that merely STARTS with "Indicator" (and isn't the first keyword) is left alone.
        Procedure ChangeIndicatorToBoolean_NotAnIdentifierPrefix
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move Indicator_State to iX" to sLine
            Move "Move Indicator_State to iX" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndicatorToBoolean of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

        {Published = True}
        // A USAGE line (ChangeLegacyIndicators' domain) is not this function's job - leave it untouched.
        Procedure ChangeIndicatorToBoolean_UsageLineUntouched
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "If [Found] Begin" to sLine
            Move "If [Found] Begin" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndicatorToBoolean of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

    End_Object
