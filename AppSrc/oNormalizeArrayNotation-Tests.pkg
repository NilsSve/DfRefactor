    Object oNormalizeArrayNotation is a cTestFixture
        Set psFunctionName to "NormalizeArrayNotation"

        {Published = True}
        Procedure NormalizeArrayNotation_1
            String sLine sExpected
            Boolean bChanged
            Move 'String [] asAddress' to sLine
            Move 'String[] asAddress'  to sExpected
            Get NormalizeArrayNotation of ghoRefactorFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Integer array type is also normalised.
        {Published = True}
        Procedure NormalizeArrayNotation_2
            String sLine sExpected
            Boolean bChanged
            Move 'Integer [] aiValues' to sLine
            Move 'Integer[] aiValues'  to sExpected
            Get NormalizeArrayNotation of ghoRefactorFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Already correct notation — bChanged must be False.
        {Published = True}
        Procedure NormalizeArrayNotation_3
            String sLine
            Boolean bChanged
            Move 'String[] asAddress' to sLine
            Get NormalizeArrayNotation of ghoRefactorFuncLib (&sLine) to bChanged
            Send Assert (bChanged = False)
        End_Procedure

        // Non-declaration line — bChanged must be False.
        {Published = True}
        Procedure NormalizeArrayNotation_4
            String sLine
            Boolean bChanged
            Move 'Move sA to sB' to sLine
            Get NormalizeArrayNotation of ghoRefactorFuncLib (&sLine) to bChanged
            Send Assert (bChanged = False)
        End_Procedure

    End_Object
