        End
        If (sMethodLower = "item_change") Begin
            Function_Return True
        End
        // Note: mouse_click is NOT legacy-only; it is converted to OnRowDoubleClick.
        Function_Return False
    End_Function

    // Returns a hint naming the closest cCJGrid equivalent of a legacy grid method,
    // or "" when no close equivalent exists.
    Function LegacyOnlyGridMethodHint String sMethodLower Returns String
        If (sMethodLower = "fill_list") Begin
            Function_Return "InitializeData (note: parameters and calling convention differ)"
        End
        If (sMethodLower = "refresh_page") Begin
            Function_Return "RefreshDataFromDD (note: parameters differ)"
        End
        If (sMethodLower = "request_new_index") Begin
            Function_Return "ChangeOrdering"
        End
        If (sMethodLower = "move_to_column") Begin
            Function_Return "MoveToColumnObject (note: takes a column object handle, not a column number)"
        End
        If (sMethodLower = "change_row_color") Begin
            Function_Return "OnSetRowColor on the grid object (note: per-row color logic moves into OnSetRowColor)"
        End
        If (sMethodLower = "item_change") Begin
            Function_Return "OnRowChange (note: Item_Change fires on every cell move; OnRowChange only fires when the row changes)"
        End
        Function_Return ""
    End_Function

    // Returns True when sTrimLower is a legacy grid property that needs translation
    // into a CJGrid equivalent rather than simple removal.
    Function IsTranslatableGridProperty String sTrimLower Returns Boolean
        If (Left(sTrimLower, 4) <> "set ") Begin
            Function_Return False
        End
        If (sTrimLower contains "peresizecolumn") Begin
            Function_Return True
        End
        If (sTrimLower contains "prompt_button_mode") Begin
            Function_Return True
        End
        If (sTrimLower contains "allow_top_add_state") Begin
            Function_Return True
        End
        If (sTrimLower contains "allow_bottom_add_state") Begin
            Function_Return True
        End
        If (sTrimLower contains "allow_insert_add_state") Begin
            Function_Return True
        End
        If (sTrimLower contains "auto_save_state") Begin
            Function_Return True
        End
        If (sTrimLower contains "auto_regenerate_state") Begin
            Function_Return True
        End
        If (sTrimLower contains "no_create_state") Begin
            Function_Return True
        End
        If (sTrimLower contains "no_delete_state") Begin
            Function_Return True
        End
        If (sTrimLower contains "read_only_state") Begin
            Function_Return True
        End
        If (sTrimLower contains "header_visible_state") Begin
            Function_Return True
        End
        If (sTrimLower contains "resize_column_state") Begin
            Function_Return True
        End
        If (sTrimLower contains "highlight_row_state") Begin
            Function_Return True
        End
        If (sTrimLower contains "gridline_mode") Begin
            Function_Return True
        End
        If (sTrimLower contains "currentrowcolor") Begin
            Function_Return True
        End
        If (sTrimLower contains "currentrowtextcolor") Begin
            Function_Return True
        End
        If (sTrimLower contains "currentcellcolor") Begin
            Function_Return True
        End
        If (sTrimLower contains "currentcelltextcolor") Begin
            Function_Return True
        End
        Function_Return False
    End_Function

    // Translates a recognised legacy grid property line into its CJGrid equivalent(s).
    // Returns an array of replacement lines; an empty array means drop the line.
    Function TranslateGridProperty String sLine String sTrimLower Returns String[]
        String[]  asResult
        String    sIndent sValue sValLower sBoolVal sNegBool
        Boolean   bBoolValue

        Move (Left(sLine, (Length(sLine) - Length(Trim(sLine))))) to sIndent
        Get ParseValueAfterTo sLine to sValue
        Move (Lowercase(Trim(sValue))) to sValLower

        Move (sValLower = "true" or sValLower = "1") to bBoolValue
        Move (If(bBoolValue, "True", "False")) to sBoolVal
        Move (If(bBoolValue, "False", "True")) to sNegBool

        If (sTrimLower contains "peresizecolumn") Begin
            If (sValLower = "rcnone" or sValLower = "0") Begin
                Move (sIndent + "Set pbAllowColumnResize to False") to asResult[0]
            End
            Function_Return asResult
        End

        If (sTrimLower contains "prompt_button_mode") Begin
            If (sValLower = "pb_prompton" or sValLower = "pb_promptauto") Begin
                Move (sIndent + "Set pbHeaderPrompts to True")  to asResult[0]
            End
            Else Begin
                Move (sIndent + "Set pbHeaderPrompts to False") to asResult[0]
            End
            Function_Return asResult
        End

        If (sTrimLower contains "allow_top_add_state") Begin
            Move (sIndent + "Set pbAllowAppendRow to " + sBoolVal) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "allow_bottom_add_state") Begin
            Move (sIndent + "Set pbAllowAppendRow to " + sBoolVal) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "allow_insert_add_state") Begin
            Move (sIndent + "Set pbAllowInsertRow to " + sBoolVal) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "auto_save_state") Begin
            Move (sIndent + "Set pbAutoSave to " + sBoolVal) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "auto_regenerate_state") Begin
            Move (sIndent + "Set pbAutoRegenerate to " + sBoolVal) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "no_create_state") Begin
            Move (sIndent + "Set pbAllowAppendRow to " + sNegBool) to asResult[0]
            Move (sIndent + "Set pbAllowInsertRow to " + sNegBool) to asResult[1]
            Function_Return asResult
        End

        If (sTrimLower contains "no_delete_state") Begin
            Move (sIndent + "Set pbAllowDeleteRow to " + sNegBool) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "read_only_state") Begin
            Move (sIndent + "Set pbReadOnly to " + sBoolVal) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "header_visible_state") Begin
            Move (sIndent + "Set pbShowHeader to " + sBoolVal) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "resize_column_state") Begin
            Move (sIndent + "Set pbAllowColumnResize to " + sBoolVal) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "highlight_row_state") Begin
            Move (sIndent + "Set pbShowRowFocus to " + sBoolVal) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "gridline_mode") Begin
            If (sValLower = "grid_visible_none" or sValLower = "0") Begin
                Move (sIndent + "Set peHorizontalGridStyle to xtpGridNoLines") to asResult[0]
                Move (sIndent + "Set peVerticalGridStyle   to xtpGridNoLines") to asResult[1]
            End
            Else If (sValLower = "grid_visible_horz" or sValLower = "1") Begin
                Move (sIndent + "Set peHorizontalGridStyle to xtpGridSolid") to asResult[0]
            End
            Else If (sValLower = "grid_visible_vert" or sValLower = "2") Begin
                Move (sIndent + "Set peVerticalGridStyle to xtpGridSolid") to asResult[0]
            End
            Else If (sValLower = "grid_visible_both" or sValLower = "3") Begin
                Move (sIndent + "Set peHorizontalGridStyle to xtpGridSolid") to asResult[0]
                Move (sIndent + "Set peVerticalGridStyle   to xtpGridSolid") to asResult[1]
            End
            Function_Return asResult
        End

        If (sTrimLower contains "currentrowcolor") Begin
            Move (sIndent + "Set piHighlightBackColor to " + sValue) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "currentrowtextcolor") Begin
            Move (sIndent + "Set piHighlightForeColor to " + sValue) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "currentcellcolor") Begin
            Move (sIndent + "Set piFocusCellBackColor to " + sValue) to asResult[0]
            Function_Return asResult
        End

        If (sTrimLower contains "currentcelltextcolor") Begin
            Move (sIndent + "Set piFocusCellForeColor to " + sValue) to asResult[0]
            Function_Return asResult
        End

        Function_Return asResult  // Unrecognised translatable -- drop.
    End_Function

    // *** Parsing helpers ***

    // Replace the class name in sLine with the target grid class from psTargetGridClass.
    Function ReplaceGridClassName String sLine String sTrimLower Returns String
        Integer iIsA
        String  sLeading sTargetClass

        Move (Pos(" is a ", Lowercase(sLine))) to iIsA
        If (iIsA = 0) Begin
            Function_Return sLine
        End
        Move (Left(sLine, (iIsA + 5))) to sLeading
        Get psTargetGridClass to sTargetClass
        Function_Return (sLeading + sTargetClass)
    End_Function

    // Parse the item index N from a line like "set form_width   item N to ..."
    Function ParseItemIndex String sTrimLower Returns Integer
        Integer iItem iSpace
        String  sRest sToken

        Move (Pos(" item ", sTrimLower)) to iItem
        If (iItem = 0) Begin
            Function_Return -1
        End
        Move (Trim(Mid(sTrimLower, CI_EOL, (iItem + 6)))) to sRest
        Move (Pos(CS_S, sRest)) to iSpace
        If (iSpace > 0) Begin
            Move (Left(sRest, iSpace - 1)) to sToken
        End
        Else Begin
            Move sRest to sToken
        End
        Function_Return (Integer(Trim(sToken)))
    End_Function

    // Extract a quoted label string from "Set Header_Label [Item] N to "Label"".
    // Strips the surrounding double-quotes from the value.
    // Uses an explicit closing-quote search so that a trailing end comment
    // (e.g. Set Header_Label Item 0 to "Name" // was "Full Name") is stripped
    // correctly, without being confused by "//" appearing inside the label text.
    Function ParseHeaderLabel String sOrigLine Returns String
        String  sVal
        Integer iPos
        Get ParseValueAfterTo sOrigLine to sVal
        If (Left(sVal, 1) = '"' and Length(sVal) >= 2) Begin
            // Locate the closing quote by searching from position 2 onwards.
            // iPos is the position of '"' within Mid(sVal, CI_EOL, 2), so
            // Mid(sVal, iPos-1, 2) extracts the label text without outer quotes.
            Move (Pos('"', Mid(sVal, CI_EOL, 2))) to iPos
            If (iPos > 0) Begin
                Move (Mid(sVal, iPos - 1, 2)) to sVal
            End
            Else Begin
                // No closing quote found (malformed line): fall back to stripping
                // first and last character as before.
                Move (Mid(sVal, (Length(sVal) - 2), 2)) to sVal
            End
        End
        Function_Return sVal
    End_Function

    // Extract an integer column width from "Set Form_Width [Item] N to W".
    Function ParseFormWidth String sTrimLower Returns Integer
        String sVal
        Get ParseValueAfterTo sTrimLower to sVal
        Function_Return (Integer(Trim(sVal)))
    End_Function

    // Parse the item index N from a per-column Set line, handling both:
    //   "set <propname> item N to value"  (with  Item keyword)
    //   "set <propname> N to value"       (without Item keyword)
    // sPropName is the lowercase property name to locate in the line.
    // Returns -1 when the index cannot be parsed.
    Function ParseColumnItemIndex String sTrimLower String sPropName Returns Integer
        Integer iProp iAfter iSpace
        String  sRest

        // Try the "item N" form first.
        Move (Pos(" item ", sTrimLower)) to iProp
        If (iProp <> 0) Begin
            Move (Trim(Mid(sTrimLower, CI_EOL, (iProp + 6)))) to sRest
            Move (Pos(CS_S, sRest)) to iSpace
            If (iSpace > 0) Begin
                Function_Return (Integer(Left(sRest, iSpace - 1)))
            End
            Function_Return (Integer(Trim(sRest)))
        End

        // No "item" keyword: N sits directly after the property name.
        Move (Pos(sPropName, sTrimLower)) to iProp
        If (iProp = 0) Begin
            Function_Return -1
        End
        // Skip past the property name + one space; then read N from the rest.
        Move (iProp + Length(sPropName)) to iAfter
        Move (Trim(Mid(sTrimLower, CI_EOL, (iAfter + 1)))) to sRest
        // sRest = "N to value"
        Move (Pos(CS_S, sRest)) to iSpace
        If (iSpace > 0) Begin
            Function_Return (Integer(Left(sRest, iSpace - 1)))
        End
        Function_Return (Integer(Trim(sRest)))
    End_Function

    // Extract the raw value after " to " from a line (uses original casing).
    Function ParseValueAfterTo String sOrigLine Returns String
        Integer iTo
        String  sLower

        Move (Lowercase(sOrigLine)) to sLower
        Move (Pos(" to ", sLower)) to iTo
        If (iTo = 0) Begin
            Function_Return ""
        End
        Function_Return (Trim(Mid(sOrigLine, CI_EOL, (iTo + 4))))
    End_Function

    // Build an indentation string of one tab-size worth of spaces.
    Function MakeSingleIndent Returns String
        String  sIndent
        Integer iTabSize iCount

        Get piTabSize of ghoFuncLib to iTabSize
        Move "" to sIndent
        For iCount from 1 to iTabSize
            Append sIndent CS_S
        Loop
        Function_Return sIndent
    End_Function

    // *** Subclass hooks -- override in derived classes ***

    // Called when a grid declaration is detected and processed.
    // iGridStartLine is the zero-based index of the grid declaration line in pasSource.
    // Subclasses reset their per-grid state (column arrays etc.) here, and may use
    // iGridStartLine to perform their own forward pre-scan of the grid body.
    Procedure OnGridStarted String sGridIndent Integer iGridStartLine
    End_Procedure

    // Called for each source line at nesting level 1 (direct grid body content)
    // before the base class dispatches properties/methods.
    // Set bSkip True to consume the line; leave False to pass through to base processing.
    // asOutput may be written to (e.g. to flush buffered column objects).
    Procedure OnHandleGridLine String sLine String sTrimLine String sLower String[] ByRef asOutput String sGridIndent Boolean ByRef bSkip
    End_Procedure

    // Called just before the grid's own End_Object is emitted.
    // Subclasses flush any buffered column objects into asOutput here.
    Procedure OnBeforeGridEndObject String[] ByRef asOutput String sGridIndent
    End_Procedure

    // Emits translatable grid properties collected from Entry_Display during
    // the grid pre-scan (see TransformSource grid detection section).
    // Idempotent: after the first call it is a no-op, so it is safe to call
    // from both AppendColumnObjects (primary - emits before first column object)
    // and from TransformSource before OnBeforeGridEndObject (safety net for grids
    // that produce no column sub-objects).
    Procedure FlushEntryDisplayExtracted String[] ByRef asOutput String sGridIndent
        String[]  asProps asEmpty
        String    sSingleIndent
        Integer   iTr iTrSize
        Boolean   bFlushed

        Get pbEntryDisplayFlushed to bFlushed
        If (bFlushed = True) Begin
            Procedure_Return
        End
        Set pbEntryDisplayFlushed to True

        Get pasEntryDisplayExtracted to asProps
        Set pasEntryDisplayExtracted to asEmpty

        If (SizeOfArray(asProps) = 0) Begin
            Procedure_Return
        End

        // Blank separator before the translated block (if needed).
        If (SizeOfArray(asOutput) > 0 and Trim(asOutput[SizeOfArray(asOutput) - 1]) <> "") Begin
            Move "" to asOutput[SizeOfArray(asOutput)]
        End

        Get MakeSingleIndent to sSingleIndent
        Move (sGridIndent + sSingleIndent + "// Translated from Entry_Display to grid level:") to asOutput[SizeOfArray(asOutput)]

        Move (SizeOfArray(asProps)) to iTrSize
        Decrement iTrSize
        For iTr from 0 to iTrSize
            Move asProps[iTr] to asOutput[SizeOfArray(asOutput)]
        Loop

        Move "" to asOutput[SizeOfArray(asOutput)]
    End_Procedure

    // *** Main transformation that operates on pasSource ***

    // Scans pasSource, transforms every matching grid object it finds, writes
    // the result back to pasSource.  Returns the number of grids transformed.
    Function TransformSource Returns Integer
        String[] asSource asOutput asTranslated asEntryDisplayProps asEmpty
        String  sLine sTrimLine sLower sGridIndent sValue sSingleIndent
        String  sMethodName sOldMethodName sNewMethodName sHint sLineIndent
        String  sScanLine sScanLower
        String  sMouseClickOldP1 sMouseClickOldP2
        Integer iCount iSize iGridsChanged iGridInnerNest iTr iTrSize
        Integer iScan iScanSize iScanNest
        Boolean bInEntryDisplay bSkip bFound bOK bScanFound
        Boolean bInRenameProcedure bInLegacyOnlyMethod
        Boolean bScanInEntryDisplay bScanDone

        Get pasSource to asSource
        Move 0 to iGridsChanged
        Move 0 to iGridInnerNest
        Move False to bInEntryDisplay
        Move False to bInRenameProcedure
        Move False to bInLegacyOnlyMethod

        Move (SizeOfArray(asSource)) to iSize
        Decrement iSize

        For iCount from 0 to iSize
            Move asSource[iCount] to sLine
            Move (Trim(sLine))          to sTrimLine
            Move (Lowercase(sTrimLine)) to sLower
            Move False to bSkip

            // NOT inside any grid
            If (iGridInnerNest = 0) Begin
                Get IsGridDeclaration sLower to bFound
                If (bFound = True) Begin
                    Move (Replace(sTrimLine, sLine, "")) to sGridIndent
                    Get ReplaceGridClassName sLine sLower to sLine
                    Move 1 to iGridInnerNest
                    Increment iGridsChanged
                    Move False to bInEntryDisplay
                    Move False to bInRenameProcedure
                    Move False to bInLegacyOnlyMethod
                    Send OnGridStarted sGridIndent iCount
                    // Pre-scan: search ahead through this grid's body for a Procedure
                    // Entry_Display block and collect any translatable grid-level Set
                    // properties (e.g. Set CurrentRowColor) within it.  Results are
                    // stored in pasEntryDisplayExtracted and flushed by
                    // FlushEntryDisplayExtracted before the first column sub-object
                    // (or at End_Object for grids with no columns).
                    Move asEmpty to asEntryDisplayProps
                    Set pbEntryDisplayFlushed to False
                    Move (iCount + 1) to iScan
                    Move (SizeOfArray(asSource) - 1) to iScanSize
                    Move 0 to iScanNest
                    Move False to bScanInEntryDisplay
                    Move False to bScanDone
                    If (iScan <= iScanSize) Begin
                        Repeat
                            Move asSource[iScan]             to sScanLine
                            Move (Lowercase(Trim(sScanLine))) to sScanLower
                            // Track object nesting so we stay within this grid's boundary.
                            Get IsObjectDeclaration sScanLower to bScanFound
                            If (bScanFound = True) Begin
                                Increment iScanNest
                            End
                            Else If (Left(sScanLower, 10) = "end_object") Begin
                                If (iScanNest = 0) Begin
                                    Move True to bScanDone  // reached grid End_Object
                                End
                                Else Begin
                                    Decrement iScanNest
                                End
                            End
                            // Only inspect direct grid body lines (nesting level 0).
                            If (bScanDone = False and iScanNest = 0) Begin
                                If (bScanInEntryDisplay = True) Begin
                                    If (Left(sScanLower, 13) = "end_procedure" or ;
                                        Left(sScanLower, 12) = "end_function") Begin
                                        Move False to bScanInEntryDisplay
                                    End
                                    Else Begin
                                        Get IsTranslatableGridProperty sScanLower to bScanFound
                                        If (bScanFound = True) Begin
                                            Get TranslateGridProperty sScanLine sScanLower to asTranslated
                                            Move (SizeOfArray(asTranslated)) to iTrSize
                                            Decrement iTrSize
                                            For iTr from 0 to iTrSize
                                                Get MakeSingleIndent to sSingleIndent
                                                Move (sGridIndent + sSingleIndent + Trim(asTranslated[iTr])) to asEntryDisplayProps[SizeOfArray(asEntryDisplayProps)]
                                            Loop
                                        End
                                    End
                                End
                                Else Begin
                                    Get IsEntryDisplayProcedure sScanLower to bScanFound
                                    If (bScanFound = True) Begin
                                        Move True to bScanInEntryDisplay
                                    End
                                End
                            End
                            Increment iScan
                        Until (bScanDone = True or iScan > iScanSize)
                    End
                    Set pasEntryDisplayExtracted to asEntryDisplayProps
                End
                Move sLine to asOutput[SizeOfArray(asOutput)]
                Move True to bSkip
            End

            // Entry_Display sub-state: comment out every line including End_Procedure.
            // Translatable properties were pre-scanned at grid detection time and
            // will be flushed by FlushEntryDisplayExtracted before column objects.
            If (bSkip = False and bInEntryDisplay = True) Begin
                If (Left(sLower, 13) = "end_procedure" or Left(sLower, 12) = "end_function") Begin
                    Move False to bInEntryDisplay
                End
                Get CommentOutLine sLine to sLine
                Move sLine to asOutput[SizeOfArray(asOutput)]
                Move True to bSkip
            End

            // Renamed procedure/function body: rename Forward Send/Get calls.
            // Mouse_Click -> OnRowDoubleClick also substitutes old parameter names.
            If (bSkip = False and bInRenameProcedure = True) Begin
                If (Left(sLower, 13) = "end_procedure" or Left(sLower, 12) = "end_function") Begin
                    Move False to bInRenameProcedure
                End
                Else Begin
                    If (sLower contains ("forward send " + sOldMethodName) or ;
                        sLower contains ("forward get "  + sOldMethodName)) Begin
                        If (sOldMethodName = "mouse_click" or sOldMethodName = "mouse_down2") Begin
                            // Replace the entire Forward Send/Get with the correct new signature,
                            // including the renamed iRow / iCol parameters.
                            Move (Left(sLine, (Length(sLine) - Length(Trim(sLine))))) to sLineIndent
                            Move (sLineIndent + "Forward Send " + sNewMethodName + " iRow iCol") to sLine
                        End
                        Else Begin
                            Get ReplaceMethodName sLine sOldMethodName sNewMethodName to sLine
                        End
                    End
                    Else Begin
                        // For Mouse_Click / Mouse_Down2 bodies: replace old parameter names
                        // with iRow / iCol throughout the method body.
                        If (sOldMethodName = "mouse_click" or sOldMethodName = "mouse_down2") Begin
                            If (sMouseClickOldP1 <> "") Begin
                                Get ReplaceMethodName sLine (Lowercase(sMouseClickOldP1)) "iRow" to sLine
                            End
                            If (sMouseClickOldP2 <> "") Begin
                                Get ReplaceMethodName sLine (Lowercase(sMouseClickOldP2)) "iCol" to sLine
                            End
                        End
                    End
                End
                Move sLine to asOutput[SizeOfArray(asOutput)]
                Move True to bSkip
            End

            // Legacy-only method body sub-state: comment out every line
            If (bSkip = False and bInLegacyOnlyMethod = True) Begin
                If (Left(sLower, 13) = "end_procedure" or Left(sLower, 12) = "end_function") Begin
                    Move False to bInLegacyOnlyMethod
                End
                Get CommentOutLine sLine to sLine
                Move sLine to asOutput[SizeOfArray(asOutput)]
                Move True to bSkip
            End

            // Subclass first crack at direct grid content (iGridInnerNest = 1 only)
            If (bSkip = False and iGridInnerNest = 1) Begin
                Send OnHandleGridLine sLine sTrimLine sLower (&asOutput) sGridIndent (&bSkip)
            End

            // End_Object -- applies at every nesting level inside the grid
            If (bSkip = False and Left(sLower, 10) = "end_object") Begin
                Decrement iGridInnerNest
                If (iGridInnerNest = 0) Begin
                    // Safety flush: emit Entry_Display extracted properties if they have
                    // not yet been flushed by AppendColumnObjects (i.e. no column objects).
                    Send FlushEntryDisplayExtracted (&asOutput) sGridIndent
                    Send OnBeforeGridEndObject (&asOutput) sGridIndent
                End
                Move sLine to asOutput[SizeOfArray(asOutput)]
                Move True to bSkip
            End

            // Nested objects (iGridInnerNest > 1): pass all content through
            If (bSkip = False and iGridInnerNest > 1) Begin
                Get IsObjectDeclaration sLower to bFound
                If (bFound = True) Begin
                    Increment iGridInnerNest
                End
                Move sLine to asOutput[SizeOfArray(asOutput)]
                Move True to bSkip
            End

            // Direct grid content: Define constant removal
            If (bSkip = False) Begin
                If (Left(sLower, 7) = "define ") Begin
                    Move True to bSkip
                End
            End

            // Direct grid content: Object / Procedure / Function / Property dispatch
            If (bSkip = False) Begin
                Get IsObjectDeclaration sLower to bOK
                If (bOK = True) Begin
                    // Nested Object starts; subclass already flushed pending columns in hook.
                    Increment iGridInnerNest
                    Move sLine to asOutput[SizeOfArray(asOutput)]
                    Move True to bSkip
                End
                Else Begin
                    Get ParseProcFuncName sLower to sMethodName
                    If (sMethodName <> "") Begin
                        // Ensure one blank line before any procedure/function block.
                        If (SizeOfArray(asOutput) > 0 and Trim(asOutput[SizeOfArray(asOutput) - 1]) <> "") Begin
                            Move "" to asOutput[SizeOfArray(asOutput)]
                        End
                        Get IsEntryDisplayProcedure sLower to bInEntryDisplay
                        If (bInEntryDisplay = True) Begin
                            // Translatable properties were pre-scanned at grid detection time.
                            // Primary flush path: AppendColumnObjects calls FlushEntryDisplayExtracted
                            // before the first column sub-object.
                            // Fallback path (no columns yet, e.g. grids without Begin_Row): flush
                            // here so translated properties appear just above the commented block.
                            // FlushEntryDisplayExtracted is idempotent; if already flushed this is a no-op.
                            Send FlushEntryDisplayExtracted (&asOutput) sGridIndent
                            Get CommentOutLine sLine to sLine
                            Move sLine to asOutput[SizeOfArray(asOutput)]
                            Move True to bSkip
                        End
                        Else Begin
                            Get RenameGridMethod sMethodName to sNewMethodName
                            If (sNewMethodName <> "") Begin
                                Move sMethodName to sOldMethodName
                                Get ReplaceMethodName sLine sOldMethodName sNewMethodName to sLine
                                Move sLine to asOutput[SizeOfArray(asOutput)]
                                Move True to bInRenameProcedure
                                Move True to bSkip
                            End
                            Else Begin
                                // Mouse_Click  -> OnRowDoubleClick
                                // Mouse_Down2  -> OnRowRightClick
                                // Both have the same legacy signature (Integer iWin Integer iPos)
                                // and the same conversion approach: replace the declaration,
                                // rewrite Forward Send, and substitute old param names in the body.
                                If (sMethodName = "mouse_click" or sMethodName = "mouse_down2") Begin
                                    Move (Left(sLine, (Length(sLine) - Length(sTrimLine)))) to sLineIndent
                                    // Parse the two legacy parameter names so the body handler
                                    // can substitute them with iRow / iCol.
                                    Move "" to sMouseClickOldP1
                                    Move "" to sMouseClickOldP2
                                    // sLower = Lowercase(sTrimLine), so offsets from Pos() align
                                    // with sTrimLine (not sLine which carries leading indentation).
                                    Move (Pos("integer ", sLower)) to iScanNest
                                    If (iScanNest > 0) Begin
                                        Move (Trim(Mid(sTrimLine, CI_EOL, (iScanNest + 8)))) to sMouseClickOldP1
                                        Move (Pos(CS_S, sMouseClickOldP1)) to iTrSize
                                        If (iTrSize > 0) Move (Left(sMouseClickOldP1, iTrSize - 1)) to sMouseClickOldP1
                                        // Locate second "integer " that follows the first param name.
                                        Move (iScanNest + 8 + Length(sMouseClickOldP1)) to iScanNest
                                        Move (Pos("integer ", Mid(sLower, CI_EOL, (iScanNest + 1)))) to iTrSize
                                        If (iTrSize > 0) Begin
                                            Move (iScanNest + iTrSize + 8) to iScanNest
                                            Move (Trim(Mid(sTrimLine, CI_EOL, iScanNest))) to sMouseClickOldP2
                                            Move (Pos(CS_S, sMouseClickOldP2)) to iTrSize
                                            If (iTrSize > 0) Move (Left(sMouseClickOldP2, iTrSize - 1)) to sMouseClickOldP2
                                        End
                                    End
                                    // Choose new name and emit conversion comment + new declaration.
                                    If (sMethodName = "mouse_click") Begin
                                        Move "OnRowDoubleClick" to sNewMethodName
                                        Move (sLineIndent + "// Converted from Mouse_Click: iRow = row index, iCol = column index.") to asOutput[SizeOfArray(asOutput)]
                                        Move (sLineIndent + "Procedure OnRowDoubleClick Integer iRow Integer iCol") to asOutput[SizeOfArray(asOutput)]
                                    End
                                    Else Begin
                                        Move "OnRowRightClick" to sNewMethodName
                                        Move (sLineIndent + "// Converted from Mouse_Down2: iRow = row index, iCol = column index.") to asOutput[SizeOfArray(asOutput)]
                                        Move (sLineIndent + "Procedure OnRowRightClick Integer iRow Integer iCol") to asOutput[SizeOfArray(asOutput)]
                                    End
                                    Move sMethodName to sOldMethodName
                                    Move True to bInRenameProcedure
                                    Move True to bSkip
                                End
                                Else Begin
                                    Get IsLegacyOnlyGridMethod sMethodName to bOK
                                    If (bOK = True) Begin
                                        Move (Left(sLine, (Length(sLine) - Length(sTrimLine)))) to sLineIndent
                                        Get LegacyOnlyGridMethodHint sMethodName to sHint
                                        If (sHint <> "") Begin
                                            Move (sLineIndent + "// TODO: Legacy grid method -- consider using " + sHint + ".") to asOutput[SizeOfArray(asOutput)]
                                        End
                                        Else Begin
                                            Move (sLineIndent + "// TODO: Legacy grid method -- no direct equivalent in cCJGrid.") to asOutput[SizeOfArray(asOutput)]
                                        End
                                        Get CommentOutLine sLine to sLine
                                        Move sLine to asOutput[SizeOfArray(asOutput)]
                                        Move True to bInLegacyOnlyMethod
                                        Move True to bSkip
                                    End
                                    // else: unknown override - falls through to emit unchanged.
                                End  // Else (not mouse_click)
                            End  // Else Begin (RenameGridMethod returned empty)
                        End
                    End
                    Else Begin
                        Get IsTranslatableGridProperty sLower to bOK
                        If (bOK = True) Begin
                            Get TranslateGridProperty sLine sLower to asTranslated
                            Move (SizeOfArray(asTranslated)) to iTrSize
                            Decrement iTrSize
                            For iTr from 0 to iTrSize
                                Move asTranslated[iTr] to asOutput[SizeOfArray(asOutput)]
                            Loop
                            Move True to bSkip
                        End
                        Else Begin
                            Get IsCommentOutGridProperty sLower to bOK
                            If (bOK = True) Begin
                                Get CommentOutLine sLine to sLine
                                Move sLine to asOutput[SizeOfArray(asOutput)]
                                Move True to bSkip
                            End
                            Else Begin
                                Get IsLegacyGridProperty sLower to bSkip
                            End
                        End
                    End
                End
            End

            // Emit line if not consumed
            If (bSkip = False) Begin
                Move sLine to asOutput[SizeOfArray(asOutput)]
            End
        Loop

        Set pasSource to asOutput
        Function_Return iGridsChanged
    End_Function

    // *** Generic file-loop interface -- call from subclass public interface ***
    //
    // Validates sParameter, loops over asFiles, calls ReadFile / TransformSource /
    // WriteFile for each, accumulates counts.
    Function TransformFiles String[] asFiles String sParameter Returns Integer
        String  sFilePath
        Integer iCount iSize iGrids iTotalGrids iTotalFiles
        Boolean bOK

        Get ParseAndSetParameter sParameter to bOK
        If (bOK = False) Begin
            Function_Return 0
        End

        Move 0 to iTotalGrids
        Move 0 to iTotalFiles
        Move (SizeOfArray(asFiles)) to iSize
        Set piMaximumTot of ghoStatusPanel to iSize

        If (iSize > 0) Begin
            Decrement iSize
            For iCount from 0 to iSize
                Move asFiles[iCount] to sFilePath
                Set Title_Text   of ghoStatusPanel to ("Converting Grid objects in:" * sFilePath)
                Set Message_Text of ghoStatusPanel to (ParseFileName(sFilePath))

                Send ReadFile sFilePath
                Get TransformSource to iGrids

                If (iGrids > 0) Begin
                    If (pbReadOnly(ghoFuncLib) = False) Begin
                        Send WriteFile
                    End
                    Increment iTotalFiles
                    Add iGrids to iTotalGrids
                End

                Send DoAdvanceTot of ghoStatusPanel
            Loop
        End

        Set Title_Text   of ghoStatusPanel to ""
        Set Message_Text of ghoStatusPanel to ""
        Set piChangedFiles to iTotalFiles
        Set piChangedGrids to iTotalGrids
        Function_Return iTotalGrids
    End_Function

End_Class
