    Object oUnusedUseStatements is a cTestFixture
        Set psFunctionName to "UnusedUseStatements"

        // Tests for cUnusedUseStatements helper functions.
        // Each test creates a local instance to access the class methods directly.

        {Published = True}
        { Description = "IsUseLine: 'Use vWin32fh.pkg' is a Use statement" }
        Procedure UnusedUseStatements_IsUseLine_1
            Handle ho
            Boolean bResult
            Get Create of ghoFuncLib (RefClass(cUnusedUseStatements)) to ho
            Get IsUseLine of ho "Use vWin32fh.pkg" to bResult
            Send Destroy of ho
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseLine: commented-out Use line is not a Use statement" }
        Procedure UnusedUseStatements_IsUseLine_2
            Handle ho
            Boolean bResult
            Get Create of ghoFuncLib (RefClass(cUnusedUseStatements)) to ho
            Get IsUseLine of ho "// Use vWin32fh.pkg" to bResult
            Send Destroy of ho
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseLine: an Object line is not a Use statement" }
        Procedure UnusedUseStatements_IsUseLine_3
            Handle ho
            Boolean bResult
            Get Create of ghoFuncLib (RefClass(cUnusedUseStatements)) to ho
            Get IsUseLine of ho "Object oMyObj is a cMyClass" to bResult
            Send Destroy of ho
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        { Description = "ExtractClassNames: finds a single class definition" }
        Procedure UnusedUseStatements_ExtractClassNames_1
            Handle ho
            String[] asFile asExpected asResult
            Move "Use vdfbase.pkg"              to asFile[0]
            Move ""                             to asFile[1]
            Move "Class cMyClass is a cObject"  to asFile[2]
            Move "    Procedure Construct_Object" to asFile[3]
            Move "    End_Procedure"             to asFile[4]
            Move "End_Class"                     to asFile[5]
            Move "cmyclass" to asExpected[0]
            Get Create of ghoFuncLib (RefClass(cUnusedUseStatements)) to ho
            Get ExtractClassNames of ho asFile to asResult
            Send Destroy of ho
            Send AssertArrayAreEqual asExpected asResult
        End_Procedure

        {Published = True}
        { Description = "ExtractClassNames: multiple classes returned sorted" }
        Procedure UnusedUseStatements_ExtractClassNames_2
            Handle ho
            String[] asFile asExpected asResult
            Move "Class cZebraClass is a cObject" to asFile[0]
            Move "Class cAlphaClass is a cObject" to asFile[1]
            Move "Class cMiddleClass is a cObject" to asFile[2]
            Move "calphaclass"  to asExpected[0]
            Move "cmiddleclass" to asExpected[1]
            Move "czebraclass"  to asExpected[2]
            Get Create of ghoFuncLib (RefClass(cUnusedUseStatements)) to ho
            Get ExtractClassNames of ho asFile to asResult
            Send Destroy of ho
            Send AssertArrayAreEqual asExpected asResult
        End_Procedure

        {Published = True}
        { Description = "ExtractClassNames: file with no classes returns empty array" }
        Procedure UnusedUseStatements_ExtractClassNames_3
            Handle ho
            String[] asFile asResult
            Move "// Utility procedures only"            to asFile[0]
            Move "Procedure GlobalHelper String sArg"    to asFile[1]
            Move "End_Procedure"                         to asFile[2]
            Get Create of ghoFuncLib (RefClass(cUnusedUseStatements)) to ho
            Get ExtractClassNames of ho asFile to asResult
            Send Destroy of ho
            Send AssertIAreEqual 0 (SizeOfArray(asResult))
        End_Procedure

        {Published = True}
        { Description = "ExtractClassNames: commented-out class definition not counted" }
        Procedure UnusedUseStatements_ExtractClassNames_4
            Handle ho
            String[] asFile asResult
            Move "// Class cOldClass is a cObject" to asFile[0]
            Move "Class cRealClass is a cObject"   to asFile[1]
            Move "crealclass" to asResult[0]  // reuse as expected
            Get Create of ghoFuncLib (RefClass(cUnusedUseStatements)) to ho
            Get ExtractClassNames of ho asFile to asResult
            Send Destroy of ho
            Send AssertIAreEqual 1 (SizeOfArray(asResult))
            Send AssertSAreEqual "crealclass" asResult[0]
        End_Procedure

        {Published = True}
        { Description = "ExtractInstantiatedClasses: finds a single Object declaration" }
        Procedure UnusedUseStatements_ExtractInstantiatedClasses_1
            Handle ho
            String[] asCode asExpected asResult
            Move "Object oMyObj is a cMyClass" to asCode[0]
            Move "End_Object"                  to asCode[1]
            Move "cmyclass" to asExpected[0]
            Get Create of ghoFuncLib (RefClass(cUnusedUseStatements)) to ho
            Get ExtractInstantiatedClasses of ho asCode to asResult
            Send Destroy of ho
            Send AssertArrayAreEqual asExpected asResult
        End_Procedure

        {Published = True}
        { Description = "ExtractInstantiatedClasses: strips trailing meta-tags from class name" }
        Procedure UnusedUseStatements_ExtractInstantiatedClasses_2
            Handle ho
            String[] asCode asResult
            Move "    Object oPanel is a cMyPanel {Visibility = Private}" to asCode[0]
            Get Create of ghoFuncLib (RefClass(cUnusedUseStatements)) to ho
            Get ExtractInstantiatedClasses of ho asCode to asResult
            Send Destroy of ho
            Send AssertIAreEqual 1 (SizeOfArray(asResult))
            Send AssertSAreEqual "cmypanel" asResult[0]
        End_Procedure

        {Published = True}
        { Description = "ExtractInstantiatedClasses: multiple objects returned sorted" }
        Procedure UnusedUseStatements_ExtractInstantiatedClasses_3
            Handle ho
            String[] asCode asExpected asResult
            Move "Object oZ is a cZebraClass"  to asCode[0]
            Move "Object oA is a cAlphaClass"  to asCode[1]
            Move "Object oM is a cMiddleClass" to asCode[2]
            Move "calphaclass"  to asExpected[0]
            Move "cmiddleclass" to asExpected[1]
            Move "czebraclass"  to asExpected[2]
            Get Create of ghoFuncLib (RefClass(cUnusedUseStatements)) to ho
            Get ExtractInstantiatedClasses of ho asCode to asResult
            Send Destroy of ho
            Send AssertArrayAreEqual asExpected asResult
        End_Procedure

        {Published = True}
        { Description = "ExtractInstantiatedClasses: commented-out Object not counted" }
        Procedure UnusedUseStatements_ExtractInstantiatedClasses_4
            Handle ho
            String[] asCode asResult
            Move "// Object oOld is a cOldClass" to asCode[0]
            Move "Object oReal is a cRealClass"  to asCode[1]
            Get Create of ghoFuncLib (RefClass(cUnusedUseStatements)) to ho
            Get ExtractInstantiatedClasses of ho asCode to asResult
            Send Destroy of ho
            Send AssertIAreEqual 1 (SizeOfArray(asResult))
            Send AssertSAreEqual "crealclass" asResult[0]
        End_Procedure

        {Published = True}
        { Description = "UnusedUseStatements (eReportFunctionAll): empty file list returns 0" }
        Procedure UnusedUseStatements_NoFiles
            String[] asFiles
            Integer iResult
            // Pass an empty file list -- should produce 0 unused Use statements.
            Get UnusedUseStatements of ghoFuncLib (&asFiles) "" to iResult
            Send AssertIAreEqual 0 iResult
        End_Procedure

    End_Object
