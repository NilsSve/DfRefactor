// oRefactorGridToCJGrid-Tests.pkg
//
// Unit tests for cGridToCJGrid.pkg (non-data-aware Grid -> cCJGrid subclass).
// Included by oUnit_Tests.pkg inside the oRefactorFuncLib_Tests fixture object.
//
// Test groups:
//   oGridIsGridDeclaration   - IsGridDeclaration (pattern and exact-match)
//   oGridTransformSource     - TransformSource end-to-end (class rename, property translation)

Use cGridToCJGrid.pkg

Object oRefactorGridToCJGrid is a cTestFixture
    Set psFunctionName to "RefactorGridToCJGrid"
        
    Object oGridIsGridDeclaration is a cTestFixture
        Set psFunctionName to "IsGridDeclaration (cGridToCJGrid)"
    
        Object oWorker is a cGridToCJGrid
        End_Object
    
        {Published = True}
        { Description = "Bare 'Grid' class is detected by pattern" }
        Procedure Grid_Detected
            Boolean bResult
            Get IsGridDeclaration of oWorker "object ogrid1 is a grid" to bResult
            Send Assert bResult
        End_Procedure
    
        {Published = True}
        { Description = "cGrid class is NOT detected by default (use explicit sParameter to target it)" }
        Procedure cGrid_NotDetectedByDefault
            Boolean bResult
            Get IsGridDeclaration of oWorker "object ogrid1 is a cgrid" to bResult
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        { Description = "Custom class ending in Grid is NOT detected by default (use explicit sParameter)" }
        Procedure CustomGrid_NotDetectedByDefault
            Boolean bResult
            Get IsGridDeclaration of oWorker "object omygrid is a clangrid" to bResult
            Send AssertFalse bResult
        End_Procedure
    
        {Published = True}
        { Description = "DbGrid class is NOT detected (belongs to cDbGridTocDbCJGrid)" }
        Procedure DbGrid_NotDetected
            Boolean bResult
            Get IsGridDeclaration of oWorker "object ogrid1 is a dbgrid" to bResult
            Send AssertFalse bResult
        End_Procedure
    
        {Published = True}
        { Description = "cDbGrid class is NOT detected (ends in dbgrid)" }
        Procedure cDbGrid_NotDetected
            Boolean bResult
            Get IsGridDeclaration of oWorker "object ogrid1 is a cdbgrid" to bResult
            Send AssertFalse bResult
        End_Procedure
    
        {Published = True}
        { Description = "cLangDbGrid class is NOT detected (ends in dbgrid)" }
        Procedure cLangDbGrid_NotDetected
            Boolean bResult
            Get IsGridDeclaration of oWorker "object ogrid1 is a clangdbgrid" to bResult
            Send AssertFalse bResult
        End_Procedure
    
        {Published = True}
        { Description = "Non-grid class is not detected" }
        Procedure NonGrid_NotDetected
            Boolean bResult
            Get IsGridDeclaration of oWorker "object oform1 is a cdbform" to bResult
            Send AssertFalse bResult
        End_Procedure
    
        {Published = True}
        { Description = "Exact-match mode: specified class is detected" }
        Procedure ExactMatch_Detected
            Boolean bResult
            Get ParseAndSetParameter of oWorker "cMyGrid,cCJGrid" to bResult
            Get IsGridDeclaration of oWorker "object omygrid is a cmygrid" to bResult
            Send Assert bResult
        End_Procedure
    
        {Published = True}
        { Description = "Exact-match mode: other grid class is NOT detected" }
        Procedure ExactMatch_OtherGrid_NotDetected
            Boolean bResult
            Get ParseAndSetParameter of oWorker "cMyGrid,cCJGrid" to bResult
            Get IsGridDeclaration of oWorker "object ogrid1 is a cgrid" to bResult
            Send AssertFalse bResult
        End_Procedure
    
    End_Object
    
    Object oGridTransformSource is a cTestFixture
        Set psFunctionName to "TransformSource (cGridToCJGrid)"
    
        Object oWorker is a cGridToCJGrid
        End_Object
    
        Procedure TearDown
            Boolean bOK
            // Reset oWorker class-name state to defaults so tests cannot contaminate each other.
            Get ParseAndSetParameter of oWorker "" to bOK
            Send _InitializeFuncLib of ghoRefactorFuncLib
        End_Procedure
    
        // Helper: loads asInput into worker, runs TransformSource, returns grid count.
        Function RunTransform String[] asInput Returns Integer
            Integer iGrids
            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Function_Return iGrids
        End_Function
    
        Function GetOutput Returns String[]
            String[] asResult
            Get pasSource of oWorker to asResult
            Function_Return asResult
        End_Function
    
        {Published = True}
        { Description = "Grid class name is replaced with cCJGrid" }
        Procedure ClassNameReplaced
            String[] asInput asOutput
            Integer  iGrids
    
            Move "Object oGrid1 is a Grid" to asInput[0]
            Move "End_Object"              to asInput[1]
    
            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput
    
            Send AssertIAreEqual 1 iGrids
            Send Assert (Lowercase(asOutput[0]) contains "is a ccjgrid")
        End_Procedure
    
        {Published = True}
        { Description = "cGrid class name is replaced with cCJGrid when sParameter explicitly targets it" }
        Procedure cGridClassNameReplaced
            String[] asInput asOutput
            Integer  iGrids
            Boolean  bOK

            Move "Object oGrid1 is a cGrid" to asInput[0]
            Move "End_Object"               to asInput[1]

            Get ParseAndSetParameter of oWorker "cGrid,cCJGrid" to bOK
            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Send AssertIAreEqual 1 iGrids
            Send Assert (Lowercase(asOutput[0]) contains "is a ccjgrid")
        End_Procedure
    
        {Published = True}
        { Description = "Returns 0 and leaves source unchanged for non-grid object" }
        Procedure NonGrid_Unchanged
            String[] asInput asOutput
            Integer  iGrids
    
            Move "Object oForm1 is a cDbForm" to asInput[0]
            Move "End_Object"                 to asInput[1]
    
            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput
    
            Send AssertIAreEqual 0 iGrids
            Send AssertSAreEqual "Object oForm1 is a cDbForm" asOutput[0]
        End_Procedure
    
        {Published = True}
        { Description = "DbGrid object is NOT converted by cGridToCJGrid" }
        Procedure DbGrid_NotConverted
            String[] asInput asOutput
            Integer  iGrids
    
            Move "Object oGrid1 is a DbGrid" to asInput[0]
            Move "End_Object"                to asInput[1]
    
            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput
    
            Send AssertIAreEqual 0 iGrids
            Send Assert (Lowercase(asOutput[0]) contains "is a dbgrid")
        End_Procedure
    
        {Published = True}
        { Description = "Grid-level Set properties are translated (pbAllowAppendRow)" }
        Procedure GridLevelProperty_Translated
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid1 is a Grid"                  to asInput[0]
            Move "    Set Allow_Bottom_Add_State to True"   to asInput[1]
            Move "End_Object"                               to asInput[2]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            // Verify the grid was detected and the legacy property was translated
            Send AssertIAreEqual 1 iGrids
            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "pbAllowAppendRow") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure
    
        {Published = True}
        { Description = "sParameter overrides both class names" }
        Procedure Parameter_OverridesClassNames
            String[] asInput asOutput
            Integer  iGrids
    
            Boolean bOK

            Move "Object oGrid1 is a cMyGrid" to asInput[0]
            Move "End_Object"                 to asInput[1]

            Get ParseAndSetParameter of oWorker "cMyGrid,cMyCJGrid" to bOK
            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Get GetOutput to asOutput

            Send AssertIAreEqual 1 iGrids
            Send Assert (Lowercase(asOutput[0]) contains "is a cmycjgrid")
        End_Procedure
    
        {Published = True}
        { Description = "Entry_Display color is extracted and placed before commented block" }
        Procedure EntryDisplay_ColorExtracted
            String[] asInput asOutput
            Integer  iGrids iIdx iTranslatedIdx iCommentedIdx

            Move "Object oGrid1 is a Grid"                     to asInput[0]
            Move "    Procedure Entry_Display"                 to asInput[1]
            Move "        Set CurrentRowColor to RGB(1,2,3)"   to asInput[2]
            Move "    End_Procedure"                           to asInput[3]
            Move "End_Object"                                  to asInput[4]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move -1 to iTranslatedIdx
            Move -1 to iCommentedIdx
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set piHighlightBackColor to RGB(1,2,3)") Begin
                    Move iIdx to iTranslatedIdx
                End
                If (Lowercase(asOutput[iIdx]) contains "// procedure entry_display") Begin
                    Move iIdx to iCommentedIdx
                End
            Loop
            // Translated property must exist and appear before the commented declaration
            Send Assert (iTranslatedIdx >= 0 and iCommentedIdx >= 0 and iTranslatedIdx < iCommentedIdx)
        End_Procedure

        {Published = True}
        { Description = "Column objects generated from Form_Width and Header_Label" }
        Procedure ColumnObjects_Generated
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bCol1 bCol2

            Move "Object oGrid1 is a Grid"           to asInput[0]
            Move "    Set Form_Width 0 to 200"       to asInput[1]
            Move "    Set Form_Width 1 to 150"       to asInput[2]
            Move '    Set Header_Label 0 to "Name"'  to asInput[3]
            Move '    Set Header_Label 1 to "Value"' to asInput[4]
            Move "End_Object"                        to asInput[5]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Send AssertIAreEqual 1 iGrids
            Move False to bCol1
            Move False to bCol2
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "object ocol1 is a") Begin
                    Move True to bCol1
                End
                If (Lowercase(asOutput[iIdx]) contains "object ocol2 is a") Begin
                    Move True to bCol2
                End
            Loop
            Send Assert (bCol1 and bCol2)
        End_Procedure

        {Published = True}
        { Description = "Column piWidth and psCaption are set from legacy Form_Width and Header_Label" }
        Procedure Column_WidthAndCaption_Set
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bWidth bCaption

            Move "Object oGrid1 is a Grid"           to asInput[0]
            Move "    Set Form_Width 0 to 300"        to asInput[1]
            Move ('    Set Header_Label 0 to "Ref"')  to asInput[2]
            Move "End_Object"                         to asInput[3]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bWidth
            Move False to bCaption
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set piWidth to 300") Begin
                    Move True to bWidth
                End
                If (asOutput[iIdx] contains 'Set psCaption to "Ref"') Begin
                    Move True to bCaption
                End
            Loop
            Send Assert (bWidth and bCaption)
        End_Procedure

        {Published = True}
        { Description = "Set Line_Width is removed silently" }
        Procedure LineWidth_Removed
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid1 is a Grid" to asInput[0]
            Move "    Set Line_Width to 5 5" to asInput[1]
            Move "End_Object"               to asInput[2]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "line_width") Begin
                    Move True to bFound
                End
            Loop
            Send AssertFalse bFound
        End_Procedure

        {Published = True}
        { Description = "Set Select_Mode to Multi_Select is translated to pbMultipleSelection" }
        Procedure SelectMode_Translated
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid1 is a Grid"                  to asInput[0]
            Move "    Set Select_Mode to Multi_Select"       to asInput[1]
            Move "End_Object"                               to asInput[2]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set pbMultipleSelection to True") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Set Visible_State is removed silently (does nothing in cCJGrid)" }
        Procedure VisibleState_Removed
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid1 is a Grid"          to asInput[0]
            Move "    Procedure Fill_the_List"       to asInput[1]
            Move "        Set Visible_State to False" to asInput[2]
            Move "        Set Visible_State to True"  to asInput[3]
            Move "    End_Procedure"                 to asInput[4]
            Move "End_Object"                        to asInput[5]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "visible_state") Begin
                    Move True to bFound
                End
            Loop
            Send AssertFalse bFound
        End_Procedure

        {Published = True}
        { Description = "Set Dynamic_Update_State inside a procedure body is commented out" }
        Procedure DynamicUpdateState_CommentedOut
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bCommented bActive

            Move "Object oGrid1 is a Grid"              to asInput[0]
            Move "    Procedure Fill_the_List"           to asInput[1]
            Move "        Set Dynamic_Update_State to False" to asInput[2]
            Move "        Send Delete_Data"              to asInput[3]
            Move "        Set Dynamic_Update_State to True"  to asInput[4]
            Move "    End_Procedure"                     to asInput[5]
            Move "End_Object"                            to asInput[6]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bCommented
            Move False to bActive
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "// set dynamic_update_state") Begin
                    Move True to bCommented
                End
                // Must not appear as active (non-commented) Set
                If (Lowercase(asOutput[iIdx]) contains "set dynamic_update_state" and ;
                    Left(Trim(Lowercase(asOutput[iIdx])), 4) = "set ") Begin
                    Move True to bActive
                End
            Loop
            Send Assert (bCommented and bActive = False)
        End_Procedure

        {Published = True}
        { Description = "Bare Send at grid body level is commented out" }
        Procedure BareSend_CommentedOut
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bCommented

            Move "Object oGrid1 is a Grid"     to asInput[0]
            Move "    Send Fill_the_List"       to asInput[1]
            Move "End_Object"                  to asInput[2]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bCommented
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "// send fill_the_list") Begin
                    Move True to bCommented
                End
            Loop
            Send Assert bCommented
        End_Procedure

        {Published = True}
        { Description = "LoadData and Activating stubs are always generated" }
        Procedure LoadDataActivating_Generated
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bLoadData bActivating

            Move "Object oGrid1 is a Grid" to asInput[0]
            Move "End_Object"              to asInput[1]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bLoadData
            Move False to bActivating
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "procedure loaddata") Begin
                    Move True to bLoadData
                End
                If (Lowercase(asOutput[iIdx]) contains "procedure activating") Begin
                    Move True to bActivating
                End
            Loop
            Send Assert (bLoadData and bActivating)
        End_Procedure

        {Published = True}
        { Description = "Column objects appear before LoadData in output" }
        Procedure ColumnObjects_BeforeLoadData
            String[] asInput asOutput
            Integer  iGrids iIdx iColIdx iLoadIdx

            Move "Object oGrid1 is a Grid"     to asInput[0]
            Move "    Set Form_Width 0 to 100"  to asInput[1]
            Move "End_Object"                  to asInput[2]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move -1 to iColIdx
            Move -1 to iLoadIdx
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "object ocol1 is a") Begin
                    Move iIdx to iColIdx
                End
                If (Lowercase(asOutput[iIdx]) contains "procedure loaddata") Begin
                    Move iIdx to iLoadIdx
                End
            Loop
            Send Assert (iColIdx >= 0 and iLoadIdx >= 0 and iColIdx < iLoadIdx)
        End_Procedure

    End_Object

End_Object
