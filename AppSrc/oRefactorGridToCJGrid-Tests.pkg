        {Published = True}
        { Description = "Increment iRow emitted after last column's Add_Item" }
        Procedure IncrementIRow_AfterLastColumn
            String[] asInput asOutput
            Integer  iGrids iIdx iMoveIdx iIncrIdx
            Boolean  bCorrectOrder

            Move "Object oGrid1 is a Grid"               to asInput[0]
            Move "    Set Form_Width 0 to 100"           to asInput[1]
            Move "    Set Form_Width 1 to 100"           to asInput[2]
            Move "    Procedure Populate"                to asInput[3]
            Move "        Send Add_Item Msg_None ColA"   to asInput[4]
            Move "        Send Add_Item Msg_None ColB"   to asInput[5]
            Move "    End_Procedure"                     to asInput[6]
            Move "End_Object"                            to asInput[7]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move -1 to iMoveIdx
            Move -1 to iIncrIdx
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "TheData[iRow].sValue[iCol2]") Move iIdx to iMoveIdx
                If (Lowercase(asOutput[iIdx]) contains "increment irow")   Move iIdx to iIncrIdx
            Loop
            // Increment iRow must exist and come right after the last column Move
            Move (iMoveIdx >= 0 and iIncrIdx = iMoveIdx + 1) to bCorrectOrder
            Send Assert bCorrectOrder
        End_Procedure

