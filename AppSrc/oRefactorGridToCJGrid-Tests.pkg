        {Published = True}
        { Description = "Legacy data-loading procedure is renamed to LoadData" }
        Procedure DataLoadProc_RenamedToLoadData
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bLoadData bOldName

            Move "Object oGrid1 is a Grid"           to asInput[0]
            Move "    Set Form_Width 0 to 100"       to asInput[1]
            Move "    Procedure Fill_the_List"       to asInput[2]
            Move "        Send Add_Item Msg_None 42" to asInput[3]
            Move "    End_Procedure"                 to asInput[4]
            Move "End_Object"                        to asInput[5]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bLoadData
            Move False to bOldName
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "procedure loaddata") Move True to bLoadData
                If (Lowercase(asOutput[iIdx]) contains "procedure fill_the_list") Move True to bOldName
            Loop
            Send Assert (bLoadData and bOldName = False)
        End_Procedure

        {Published = True}
        { Description = "Send Add_Item is converted to TheData row assignment" }
        Procedure AddItem_ConvertedToTheData
            String[] asInput asOutput
            Integer  iGrids iIdx
