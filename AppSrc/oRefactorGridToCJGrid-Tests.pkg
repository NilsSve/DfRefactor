            Move False to bCol1
            Move False to bCol2
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "get picolumnid of ocol1") Move True to bCol1
                If (Lowercase(asOutput[iIdx]) contains "get picolumnid of ocol2") Move True to bCol2
            Loop
