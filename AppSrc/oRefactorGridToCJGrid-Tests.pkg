            Move "        Set Entry_State 0 to False"            to asInput[4]
            Move "    End_Procedure"                             to asInput[5]
            Move "End_Object"                                    to asInput[6]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "entry_state") Move True to bFound
            Loop
            Send AssertFalse bFound
        End_Procedure

        {Published = True}
        { Description = "Form_Bitmap is commented out with a TODO hint" }
        Procedure FormBitmap_CommentedWithTodo
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bTodo bCommented bActive

            Move "Object oGrid1 is a Grid"                            to asInput[0]
            Move "    Set Form_Width 0 to 100"                        to asInput[1]
            Move "    Procedure Fill_the_List"                        to asInput[2]
            Move "        Send Add_Item Msg_None X"                   to asInput[3]
            Move '        Set Form_Bitmap 0 to "icon.bmp"'            to asInput[4]
            Move "    End_Procedure"                                  to asInput[5]
            Move "End_Object"                                         to asInput[6]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bTodo
            Move False to bCommented
            Move False to bActive
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "todo" and ;
                    Lowercase(asOutput[iIdx]) contains "form_bitmap") Move True to bTodo
                If (Lowercase(asOutput[iIdx]) contains "// set form_bitmap") Move True to bCommented
                If (Left(Trim(Lowercase(asOutput[iIdx])), 4) = "set " and ;
                    asOutput[iIdx] contains "Form_Bitmap")             Move True to bActive
            Loop
            Send Assert (bTodo and bCommented and bActive = False)
        End_Procedure

    End_Object

    Object oGridCellAccess is a cTestFixture
        Set psFunctionName to "CellAccess (cGridToCJGrid)"

        Object oWorker is a cGridToCJGrid
        End_Object

        Procedure TearDown
            Boolean bOK
            Get ParseAndSetParameter of oWorker "" to bOK
            Send _InitializeFuncLib of ghoFuncLib
        End_Procedure

        Function RunTransform String[] asInput Returns Integer
            Integer iGrids
            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Function_Return iGrids
        End_Function

        Function GetOutput Returns String[]
            String[] asResult
            Get pasSource of oWorker to asResult
            Function_Return asResult
        End_Function

        {Published = True}
        { Description = "Get Line_Size is removed silently from a method body" }
        Procedure LineSize_Removed
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid1 is a Grid"           to asInput[0]
            Move "    Set Form_Width 0 to 100"       to asInput[1]
            Move "    Procedure pRead"               to asInput[2]
            Move "        Integer iCols"             to asInput[3]
            Move "        Get Line_Size to iCols"    to asInput[4]
            Move "    End_Procedure"                 to asInput[5]
            Move "End_Object"                        to asInput[6]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "line_size") Move True to bFound
            Loop
            Send AssertFalse bFound
        End_Procedure

        {Published = True}
        { Description = "Get Current_Item is converted to phoDataSource / SelectedRow pattern" }
        Procedure GetCurrentItem_Converted
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bDataSource bSelectedRow bGetDataSource bOld

            Move "Object oGrid1 is a Grid"                  to asInput[0]
            Move "    Set Form_Width 0 to 100"              to asInput[1]
            Move "    Procedure pGetRow"                    to asInput[2]
            Move "        Integer iItem"                    to asInput[3]
            Move "        Get Current_Item to iItem"        to asInput[4]
            Move "    End_Procedure"                        to asInput[5]
            Move "End_Object"                               to asInput[6]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bDataSource
            Move False to bSelectedRow
            Move False to bGetDataSource
            Move False to bOld
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "get phodatasource")  Move True to bDataSource
                If (Lowercase(asOutput[iIdx]) contains "get selectedrow")    Move True to bSelectedRow
                If (Lowercase(asOutput[iIdx]) contains "get datasource")     Move True to bGetDataSource
                If (Lowercase(asOutput[iIdx]) contains "get current_item")   Move True to bOld
            Loop
            Send Assert (bDataSource and bSelectedRow and bGetDataSource and bOld = False)
        End_Procedure

        {Published = True}
        { Description = "Row normalisation Move is removed silently after Get Current_Item" }
        Procedure NormalisationMove_Removed
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid1 is a Grid"                      to asInput[0]
            Move "    Set Form_Width 0 to 100"                  to asInput[1]
            Move "    Procedure pGetRow"                        to asInput[2]
            Move "        Integer iItem"                        to asInput[3]
            Move "        Get Current_Item to iItem"            to asInput[4]
            Move "        Move (iItem /4 * 4) to iItem"         to asInput[5]
            Move "    End_Procedure"                            to asInput[6]
            Move "End_Object"                                   to asInput[7]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            // The normalisation Move must not appear in the output.
            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "move (iitem") Move True to bFound
            Loop
            Send AssertFalse bFound
        End_Procedure

        {Published = True}
        { Description = "Get Value of <grid> (var+N) is converted to Get piColumnId + TheData array access" }
        Procedure GetValue_ConvertedToTheData
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bColId bTheData bOld

            Move "Object oGrid1 is a Grid"                         to asInput[0]
            Move "    Set Form_Width 0 to 100"                     to asInput[1]
            Move "    Set Form_Width 1 to 100"                     to asInput[2]
            Move "    Set Form_Width 2 to 100"                     to asInput[3]
            Move "    Procedure pRead"                             to asInput[4]
            Move "        Integer iItem"                           to asInput[5]
            Move "        String sVal"                             to asInput[6]
            Move "        Get Current_Item to iItem"               to asInput[7]
            Move "        Move (iItem /3 * 3) to iItem"            to asInput[8]
            Move "        Get Value of oGrid1 (iItem + 2) to sVal" to asInput[9]
            Move "    End_Procedure"                               to asInput[10]
            Move "End_Object"                                      to asInput[11]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bColId
            Move False to bTheData
            Move False to bOld
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "get picolumnid of ocol3") Move True to bColId
                If (asOutput[iIdx] contains "TheData[iRow].sValue[iCol]" and ;
                    asOutput[iIdx] contains "sVal") Move True to bTheData
                If (Lowercase(asOutput[iIdx]) contains "get value of") Move True to bOld
            Loop
            Send Assert (bColId and bTheData and bOld = False)
        End_Procedure

        {Published = True}
        { Description = "Full 3-line row-access sequence produces correct cCJGrid pattern" }
        Procedure FullSequence_Converted
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bSelectedRow bTheData bNoCurrentItem bNoNormalise bNoGetValue

            Move "Object oGrid1 is a Grid"                            to asInput[0]
            Move "    Set Form_Width 0 to 100"                        to asInput[1]
            Move "    Set Form_Width 1 to 100"                        to asInput[2]
            Move "    Set Form_Width 2 to 100"                        to asInput[3]
            Move "    Set Form_Width 3 to 0"                          to asInput[4]
            Move "    Procedure pSnooze"                              to asInput[5]
            Move "        Integer iItem iArrayPos"                    to asInput[6]
            Move "        Get Current_Item to iItem"                  to asInput[7]
            Move "        Move (iItem /4 * 4) to iItem"               to asInput[8]
            Move "        Get Value of oGrid1 (iItem + 3) to iArrayPos" to asInput[9]
            Move "    End_Procedure"                                  to asInput[10]
            Move "End_Object"                                         to asInput[11]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bSelectedRow
            Move False to bTheData
            Move True  to bNoCurrentItem
            Move True  to bNoNormalise
            Move True  to bNoGetValue
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "get selectedrow")           Move True  to bSelectedRow
                // iItem is renamed to iRow; column offset 3 -> oCol4 -> iCol (generic)
                If (asOutput[iIdx] contains "TheData[iRow].sValue[iCol]" and ;
                    asOutput[iIdx] contains "iArrayPos")                            Move True  to bTheData
                If (Lowercase(asOutput[iIdx]) contains "get current_item")          Move False to bNoCurrentItem
                If (Lowercase(asOutput[iIdx]) contains "/4 * 4")                    Move False to bNoNormalise
                If (Lowercase(asOutput[iIdx]) contains "get value of")              Move False to bNoGetValue
            Loop
            Send Assert (bSelectedRow and bTheData and bNoCurrentItem and bNoNormalise and bNoGetValue)
        End_Procedure

        {Published = True}
        { Description = "Var decls injected: iRow/iCol/Handle/tDataSourceRow[], no TODO, iItem renamed to iRow" }
        Procedure CurrentItem_VarDecls_Injected
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bHandle bTheData bIRow bColId bNoTodo bNoOldName

            Move "Object oGrid1 is a Grid"                           to asInput[0]
            Move "    Set Form_Width 0 to 100"                       to asInput[1]
            Move "    Procedure pGetRow"                             to asInput[2]
            Move "        Integer iItem"                             to asInput[3]
            Move "        Get Current_Item to iItem"                 to asInput[4]
            Move "        Get Value of oGrid1 (iItem + 0) to sName" to asInput[5]
            Move "    End_Procedure"                                 to asInput[6]
            Move "End_Object"                                        to asInput[7]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bHandle
            Move False to bTheData
            Move False to bIRow
            Move False to bColId
            Move True  to bNoTodo
            Move True  to bNoOldName    // stays True if iItem does not appear in active code
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "handle hodatasource")      Move True  to bHandle
                If (Lowercase(asOutput[iIdx]) contains "tdatasourcerow[] thedata") Move True  to bTheData
                If (Lowercase(asOutput[iIdx]) contains "integer" and ;
                    Lowercase(asOutput[iIdx]) contains "irow")                     Move True  to bIRow
                If (Lowercase(asOutput[iIdx]) contains "get picolumnid of ocol1")  Move True  to bColId
                If (Lowercase(asOutput[iIdx]) contains "todo" and ;
                    Lowercase(asOutput[iIdx]) contains "var decls")                Move False to bNoTodo
                // iItem must not appear in any active (non-commented) output line.
                If (Lowercase(asOutput[iIdx]) contains "iitem" and ;
                    Left(Trim(Lowercase(asOutput[iIdx])), 2) <> "//")              Move False to bNoOldName
            Loop
            Send Assert (bHandle and bTheData and bIRow and bColId and bNoTodo and bNoOldName)
        End_Procedure

    End_Object

    // -----------------------------------------------------------------------
    // oTrailingWhitespaceIndent
    //   Regression tests for the indent-math bug where Length(sLine)-Length(Trim(sLine))
    //   was used to compute indent length.  Trim strips BOTH ends, so any source line
    //   with trailing whitespace caused the "indent" to grab part of the line content,
    //   producing corrupted output like "    If (// If (cond) Send cmd args".
    //   Fix: a GetIndent helper that uses LTrim (leading-only) is used everywhere
    //   instead of the open-coded Length-Trim arithmetic.
    // -----------------------------------------------------------------------
    Object oTrailingWhitespaceIndent is a cTestFixture
        Set psFunctionName to "TrailingWhitespaceIndent (cGridToCJGrid)"

        Object oWorker is a cGridToCJGrid
        End_Object

        Procedure TearDown
            Boolean bOK
            Get ParseAndSetParameter of oWorker "" to bOK
            Send _InitializeFuncLib of ghoFuncLib
        End_Procedure

        Function RunTransform String[] asInput Returns String[]
            String[] asOutput
            Integer  iGrids
            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Get pasSource of oWorker to asOutput
            Function_Return asOutput
        End_Function

        // -----------------------------------------------------------------------
        // GetIndent direct unit tests
        // -----------------------------------------------------------------------

        {Published = True}
        { Description = "GetIndent returns the leading whitespace for a normal line" }
        Procedure GetIndent_LeadingSpaces
            String sResult
            Get GetIndent of oWorker "    If (a) b"  to sResult
            Send AssertSAreEqual "    " sResult
        End_Procedure

        {Published = True}
        { Description = "GetIndent returns leading whitespace only, NOT trailing whitespace" }
        Procedure GetIndent_IgnoresTrailingWhitespace
            String sResult
            // 4 leading spaces + "If (a) b" + 4 trailing spaces.
            // The old (buggy) math returned 8 chars ("    If (").  The fix returns 4.
            Get GetIndent of oWorker "    If (a) b    " to sResult
            Send AssertSAreEqual "    " sResult
        End_Procedure

        {Published = True}
        { Description = "GetIndent returns empty string for a line with no indent" }
        Procedure GetIndent_NoIndent
            String sResult
            Get GetIndent of oWorker "End_Procedure" to sResult
            Send AssertSAreEqual "" sResult
        End_Procedure

        {Published = True}
        { Description = "GetIndent returns empty string for an empty string" }
        Procedure GetIndent_EmptyString
            String sResult
            Get GetIndent of oWorker "" to sResult
            Send AssertSAreEqual "" sResult
        End_Procedure

        // -----------------------------------------------------------------------
        // CommentOutLine direct unit tests
        // -----------------------------------------------------------------------

        {Published = True}
        { Description = "CommentOutLine prefixes content with // and preserves leading indent" }
        Procedure CommentOutLine_PreservesIndent
            String sResult
            Get CommentOutLine of oWorker "    Set Main_File to Orders" to sResult
            Send AssertSAreEqual "    // Set Main_File to Orders" sResult
        End_Procedure

        {Published = True}
        { Description = "CommentOutLine handles a line WITH trailing whitespace correctly (regression)" }
        Procedure CommentOutLine_TrailingWhitespace_NoCorruption
            String sResult sExpected
            // Source has 4 trailing spaces.  Old bug: result = "    If (// If (a <> b) Send c d"
            // Fix: result = "    // If (a <> b) Send c d"
            Get CommentOutLine of oWorker "    If (a <> b) Send c d    " to sResult
            Move "    // If (a <> b) Send c d" to sExpected
            Send AssertSAreEqual sExpected sResult
        End_Procedure

        {Published = True}
        { Description = "CommentOutLine handles a 0-indent line with trailing whitespace" }
        Procedure CommentOutLine_NoIndentTrailingWhitespace
            String sResult
            Get CommentOutLine of oWorker "End_Procedure    " to sResult
            Send AssertSAreEqual "// End_Procedure" sResult
        End_Procedure

        // -----------------------------------------------------------------------
        // End-to-end TransformSource: the exact bug the user hit
        // -----------------------------------------------------------------------

        {Published = True}
        { Description = "Item_Change body with trailing whitespace on inline If line is commented out cleanly (no 'If (// If (' corruption)" }
        Procedure ItemChange_InlineIf_TrailingWhitespace_NoCorruption
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFoundCorruption bFoundCleanComment

            // Mirror the user's exact failing input: 4 trailing spaces on the If line.
            Move "Object oGrid1 is a Grid"                                      to asInput[0]
            Move "    Procedure Item_Change Integer iFromItem Integer iToItem Returns Integer" to asInput[1]
            Move "        Integer iRetVal"                                       to asInput[2]
            Move "        Forward Get msg_Item_Change iFromItem iToItem to iRetVal" to asInput[3]
            Move "        If (iToItem <> iFromItem) Send pAddLabels iToItem    " to asInput[4]
            Move "        Procedure_Return iRetVal"                              to asInput[5]
            Move "    End_Procedure"                                              to asInput[6]
            Move "End_Object"                                                     to asInput[7]

            Get RunTransform asInput to asOutput

            Move False to bFoundCorruption
            Move False to bFoundCleanComment
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                // The corruption pattern: "If (" appears BEFORE the comment marker on the same line.
                If (asOutput[iIdx] contains "If (//") Begin
                    Move True to bFoundCorruption
                End
                // The clean output: "// If (iToItem <> iFromItem) Send pAddLabels iToItem"
                If (Trim(asOutput[iIdx]) contains "// If (iToItem <> iFromItem) Send pAddLabels iToItem") Begin
                    Move True to bFoundCleanComment
                End
            Loop
            Send AssertFalse bFoundCorruption
            Send Assert bFoundCleanComment
        End_Procedure

        {Published = True}
        { Description = "Item_Change body with trailing whitespace on Send line is commented out cleanly" }
        Procedure ItemChange_SendLine_TrailingWhitespace_NoCorruption
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFoundCorruption bFoundCleanComment

            Move "Object oGrid1 is a Grid"                              to asInput[0]
            Move "    Procedure Item_Change Integer iOld Integer iNew"  to asInput[1]
            Move "        Send DoSomething iNew     "                   to asInput[2]
            Move "    End_Procedure"                                    to asInput[3]
            Move "End_Object"                                            to asInput[4]

            Get RunTransform asInput to asOutput

            Move False to bFoundCorruption
            Move False to bFoundCleanComment
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                // Any sign of indent-corruption: original keyword appears BEFORE the comment marker.
                If (asOutput[iIdx] contains "Send //") Move True to bFoundCorruption
                If (Trim(asOutput[iIdx]) contains "// Send DoSomething iNew") Begin
                    Move True to bFoundCleanComment
                End
            Loop
            Send AssertFalse bFoundCorruption
            Send Assert bFoundCleanComment
        End_Procedure

    End_Object

End_Object
