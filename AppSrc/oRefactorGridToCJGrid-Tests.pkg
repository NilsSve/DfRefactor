            Move '    Set Header_Label 0 to "Name"'   to asInput[2]
            Move "    Procedure Fill_the_List"        to asInput[3]
            Move '        Send Add_Item Msg_None "X"' to asInput[4]
            Move "    End_Procedure"                  to asInput[5]
            Move "End_Object"                         to asInput[6]

            Get RunTransform asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains 'TheData[iRow].sValue[iCol1]') Move True to bFound
            Loop
            Send Assert bFound
