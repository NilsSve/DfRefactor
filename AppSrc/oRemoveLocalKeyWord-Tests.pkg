            Get RemoveLocalKeyWord of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Return value must be True when Local keyword is removed.
        {Published = True}
        Procedure RemoveLocalKeyWord_ReturnValue
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Set pbInFunction of ghoFuncLib to True
            Move '  Local Boolean bFound' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveLocalKeyWord of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
        End_Procedure

        // Comment line: bLineIsReady guard fires, bChanged must be False.
        {Published = True}
        Procedure RemoveLocalKeyWord_NoChange_Comment
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move '// Local Integer iCount' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveLocalKeyWord of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual '// Local Integer iCount' sLine
        End_Procedure

    End_Object
