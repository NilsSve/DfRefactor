        Move "    Set CurrentRowColor to 16711680" to sLine
        Move (Lowercase(Trim(sLine))) to sLower
        Get TranslateGridProperty of oWorker sLine sLower to asResult
        Send AssertIAreEqual 1 (SizeOfArray(asResult))
        Send AssertSAreEqual "    Set piHighlightBackColor to 16711680" asResult[0]
    End_Procedure

    {Published = True}
    { Description = "CurrentRowTextColor -> piHighlightForeColor (RGB value preserved)" }
