    // -----------------------------------------------------------------------
    // Indentation preservation
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "Indentation from the original line is preserved in the output" }
    Procedure IndentPreserved
        String[] asResult
        String   sLine sLower
        // Two-tab indent (8 spaces)
        Move "        Set Auto_Save_State to True" to sLine
        Move (Lowercase(Trim(sLine))) to sLower
        Get TranslateGridProperty of oWorker sLine sLower to asResult
        Send AssertIAreEqual 1 (SizeOfArray(asResult))
        Send AssertSAreEqual "        Set pbAutoSave to True" asResult[0]
    End_Procedure

End_Object

// ---------------------------------------------------------------------------

Object oTransformSource is a cTestFixture
    Set psFunctionName to "TransformSource"

    Object oWorker is a cDbGridToCJGrid
    End_Object

    // Helper: load a String[] into oWorker and run TransformSource.
    // Returns the result array via ByRef and the grid count as the function return.
    Function RunTransform String[] asInput Returns Integer
        Integer iGrids
        Set pasSource of oWorker to asInput
        Get TransformSource of oWorker to iGrids
        Function_Return iGrids
    End_Function

    // Helper: retrieve the output array from oWorker after RunTransform.
    Function GetOutput Returns String[]
        String[] asOut
        Get pasSource of oWorker to asOut
        Function_Return asOut
    End_Function

    // -----------------------------------------------------------------------
    // Class name replacement
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "DbGrid class name is replaced with the default cDbCJGrid target" }
    Procedure ClassNameReplaced
        String[] asInput asOutput
        Integer  iGrids

        Move "Object oMyGrid is a cDbGrid" to asInput[0]
        Move "End_Object"                  to asInput[1]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Send AssertIAreEqual 1 iGrids
        Send AssertSAreEqual "Object oMyGrid is a cDbCJGrid" asOutput[0]
    End_Procedure

    {Published = True}
    { Description = "Pattern-match: any class ending in 'dbgrid' is replaced" }
    Procedure PatternMatch_AnyDbGrid
        String[] asInput asOutput
        Integer  iGrids

        Move "    Object oGrid is a cLangDbGrid" to asInput[0]
        Move "    End_Object"                    to asInput[1]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Send AssertIAreEqual 1 iGrids
        Send AssertSAreEqual "    Object oGrid is a cDbCJGrid" asOutput[0]
    End_Procedure

    {Published = True}
    { Description = "Non-grid objects are passed through unchanged" }
    Procedure NonGridObject_PassedThrough
        String[] asInput asOutput
        Integer  iGrids

        Move "Object oMyPanel is a cPanel" to asInput[0]
        Move "End_Object"                  to asInput[1]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Send AssertIAreEqual 0 iGrids
        Send AssertSAreEqual "Object oMyPanel is a cPanel" asOutput[0]
        Send AssertSAreEqual "End_Object"                  asOutput[1]
    End_Procedure

    {Published = True}
    { Description = "Return value counts the number of grids converted" }
    Procedure GridCount_TwoGrids
        String[] asInput asOutput
        Integer  iGrids

        Move "Object oGrid1 is a cDbGrid" to asInput[0]
        Move "End_Object"                 to asInput[1]
        Move "Object oGrid2 is a cDbGrid" to asInput[2]
        Move "End_Object"                 to asInput[3]

        Get RunTransform asInput to iGrids
        Send AssertIAreEqual 2 iGrids
    End_Procedure

    // -----------------------------------------------------------------------
    // Legacy property removal inside a grid
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "Set Main_File inside a grid is commented out, not removed" }
    Procedure MainFile_CommentedOut
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFoundCommented bFoundRaw

        Move "Object oGrid is a cDbGrid"     to asInput[0]
        Move "    Set Main_File to Orders"   to asInput[1]
        Move "    Set Size to 100 200"       to asInput[2]
        Move "End_Object"                    to asInput[3]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        // Verify the commented-out line is present
        Move False to bFoundCommented
        Move False to bFoundRaw
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (Lowercase(asOutput[iIdx]) contains "// set main_file") Begin
                Move True to bFoundCommented
            End
            // The raw (un-commented) Set Main_File line must not appear
            If (Trim(Lowercase(asOutput[iIdx])) = "set main_file to orders") Begin
                Move True to bFoundRaw
            End
        Loop
        Send Assert bFoundCommented
        Send AssertFalse bFoundRaw

        // Verify the ordinary property still passes through unchanged
        Move False to bFoundRaw
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (asOutput[iIdx] = "    Set Size to 100 200") Begin
                Move True to bFoundRaw
            End
        Loop
        Send Assert bFoundRaw
    End_Procedure

    {Published = True}
    { Description = "Set Item_Limit inside a grid is removed" }
    Procedure ItemLimit_Removed
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFound

        Move "Object oGrid is a cDbGrid"   to asInput[0]
        Move "    Set Item_Limit to 5"     to asInput[1]
        Move "End_Object"                  to asInput[2]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFound
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (Lowercase(asOutput[iIdx]) contains "item_limit") Begin
                Move True to bFound
            End
        Loop
        Send AssertFalse bFound
    End_Procedure

    // -----------------------------------------------------------------------
    // Property translation inside a grid
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "No_Create_State True inside a grid -> 2 pbAllow lines (inverted)" }
    Procedure NoCreateState_InGrid
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFoundAppend bFoundInsert

        Move "Object oGrid is a cDbGrid"         to asInput[0]
        Move "    Set No_Create_State to True"   to asInput[1]
        Move "End_Object"                        to asInput[2]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFoundAppend
        Move False to bFoundInsert
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (asOutput[iIdx] = "    Set pbAllowAppendRow to False") Begin
                Move True to bFoundAppend
            End
            If (asOutput[iIdx] = "    Set pbAllowInsertRow to False") Begin
                Move True to bFoundInsert
            End
        Loop
        Send Assert bFoundAppend
        Send Assert bFoundInsert
    End_Procedure

    {Published = True}
    { Description = "Read_Only_State True inside a grid -> pbReadOnly True" }
    Procedure ReadOnlyState_InGrid
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFound

        Move "Object oGrid is a cDbGrid"          to asInput[0]
        Move "    Set Read_Only_State to True"    to asInput[1]
        Move "End_Object"                         to asInput[2]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFound
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (asOutput[iIdx] = "    Set pbReadOnly to True") Begin
                Move True to bFound
            End
        Loop
        Send Assert bFound
    End_Procedure

    {Published = True}
    { Description = "Gridline_Mode Grid_Visible_Both inside a grid -> 2 xtpGridSolid lines" }
    Procedure GridlineModeBoth_InGrid
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFoundH bFoundV

        Move "Object oGrid is a cDbGrid"                    to asInput[0]
        Move "    Set Gridline_Mode to Grid_Visible_Both"   to asInput[1]
        Move "End_Object"                                   to asInput[2]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFoundH
        Move False to bFoundV
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (asOutput[iIdx] = "    Set peHorizontalGridStyle to xtpGridSolid") Begin
                Move True to bFoundH
            End
            If (asOutput[iIdx] = "    Set peVerticalGridStyle   to xtpGridSolid") Begin
                Move True to bFoundV
            End
        Loop
        Send Assert bFoundH
        Send Assert bFoundV
    End_Procedure

    {Published = True}
    { Description = "peResizeColumn = rcNone inside a grid -> pbAllowColumnResize False" }
    Procedure PeResizeColumn_InGrid
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFound

        Move "Object oGrid is a cDbGrid"             to asInput[0]
        Move "    Set peResizeColumn to rcNone"      to asInput[1]
        Move "End_Object"                            to asInput[2]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFound
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (asOutput[iIdx] = "    Set pbAllowColumnResize to False") Begin
                Move True to bFound
            End
        Loop
        Send Assert bFound
    End_Procedure

    {Published = True}
    { Description = "peResizeColumn = rcAll inside a grid -> line is dropped" }
    Procedure PeResizeColumn_rcAll_InGrid
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFoundOld bFoundNew

        Move "Object oGrid is a cDbGrid"             to asInput[0]
        Move "    Set peResizeColumn to rcAll"       to asInput[1]
        Move "End_Object"                            to asInput[2]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFoundOld
        Move False to bFoundNew
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (Lowercase(asOutput[iIdx]) contains "peresizecolumn") Begin
                Move True to bFoundOld
            End
            If (Lowercase(asOutput[iIdx]) contains "pbresizecolumn") Begin
                Move True to bFoundNew
            End
        Loop
        Send AssertFalse bFoundOld
        Send AssertFalse bFoundNew
    End_Procedure

    // -----------------------------------------------------------------------
    // Entry_Display procedure removal
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "Entry_Display procedure block is commented out, not removed" }
    Procedure EntryDisplay_CommentedOut
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFoundDecl bFoundBody bFoundEnd bFoundRaw

        Move "Object oGrid is a cDbGrid"      to asInput[0]
        Move "    Set Size to 100 200"        to asInput[1]
        Move "    Procedure Entry_Display"    to asInput[2]
        Move "        Send Something"         to asInput[3]
        Move "    End_Procedure"              to asInput[4]
        Move "End_Object"                     to asInput[5]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFoundDecl
        Move False to bFoundBody
        Move False to bFoundEnd
        Move False to bFoundRaw
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (Lowercase(asOutput[iIdx]) contains "// procedure entry_display") Begin
                Move True to bFoundDecl
            End
            If (Lowercase(asOutput[iIdx]) contains "// send something") Begin
                Move True to bFoundBody
            End
            If (Lowercase(asOutput[iIdx]) contains "// end_procedure") Begin
                Move True to bFoundEnd
            End
            // The raw (un-commented) lines must not appear
            If (Trim(Lowercase(asOutput[iIdx])) = "procedure entry_display") Begin
                Move True to bFoundRaw
            End
        Loop
        Send Assert bFoundDecl
        Send Assert bFoundBody
        Send Assert bFoundEnd
        Send AssertFalse bFoundRaw
    End_Procedure

    // -----------------------------------------------------------------------
    // Content outside grids passes through untouched
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "Lines before and after a grid block are preserved unchanged" }
    Procedure SurroundingContent_Preserved
        String[] asInput asOutput
        Integer  iGrids

        Move "Use SomePackage.pkg"            to asInput[0]
        Move ""                               to asInput[1]
        Move "Object oGrid is a cDbGrid"      to asInput[2]
        Move "End_Object"                     to asInput[3]
        Move ""                               to asInput[4]
        Move "// trailing comment"            to asInput[5]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Send AssertSAreEqual "Use SomePackage.pkg" asOutput[0]
        Send AssertSAreEqual ""                    asOutput[1]
        Send AssertSAreEqual ""                    asOutput[4]
        Send AssertSAreEqual "// trailing comment" asOutput[5]
    End_Procedure

    // -----------------------------------------------------------------------
    // ParseAndSetParameter
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "Empty parameter -> pattern-based detection, default class names" }
    Procedure ParseParam_Empty
        Boolean bOK
        String  sGrid sCol

        Get ParseAndSetParameter of oWorker "" to bOK
        Send Assert bOK
        Get psLegacyGridClass   of oWorker to sGrid
        Send AssertSAreEqual "" sGrid
        Get psTargetGridClass   of oWorker to sGrid
        Send AssertSAreEqual CS_CJGrid_TargetClass sGrid
        Get psTargetColumnClass of oWorker to sCol
        Send AssertSAreEqual CS_CJGrid_TargetColumn sCol
    End_Procedure

    {Published = True}
    { Description = "2-part parameter sets old and new grid class; column stays default" }
    Procedure ParseParam_TwoParts
        Boolean bOK
        String  sVal

        Get ParseAndSetParameter of oWorker "cMyOldGrid,cMyNewGrid" to bOK
        Send Assert bOK
        Get psLegacyGridClass of oWorker to sVal
        Send AssertSAreEqual "cmyoldgrid" sVal   // stored lowercase
        Get psTargetGridClass of oWorker to sVal
        Send AssertSAreEqual "cMyNewGrid" sVal
        Get psTargetColumnClass of oWorker to sVal
        Send AssertSAreEqual CS_CJGrid_TargetColumn sVal
    End_Procedure

    {Published = True}
    { Description = "3-part parameter sets all three class names" }
    Procedure ParseParam_ThreeParts
        Boolean bOK
        String  sVal

        Get ParseAndSetParameter of oWorker "cOld,cNewGrid,cNewCol" to bOK
        Send Assert bOK
        Get psLegacyGridClass   of oWorker to sVal
        Send AssertSAreEqual "cold" sVal
        Get psTargetGridClass   of oWorker to sVal
        Send AssertSAreEqual "cNewGrid" sVal
        Get psTargetColumnClass of oWorker to sVal
        Send AssertSAreEqual "cNewCol" sVal
    End_Procedure

    {Published = True}
    { Description = "1-part parameter returns False (invalid)" }
    Procedure ParseParam_OnePart_Invalid
        Boolean bOK
        Get ParseAndSetParameter of oWorker "OnlyOneClass" to bOK
        Send AssertFalse bOK
    End_Procedure

    // -----------------------------------------------------------------------
    // ReplaceGridClassName preserves indentation
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "ReplaceGridClassName keeps leading spaces intact" }
    Procedure ReplaceGridClassName_Indent
        String sResult sLine sLower

        Get ParseAndSetParameter of oWorker "" to sResult  // default classes
        Move "    Object oGrid is a cDbGrid" to sLine
        Move (Lowercase(Trim(sLine)))         to sLower
        Get ReplaceGridClassName of oWorker sLine sLower to sResult
        Send AssertSAreEqual "    Object oGrid is a cDbCJGrid" sResult
    End_Procedure

End_Object

