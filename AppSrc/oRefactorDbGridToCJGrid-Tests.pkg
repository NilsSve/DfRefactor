    // -----------------------------------------------------------------------
    // Gridline_Mode (all four enum values)
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "Gridline_Mode Grid_Visible_None -> both NoLines (2 lines)" }
    Procedure GridlineMode_None
        String[] asResult
        String   sLine sLower
        Move "    Set Gridline_Mode to Grid_Visible_None" to sLine
        Move (Lowercase(Trim(sLine))) to sLower
        Get TranslateGridProperty of oWorker sLine sLower to asResult
        Send AssertIAreEqual 2 (SizeOfArray(asResult))
        Send AssertSAreEqual "    Set peHorizontalGridStyle to xtpGridNoLines" asResult[0]
        Send AssertSAreEqual "    Set peVerticalGridStyle   to xtpGridNoLines" asResult[1]
    End_Procedure

    {Published = True}
    { Description = "Gridline_Mode 0 (numeric) -> both NoLines (2 lines)" }
    Procedure GridlineMode_0
        String[] asResult
        String   sLine sLower
        Move "    Set Gridline_Mode to 0" to sLine
        Move (Lowercase(Trim(sLine))) to sLower
        Get TranslateGridProperty of oWorker sLine sLower to asResult
        Send AssertIAreEqual 2 (SizeOfArray(asResult))
        Send AssertSAreEqual "    Set peHorizontalGridStyle to xtpGridNoLines" asResult[0]
        Send AssertSAreEqual "    Set peVerticalGridStyle   to xtpGridNoLines" asResult[1]
    End_Procedure

    {Published = True}
    { Description = "Gridline_Mode Grid_Visible_Horz -> peHorizontalGridStyle xtpGridSolid (1 line)" }
    Procedure GridlineMode_Horz
        String[] asResult
        String   sLine sLower
        Move "    Set Gridline_Mode to Grid_Visible_Horz" to sLine
        Move (Lowercase(Trim(sLine))) to sLower
        Get TranslateGridProperty of oWorker sLine sLower to asResult
        Send AssertIAreEqual 1 (SizeOfArray(asResult))
        Send AssertSAreEqual "    Set peHorizontalGridStyle to xtpGridSolid" asResult[0]
    End_Procedure

    {Published = True}
    { Description = "Gridline_Mode Grid_Visible_Vert -> peVerticalGridStyle xtpGridSolid (1 line)" }
    Procedure GridlineMode_Vert
        String[] asResult
        String   sLine sLower
        Move "    Set Gridline_Mode to Grid_Visible_Vert" to sLine
        Move (Lowercase(Trim(sLine))) to sLower
        Get TranslateGridProperty of oWorker sLine sLower to asResult
        Send AssertIAreEqual 1 (SizeOfArray(asResult))
        Send AssertSAreEqual "    Set peVerticalGridStyle to xtpGridSolid" asResult[0]
    End_Procedure

    {Published = True}
    { Description = "Gridline_Mode Grid_Visible_Both -> both xtpGridSolid (2 lines)" }
    Procedure GridlineMode_Both
        String[] asResult
        String   sLine sLower
        Move "    Set Gridline_Mode to Grid_Visible_Both" to sLine
        Move (Lowercase(Trim(sLine))) to sLower
        Get TranslateGridProperty of oWorker sLine sLower to asResult
        Send AssertIAreEqual 2 (SizeOfArray(asResult))
        Send AssertSAreEqual "    Set peHorizontalGridStyle to xtpGridSolid" asResult[0]
        Send AssertSAreEqual "    Set peVerticalGridStyle   to xtpGridSolid" asResult[1]
    End_Procedure

    {Published = True}
    { Description = "Gridline_Mode 3 (numeric Both) -> both xtpGridSolid (2 lines)" }
    Procedure GridlineMode_3
        String[] asResult
        String   sLine sLower
        Move "    Set Gridline_Mode to 3" to sLine
        Move (Lowercase(Trim(sLine))) to sLower
        Get TranslateGridProperty of oWorker sLine sLower to asResult
        Send AssertIAreEqual 2 (SizeOfArray(asResult))
        Send AssertSAreEqual "    Set peHorizontalGridStyle to xtpGridSolid" asResult[0]
        Send AssertSAreEqual "    Set peVerticalGridStyle   to xtpGridSolid" asResult[1]
    End_Procedure

    // -----------------------------------------------------------------------
