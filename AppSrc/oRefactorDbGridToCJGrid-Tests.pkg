// ---------------------------------------------------------------------------

Object oCommentOutLine is a cTestFixture
    Set psFunctionName to "CommentOutLine"

    Object oWorker is a cDbGridToCJGrid
    End_Object

    {Published = True}
    { Description = "Indented line gets '// ' inserted after the indent" }
    Procedure IndentedLine
        String sResult
        Get CommentOutLine of oWorker "    Set Main_File to Orders" to sResult
        Send AssertSAreEqual "    // Set Main_File to Orders" sResult
    End_Procedure

    {Published = True}
    { Description = "Unindented line gets '// ' prepended" }
    Procedure UnindentedLine
        String sResult
        Get CommentOutLine of oWorker "Set Main_File to Orders" to sResult
        Send AssertSAreEqual "// Set Main_File to Orders" sResult
    End_Procedure

    {Published = True}
    { Description = "Deeply indented line preserves all leading spaces" }
    Procedure DeeplyIndentedLine
        String sResult
        Get CommentOutLine of oWorker "        Procedure Entry_Display" to sResult
        Send AssertSAreEqual "        // Procedure Entry_Display" sResult
    End_Procedure

    {Published = True}
    { Description = "Empty line returns '// '" }
    Procedure EmptyLine
        String sResult
        Get CommentOutLine of oWorker "" to sResult
        Send AssertSAreEqual "// " sResult
    End_Procedure

End_Object

