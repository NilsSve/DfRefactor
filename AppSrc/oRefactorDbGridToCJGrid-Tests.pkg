Object oGridMethodTransformSource is a cTestFixture
    Set psFunctionName to "TransformSource - method overrides"

    Object oWorker is a cDbGridToCJGrid
    End_Object

    // Helper procedures
    Function RunTransform String[] asInput Returns Integer
        Integer iGrids
        Set pasSource of oWorker to asInput
        Get TransformSource of oWorker to iGrids
        Function_Return iGrids
    End_Function

    Function GetOutput Returns String[]
        String[] asOut
        Get pasSource of oWorker to asOut
        Function_Return asOut
    End_Function

    // -----------------------------------------------------------------------
    // Clean rename: declaration and Forward Send renamed
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "Goto_Top_Row declaration is renamed to MoveToFirstRow" }
    Procedure GotoTopRow_DeclRenamed
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFoundNew bFoundOld

        Move "Object oGrid is a cDbGrid"      to asInput[0]
        Move "    Procedure Goto_Top_Row"      to asInput[1]
        Move "    End_Procedure"               to asInput[2]
        Move "End_Object"                      to asInput[3]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFoundNew
        Move False to bFoundOld
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (asOutput[iIdx] = "    Procedure MoveToFirstRow") Begin
                Move True to bFoundNew
            End
            If (Lowercase(asOutput[iIdx]) contains "goto_top_row") Begin
                Move True to bFoundOld
            End
        Loop
        Send Assert bFoundNew
        Send AssertFalse bFoundOld
    End_Procedure

    {Published = True}
    { Description = "Forward Send of old name is renamed inside the procedure body" }
    Procedure GotoTopRow_ForwardSendRenamed
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFoundNew bFoundOld

        Move "Object oGrid is a cDbGrid"           to asInput[0]
        Move "    Procedure Goto_Top_Row"           to asInput[1]
        Move "        Forward Send Goto_Top_Row"    to asInput[2]
        Move "    End_Procedure"                    to asInput[3]
        Move "End_Object"                           to asInput[4]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFoundNew
        Move False to bFoundOld
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (asOutput[iIdx] = "        Forward Send MoveToFirstRow") Begin
                Move True to bFoundNew
            End
            If (Lowercase(asOutput[iIdx]) contains "goto_top_row") Begin
                Move True to bFoundOld
            End
        Loop
        Send Assert bFoundNew
        Send AssertFalse bFoundOld
    End_Procedure

    {Published = True}
    { Description = "Down_Row declaration is renamed to MoveDownRow" }
    Procedure DownRow_DeclRenamed
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFoundNew

        Move "Object oGrid is a cDbGrid"  to asInput[0]
        Move "    Procedure Down_Row"     to asInput[1]
        Move "    End_Procedure"          to asInput[2]
        Move "End_Object"                 to asInput[3]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFoundNew
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (asOutput[iIdx] = "    Procedure MoveDownRow") Begin
                Move True to bFoundNew
            End
        Loop
        Send Assert bFoundNew
    End_Procedure

    {Published = True}
    { Description = "Non-rename body lines pass through unchanged inside renamed procedure" }
    Procedure RenameProc_BodyPassThrough
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFound

        Move "Object oGrid is a cDbGrid"             to asInput[0]
        Move "    Procedure Up_Row"                  to asInput[1]
        Move "        Send MyCustomMessage"          to asInput[2]
        Move "        Forward Send Up_Row"           to asInput[3]
        Move "    End_Procedure"                     to asInput[4]
        Move "End_Object"                            to asInput[5]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFound
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (asOutput[iIdx] = "        Send MyCustomMessage") Begin
                Move True to bFound
            End
        Loop
        Send Assert bFound
    End_Procedure

    // -----------------------------------------------------------------------
