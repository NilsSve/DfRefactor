    // -----------------------------------------------------------------------
    // Unknown method override: passes through unchanged
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "An unknown method override (e.g. OnSomeEvent) passes through unchanged" }
    Procedure UnknownMethod_PassThrough
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFound

        Move "Object oGrid is a cDbGrid"      to asInput[0]
        Move "    Procedure OnSomeEvent"       to asInput[1]
        Move "        Send DoSomething"        to asInput[2]
        Move "    End_Procedure"               to asInput[3]
        Move "End_Object"                      to asInput[4]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        Move False to bFound
        For iIdx from 0 to (SizeOfArray(asOutput) - 1)
            If (asOutput[iIdx] = "    Procedure OnSomeEvent") Begin
                Move True to bFound
            End
        Loop
        Send Assert bFound
    End_Procedure

    // -----------------------------------------------------------------------
    // Blank line inserted before each procedure/function block
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "A blank line is inserted before a renamed procedure if not already blank" }
    Procedure BlankLine_BeforeRenamedProc
        String[] asInput asOutput
        Integer  iGrids iIdx
        Boolean  bFound

        Move "Object oGrid is a cDbGrid"  to asInput[0]
        Move "    Set Size to 100 200"    to asInput[1]
        Move "    Procedure Goto_Top_Row" to asInput[2]
        Move "    End_Procedure"          to asInput[3]
        Move "End_Object"                 to asInput[4]

        Get RunTransform asInput to iGrids
        Get GetOutput            to asOutput

        // The line before "    Procedure MoveToFirstRow" should be blank
        Move False to bFound
        For iIdx from 1 to (SizeOfArray(asOutput) - 1)
            If (asOutput[iIdx] = "    Procedure MoveToFirstRow" and asOutput[iIdx - 1] = "") Begin
                Move True to bFound
            End
        Loop
        Send Assert bFound
    End_Procedure

End_Object
