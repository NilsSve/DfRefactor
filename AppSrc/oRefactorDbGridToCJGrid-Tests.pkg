// cDbGridToCJGrid-Tests.pkg
//
// Unit tests for cDbGridToCJGrid.pkg.
// Included by oUnit_Tests.pkg inside the oRefactorFuncLib_Tests fixture object.
//
// Test groups:
//   oIsLegacyGridProperty       - IsLegacyGridProperty
//   oIsTranslatableGridProperty - IsTranslatableGridProperty
//   oTranslateGridProperty      - TranslateGridProperty
//   oTransformSource            - TransformSource (end-to-end)
//   oParseProcFuncName          - ParseProcFuncName
//   oRenameGridMethod           - RenameGridMethod
//   oIsLegacyOnlyGridMethod     - IsLegacyOnlyGridMethod
//   oGridMethodTransformSource  - TransformSource method-override end-to-end

Use cDbGridToCJGrid.pkg

// Helper: create a fresh worker object per test group.
// All test groups share the class; each creates its own instance
// so property state is independent.

Object oIsLegacyGridProperty is a cTestFixture
    Set psFunctionName to "IsLegacyGridProperty"

    Object oWorker is a cDbGridToCJGrid
    End_Object

    // -----------------------------------------------------------------------
    // Properties that MUST be removed (IsLegacyGridProperty = True)
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "main_file is NOT a legacy-remove property (it is commented out instead)" }
    Procedure MainFile_NotInLegacyRemoveList
        Boolean bResult
        Get IsLegacyGridProperty of oWorker "set main_file to orders" to bResult
        Send AssertFalse bResult
    End_Procedure

    {Published = True}
    { Description = "wrap_state is a legacy-remove property" }
    Procedure WrapState_IsLegacy
        Boolean bResult
        Get IsLegacyGridProperty of oWorker "set wrap_state to true" to bResult
        Send Assert bResult
    End_Procedure

    {Published = True}
    { Description = "pscolumnsid is a legacy-remove property" }
    Procedure PsColumnsID_IsLegacy
        Boolean bResult
        Get IsLegacyGridProperty of oWorker "set pscolumnsid to "'mygrid'"" to bResult
        Send Assert bResult
    End_Procedure

    {Published = True}
    { Description = "child_table_state is a legacy-remove property" }
    Procedure ChildTableState_IsLegacy
        Boolean bResult
        Get IsLegacyGridProperty of oWorker "set child_table_state to true" to bResult
        Send Assert bResult
    End_Procedure

    {Published = True}
    { Description = "item_limit is a legacy-remove property" }
    Procedure ItemLimit_IsLegacy
        Boolean bResult
        Get IsLegacyGridProperty of oWorker "set item_limit to 5" to bResult
        Send Assert bResult
    End_Procedure

    {Published = True}
    { Description = "base_item is a legacy-remove property" }
    Procedure BaseItem_IsLegacy
        Boolean bResult
        Get IsLegacyGridProperty of oWorker "set base_item to 0" to bResult
        Send Assert bResult
    End_Procedure

    {Published = True}
    { Description = "pbcombonavigation is a legacy-remove property" }
    Procedure PbComboNavigation_IsLegacy
        Boolean bResult
        Get IsLegacyGridProperty of oWorker "set pbcombonavigation to false" to bResult
        Send Assert bResult
    End_Procedure

    // -----------------------------------------------------------------------
    // Things that must NOT be flagged as legacy-remove properties
    // -----------------------------------------------------------------------

    {Published = True}
    { Description = "A translatable property (no_create_state) must not be in the remove list" }
    Procedure NoCreateState_NotLegacy
        Boolean bResult
        Get IsLegacyGridProperty of oWorker "set no_create_state to true" to bResult
        Send AssertFalse bResult
    End_Procedure

    {Published = True}
    { Description = "An ordinary CJGrid property must not be flagged" }
    Procedure OrdinaryProperty_NotLegacy
        Boolean bResult
        Get IsLegacyGridProperty of oWorker "set pbeditable to true" to bResult
        Send AssertFalse bResult
    End_Procedure

    {Published = True}
    { Description = "A line that does not start with 'set ' must not be flagged" }
    Procedure NonSet_NotLegacy
        Boolean bResult
        Get IsLegacyGridProperty of oWorker "object omygrid is a cdbgrid" to bResult
        Send AssertFalse bResult
    End_Procedure

End_Object


