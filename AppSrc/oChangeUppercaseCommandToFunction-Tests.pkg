    // Unit tests for ChangeUppercaseCommandToFunction - "Uppercase <arg> to <dest>" ->
    // "Move (Uppercase(<arg>)) to <dest>" (4531 obsolete-string-command family).
    Object oChangeUppercaseCommandToFunction is a cTestFixture
        Set psFunctionName to "ChangeUppercaseCommandToFunction"

        {Published = True}
        Procedure ChangeUppercaseCommandToFunction_InPlace
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Uppercase sVal to sVal" to sLine
            Move "Move (Uppercase(sVal)) to sVal" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeUppercaseCommandToFunction of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // Real-world casing ("UpperCase") + indentation; the canonical "Uppercase" is emitted.
        Procedure ChangeUppercaseCommandToFunction_CamelCaseIndent
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    UpperCase sPassWord to sPassWord" to sLine
            Move "    Move (Uppercase(sPassWord)) to sPassWord" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeUppercaseCommandToFunction of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // A table.field argument survives intact (position-based extraction, not a single-token grab).
        Procedure ChangeUppercaseCommandToFunction_TableField
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Uppercase USER.SPRAK to sLang" to sLine
            Move "Move (Uppercase(USER.SPRAK)) to sLang" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeUppercaseCommandToFunction of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // An existing Uppercase() function CALL is left untouched (keyword not followed by whitespace).
        Procedure ChangeUppercaseCommandToFunction_CallUntouched
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move (Uppercase(sVal)) to sX" to sLine
            Move "Move (Uppercase(sVal)) to sX" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeUppercaseCommandToFunction of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

    End_Object
