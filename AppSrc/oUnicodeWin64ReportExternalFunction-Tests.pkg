    // Unit tests for the External_Function audit DETECTION CORE (_AuditApiDeclaration +
    // _SuggestPointerType in cRefactorUtilities) - the heart of UnicodeWin64ReportExternalFunction.
    // Each test passes ONE logical declaration string and checks the findings. The file-scan
    // + log-writing orchestration (cExternalFunctionAudit) is integration-tested in the app,
    // like the other Report* functions. Findings are "<type> <name> -> <suggested>" lines.
    Object oUnicodeWin64ReportExternalFunction is a cTestFixture
        Set psFunctionName to "UnicodeWin64ReportExternalFunction"

        // Integer hWnd -> Handle (Hungarian h + uppercase).
        {Published = True}
        Procedure UnicodeWin64ReportExternalFunction_HandleParam_Flagged
            String[] asFindings
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Get _AuditApiDeclaration of ghoFuncLib 'External_Function Foo "Foo" user32.dll Integer hWnd Returns Integer' (&asFindings) to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "Integer hWnd -> Handle" asFindings[0]
        End_Procedure

        // Integer lParam -> Longptr.
        {Published = True}
        Procedure UnicodeWin64ReportExternalFunction_LongptrParam_Flagged
            String[] asFindings
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Get _AuditApiDeclaration of ghoFuncLib 'External_Function Foo "Foo" user32.dll Integer lParam Returns Integer' (&asFindings) to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "Integer lParam -> Longptr" asFindings[0]
        End_Procedure

        // Integer lpBuffer -> Pointer (lp* prefix).
        {Published = True}
        Procedure UnicodeWin64ReportExternalFunction_PointerParam_Flagged
            String[] asFindings
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Get _AuditApiDeclaration of ghoFuncLib 'External_Function Foo "Foo" user32.dll Integer lpBuffer Returns Integer' (&asFindings) to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "Integer lpBuffer -> Pointer" asFindings[0]
        End_Procedure

        // Integer cbSize -> ULongptr (size_t-ish).
        {Published = True}
        Procedure UnicodeWin64ReportExternalFunction_ULongptrParam_Flagged
            String[] asFindings
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Get _AuditApiDeclaration of ghoFuncLib 'External_Function Foo "Foo" user32.dll Integer cbSize Returns Integer' (&asFindings) to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "Integer cbSize -> ULongptr" asFindings[0]
        End_Procedure

        // String param in an ANSI ("...A") wrapper -> WString (Unicode A->W).
        {Published = True}
        Procedure UnicodeWin64ReportExternalFunction_AnsiStringParam_Flagged
            String[] asFindings
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Get _AuditApiDeclaration of ghoFuncLib 'External_Function Foo "GetFooA" user32.dll String lpName Returns Integer' (&asFindings) to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "String lpName -> WString" asFindings[0]
        End_Procedure

        // An Integer param with no pointer-sized name signal is left alone.
        {Published = True}
        Procedure UnicodeWin64ReportExternalFunction_CleanIntParam_NotFlagged
            String[] asFindings
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Get _AuditApiDeclaration of ghoFuncLib 'External_Function Foo "Foo" user32.dll Integer nIndex Returns Integer' (&asFindings) to iCount
            Send Assert (iCount = 0)
        End_Procedure

        // Idempotent: an already-correct Handle param (not Integer/DWord) is not flagged.
        {Published = True}
        Procedure UnicodeWin64ReportExternalFunction_AlreadyCorrect_NotFlagged
            String[] asFindings
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Get _AuditApiDeclaration of ghoFuncLib 'External_Function Foo "Foo" user32.dll Handle hWnd Returns Integer' (&asFindings) to iCount
            Send Assert (iCount = 0)
        End_Procedure

        // ByRef/ByVal between type and name is skipped (still flags Integer hWnd).
        {Published = True}
        Procedure UnicodeWin64ReportExternalFunction_ByRef_Flagged
            String[] asFindings
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Get _AuditApiDeclaration of ghoFuncLib 'External_Function Foo "Foo" user32.dll Integer ByRef hWnd Returns Integer' (&asFindings) to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "Integer hWnd -> Handle" asFindings[0]
        End_Procedure

        // Combined: an ANSI Create* wrapper flags BOTH the String param (->WString) and the
        // Integer return (->Handle).
        {Published = True}
        Procedure UnicodeWin64ReportExternalFunction_CreateAnsi_Flagged
            String[] asFindings
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Get _AuditApiDeclaration of ghoFuncLib 'External_Function Foo "CreateFileA" kernel32.dll String lpFileName Returns Integer' (&asFindings) to iCount
            Send Assert (iCount = 2)
            Send AssertSAreEqual "String lpFileName -> WString" asFindings[0]
            Send AssertSAreEqual "Returns Integer -> Handle" asFindings[1]
        End_Procedure

    End_Object
