    Object oChangeIndexNumber is a cTestFixture
        Set psFunctionName to "ChangeIndexNumber"

        // ============================================================
        //  Positive cases - sParameter "<Table>,3,5" rewrites the
        //  index ONLY on lines that reference that specific table.
        //  Table is identified directly (token == table name) or via
        //  the DDO conventions o<Table>_DD / o<Table>_DataDictionary.
        // ============================================================

        {Published = True}
        Procedure ChangeIndexNumber_Find_EQ_IndexDot
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    Send Find of oMy_DD EQ Index.3" to sLine
            Move "    Send Find of oMy_DD EQ Index.5" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "My,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_Find_EQ_Bare
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    Send Find of oMy_DD EQ 3" to sLine
            Move "    Send Find of oMy_DD EQ 5" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "My,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_Find_GT_Bare
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    Find of oMy_DD GT 3" to sLine
            Move "    Find of oMy_DD GT 5" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "My,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_Find_DataDictionarySuffix
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            // Verifies the alternative o<Table>_DataDictionary convention
            // is recognised alongside o<Table>_DD.
            Move "    Send Find of oCustomer_DataDictionary EQ 3" to sLine
            Move "    Send Find of oCustomer_DataDictionary EQ 5" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "Customer,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_vFind_Bare
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    vFind MyTable.File_Number 3 GT" to sLine
            Move "    vFind MyTable.File_Number 5 GT" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "MyTable,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_vFind_IndexDot
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    vFind MyTable.File_Number Index.3 GT" to sLine
            Move "    vFind MyTable.File_Number Index.5 GT" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "MyTable,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_ConstrainedFind_By_IndexDot
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    Constrained_Find First MyTable by Index.3" to sLine
            Move "    Constrained_Find First MyTable by Index.5" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "MyTable,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_ConstrainedFind_By_Bare
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    Constrained_Find First MyTable by 3" to sLine
            Move "    Constrained_Find First MyTable by 5" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "MyTable,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_ConstrainedClear_By_Bare
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    Constrained_Clear EQ MyTable by 3" to sLine
            Move "    Constrained_Clear EQ MyTable by 5" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "MyTable,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_ForAll_By_Bare
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    For_all MyTable by 3" to sLine
            Move "    For_all MyTable by 5" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "MyTable,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_ForAll_Down_Bare
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    For_all MyTable down 3" to sLine
            Move "    For_all MyTable down 5" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "MyTable,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // ============================================================
        //  Negative cases - line must remain unchanged
        // ============================================================

        {Published = True}
        Procedure ChangeIndexNumber_ConstrainedFind_Recnum_Unchanged
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            // -1 is recnum mode; must never be rewritten.
            Move "    Constrained_Find First MyTable by -1" to sLine
            Move "    Constrained_Find First MyTable by -1" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "MyTable,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_WrongIndexNumber_Unchanged
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            // "30" is not "3"; must NOT match the FROM filter.
            Move "    Send Find of oMy_DD EQ 30" to sLine
            Move "    Send Find of oMy_DD EQ 30" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "My,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_NonFindContext_Unchanged
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            // No Find/Constrained/For_all keyword: line filter must reject.
            Move "    Move 3 to iValue" to sLine
            Move "    Move 3 to iValue" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "MyTable,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_Constrain_Unchanged
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            // `Constrain` (not Constrained_Find/Clear) must NOT be touched
            // - its `eq` is a constraint operator, not a Find mode.
            Move "    Constrain FunctionsA.Type eq 3" to sLine
            Move "    Constrain FunctionsA.Type eq 3" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "FunctionsA,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_WrongTable_Unchanged
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            // Line references MyTable but the param targets a different
            // table -> table-scoping must reject the line.
            Move "    Constrained_Find First MyTable by 3" to sLine
            Move "    Constrained_Find First MyTable by 3" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "OtherTable,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_UnknownDDOConvention_Unchanged
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            // DDO uses an unrecognized convention (oCustomerDD without
            // underscore). Only o<Table>_DD and o<Table>_DataDictionary
            // are recognized - the line must NOT be rewritten.
            Move "    Send Find of oCustomerDD EQ 3" to sLine
            Move "    Send Find of oCustomerDD EQ 3" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "Customer,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

        {Published = True}
        Procedure ChangeIndexNumber_CompoundDDOName_Unchanged
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            // oCustomerOrderHistory_DD must NOT match "Customer" - the
            // table-scoping check requires the DDO name to be exactly
            // o<Table>_DD (full-word boundary).
            Move "    Send Find of oCustomerOrderHistory_DD EQ 3" to sLine
            Move "    Send Find of oCustomerOrderHistory_DD EQ 3" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIndexNumber of ghoFuncLib (&sLine) "Customer,3,5" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

    End_Object
