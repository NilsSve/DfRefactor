    Object oReportUnusedSourceFiles is a cTestFixture
        Set psFunctionName to "ReportUnusedSourceFiles"

        {Published = True}
        // NOTE: tests use phoWorkspace (not pOrgWS) because DFUnit_TestRunner
        // is built on cApplication, not cRefactorApplication.
        Procedure ReportUnusedSourceFiles_1
            String sLine sExpected sPath
            String[] asFiles
            Boolean bChanged
            tTokenizer TokenizerData
            Move '' to sLine
            Move ' ' to sExpected
            Get psHome of (phoWorkspace(ghoApplication)) to sPath
            Move (sPath + CS_LegacyCode) to asFiles[0]
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ReportUnusedSourceFiles of ghoFuncLib (&asFiles) to bChanged
            Send AssertFalse bChanged ""
        End_Procedure

        {Published = True}
        { Description = "IsUseOrIncludeLine: 'Use Foo.pkg' is recognised" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_Use
            Handle ho
            Boolean bResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "Use Foo.pkg" to bResult
            Send Destroy of ho
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseOrIncludeLine: indented Use line is recognised" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_Indented
            Handle ho
            Boolean bResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "    Use Foo.pkg" to bResult
            Send Destroy of ho
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseOrIncludeLine: '#include Bar.h' is recognised" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_Include
            Handle ho
            Boolean bResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "#include Bar.h" to bResult
            Send Destroy of ho
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseOrIncludeLine: commented-out Use line returns False" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_Commented
            Handle ho
            Boolean bResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "// Use Foo.pkg" to bResult
            Send Destroy of ho
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseOrIncludeLine: non-Use line returns False" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_NonUse
            Handle ho
            Boolean bResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "Object oFoo is a cFoo" to bResult
            Send Destroy of ho
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseOrIncludeLine: LoginEncryption.pkg is always excluded" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_LoginEncryption
            Handle ho
            Boolean bResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "Use LoginEncryption.pkg" to bResult
            Send Destroy of ho
            Send AssertFalse bResult
        End_Procedure

        // --- ExtractUseFileName ---

        {Published = True}
        { Description = "ExtractUseFileName: extracts bare filename from Use statement" }
        Procedure ReportUnusedSourceFiles_ExtractUseFileName_Simple
            Handle ho
            String sResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get ExtractUseFileName of ho "Use Foo.pkg" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "foo.pkg" sResult
        End_Procedure

        {Published = True}
        { Description = "ExtractUseFileName: appends .pkg when no extension given" }
        Procedure ReportUnusedSourceFiles_ExtractUseFileName_NoExt
            Handle ho
            String sResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get ExtractUseFileName of ho "Use Bar" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "bar.pkg" sResult
        End_Procedure

        {Published = True}
        { Description = "ExtractUseFileName: extracts filename from #include statement" }
        Procedure ReportUnusedSourceFiles_ExtractUseFileName_Include
            Handle ho
            String sResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get ExtractUseFileName of ho "#include Baz.h" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "baz.h" sResult
        End_Procedure

        {Published = True}
        { Description = "IncludeOrUseFile: extracts filename from Use statement" }
        Procedure ReportUnusedSourceFiles_IncludeOrUseFile_Use
            Handle ho
            String sResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get IncludeOrUseFile of ho "Use Foo.pkg" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "foo.pkg" sResult
        End_Procedure

        {Published = True}
        { Description = "IncludeOrUseFile: #include treated as Use, extracts filename" }
        Procedure ReportUnusedSourceFiles_IncludeOrUseFile_Include
            Handle ho
            String sResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get IncludeOrUseFile of ho "#include Bar.h" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "bar.h" sResult
        End_Procedure

        {Published = True}
        { Description = "IncludeOrUseFile: non-Use line returns empty string" }
        Procedure ReportUnusedSourceFiles_IncludeOrUseFile_NonUse
            Handle ho
            String sResult
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get IncludeOrUseFile of ho "Object oFoo is a cFoo" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "" sResult
        End_Procedure

        {Published = True}
        { Description = "UnusedPackages: file that appears in the used list is not returned" }
        Procedure ReportUnusedSourceFiles_UnusedPackages_Used
            Handle ho
            String[] asUsed
            tUnusedSourceFiles[] asAll asResult
            Move "foo.pkg" to asUsed[0]
            Move "" to asAll[0].sPath
            Move "foo.pkg" to asAll[0].sFileName
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get UnusedPackages of ho asUsed asAll to asResult
            Send Destroy of ho
            Send AssertIAreEqual 0 (SizeOfArray(asResult))
        End_Procedure

        {Published = True}
        { Description = "UnusedPackages: file absent from the used list is returned" }
        Procedure ReportUnusedSourceFiles_UnusedPackages_Unused
            Handle ho
            String[] asUsed
            tUnusedSourceFiles[] asAll asResult
            Move "other.pkg" to asUsed[0]
            Move "" to asAll[0].sPath
            Move "unused.pkg" to asAll[0].sFileName
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get UnusedPackages of ho asUsed asAll to asResult
            Send Destroy of ho
            Send AssertIAreEqual 1 (SizeOfArray(asResult))
            Send AssertSAreEqual "unused.pkg" asResult[0].sFileName
        End_Procedure

        {Published = True}
        { Description = "UnusedPackages: .src entry is never reported as unused" }
        Procedure ReportUnusedSourceFiles_UnusedPackages_SrcExcluded
            Handle ho
            String[] asUsed
            tUnusedSourceFiles[] asAll asResult
            Move "other.pkg" to asUsed[0]
            Move "" to asAll[0].sPath
            Move "main.src" to asAll[0].sFileName
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get UnusedPackages of ho asUsed asAll to asResult
            Send Destroy of ho
            Send AssertIAreEqual 0 (SizeOfArray(asResult))
        End_Procedure

        {Published = True}
        { Description = "UnusedPackages: LoginEncryptionKey.inc is never reported as unused" }
        Procedure ReportUnusedSourceFiles_UnusedPackages_LoginEncryptionKey
            Handle ho
            String[] asUsed
            tUnusedSourceFiles[] asAll asResult
            Move "other.pkg" to asUsed[0]
            Move "" to asAll[0].sPath
            Move "LoginEncryptionKey.inc" to asAll[0].sFileName
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get UnusedPackages of ho asUsed asAll to asResult
            Send Destroy of ho
            Send AssertIAreEqual 0 (SizeOfArray(asResult))
        End_Procedure

        {Published = True}
        { Description = "UnusedPackages: multiple files, only unused non-src ones returned" }
        Procedure ReportUnusedSourceFiles_UnusedPackages_Mixed
            Handle ho
            String[] asUsed
            tUnusedSourceFiles[] asAll asResult
            Move "alpha.pkg" to asUsed[0]
            Move "" to asAll[0].sPath
            Move "alpha.pkg" to asAll[0].sFileName  // used -> not returned
            Move "" to asAll[1].sPath
            Move "beta.pkg" to asAll[1].sFileName   // unused -> returned
            Move "" to asAll[2].sPath
            Move "main.src" to asAll[2].sFileName   // .src -> excluded
            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get UnusedPackages of ho asUsed asAll to asResult
            Send Destroy of ho
            Send AssertIAreEqual 1 (SizeOfArray(asResult))
            Send AssertSAreEqual "beta.pkg" asResult[0].sFileName
        End_Procedure

        {Published = True}
        { Description = "Reachability: an unused DD's Use of other DD/SL does not mask them as used" }
        Procedure ReportUnusedSourceFiles_Reachable_MaskedDependentsNotUsed
            Handle ho
            tNodeEdges[] aNodes
            String[] asUsed
            Boolean bAlpha bVictimDD bVictimSL

            // main.src (root) -> alpha.pkg
            Move "main.src"  to aNodes[0].sFull
            Move "main.src"  to aNodes[0].sBare
            Move "src"       to aNodes[0].sExt
            Move "alpha.pkg" to aNodes[0].asUses[0]
            // alpha.pkg - reachable, no further uses
            Move "alpha.pkg" to aNodes[1].sFull
            Move "alpha.pkg" to aNodes[1].sBare
            Move "pkg"       to aNodes[1].sExt
            // orphan.dd - NOT used by any root, but itself Uses victim.dd / victim.sl
            Move "orphan.dd" to aNodes[2].sFull
            Move "orphan.dd" to aNodes[2].sBare
            Move "dd"        to aNodes[2].sExt
            Move "victim.dd" to aNodes[2].asUses[0]
            Move "victim.sl" to aNodes[2].asUses[1]
            // victim.dd / victim.sl - only referenced by the unreachable orphan
            Move "victim.dd" to aNodes[3].sFull
            Move "victim.dd" to aNodes[3].sBare
            Move "dd"        to aNodes[3].sExt
            Move "victim.sl" to aNodes[4].sFull
            Move "victim.sl" to aNodes[4].sBare
            Move "sl"        to aNodes[4].sExt

            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get ReachableUsedNames of ho aNodes to asUsed
            Send Destroy of ho

            Move (SearchArray("alpha.pkg", asUsed) <> -1) to bAlpha
            Move (SearchArray("victim.dd", asUsed) <> -1) to bVictimDD
            Move (SearchArray("victim.sl", asUsed) <> -1) to bVictimSL

            Send Assert      bAlpha     // reachable from main.src -> used
            Send AssertFalse bVictimDD  // masked dependent -> must NOT be "used"
            Send AssertFalse bVictimSL
        End_Procedure

        {Published = True}
        { Description = "Reachability: dependents of a root-reachable file ARE reported as used" }
        Procedure ReportUnusedSourceFiles_Reachable_RootChainKeepsDependents
            Handle ho
            tNodeEdges[] aNodes
            String[] asUsed
            Boolean bOrphan bVictimDD bVictimSL

            // main.src (root) -> alpha.pkg AND orphan.dd
            Move "main.src"  to aNodes[0].sFull
            Move "main.src"  to aNodes[0].sBare
            Move "src"       to aNodes[0].sExt
            Move "alpha.pkg" to aNodes[0].asUses[0]
            Move "orphan.dd" to aNodes[0].asUses[1]
            Move "alpha.pkg" to aNodes[1].sFull
            Move "alpha.pkg" to aNodes[1].sBare
            Move "pkg"       to aNodes[1].sExt
            Move "orphan.dd" to aNodes[2].sFull
            Move "orphan.dd" to aNodes[2].sBare
            Move "dd"        to aNodes[2].sExt
            Move "victim.dd" to aNodes[2].asUses[0]
            Move "victim.sl" to aNodes[2].asUses[1]
            Move "victim.dd" to aNodes[3].sFull
            Move "victim.dd" to aNodes[3].sBare
            Move "dd"        to aNodes[3].sExt
            Move "victim.sl" to aNodes[4].sFull
            Move "victim.sl" to aNodes[4].sBare
            Move "sl"        to aNodes[4].sExt

            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get ReachableUsedNames of ho aNodes to asUsed
            Send Destroy of ho

            Move (SearchArray("orphan.dd", asUsed) <> -1) to bOrphan
            Move (SearchArray("victim.dd", asUsed) <> -1) to bVictimDD
            Move (SearchArray("victim.sl", asUsed) <> -1) to bVictimSL

            Send Assert bOrphan
            Send Assert bVictimDD
            Send Assert bVictimSL
        End_Procedure

        {Published = True}
        { Description = "Reachability end-to-end: an unused DD cluster is fully reported; used files are not" }
        Procedure ReportUnusedSourceFiles_Reachable_EndToEndClusterReported
            Handle ho
            tNodeEdges[] aNodes
            tUnusedSourceFiles[] asAll asUnused
            String[] asUsed
            Boolean bOrphan bVictimDD bVictimSL bAlpha bMain
            Integer iCount iSize

            // Graph: main.src -> alpha.pkg ; orphan.dd -> victim.dd, victim.sl (orphan unreached)
            Move "main.src"  to aNodes[0].sFull
            Move "main.src"  to aNodes[0].sBare
            Move "src"       to aNodes[0].sExt
            Move "alpha.pkg" to aNodes[0].asUses[0]
            Move "alpha.pkg" to aNodes[1].sFull
            Move "alpha.pkg" to aNodes[1].sBare
            Move "pkg"       to aNodes[1].sExt
            Move "orphan.dd" to aNodes[2].sFull
            Move "orphan.dd" to aNodes[2].sBare
            Move "dd"        to aNodes[2].sExt
            Move "victim.dd" to aNodes[2].asUses[0]
            Move "victim.sl" to aNodes[2].asUses[1]
            Move "victim.dd" to aNodes[3].sFull
            Move "victim.dd" to aNodes[3].sBare
            Move "dd"        to aNodes[3].sExt
            Move "victim.sl" to aNodes[4].sFull
            Move "victim.sl" to aNodes[4].sBare
            Move "sl"        to aNodes[4].sExt

            // Same five files as the flat list UnusedPackages receives.
            Move ""          to asAll[0].sPath
            Move "main.src"  to asAll[0].sFileName
            Move ""          to asAll[1].sPath
            Move "alpha.pkg" to asAll[1].sFileName
            Move ""          to asAll[2].sPath
            Move "orphan.dd" to asAll[2].sFileName
            Move ""          to asAll[3].sPath
            Move "victim.dd" to asAll[3].sFileName
            Move ""          to asAll[4].sPath
            Move "victim.sl" to asAll[4].sFileName

            Get Create of ghoFuncLib (RefClass(cUnusedSourceFiles)) to ho
            Get ReachableUsedNames of ho aNodes to asUsed
            Get UnusedPackages of ho asUsed asAll to asUnused
            Send Destroy of ho

            Move False to bOrphan
            Move False to bVictimDD
            Move False to bVictimSL
            Move False to bAlpha
            Move False to bMain
            Move (SizeOfArray(asUnused)) to iSize
            Decrement iSize
            For iCount from 0 to iSize
                If (Lowercase(asUnused[iCount].sFileName) = "orphan.dd") Move True to bOrphan
                If (Lowercase(asUnused[iCount].sFileName) = "victim.dd") Move True to bVictimDD
                If (Lowercase(asUnused[iCount].sFileName) = "victim.sl") Move True to bVictimSL
                If (Lowercase(asUnused[iCount].sFileName) = "alpha.pkg") Move True to bAlpha
                If (Lowercase(asUnused[iCount].sFileName) = "main.src")  Move True to bMain
            Loop

            Send AssertIAreEqual 3 (SizeOfArray(asUnused))
            Send Assert      bOrphan    // the orphan itself - unused
            Send Assert      bVictimDD  // masked dependent - now correctly unused
            Send Assert      bVictimSL
            Send AssertFalse bAlpha     // reachable from main.src -> used
            Send AssertFalse bMain      // .src roots are never reported
        End_Procedure

    End_Object
