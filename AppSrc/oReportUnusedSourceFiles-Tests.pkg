    Object oReportUnusedSourceFiles is a cTestFixture
        Set psFunctionName to "ReportUnusedSourceFiles"

        {Published = True}
        Procedure ReportUnusedSourceFiles_1
            String sLine sExpected sPath
            String[] asFiles
            Boolean bChanged
            tTokenizer TokenizerData
            Move '' to sLine
            Move ' ' to sExpected
            Get psHome of (phoWorkspace(ghoApplication)) to sPath
            Move (sPath + CS_LegacyCode) to asFiles[0]
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ReportUnusedSourceFiles of ghoFuncLib (&asFiles) to bChanged
            Send AssertFalse bChanged ""
        End_Procedure

        // --- IsUseOrIncludeLine ---

        {Published = True}
        { Description = "IsUseOrIncludeLine: 'Use Foo.pkg' is recognised" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_Use
            Handle ho
            Boolean bResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "Use Foo.pkg" to bResult
            Send Destroy of ho
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseOrIncludeLine: indented Use line is recognised" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_Indented
            Handle ho
            Boolean bResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "    Use Foo.pkg" to bResult
            Send Destroy of ho
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseOrIncludeLine: '#include Bar.h' is recognised" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_Include
            Handle ho
            Boolean bResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "#include Bar.h" to bResult
            Send Destroy of ho
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseOrIncludeLine: commented-out Use line returns False" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_Commented
            Handle ho
            Boolean bResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "// Use Foo.pkg" to bResult
            Send Destroy of ho
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseOrIncludeLine: non-Use line returns False" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_NonUse
            Handle ho
            Boolean bResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "Object oFoo is a cFoo" to bResult
            Send Destroy of ho
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        { Description = "IsUseOrIncludeLine: LoginEncryption.pkg is always excluded" }
        Procedure ReportUnusedSourceFiles_IsUseOrIncludeLine_LoginEncryption
            Handle ho
            Boolean bResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get IsUseOrIncludeLine of ho "Use LoginEncryption.pkg" to bResult
            Send Destroy of ho
            Send AssertFalse bResult
        End_Procedure

        // --- StripComment ---

        {Published = True}
        { Description = "StripComment: removes everything after //" }
        Procedure ReportUnusedSourceFiles_StripComment_Inline
            Handle ho
            String sResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get StripComment of ho "Move x to y // comment" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "Move x to y " sResult
        End_Procedure

        {Published = True}
        { Description = "StripComment: full comment line becomes empty string" }
        Procedure ReportUnusedSourceFiles_StripComment_FullLine
            Handle ho
            String sResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get StripComment of ho "// full comment" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "" sResult
        End_Procedure

        {Published = True}
        { Description = "StripComment: line with no comment is returned unchanged" }
        Procedure ReportUnusedSourceFiles_StripComment_NoComment
            Handle ho
            String sResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get StripComment of ho "Move True to bFlag" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "Move True to bFlag" sResult
        End_Procedure

        // --- ExtractUseFileName ---

        {Published = True}
        { Description = "ExtractUseFileName: extracts bare filename from Use statement" }
        Procedure ReportUnusedSourceFiles_ExtractUseFileName_Simple
            Handle ho
            String sResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get ExtractUseFileName of ho "Use Foo.pkg" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "foo.pkg" sResult
        End_Procedure

        {Published = True}
        { Description = "ExtractUseFileName: appends .pkg when no extension given" }
        Procedure ReportUnusedSourceFiles_ExtractUseFileName_NoExt
            Handle ho
            String sResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get ExtractUseFileName of ho "Use Bar" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "bar.pkg" sResult
        End_Procedure

        {Published = True}
        { Description = "ExtractUseFileName: extracts filename from #include statement" }
        Procedure ReportUnusedSourceFiles_ExtractUseFileName_Include
            Handle ho
            String sResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get ExtractUseFileName of ho "#include Baz.h" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "baz.h" sResult
        End_Procedure

        // --- IncludeOrUseFile ---

        {Published = True}
        { Description = "IncludeOrUseFile: extracts filename from Use statement" }
        Procedure ReportUnusedSourceFiles_IncludeOrUseFile_Use
            Handle ho
            String sResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get IncludeOrUseFile of ho "Use Foo.pkg" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "foo.pkg" sResult
        End_Procedure

        {Published = True}
        { Description = "IncludeOrUseFile: #include treated as Use, extracts filename" }
        Procedure ReportUnusedSourceFiles_IncludeOrUseFile_Include
            Handle ho
            String sResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get IncludeOrUseFile of ho "#include Bar.h" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "bar.h" sResult
        End_Procedure

        {Published = True}
        { Description = "IncludeOrUseFile: non-Use line returns empty string" }
        Procedure ReportUnusedSourceFiles_IncludeOrUseFile_NonUse
            Handle ho
            String sResult
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get IncludeOrUseFile of ho "Object oFoo is a cFoo" to sResult
            Send Destroy of ho
            Send AssertSAreEqual "" sResult
        End_Procedure

        // --- UnusedPackages ---

        {Published = True}
        { Description = "UnusedPackages: file that appears in the used list is not returned" }
        Procedure ReportUnusedSourceFiles_UnusedPackages_Used
            Handle ho
            String[] asUsed
            tUnusedSourceFiles[] asAll asResult
            Move "foo.pkg" to asUsed[0]
            Move "" to asAll[0].sPath
            Move "foo.pkg" to asAll[0].sFileName
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get UnusedPackages of ho asUsed asAll to asResult
            Send Destroy of ho
            Send AssertIAreEqual 0 (SizeOfArray(asResult))
        End_Procedure

        {Published = True}
        { Description = "UnusedPackages: file absent from the used list is returned" }
        Procedure ReportUnusedSourceFiles_UnusedPackages_Unused
            Handle ho
            String[] asUsed
            tUnusedSourceFiles[] asAll asResult
            Move "other.pkg" to asUsed[0]
            Move "" to asAll[0].sPath
            Move "unused.pkg" to asAll[0].sFileName
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get UnusedPackages of ho asUsed asAll to asResult
            Send Destroy of ho
            Send AssertIAreEqual 1 (SizeOfArray(asResult))
            Send AssertSAreEqual "unused.pkg" asResult[0].sFileName
        End_Procedure

        {Published = True}
        { Description = "UnusedPackages: .src entry is never reported as unused" }
        Procedure ReportUnusedSourceFiles_UnusedPackages_SrcExcluded
            Handle ho
            String[] asUsed
            tUnusedSourceFiles[] asAll asResult
            Move "other.pkg" to asUsed[0]
            Move "" to asAll[0].sPath
            Move "main.src" to asAll[0].sFileName
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get UnusedPackages of ho asUsed asAll to asResult
            Send Destroy of ho
            Send AssertIAreEqual 0 (SizeOfArray(asResult))
        End_Procedure

        {Published = True}
        { Description = "UnusedPackages: LoginEncryptionKey.inc is never reported as unused" }
        Procedure ReportUnusedSourceFiles_UnusedPackages_LoginEncryptionKey
            Handle ho
            String[] asUsed
            tUnusedSourceFiles[] asAll asResult
            Move "other.pkg" to asUsed[0]
            Move "" to asAll[0].sPath
            Move "LoginEncryptionKey.inc" to asAll[0].sFileName
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get UnusedPackages of ho asUsed asAll to asResult
            Send Destroy of ho
            Send AssertIAreEqual 0 (SizeOfArray(asResult))
        End_Procedure

        {Published = True}
        { Description = "UnusedPackages: multiple files, only unused non-src ones returned" }
        Procedure ReportUnusedSourceFiles_UnusedPackages_Mixed
            Handle ho
            String[] asUsed
            tUnusedSourceFiles[] asAll asResult
            Move "alpha.pkg" to asUsed[0]
            Move "" to asAll[0].sPath
            Move "alpha.pkg" to asAll[0].sFileName  // used -> not returned
            Move "" to asAll[1].sPath
            Move "beta.pkg" to asAll[1].sFileName   // unused -> returned
            Move "" to asAll[2].sPath
            Move "main.src" to asAll[2].sFileName   // .src -> excluded
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get UnusedPackages of ho asUsed asAll to asResult
            Send Destroy of ho
            Send AssertIAreEqual 1 (SizeOfArray(asResult))
            Send AssertSAreEqual "beta.pkg" asResult[0].sFileName
        End_Procedure

        // --- UniqueQuarantineName ---

        {Published = True}
        { Description = "UniqueQuarantineName: name with no collision is returned unchanged" }
        Procedure ReportUnusedSourceFiles_UniqueQuarantineName_NoCollision
            Handle ho
            String sResult
            String[] asTaken
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get UniqueQuarantineName of ho "Foo.pkg" (&asTaken) to sResult
            Send Destroy of ho
            Send AssertSAreEqual "Foo.pkg" sResult
        End_Procedure

        {Published = True}
        { Description = "UniqueQuarantineName: one collision yields _2 before the extension" }
        Procedure ReportUnusedSourceFiles_UniqueQuarantineName_Collision
            Handle ho
            String sResult
            String[] asTaken
            Move "foo.pkg" to asTaken[0]
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get UniqueQuarantineName of ho "Foo.pkg" (&asTaken) to sResult
            Send Destroy of ho
            Send AssertSAreEqual "Foo_2.pkg" sResult
        End_Procedure

        {Published = True}
        { Description = "UniqueQuarantineName: chained collisions advance to _3" }
        Procedure ReportUnusedSourceFiles_UniqueQuarantineName_Chained
            Handle ho
            String sResult
            String[] asTaken
            Move "foo.pkg"   to asTaken[0]
            Move "foo_2.pkg" to asTaken[1]
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get UniqueQuarantineName of ho "Foo.pkg" (&asTaken) to sResult
            Send Destroy of ho
            Send AssertSAreEqual "Foo_3.pkg" sResult
        End_Procedure

        {Published = True}
        { Description = "UniqueQuarantineName: suffix is inserted before the extension, not appended" }
        Procedure ReportUnusedSourceFiles_UniqueQuarantineName_ExtPreserved
            Handle ho
            String sResult
            String[] asTaken
            Move "bar.vw" to asTaken[0]
            Get Create (RefClass(cUnusedSourceFiles)) to ho
            Get UniqueQuarantineName of ho "bar.vw" (&asTaken) to sResult
            Send Destroy of ho
            Send AssertSAreEqual "bar_2.vw" sResult
        End_Procedure

    End_Object
