    // Unit tests for cRefactorUtilities._IsFunctionDeclaration.
    // Regression guard: "Function_Return" (and any other identifier that merely
    // starts with "function") must NOT be treated as a function declaration.
    // That bug made per-line callers reset their scope state on every early
    // return - it wiped cUnicodePointerToString's per-method type map, so
    // "Move aResult to sResult" in WinServCrypt.AESDecrypt was never rewritten.
    // A real declaration is "Function <name> ..." - whitespace after the keyword.
    Object oIsFunctionDeclaration is a cTestFixture
        Set psFunctionName to "_IsFunctionDeclaration"

        // *** Real declarations -> True ***
        {Published = True}
        Procedure IsFunctionDeclaration_GlobalDecl_True
            Boolean bResult
            Get _IsFunctionDeclaration of ghoFuncLib "Function AESDecrypt Global String sData Returns String" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        Procedure IsFunctionDeclaration_SimpleDecl_True
            Boolean bResult
            Get _IsFunctionDeclaration of ghoFuncLib "Function Foo Returns Integer" to bResult
            Send Assert bResult
        End_Procedure

        // Leading whitespace is trimmed, so an indented declaration still counts.
        {Published = True}
        Procedure IsFunctionDeclaration_LeadingWhitespace_True
            Boolean bResult
            Get _IsFunctionDeclaration of ghoFuncLib "    Function Bar Returns String" to bResult
            Send Assert bResult
        End_Procedure

        // *** The regression: Function_Return must NOT be a declaration ***
        {Published = True}
        Procedure IsFunctionDeclaration_FunctionReturn_False
            Boolean bResult
            Get _IsFunctionDeclaration of ghoFuncLib "Function_Return sResult" to bResult
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        Procedure IsFunctionDeclaration_FunctionReturnBare_False
            Boolean bResult
            Get _IsFunctionDeclaration of ghoFuncLib "Function_Return" to bResult
            Send AssertFalse bResult
        End_Procedure

        // An identifier that merely starts with "function" (no word boundary).
        {Published = True}
        Procedure IsFunctionDeclaration_NoWordBoundary_False
            Boolean bResult
            Get _IsFunctionDeclaration of ghoFuncLib "FunctionFoo Returns Integer" to bResult
            Send AssertFalse bResult
        End_Procedure

        // An ordinary statement is not a declaration.
        {Published = True}
        Procedure IsFunctionDeclaration_Statement_False
            Boolean bResult
            Get _IsFunctionDeclaration of ghoFuncLib "Move aResult to sResult" to bResult
            Send AssertFalse bResult
        End_Procedure

    End_Object
