    Object oChangeDfTrueDfFalse is a cTestFixture
        Set psFunctionName to "ChangeDfTrueDfFalse"

        {Published = True}
        Procedure ChangeDfTrueDfFalse_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move DFTrue to Found' to sLine
            Move 'Move True to Found' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeDfTrueDfFalse of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeDfTrueDfFalse_2
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If ((Left(sRow,1)) ne "#") Move dfFalse to bRename' to sLine
            Move 'If ((Left(sRow,1)) ne "#") Move False to bRename' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeDfTrueDfFalse of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Line with no DfTrue or DfFalse must be returned unchanged and return False.
        {Published = True}
        Procedure ChangeDfTrueDfFalse_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move True to bFlag" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeDfTrueDfFalse of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "Move True to bFlag" sLine
        End_Procedure

        // Simple DfFalse conversion without a leading expression; also verifies bChanged = True.
        {Published = True}
        Procedure ChangeDfTrueDfFalse_DfFalseSimple
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move DfFalse to bFlag" to sLine
            Move "Move False to bFlag" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeDfTrueDfFalse of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Indented line: leading whitespace must be preserved in the result.
        {Published = True}
        Procedure ChangeDfTrueDfFalse_IndentationPreserved
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    Set pbActive to DfTrue" to sLine
            Move "    Set pbActive to True" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeDfTrueDfFalse of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

    End_Object
