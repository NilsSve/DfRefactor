    Object oRemovePropertyPublic is a cTestFixture
        Set psFunctionName to "RemovePropertyPublic"

        {Published = True}
        Procedure RemovePropertyPublic_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Property Boolean pbState Public' to sLine
            Move 'Property Boolean pbState' to sExpected
            Get Tokenizer of ghoRefactorFuncLib sLine to TokenizerData
            Get RemovePropertyPublic of ghoRefactorFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Lowercase keyword is also removed.
        {Published = True}
        Procedure RemovePropertyPublic_2
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Property Boolean pbState public' to sLine
            Move 'Property Boolean pbState' to sExpected
            Get Tokenizer of ghoRefactorFuncLib sLine to TokenizerData
            Get RemovePropertyPublic of ghoRefactorFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Leading indentation is preserved.
        {Published = True}
        Procedure RemovePropertyPublic_3
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Property String psName Public' to sLine
            Move '    Property String psName' to sExpected
            Get Tokenizer of ghoRefactorFuncLib sLine to TokenizerData
            Get RemovePropertyPublic of ghoRefactorFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Non-property line — bChanged must be False.
        {Published = True}
        Procedure RemovePropertyPublic_4
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move sA to sB' to sLine
            Get Tokenizer of ghoRefactorFuncLib sLine to TokenizerData
            Get RemovePropertyPublic of ghoRefactorFuncLib (&sLine) to bChanged
            Send Assert (bChanged = False)
        End_Procedure

    End_Object
