    Object MarkedGrid is a Grid
        Set Location to 150 7
        Set Size to 107 315
        Set CurrentCellColor to gRowColor
        Set CurrentCellTextColor to clBlack
        Set CurrentRowColor to gRowColor
        Set CurrentRowTextColor  to clBlack
        Set GridLine_Mode to Grid_Visible_Both
        Set Line_Width to 2 0
        Set Select_Mode to Multi_Select
        Set Highlight_Row_State to True
        Set peDisabledTextColor to clBlack
        Set peAnchors to anAll

        Set Header_Label 0 to 'Rad'
        Set Form_Width 0 to 29

        Set Header_Label 1 to 'Artikelnr'
        Set Form_Width 1 to 62

        Set Header_Label 2 to 'Ben„mning'
        Set Form_Width 2 to 82

        Procedure Fill_the_List Integer iID
            Set Dynamic_Update_State to False
            Send Delete_Data

            Clear StatLog
            Find gt StatLog by Index.1
            While (Found)
				Send Add_Item Msg_None (Trim(StatLog.Date))
				Set Item_Shadow_State (Item_Count (Self) - 1) to True
				Send Add_Item Msg_None (Trim(StatLog.Description))
				Set Item_Shadow_State (Item_Count (Self) - 1) to True
				Send Add_Item Msg_None True
				Set Checkbox_Item_State (Item_Count (Self) - 1) to True
				Set Select_State (Item_Count (Self) - 1) to (StatLog.Date <> 0)
                Find Gt StatLog by Index.1
            Loop

            Set Dynamic_Update_State to True
        End_Procedure

    End_Object

        Object oWatches is a Grid
            Set peDisabledTextColor to clBlack
            Set Location to 13 8
            Set Size to 188 393
            Set Line_Width to 3 0
            Set Header_Label 0 to "DataDictionary"
            Set Form_Width 0 to 149
            Set Form_Width 1 to 105
            Set Header_Label 1 to "File.Field"
            Set Form_Width 2 to 130
            Set Header_Label 2 to "Changed to Value"

            Procedure Populate
                Handle hDD
                Handle[] haDDs
                Integer iCount iSize iItems
                Boolean bChanged
                String sTableName sColumnName sValue

                Set Dynamic_Update_State to False
                Send Delete_Data
                Get phaHandles to haDDs
                Move (SizeOfArray(haDDs)) to iSize
                Decrement iSize

                For iCount From 0 to iSize
                    Move haDDs[iCount] to hDD
					Get Item_Count to iItems

					Send Add_Item Msg_None (Object_Label(hDD))
					Send Add_Item Msg_None (SFormat("ShouldSave(%1) is True", sTableName))
					Send Add_Item Msg_None ""

					Set Item_Shadow_State (iItems + 0) to True
					Set Item_Shadow_State (iItems + 1) to True
					Set Item_Shadow_State (iItems + 2) to True
					Set Checkbox_Item_State (iItems + 2) to True
                Loop
                Set Dynamic_Update_State to True
            End_Procedure

        End_Object

