Procedure OnIdle
    Boolean bShouldSave
    Integer iSdagnr iServicedag
    String SERVICEDAG SERVICEDAG2 SERVICEDAG3 SERVICEDAG4
    
	Move ("ŹŹŹŹ-MM-DD") to SERVICEDAG
    Move ( (Should_Save(self)) ) to bShouldSave
    If (bShouldSave and Windowindex = 0)Move False to bShouldSave
    // Only enable save / update if permitted
    If (bShouldSave)Begin
//        Set pbEnabled to False
    End
    If (((iSdagnr Eq 1) and (SERVICEDAG  eq iServicedag)) ;
        or ((iSdagnr Eq 2) and (SERVICEDAG2 eq iServicedag)) ;
        or ((iSdagnr Eq 3) and (SERVICEDAG3 eq iServicedag)) ;
        or ((iSdagnr Eq 4) and (SERVICEDAG4 eq iServicedag))) Begin
        Send None
    End

End_Procedure

