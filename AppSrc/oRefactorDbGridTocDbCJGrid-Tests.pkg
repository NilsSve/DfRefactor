    Object oTranslateGridProperty is a cTestFixture
        Set psFunctionName to "TranslateGridProperty"
    
        Object oWorker is a cDbGridTocDbCJGrid
        End_Object
    
        // -----------------------------------------------------------------------
        // peResizeColumn
        // -----------------------------------------------------------------------
    
        {Published = True}
        { Description = "peResizeColumn = rcNone -> pbAllowColumnResize False (1 line)" }
        Procedure PeResizeColumn_rcNone
            String[] asResult
            String   sLine sLower
            Move "    Set peResizeColumn to rcNone" to sLine
            Move (Lowercase(Trim(sLine))) to sLower
            Get TranslateGridProperty of oWorker sLine sLower to asResult
            Send AssertIAreEqual 1 (SizeOfArray(asResult))
            Send AssertSAreEqual "    Set pbAllowColumnResize to False" asResult[0]
        End_Procedure
    
        {Published = True}
        { Description = "peResizeColumn = rcNone numeric (0) -> pbAllowColumnResize False" }
        Procedure PeResizeColumn_0
            String[] asResult
            String   sLine sLower
            Move "    Set peResizeColumn to 0" to sLine
            Move (Lowercase(Trim(sLine))) to sLower
            Get TranslateGridProperty of oWorker sLine sLower to asResult
            Send AssertIAreEqual 1 (SizeOfArray(asResult))
            Send AssertSAreEqual "    Set pbAllowColumnResize to False" asResult[0]
        End_Procedure
    
        {Published = True}
        { Description = "peResizeColumn = rcAll (not rcNone) -> dropped (0 lines)" }
        Procedure PeResizeColumn_rcAll_Dropped
            String[] asResult
            String   sLine sLower
            Move "    Set peResizeColumn to rcAll" to sLine
            Move (Lowercase(Trim(sLine))) to sLower
            Get TranslateGridProperty of oWorker sLine sLower to asResult
            Send AssertIAreEqual 0 (SizeOfArray(asResult))
        End_Procedure
    
