                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        // -----------------------------------------------------------------------
        // column_option NoEnter -> pbEditable (inverted)
        // -----------------------------------------------------------------------

        {Published = True}
        { Description = "column_option NoEnter True -> Set pbEditable to False (inverted)" }
        Procedure ColumnOption_NoEnterTrue_EmitsFalse
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"                         to asInput[0]
            Move "    Begin_Row"                                     to asInput[1]
            Move "        Entry_Item Orders.ID"                      to asInput[2]
            Move "    End_Row"                                       to asInput[3]
            Move "    Set column_option Item 0 to NoEnter True"      to asInput[4]
            Move "End_Object"                                        to asInput[5]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set pbEditable to False") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "column_option NoEnter False -> Set pbEditable to True (inverted)" }
        Procedure ColumnOption_NoEnterFalse_EmitsTrue
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"                         to asInput[0]
            Move "    Begin_Row"                                     to asInput[1]
            Move "        Entry_Item Orders.ID"                      to asInput[2]
            Move "    End_Row"                                       to asInput[3]
            Move "    Set column_option Item 0 to NoEnter False"     to asInput[4]
            Move "End_Object"                                        to asInput[5]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set pbEditable to True") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "column_option NoTab only (no NoEnter) -> no pbEditable emitted" }
        Procedure ColumnOption_NoTabOnly_NoOutput
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"                     to asInput[0]
            Move "    Begin_Row"                                 to asInput[1]
            Move "        Entry_Item Orders.ID"                  to asInput[2]
            Move "    End_Row"                                   to asInput[3]
            Move "    Set column_option Item 0 to NoTab True"    to asInput[4]
            Move "End_Object"                                    to asInput[5]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            // column_option raw line must not appear; and no pbEditable should be emitted
            // for a NoTab-only option since it has no CJGrid equivalent.
            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "column_option") Begin
                    Move True to bFound
                End
            Loop
            Send AssertFalse bFound
        End_Procedure

        {Published = True}
        { Description = "column_option without Item keyword also works" }
        Procedure ColumnOption_WithoutItem
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"                     to asInput[0]
            Move "    Begin_Row"                                 to asInput[1]
            Move "        Entry_Item Orders.ID"                  to asInput[2]
            Move "    End_Row"                                   to asInput[3]
            Move "    Set column_option 0 to NoEnter True"       to asInput[4]
            Move "End_Object"                                    to asInput[5]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set pbEditable to False") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        // -----------------------------------------------------------------------
        // Define column constant removal
        // -----------------------------------------------------------------------

        {Published = True}
        { Description = "Define COL_xxx inside a grid body is removed" }
        Procedure DefineConstant_Removed
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"         to asInput[0]
            Move "    Begin_Row"                     to asInput[1]
            Move "        Entry_Item Orders.ID"      to asInput[2]
            Move "        Entry_Item Orders.Name"    to asInput[3]
            Move "    End_Row"                       to asInput[4]
            Move "    Define COL_ID   for 0"         to asInput[5]
            Move "    Define COL_NAME for 1"         to asInput[6]
            Move "    Set Form_Width 0 to 60"        to asInput[7]
            Move "    Set Form_Width 1 to 120"       to asInput[8]
            Move "End_Object"                        to asInput[9]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "define col_") Begin
                    Move True to bFound
                End
            Loop
            Send AssertFalse bFound
        End_Procedure

        {Published = True}
        { Description = "Define constant removal does not suppress column objects" }
        Procedure DefineConstant_ColumnObjectsStillEmitted
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"     to asInput[0]
            Move "    Begin_Row"                 to asInput[1]
            Move "        Entry_Item Orders.ID"  to asInput[2]
            Move "    End_Row"                   to asInput[3]
            Move "    Define COL_ID for 0"       to asInput[4]
            Move "    Set Form_Width 0 to 80"    to asInput[5]
            Move "End_Object"                    to asInput[6]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            // The column object (Entry_Item Orders.ID -> oOrders_ID column) must be present
            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "entry_item orders.id") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Define constant outside a grid body passes through unchanged" }
        Procedure DefineConstant_OutsideGrid_Preserved
            String[] asInput asOutput
            Integer  iGrids

            Move "Define MY_CONST for 42"       to asInput[0]
            Move "Object oGrid is a cDbGrid"    to asInput[1]
            Move "End_Object"                   to asInput[2]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            // The Define outside the grid must still be in the output
            Send AssertSAreEqual "Define MY_CONST for 42" asOutput[0]
        End_Procedure

        // -----------------------------------------------------------------------
        // Per-column Set properties appearing BEFORE Begin_Row must be
        // pre-collected and converted to column object properties — not emitted
        // verbatim at the grid level and not silently discarded.
        // -----------------------------------------------------------------------

        {Published = True}
        { Description = "Column_Checkbox_State before Begin_Row -> Set pbCheckBox on column object" }
        Procedure CheckboxState_BeforeBeginRow_ConvertedToColumn
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundConverted bFoundRaw

            Move "Object oGrid is a cDbGrid"                    to asInput[0]
            Move "    Set Column_Checkbox_State Item 0 to True" to asInput[1]
            Move "    Begin_Row"                                to asInput[2]
            Move "        Entry_Item Orders.ID"                 to asInput[3]
            Move "    End_Row"                                  to asInput[4]
            Move "End_Object"                                   to asInput[5]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFoundConverted
            Move False to bFoundRaw
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set pbCheckBox to True") Begin
                    Move True to bFoundConverted
                End
                If (Lowercase(asOutput[iIdx]) contains "column_checkbox_state") Begin
                    Move True to bFoundRaw
                End
            Loop
            Send Assert     bFoundConverted   // must be converted
            Send AssertFalse bFoundRaw         // must not appear verbatim
        End_Procedure

        {Published = True}
        { Description = "Column_Shadow_State True before Begin_Row -> Set pbEditable to False on column" }
        Procedure ShadowState_BeforeBeginRow_ConvertedToColumn
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundConverted bFoundRaw

            Move "Object oGrid is a cDbGrid"                  to asInput[0]
            Move "    Set Column_Shadow_State 0 to True"      to asInput[1]
            Move "    Begin_Row"                              to asInput[2]
            Move "        Entry_Item Orders.ID"               to asInput[3]
            Move "    End_Row"                                to asInput[4]
            Move "End_Object"                                 to asInput[5]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFoundConverted
            Move False to bFoundRaw
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set pbEditable to False") Begin
                    Move True to bFoundConverted
                End
                If (Lowercase(asOutput[iIdx]) contains "column_shadow_state") Begin
                    Move True to bFoundRaw
                End
            Loop
            Send Assert     bFoundConverted
            Send AssertFalse bFoundRaw
        End_Procedure

        {Published = True}
        { Description = "Column_Combo_State item 1 before Begin_Row -> Set pbComboButton on column 1" }
        Procedure ComboState_BeforeBeginRow_ConvertedToColumn
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundConverted bFoundRaw

            Move "Object oGrid is a cDbGrid"                   to asInput[0]
            Move "    Set Column_Combo_State item 1 to True"   to asInput[1]
            Move "    Begin_Row"                               to asInput[2]
            Move "        Entry_Item Orders.ID"                to asInput[3]
            Move "        Entry_Item Orders.Name"              to asInput[4]
            Move "    End_Row"                                 to asInput[5]
            Move "End_Object"                                  to asInput[6]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFoundConverted
            Move False to bFoundRaw
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set pbComboButton to True") Begin
                    Move True to bFoundConverted
                End
                If (Lowercase(asOutput[iIdx]) contains "column_combo_state") Begin
                    Move True to bFoundRaw
                End
            Loop
            Send Assert     bFoundConverted
            Send AssertFalse bFoundRaw
        End_Procedure

    End_Object

    // ---------------------------------------------------------------------------

    Object oTranslateDataTypeValue is a cTestFixture
        Set psFunctionName to "TranslateDataTypeValue"

        Object oWorker is a cDbGridTocDbCJGrid
        End_Object

        {Published = True}
        { Description = "mask_default_window -> typeText" }
        Procedure MaskDefault_ToTypeText
            String sResult
            Get TranslateDataTypeValue of oWorker "mask_default_window" to sResult
            Send AssertSAreEqual "typeText" sResult
        End_Procedure

        {Published = True}
        { Description = "mask_numeric_window -> typeNumeric" }
        Procedure MaskNumeric_ToTypeNumeric
            String sResult
            Get TranslateDataTypeValue of oWorker "mask_numeric_window" to sResult
            Send AssertSAreEqual "typeNumeric" sResult
        End_Procedure

        {Published = True}
        { Description = "mask_date_window -> typeDate" }
        Procedure MaskDate_ToTypeDate
            String sResult
            Get TranslateDataTypeValue of oWorker "mask_date_window" to sResult
            Send AssertSAreEqual "typeDate" sResult
        End_Procedure

        {Published = True}
        { Description = "Unknown value is returned unchanged" }
        Procedure Unknown_PassThrough
            String sResult
            Get TranslateDataTypeValue of oWorker "someunknowntype" to sResult
            Send AssertSAreEqual "someunknowntype" sResult
        End_Procedure

    End_Object

    // ---------------------------------------------------------------------------

    Object oMainFileLine is a cTestFixture
        Set psFunctionName to "HandleMainFileLine (cDbGridTocDbCJGrid)"

        Object oWorker is a cDbGridTocDbCJGrid
        End_Object

        Procedure TearDown
            Boolean bOK
            Get ParseAndSetParameter of oWorker "" to bOK
            Send _InitializeFuncLib of ghoFuncLib
        End_Procedure

        // Helper: runs TransformSource on a single-grid input, returns output array.
        Function RunTransform_as String[] asInput Returns String[]
            String[] asOutput
            Integer  iGrids
            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Get pasSource of oWorker to asOutput
            Function_Return asOutput
        End_Function

        {Published = True}
        { Description = "Set Main_File is commented out in the output" }
        Procedure MainFile_IsCommentedOut
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFound

            Move "Object oGrid1 is a DbGrid"                  to asInput[0]
            Move "    Set Main_File to Arbtrans.File_Number"  to asInput[1]
            Move "End_Object"                                 to asInput[2]

            Get RunTransform_as asInput to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "// set main_file") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Commented Set Server suggestion is added after the commented Set Main_File" }
        Procedure SetServer_SuggestionAdded
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFound

            Move "Object oGrid1 is a DbGrid"                  to asInput[0]
            Move "    Set Main_File to Arbtrans.File_Number"  to asInput[1]
            Move "End_Object"                                 to asInput[2]

            Get RunTransform_as asInput to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "// Set Server to oArbtrans_dd") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Commented Set Server appears immediately after the commented Set Main_File" }
        Procedure SetServer_AppearsBelowCommentedMainFile
            String[] asInput asOutput
            Integer  iIdx iCommentIdx iServerIdx

            Move "Object oGrid1 is a DbGrid"                  to asInput[0]
            Move "    Set Main_File to Arbtrans.File_Number"  to asInput[1]
            Move "End_Object"                                 to asInput[2]

            Get RunTransform_as asInput to asOutput

            Move -1 to iCommentIdx
            Move -1 to iServerIdx
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "// set main_file") Begin
                    Move iIdx to iCommentIdx
                End
                If (asOutput[iIdx] contains "// Set Server to oArbtrans_dd") Begin
                    Move iIdx to iServerIdx
                End
            Loop
            // Commented original must appear immediately before the commented Set Server line.
            Send Assert (iCommentIdx >= 0 and iServerIdx = iCommentIdx + 1)
        End_Procedure

        {Published = True}
        { Description = "DDO name is derived from table name before the dot" }
        Procedure DdoName_DerivedFromTableName
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFound

            Move "Object oGrid1 is a DbGrid"                  to asInput[0]
            Move "    Set Main_File to Customer.File_Number"  to asInput[1]
            Move "End_Object"                                 to asInput[2]

            Get RunTransform_as asInput to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "// Set Server to oCustomer_dd") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

    End_Object

    // -----------------------------------------------------------------------
    // oCalculatedEntryItem
    //   Tests for Expression Entry_Item -> OnSetCalculatedValue conversion.
    // -----------------------------------------------------------------------
    Object oCalculatedEntryItem is a cTestFixture
        Set psFunctionName to "CalculatedEntryItem (cDbGridTocDbCJGrid)"

        Object oWorker is a cDbGridTocDbCJGrid
        End_Object

        Procedure TearDown
            Boolean bOK
            Get ParseAndSetParameter of oWorker "" to bOK
            Send _InitializeFuncLib of ghoFuncLib
        End_Procedure

        Function RunTransform_as String[] asInput Returns String[]
            String[] asOutput
            Integer  iGrids
            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Get pasSource of oWorker to asOutput
            Function_Return asOutput
        End_Function

        // -----------------------------------------------------------------------
        // IsEntryItemExpression
        // -----------------------------------------------------------------------

        {Published = True}
        { Description = "Expression starting with ( is detected as an expression" }
        Procedure IsExpression_LeadingParen
            Boolean bResult
            Get IsEntryItemExpression of oWorker "(StatLog.FunctionName * string(StatLog.Date))" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "Value with an internal space is detected as an expression" }
        Procedure IsExpression_ContainsSpace
            Boolean bResult
            Get IsEntryItemExpression of oWorker "Table.FieldA + Table.FieldB" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "Plain Table.Field is NOT an expression" }
        Procedure IsExpression_PlainFieldRef_False
            Boolean bResult
            Get IsEntryItemExpression of oWorker "StatLog.FunctionName" to bResult
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        { Description = "Bare field name without a dot is NOT an expression" }
        Procedure IsExpression_BareFieldName_False
            Boolean bResult
            Get IsEntryItemExpression of oWorker "FunctionName" to bResult
            Send AssertFalse bResult
        End_Procedure

        // -----------------------------------------------------------------------
        // End-to-end TransformSource: expression column
        // -----------------------------------------------------------------------

        {Published = True}
        { Description = "Expression Entry_Item produces no Entry_Item line in the column object" }
        Procedure ExpressionColumn_NoEntryItemLine
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"                                         to asInput[0]
            Move "    Begin_Row"                                                      to asInput[1]
            Move "        Entry_Item (StatLog.FunctionName * string(StatLog.Date))"  to asInput[2]
            Move "    End_Row"                                                        to asInput[3]
            Move "End_Object"                                                         to asInput[4]

            Get RunTransform_as asInput to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Trim(Lowercase(asOutput[iIdx])) contains "entry_item") Begin
                    Move True to bFound
                End
            Loop
            Send AssertFalse bFound
        End_Procedure

        {Published = True}
        { Description = "Expression Entry_Item produces an OnSetCalculatedValue procedure" }
        Procedure ExpressionColumn_OnSetCalculatedValueEmitted
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"                                         to asInput[0]
            Move "    Begin_Row"                                                      to asInput[1]
            Move "        Entry_Item (StatLog.FunctionName * string(StatLog.Date))"  to asInput[2]
            Move "    End_Row"                                                        to asInput[3]
            Move "End_Object"                                                         to asInput[4]

            Get RunTransform_as asInput to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Procedure OnSetCalculatedValue") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "OnSetCalculatedValue body contains the original expression" }
        Procedure ExpressionColumn_MoveExpressionToSValue
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"                                         to asInput[0]
            Move "    Begin_Row"                                                      to asInput[1]
            Move "        Entry_Item (StatLog.FunctionName * string(StatLog.Date))"  to asInput[2]
            Move "    End_Row"                                                        to asInput[3]
            Move "End_Object"                                                         to asInput[4]

            Get RunTransform_as asInput to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Move (StatLog.FunctionName * string(StatLog.Date)) to sValue") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Expression column object is named oCalcCol1 (1-based positional name)" }
        Procedure ExpressionColumn_PositionalName
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"                                         to asInput[0]
            Move "    Begin_Row"                                                      to asInput[1]
            Move "        Entry_Item (StatLog.FunctionName * string(StatLog.Date))"  to asInput[2]
            Move "    End_Row"                                                        to asInput[3]
            Move "End_Object"                                                         to asInput[4]

            Get RunTransform_as asInput to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Object oCalcCol1 is a") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Header_Label on an expression column is used as the caption" }
        Procedure ExpressionColumn_HeaderLabelUsedAsCaption
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"                                         to asInput[0]
            Move "    Begin_Row"                                                      to asInput[1]
            Move "        Entry_Item (StatLog.FunctionName * string(StatLog.Date))"  to asInput[2]
            Move "    End_Row"                                                        to asInput[3]
            Move '    Set Header_Label Item 0 to "Function / Date"'                  to asInput[4]
            Move "End_Object"                                                         to asInput[5]

            Get RunTransform_as asInput to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains 'Set psCaption to "Function / Date"') Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Plain column alongside expression column: plain column retains Entry_Item" }
        Procedure MixedColumns_PlainColumnRetainsEntryItem
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"                                         to asInput[0]
            Move "    Begin_Row"                                                      to asInput[1]
            Move "        Entry_Item (StatLog.FunctionName * string(StatLog.Date))"  to asInput[2]
            Move "        Entry_Item StatLog.Description"                            to asInput[3]
            Move "    End_Row"                                                        to asInput[4]
            Move "End_Object"                                                         to asInput[5]

            Get RunTransform_as asInput to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Entry_Item StatLog.Description") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Plain column alongside expression column: expression column has no Entry_Item" }
        Procedure MixedColumns_ExpressionColumnHasNoEntryItem
            String[] asInput asOutput
            Integer  iIdx
            Integer  iEntryItemCount

            Move "Object oGrid is a cDbGrid"                                         to asInput[0]
            Move "    Begin_Row"                                                      to asInput[1]
            Move "        Entry_Item (StatLog.FunctionName * string(StatLog.Date))"  to asInput[2]
            Move "        Entry_Item StatLog.Description"                            to asInput[3]
            Move "    End_Row"                                                        to asInput[4]
            Move "End_Object"                                                         to asInput[5]

            Get RunTransform_as asInput to asOutput

            // Exactly one Entry_Item must appear: the plain column only.
            Move 0 to iEntryItemCount
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Trim(Lowercase(asOutput[iIdx])) contains "entry_item") Begin
                    Increment iEntryItemCount
                End
            Loop
            Send AssertIAreEqual 1 iEntryItemCount
        End_Procedure

        {Published = True}
        { Description = "Second column (expression) gets oCalcCol2 when it is in position 2" }
        Procedure MixedColumns_ExpressionInSecondPosition_IsCalcCol2
            String[] asInput asOutput
            Integer  iIdx
            Boolean  bFound

            Move "Object oGrid is a cDbGrid"                                         to asInput[0]
            Move "    Begin_Row"                                                      to asInput[1]
            Move "        Entry_Item StatLog.Description"                            to asInput[2]
            Move "        Entry_Item (StatLog.FunctionName * string(StatLog.Date))"  to asInput[3]
            Move "    End_Row"                                                        to asInput[4]
            Move "End_Object"                                                         to asInput[5]

            Get RunTransform_as asInput to asOutput

            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Object oCalcCol2 is a") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

    End_Object

End_Object
