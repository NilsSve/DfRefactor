            Send AssertSAreEqual "    Set peHorizontalGridStyle to xtpGridNoLines" asResult[0]
            Send AssertSAreEqual "    Set peVerticalGridStyle   to xtpGridNoLines" asResult[1]
        End_Procedure
    
