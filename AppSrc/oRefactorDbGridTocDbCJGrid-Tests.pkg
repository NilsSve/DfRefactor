            Boolean  bFound
    
            Move "Object oGrid is a cDbGrid"          to asInput[0]
            Move "    Set Read_Only_State to True"    to asInput[1]
            Move "End_Object"                         to asInput[2]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] = "    Set pbReadOnly to True") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure
    
        {Published = True}
        { Description = "Gridline_Mode Grid_Visible_Both inside a grid -> 2 xtpGridSolid lines" }
        Procedure GridlineModeBoth_InGrid
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundH bFoundV
    
            Move "Object oGrid is a cDbGrid"                    to asInput[0]
            Move "    Set Gridline_Mode to Grid_Visible_Both"   to asInput[1]
            Move "End_Object"                                   to asInput[2]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFoundH
            Move False to bFoundV
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] = "    Set peHorizontalGridStyle to xtpGridSolid") Begin
                    Move True to bFoundH
                End
                If (asOutput[iIdx] = "    Set peVerticalGridStyle   to xtpGridSolid") Begin
                    Move True to bFoundV
                End
            Loop
            Send Assert bFoundH
            Send Assert bFoundV
        End_Procedure
    
        {Published = True}
        { Description = "peResizeColumn = rcNone inside a grid -> pbAllowColumnResize False" }
        Procedure PeResizeColumn_InGrid
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound
    
            Move "Object oGrid is a cDbGrid"             to asInput[0]
            Move "    Set peResizeColumn to rcNone"      to asInput[1]
            Move "End_Object"                            to asInput[2]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] = "    Set pbAllowColumnResize to False") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure
    
        {Published = True}
        { Description = "peResizeColumn = rcAll inside a grid -> line is dropped" }
        Procedure PeResizeColumn_rcAll_InGrid
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundOld bFoundNew
    
            Move "Object oGrid is a cDbGrid"             to asInput[0]
            Move "    Set peResizeColumn to rcAll"       to asInput[1]
            Move "End_Object"                            to asInput[2]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFoundOld
            Move False to bFoundNew
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "peresizecolumn") Begin
                    Move True to bFoundOld
                End
                If (Lowercase(asOutput[iIdx]) contains "pbresizecolumn") Begin
                    Move True to bFoundNew
                End
            Loop
            Send AssertFalse bFoundOld
            Send AssertFalse bFoundNew
        End_Procedure
    
        // -----------------------------------------------------------------------
        // Entry_Display procedure removal
        // -----------------------------------------------------------------------
    
        {Published = True}
        { Description = "Entry_Display procedure block is commented out, not removed" }
        Procedure EntryDisplay_CommentedOut
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundDecl bFoundBody bFoundEnd bFoundRaw
    
            Move "Object oGrid is a cDbGrid"      to asInput[0]
            Move "    Set Size to 100 200"        to asInput[1]
            Move "    Procedure Entry_Display"    to asInput[2]
            Move "        Send Something"         to asInput[3]
            Move "    End_Procedure"              to asInput[4]
            Move "End_Object"                     to asInput[5]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFoundDecl
            Move False to bFoundBody
            Move False to bFoundEnd
            Move False to bFoundRaw
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "// procedure entry_display") Begin
                    Move True to bFoundDecl
                End
                If (Lowercase(asOutput[iIdx]) contains "// send something") Begin
                    Move True to bFoundBody
                End
                If (Lowercase(asOutput[iIdx]) contains "// end_procedure") Begin
                    Move True to bFoundEnd
                End
                // The raw (un-commented) lines must not appear
                If (Trim(Lowercase(asOutput[iIdx])) = "procedure entry_display") Begin
                    Move True to bFoundRaw
                End
            Loop
            Send Assert bFoundDecl
            Send Assert bFoundBody
            Send Assert bFoundEnd
            Send AssertFalse bFoundRaw
        End_Procedure
    
        // -----------------------------------------------------------------------
        // Content outside grids passes through untouched
        // -----------------------------------------------------------------------
    
        {Published = True}
        { Description = "Lines before and after a grid block are preserved unchanged" }
        Procedure SurroundingContent_Preserved
            String[] asInput asOutput
            Integer  iGrids
    
            Move "Use SomePackage.pkg"            to asInput[0]
            Move ""                               to asInput[1]
            Move "Object oGrid is a cDbGrid"      to asInput[2]
            Move "End_Object"                     to asInput[3]
            Move ""                               to asInput[4]
            Move "// trailing comment"            to asInput[5]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Send AssertSAreEqual "Use SomePackage.pkg" asOutput[0]
            Send AssertSAreEqual ""                    asOutput[1]
            Send AssertSAreEqual ""                    asOutput[4]
            Send AssertSAreEqual "// trailing comment" asOutput[5]
        End_Procedure
    
        // -----------------------------------------------------------------------
        // ParseAndSetParameter
        // -----------------------------------------------------------------------
    
        {Published = True}
        { Description = "Empty parameter -> pattern-based detection, default class names" }
        Procedure ParseParam_Empty
            Boolean bOK
            String  sGrid sCol
    
            Get ParseAndSetParameter of oWorker "" to bOK
            Send Assert bOK
            Get psLegacyGridClass   of oWorker to sGrid
            Send AssertSAreEqual "" sGrid
            Get psTargetGridClass   of oWorker to sGrid
            Send AssertSAreEqual CS_CJGrid_TargetClass sGrid
            Get psTargetColumnClass of oWorker to sCol
            Send AssertSAreEqual CS_CJGrid_TargetColumn sCol
        End_Procedure
    
        {Published = True}
        { Description = "2-part parameter sets old and new grid class; column stays default" }
        Procedure ParseParam_TwoParts
            Boolean bOK
            String  sVal
    
            Get ParseAndSetParameter of oWorker "cMyOldGrid,cMyNewGrid" to bOK
            Send Assert bOK
            Get psLegacyGridClass of oWorker to sVal
            Send AssertSAreEqual "cmyoldgrid" sVal   // stored lowercase
            Get psTargetGridClass of oWorker to sVal
            Send AssertSAreEqual "cMyNewGrid" sVal
            Get psTargetColumnClass of oWorker to sVal
            Send AssertSAreEqual CS_CJGrid_TargetColumn sVal
        End_Procedure
    
        {Published = True}
        { Description = "3-part parameter sets all three class names" }
        Procedure ParseParam_ThreeParts
            Boolean bOK
            String  sVal
    
            Get ParseAndSetParameter of oWorker "cOld,cNewGrid,cNewCol" to bOK
            Send Assert bOK
            Get psLegacyGridClass   of oWorker to sVal
            Send AssertSAreEqual "cold" sVal
            Get psTargetGridClass   of oWorker to sVal
            Send AssertSAreEqual "cNewGrid" sVal
            Get psTargetColumnClass of oWorker to sVal
            Send AssertSAreEqual "cNewCol" sVal
        End_Procedure
    
        {Published = True}
        { Description = "1-part parameter returns False (invalid)" }
        Procedure ParseParam_OnePart_Invalid
            Boolean bOK
            Get ParseAndSetParameter of oWorker "OnlyOneClass" to bOK
            Send AssertFalse bOK
        End_Procedure
    
        // -----------------------------------------------------------------------
        // ReplaceGridClassName preserves indentation
        // -----------------------------------------------------------------------
    
        {Published = True}
        { Description = "ReplaceGridClassName keeps leading spaces intact" }
        Procedure ReplaceGridClassName_Indent
            String sResult sLine sLower

            Get ParseAndSetParameter of oWorker "" to sResult  // default classes
            Move "    Object oGrid is a cDbGrid" to sLine
            Move (Lowercase(Trim(sLine)))         to sLower
            Get ReplaceGridClassName of oWorker sLine sLower to sResult
            Send AssertSAreEqual "    Object oGrid is a cDbCJGrid" sResult
        End_Procedure

        // -----------------------------------------------------------------------
        // Entry_Display: translatable color properties are extracted to grid body
        // -----------------------------------------------------------------------

        {Published = True}
        { Description = "Set CurrentRowColor inside Entry_Display is translated to Set piHighlightBackColor BEFORE the commented block" }
        Procedure EntryDisplay_CurrentRowColor_ExtractedAndTranslated
            String[] asInput asOutput
            Integer  iGrids iIdx iTranslatedIdx iCommentedIdx
            Boolean  bFoundTranslated bFoundRaw

            Move "Object oGrid is a cDbGrid"                        to asInput[0]
            Move "    Procedure Entry_Display"                      to asInput[1]
            Move "        Forward Send Entry_Display"               to asInput[2]
            Move "        Set CurrentRowColor to RGB(200,220,240)"  to asInput[3]
            Move "    End_Procedure"                                to asInput[4]
            Move "End_Object"                                       to asInput[5]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFoundTranslated
            Move False to bFoundRaw
            Move -1 to iTranslatedIdx
            Move -1 to iCommentedIdx
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set piHighlightBackColor to RGB(200,220,240)") Begin
                    Move True to bFoundTranslated
                    Move iIdx to iTranslatedIdx
                End
                If (Lowercase(asOutput[iIdx]) contains "// procedure entry_display") Begin
                    Move iIdx to iCommentedIdx
                End
                // The raw legacy line must not pass through uncommented
                If (asOutput[iIdx] = "        Set CurrentRowColor to RGB(200,220,240)") Begin
                    Move True to bFoundRaw
                End
            Loop
            Send Assert      bFoundTranslated
            Send AssertFalse bFoundRaw
            // Translated property must appear BEFORE the commented Entry_Display block
            Send Assert (iTranslatedIdx >= 0 and iCommentedIdx >= 0 and iTranslatedIdx < iCommentedIdx)
        End_Procedure

        {Published = True}
        { Description = "Set CurrentRowTextColor inside Entry_Display is extracted as Set piHighlightForeColor" }
        Procedure EntryDisplay_CurrentRowTextColor_ExtractedAndTranslated
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundTranslated

            Move "Object oGrid is a cDbGrid"              to asInput[0]
            Move "    Procedure Entry_Display"            to asInput[1]
            Move "        Forward Send Entry_Display"     to asInput[2]
            Move "        Set CurrentRowTextColor to 255" to asInput[3]
            Move "    End_Procedure"                      to asInput[4]
            Move "End_Object"                             to asInput[5]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFoundTranslated
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set piHighlightForeColor to 255") Begin
                    Move True to bFoundTranslated
                End
            Loop
            Send Assert bFoundTranslated
        End_Procedure

        {Published = True}
        { Description = "Entry_Display body is still fully commented out even when color is extracted" }
        Procedure EntryDisplay_BodyStillCommentedOut
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundCommentedDecl bFoundCommentedColor bFoundCommentedEnd

            Move "Object oGrid is a cDbGrid"                       to asInput[0]
            Move "    Procedure Entry_Display"                     to asInput[1]
            Move "        Forward Send Entry_Display"              to asInput[2]
            Move "        Set CurrentRowColor to RGB(200,220,240)" to asInput[3]
            Move "    End_Procedure"                               to asInput[4]
            Move "End_Object"                                      to asInput[5]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFoundCommentedDecl
            Move False to bFoundCommentedColor
            Move False to bFoundCommentedEnd
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "// procedure entry_display") Begin
                    Move True to bFoundCommentedDecl
                End
                If (Lowercase(asOutput[iIdx]) contains "// " + "        set currentrowcolor") Begin
                    Move True to bFoundCommentedColor
                End
                If (Lowercase(asOutput[iIdx]) contains "// end_procedure") Begin
                    Move True to bFoundCommentedEnd
                End
            Loop
            Send Assert bFoundCommentedDecl
            Send Assert bFoundCommentedColor
            Send Assert bFoundCommentedEnd
        End_Procedure

        {Published = True}
        { Description = "Non-color lines in Entry_Display are not extracted to grid body" }
        Procedure EntryDisplay_NonColorLine_NotExtracted
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundRaw

            Move "Object oGrid is a cDbGrid"              to asInput[0]
            Move "    Procedure Entry_Display"            to asInput[1]
            Move "        Forward Send Entry_Display"     to asInput[2]
            Move "        Send SomeCustomMessage"         to asInput[3]
            Move "    End_Procedure"                      to asInput[4]
            Move "End_Object"                             to asInput[5]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFoundRaw
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] = "        Send SomeCustomMessage") Begin
                    Move True to bFoundRaw
                End
            Loop
            Send AssertFalse bFoundRaw
        End_Procedure

        {Published = True}
        { Description = "Entry_Display color appears BEFORE column objects when grid has columns" }
        Procedure EntryDisplay_AppearsBeforeColumnObjects
            String[] asInput asOutput
            Integer  iGrids iIdx iTranslatedIdx iFirstColumnIdx
            Boolean  bFoundTranslated

            Move "Object oGrid is a cDbGrid"                        to asInput[0]
            Move "    Begin_Row"                                    to asInput[1]
            Move "        Entry_Item MyTable.Field1"                to asInput[2]
            Move "    End_Row"                                      to asInput[3]
            Move "    Procedure Entry_Display"                      to asInput[4]
            Move "        Set CurrentRowColor to RGB(10,20,30)"     to asInput[5]
            Move "    End_Procedure"                                to asInput[6]
            Move "End_Object"                                       to asInput[7]

            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput

            Move False to bFoundTranslated
            Move -1 to iTranslatedIdx
            Move -1 to iFirstColumnIdx
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Set piHighlightBackColor to RGB(10,20,30)") Begin
                    Move True to bFoundTranslated
                    Move iIdx to iTranslatedIdx
                End
                If (iFirstColumnIdx = -1 and Lowercase(asOutput[iIdx]) contains "object o" and ;
                    Lowercase(asOutput[iIdx]) contains "is a") Begin
                    // Skip the outer grid object declaration itself (index 0)
                    If (iIdx > 0) Begin
                        Move iIdx to iFirstColumnIdx
                    End
                End
            Loop
            Send Assert bFoundTranslated
            // Translated color must appear BEFORE the first column Object line
            Send Assert (iTranslatedIdx >= 0 and iFirstColumnIdx >= 0 and iTranslatedIdx < iFirstColumnIdx)
        End_Procedure

    End_Object

