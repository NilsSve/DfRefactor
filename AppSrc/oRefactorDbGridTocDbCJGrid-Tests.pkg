            Get IsCommentOutGridProperty of oWorker "set main_file to orders" to bResult
            Send Assert bResult
        End_Procedure
    
        {Published = True}
        { Description = "wrap_state (legacy-remove) must not be a comment-out property" }
        Procedure WrapState_NotCommentOut
            Boolean bResult
            Get IsCommentOutGridProperty of oWorker "set wrap_state to true" to bResult
            Send AssertFalse bResult
        End_Procedure
    
        {Published = True}
        { Description = "An ordinary CJGrid property must not be a comment-out property" }
        Procedure OrdinaryProperty_NotCommentOut
            Boolean bResult
            Get IsCommentOutGridProperty of oWorker "set pbeditable to true" to bResult
            Send AssertFalse bResult
        End_Procedure
    
        {Published = True}
        { Description = "A line that does not start with 'set ' must not be a comment-out property" }
        Procedure NonSet_NotCommentOut
            Boolean bResult
            Get IsCommentOutGridProperty of oWorker "object omygrid is a cdbgrid" to bResult
            Send AssertFalse bResult
