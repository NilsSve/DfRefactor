    Object oGridMethodTransformSource is a cTestFixture
        Set psFunctionName to "TransformSource - method overrides"
    
        Object oWorker is a cDbGridTocDbCJGrid
        End_Object
    
        // Helper procedures
        Function RunTransform_i String[] asInput Returns Integer
            Integer iGrids
            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Function_Return iGrids
        End_Function
    
        Function GetOutput Returns String[]
            String[] asOut
            Get pasSource of oWorker to asOut
            Function_Return asOut
        End_Function
    
        // -----------------------------------------------------------------------
        // Clean rename: declaration and Forward Send renamed
        // -----------------------------------------------------------------------
    
        {Published = True}
        { Description = "Goto_Top_Row declaration is renamed to MoveToFirstRow" }
        Procedure GotoTopRow_DeclRenamed
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundNew bFoundOld
    
            Move "Object oGrid is a cDbGrid"       to asInput[0]
            Move "    Procedure Goto_Top_Row"      to asInput[1]
            Move "    End_Procedure"               to asInput[2]
            Move "End_Object"                      to asInput[3]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFoundNew
            Move False to bFoundOld
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] = "    Procedure MoveToFirstRow") Begin
                    Move True to bFoundNew
                End
                If (Lowercase(asOutput[iIdx]) contains "goto_top_row") Begin
                    Move True to bFoundOld
                End
            Loop
            Send Assert bFoundNew
            Send AssertFalse bFoundOld
        End_Procedure
    
        {Published = True}
        { Description = "Forward Send of old name is renamed inside the procedure body" }
        Procedure GotoTopRow_ForwardSendRenamed
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundNew bFoundOld
    
            Move "Object oGrid is a cDbGrid"            to asInput[0]
            Move "    Procedure Goto_Top_Row"           to asInput[1]
            Move "        Forward Send Goto_Top_Row"    to asInput[2]
            Move "    End_Procedure"                    to asInput[3]
            Move "End_Object"                           to asInput[4]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFoundNew
            Move False to bFoundOld
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] = "        Forward Send MoveToFirstRow") Begin
                    Move True to bFoundNew
                End
                If (Lowercase(asOutput[iIdx]) contains "goto_top_row") Begin
                    Move True to bFoundOld
                End
            Loop
            Send Assert bFoundNew
            Send AssertFalse bFoundOld
        End_Procedure
    
        {Published = True}
        { Description = "Down_Row declaration is renamed to MoveDownRow" }
        Procedure DownRow_DeclRenamed
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundNew
    
            Move "Object oGrid is a cDbGrid"  to asInput[0]
            Move "    Procedure Down_Row"     to asInput[1]
            Move "    End_Procedure"          to asInput[2]
            Move "End_Object"                 to asInput[3]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFoundNew
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] = "    Procedure MoveDownRow") Begin
                    Move True to bFoundNew
                End
            Loop
            Send Assert bFoundNew
        End_Procedure
    
        {Published = True}
        { Description = "Non-rename body lines pass through unchanged inside renamed procedure" }
        Procedure RenameProc_BodyPassThrough
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound
    
            Move "Object oGrid is a cDbGrid"             to asInput[0]
            Move "    Procedure Up_Row"                  to asInput[1]
            Move "        Send MyCustomMessage"          to asInput[2]
            Move "        Forward Send Up_Row"           to asInput[3]
            Move "    End_Procedure"                     to asInput[4]
            Move "End_Object"                            to asInput[5]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] = "        Send MyCustomMessage") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure
    
        // -----------------------------------------------------------------------
        // Legacy-only method: commented out with TODO
        // -----------------------------------------------------------------------
    
        {Published = True}
        { Description = "Fill_List declaration is commented out with a TODO hint" }
        Procedure FillList_CommentedOutWithHint
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundTodo bFoundCommented bFoundRaw
    
            Move "Object oGrid is a cDbGrid"       to asInput[0]
            Move "    Procedure Fill_List"         to asInput[1]
            Move "        Forward Send Fill_List"  to asInput[2]
            Move "    End_Procedure"               to asInput[3]
            Move "End_Object"                      to asInput[4]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFoundTodo
            Move False to bFoundCommented
            Move False to bFoundRaw
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "// todo:") Begin
                    Move True to bFoundTodo
                End
                If (Lowercase(asOutput[iIdx]) contains "// procedure fill_list") Begin
                    Move True to bFoundCommented
                End
                If (Trim(Lowercase(asOutput[iIdx])) = "procedure fill_list") Begin
                    Move True to bFoundRaw
                End
            Loop
            Send Assert bFoundTodo
            Send Assert bFoundCommented
            Send AssertFalse bFoundRaw
        End_Procedure
    
        {Published = True}
        { Description = "Body of Fill_List is also commented out" }
        Procedure FillList_BodyCommentedOut
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundBody bFoundEnd
    
            Move "Object oGrid is a cDbGrid"       to asInput[0]
            Move "    Procedure Fill_List"         to asInput[1]
            Move "        Forward Send Fill_List"  to asInput[2]
            Move "    End_Procedure"               to asInput[3]
            Move "End_Object"                      to asInput[4]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFoundBody
            Move False to bFoundEnd
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "// forward send fill_list") Begin
                    Move True to bFoundBody
                End
                If (Lowercase(asOutput[iIdx]) contains "// end_procedure") Begin
                    Move True to bFoundEnd
                End
            Loop
            Send Assert bFoundBody
            Send Assert bFoundEnd
        End_Procedure
    
        {Published = True}
        { Description = "Beginning_of_Data is commented out with no-equivalent TODO" }
        Procedure BeginningOfData_CommentedOut
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFoundTodo bFoundCommented
    
            Move "Object oGrid is a cDbGrid"           to asInput[0]
            Move "    Procedure Beginning_of_Data"     to asInput[1]
            Move "    End_Procedure"                   to asInput[2]
            Move "End_Object"                          to asInput[3]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFoundTodo
            Move False to bFoundCommented
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "// todo:") Begin
                    Move True to bFoundTodo
                End
                If (Lowercase(asOutput[iIdx]) contains "// procedure beginning_of_data") Begin
                    Move True to bFoundCommented
                End
            Loop
            Send Assert bFoundTodo
            Send Assert bFoundCommented
        End_Procedure
    
        // -----------------------------------------------------------------------
        // Unknown method override: passes through unchanged
        // -----------------------------------------------------------------------
    
        {Published = True}
        { Description = "An unknown method override (e.g. OnSomeEvent) passes through unchanged" }
        Procedure UnknownMethod_PassThrough
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound
    
            Move "Object oGrid is a cDbGrid"       to asInput[0]
            Move "    Procedure OnSomeEvent"       to asInput[1]
            Move "        Send DoSomething"        to asInput[2]
            Move "    End_Procedure"               to asInput[3]
            Move "End_Object"                      to asInput[4]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            Move False to bFound
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] = "    Procedure OnSomeEvent") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure
    
        // -----------------------------------------------------------------------
        // Blank line inserted before each procedure/function block
        // -----------------------------------------------------------------------
    
        {Published = True}
        { Description = "A blank line is inserted before a renamed procedure if not already blank" }
        Procedure BlankLine_BeforeRenamedProc
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bFound
    
            Move "Object oGrid is a cDbGrid"  to asInput[0]
            Move "    Set Size to 100 200"    to asInput[1]
            Move "    Procedure Goto_Top_Row" to asInput[2]
            Move "    End_Procedure"          to asInput[3]
            Move "End_Object"                 to asInput[4]
    
            Get RunTransform_i asInput to iGrids
            Get GetOutput            to asOutput
    
            // The line before "    Procedure MoveToFirstRow" should be blank
            Move False to bFound
            For iIdx from 1 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] = "    Procedure MoveToFirstRow" and asOutput[iIdx - 1] = "") Begin
                    Move True to bFound
                End
            Loop
            Send Assert bFound
        End_Procedure

    End_Object

