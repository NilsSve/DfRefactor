    Object oChangeZeroStringCommandToFunction is a cTestFixture
        Set psFunctionName to "ChangeZeroStringCommandToFunction"

        {Published = True}
        Procedure ChangeZeroStringCommandToFunction_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'ZeroString iLength to sParameter' to sLine
            Move 'Move (ZeroString(iLength)) to sParameter' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeZeroStringCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Literal integer length parameter.
        {Published = True}
        Procedure ChangeZeroStringCommandToFunction_2
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'ZeroString 10 to sBuffer' to sLine
            Move 'Move (ZeroString(10)) to sBuffer' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeZeroStringCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Leading indentation and end comment are preserved.
        {Published = True}
        Procedure ChangeZeroStringCommandToFunction_3
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    ZeroString iLength to sParameter // init' to sLine
            Move '    Move (ZeroString(iLength)) to sParameter // init' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeZeroStringCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // No ZeroString command present -- bChanged must be False.
        {Published = True}
        Procedure ChangeZeroStringCommandToFunction_4
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move sA to sB' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeZeroStringCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send Assert (bChanged = False)
        End_Procedure

    End_Object
