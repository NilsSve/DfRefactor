    // Unit tests for Win64PointerTruncation (the cWin64PointerTruncation worker's
    // AuditFile). It is REPORT-ONLY - asCode is never modified - and flags a
    // pointer-sized value moved into a 32-bit Integer/DWord:
    //   Move <Pointer/Address var or param> to <Integer/DWord var>
    //   Move (AddressOf(...))               to <Integer/DWord var>
    // Each test resets the lexer first (ClearFuncLibProperties, as the wrapper does
    // per file), creates the worker, runs the audit, and asserts the finding count.
    Object oWin64PointerTruncation is a cTestFixture
        Set psFunctionName to "Win64PointerTruncation"

        // Helper: reset the lexer, create the worker, audit one synthetic file,
        // return the finding count (asFindings comes back by reference).
        Function RunAudit String[] asCode String[] ByRef asFindings Returns Integer
            Handle  ho
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Get Create (RefClass(cWin64PointerTruncation)) to ho
            Get AuditFile of ho asCode (&asFindings) to iCount
            Send Destroy of ho
            Function_Return iCount
        End_Function

        // Pointer local -> Integer local: flagged.
        {Published = True}
        Procedure Win64PointerTruncation_PointerToInteger_Flagged
            String[] asCode asFindings
            Integer iCount
            Move "Procedure Foo"            to asCode[0]
            Move "    Pointer pBuf"         to asCode[1]
            Move "    Integer iHandle"      to asCode[2]
            Move "    Move pBuf to iHandle" to asCode[3]
            Move "End_Procedure"            to asCode[4]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 1)
        End_Procedure

        // Address local -> DWord local: flagged (Address is pointer-sized; DWord truncates).
        {Published = True}
        Procedure Win64PointerTruncation_AddressToDWord_Flagged
            String[] asCode asFindings
            Integer iCount
            Move "Procedure Foo"           to asCode[0]
            Move "    Address aPtr"        to asCode[1]
            Move "    DWord dwVal"         to asCode[2]
            Move "    Move aPtr to dwVal"  to asCode[3]
            Move "End_Procedure"           to asCode[4]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 1)
        End_Procedure

        // AddressOf(...) -> Integer: flagged.
        {Published = True}
        Procedure Win64PointerTruncation_AddressOfToInteger_Flagged
            String[] asCode asFindings
            Integer iCount
            Move "Procedure Foo"                       to asCode[0]
            Move "    String sBuf"                     to asCode[1]
            Move "    Integer iAddr"                   to asCode[2]
            Move "    Move (AddressOf(sBuf)) to iAddr" to asCode[3]
            Move "End_Procedure"                       to asCode[4]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 1)
        End_Procedure

        // Pointer PARAMETER -> Integer local: flagged (parameters are collected).
        {Published = True}
        Procedure Win64PointerTruncation_PointerParam_Flagged
            String[] asCode asFindings
            Integer iCount
            Move "Function Foo Pointer pIn Returns Integer" to asCode[0]
            Move "    Integer iOut"                         to asCode[1]
            Move "    Move pIn to iOut"                     to asCode[2]
            Move "End_Function"                             to asCode[3]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 1)
        End_Procedure

        // Integer -> Integer: NOT flagged (no pointer source).
        {Published = True}
        Procedure Win64PointerTruncation_IntToInt_NotFlagged
            String[] asCode asFindings
            Integer iCount
            Move "Procedure Foo"       to asCode[0]
            Move "    Integer iA"      to asCode[1]
            Move "    Integer iB"      to asCode[2]
            Move "    Move iA to iB"   to asCode[3]
            Move "End_Procedure"       to asCode[4]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 0)
        End_Procedure

        // Pointer -> Pointer: NOT flagged (destination is not a 32-bit Integer/DWord).
        {Published = True}
        Procedure Win64PointerTruncation_PointerToPointer_NotFlagged
            String[] asCode asFindings
            Integer iCount
            Move "Procedure Foo"      to asCode[0]
            Move "    Pointer pA"     to asCode[1]
            Move "    Pointer pB"     to asCode[2]
            Move "    Move pA to pB"  to asCode[3]
            Move "End_Procedure"      to asCode[4]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 0)
        End_Procedure

        // Scope isolation: a Pointer declared in method One must NOT be treated as a
        // pointer in method Two, so Two's "Move pBuf to iBuf" is NOT flagged.
        {Published = True}
        Procedure Win64PointerTruncation_ScopeIsolation_NotFlagged
            String[] asCode asFindings
            Integer iCount
            Move "Procedure One"          to asCode[0]
            Move "    Pointer pBuf"       to asCode[1]
            Move "End_Procedure"          to asCode[2]
            Move "Procedure Two"          to asCode[3]
            Move "    Integer iBuf"       to asCode[4]
            Move "    Move pBuf to iBuf"  to asCode[5]
            Move "End_Procedure"          to asCode[6]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 0)
        End_Procedure

    End_Object
