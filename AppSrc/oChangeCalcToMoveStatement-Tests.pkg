    Object oChangeCalcToMoveStatement is a cTestFixture
        Set psFunctionName to "ChangeCalcToMoveStatement"

        {Published = True}
        { Description = "Changes: 'Calc (iA * iB) to iC' to 'Move (iA * iB) to iC'" }
        Procedure ChangeCalcToMoveStatement_1
