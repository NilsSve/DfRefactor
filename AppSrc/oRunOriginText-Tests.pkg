// Unit tests for RunOriginText (cRefactorEngine.pkg) - the run-origin label shown in the
// summary log ("Run source:"). RunOriginText is a global, pure enum->label map, so the engine's
// peRunOrigin (set by each entry point; stamped eRunBatch by StartEngine for a /bm run) reads as
// a human-readable line in the saved summary.
Object oRunOriginText is a cTestFixture
    Set psFunctionName to "RunOriginText"

    {Published = True}
    Procedure RunOriginText_Manual
        Send AssertSAreEqual "Manual selection (Start Refactoring)" (RunOriginText(eRunManual))
    End_Procedure

    {Published = True}
    Procedure RunOriginText_Plan
        Send AssertSAreEqual "Refactor Plan (from Analyze)" (RunOriginText(eRunPlan))
    End_Procedure

    {Published = True}
    Procedure RunOriginText_Batch
        Send AssertSAreEqual "Batch mode (command-line)" (RunOriginText(eRunBatch))
    End_Procedure

    {Published = True}
    Procedure RunOriginText_TestBench
        Send AssertSAreEqual "Test Bench" (RunOriginText(eRunTestBench))
    End_Procedure

    // An unknown / uninitialized origin must fall back to the safe "Manual" label, never blank.
    {Published = True}
    Procedure RunOriginText_UnknownDefaultsToManual
        Send AssertSAreEqual "Manual selection (Start Refactoring)" (RunOriginText(99))
    End_Procedure
End_Object
