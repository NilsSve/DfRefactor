    Object oChangeMidCommandToFunction is a cTestFixture
        Set psFunctionName to "ChangeMidCommandToFunction"

        // Mid {source} to {dest} {length} {position} -> Move (Mid(source, length, position)) to dest
        { Published = True }
        Procedure ChangeMidCommandToFunction_NumericArgs
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Mid sText to sResult 5 3' to sLine
            Move 'Move (Mid(sText, 5, 3)) to sResult' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeMidCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        { Published = True }
        Procedure ChangeMidCommandToFunction_VariableArgs
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Mid sPath to sDir iLen iStart' to sLine
            Move 'Move (Mid(sPath, iLen, iStart)) to sDir' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeMidCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // A parenthesised expression argument must stay intact as a single token.
        { Published = True }
        Procedure ChangeMidCommandToFunction_ExpressionArg
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Mid sValue to sOut (iEnd - iStart) iStart' to sLine
            Move 'Move (Mid(sValue, (iEnd - iStart), iStart)) to sOut' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeMidCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Leading indentation is preserved.
        { Published = True }
        Procedure ChangeMidCommandToFunction_PreservesIndent
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Mid sText to sResult 2 1' to sLine
            Move '    Move (Mid(sText, 2, 1)) to sResult' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeMidCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Code before the command (the "nose") is kept; Move is inserted after it.
        { Published = True }
        Procedure ChangeMidCommandToFunction_KeepsLineNose
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (bFlag) Mid sVal to sOut 3 2' to sLine
            Move 'If (bFlag) Move (Mid(sVal, 3, 2)) to sOut' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeMidCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // A line with no Mid command is returned unchanged and reports no change.
        { Published = True }
        Procedure ChangeMidCommandToFunction_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move x to y' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeMidCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Move x to y' sLine
        End_Procedure

        // Regression: variable/field names with underscores must NOT be mistaken for string
        // constants (the _IsStringArrayConstant bug that blanked the names to '').
        { Published = True }
        Procedure ChangeMidCommandToFunction_UnderscoreNames
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Mid Functions.Function_NAME to sF_Name 30 1' to sLine
            Move 'Move (Mid(Functions.Function_NAME, 30, 1)) to sF_Name' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeMidCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

    End_Object
