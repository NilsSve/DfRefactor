    Object oChangeIncrToIncrement is a cTestFixture
        Set psFunctionName to "ChangeIncrToIncrement"

        // Incr X -> Increment X
        { Published = True }
        Procedure ChangeIncrToIncrement_BasicSwap
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Incr iCount' to sLine
            Move 'Increment iCount' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIncrToIncrement of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Leading indentation is preserved.
        { Published = True }
        Procedure ChangeIncrToIncrement_PreservesIndent
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Incr iCount' to sLine
            Move '    Increment iCount' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIncrToIncrement of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Code before the command (the "nose") is kept.
        { Published = True }
        Procedure ChangeIncrToIncrement_KeepsLineNose
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (bFlag) Incr iCount' to sLine
            Move 'If (bFlag) Increment iCount' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIncrToIncrement of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Already-modern Increment is left untouched (no double-swap; whole-token guard).
        { Published = True }
        Procedure ChangeIncrToIncrement_AlreadyModern
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Increment iCount' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIncrToIncrement of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Increment iCount' sLine
        End_Procedure

        // A variable that merely contains "Incr" is not the command -> unchanged.
        { Published = True }
        Procedure ChangeIncrToIncrement_NotASubstring
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move iIncrStep to x' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIncrToIncrement of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Move iIncrStep to x' sLine
        End_Procedure

    End_Object
