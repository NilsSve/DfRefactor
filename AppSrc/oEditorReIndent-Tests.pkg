    Object oEditorReIndent is a cTestFixture
        Set psFunctionName to "EditorReIndent"

        {Published = True}
        Procedure EditorReIndent_1
            String sLine sExpected sParam
            Boolean bChanged bOK
            String[] asData
            Handle hoEditor

            Get phoEditor of ghoFuncLib to hoEditor
            If (hoEditor = 0) Procedure_Return  // Console mode has no GUI Scintilla editor; skip this test.
            Move "    If (Found) Begin"     to asData[0]
            Move "    Move False to Found"  to asData[1]
            Move "    End"                  to asData[2]
            Get WriteDataToEditor of hoEditor asData to bOK
            Get EditorReIndent of ghoFuncLib (&asData) to bChanged
            If (bChanged = True) Begin
                // See oEditorNormalizeCase above for comment:
                Get EditorDataAsStringArray of hoEditor to asData
                Move (asData[0] = "If (Found) Begin") to bOK
                If (bOK) Begin
                    Move (asData[1] = "    Move False to Found") to bOK
                End
                If (bOK) Begin
                    Move (asData[2] = "End") to bOK
                End
            End
            Send Assert (bChanged and bOK)
        End_Procedure


        // Passing sParameter = "2" must apply a 2-space indent; also exercises the
        // piTabSize code path that the no-argument call leaves untested.
        {Published = True}
        Procedure EditorReIndent_WithParameter
            Boolean bChanged bOK
            String[] asData
            Handle hoEditor

            Get phoEditor of ghoFuncLib to hoEditor
            If (hoEditor = 0) Procedure_Return  // Console mode has no GUI Scintilla editor; skip this test.
            Move "    If (Found) Begin"     to asData[0]
            Move "    Move False to Found"  to asData[1]
            Move "    End"                  to asData[2]
            Get WriteDataToEditor of hoEditor asData to bOK
            Get EditorReIndent of ghoFuncLib (&asData) "2" to bChanged
            Send Assert bChanged
            If (bChanged = True) Begin
                Get EditorDataAsStringArray of hoEditor to asData
            End
            Send AssertSAreEqual "If (Found) Begin"      asData[0]
            Send AssertSAreEqual "  Move False to Found" asData[1]
            Send AssertSAreEqual "End"                   asData[2]
            Set piTabSize of hoEditor to 4
        End_Procedure

        // Deeply nested block (3 levels): all levels are re-indented correctly.
        {Published = True}
        Procedure EditorReIndent_DeepNesting
            Boolean bChanged bOK
            String[] asData
            Handle hoEditor

            Get phoEditor of ghoFuncLib to hoEditor
            If (hoEditor = 0) Procedure_Return  // Console mode has no GUI Scintilla editor; skip this test.
            Move "        Procedure DoSomething"           to asData[0]
            Move "            If (bFound) Begin"           to asData[1]
            Move "                For iCount from 0 to 9" to asData[2]
            Move "                    Move iCount to iX"  to asData[3]
            Move "                Loop"                   to asData[4]
            Move "            End"                        to asData[5]
            Move "        End_Procedure"                  to asData[6]
            Get WriteDataToEditor of hoEditor asData to bOK
            Get EditorReIndent of ghoFuncLib (&asData) to bChanged
            Send Assert bChanged
            If (bChanged = True) Begin
                Get EditorDataAsStringArray of hoEditor to asData
            End
            Send AssertSAreEqual "Procedure DoSomething"           asData[0]
            Send AssertSAreEqual "    If (bFound) Begin"           asData[1]
            Send AssertSAreEqual "        For iCount from 0 to 9" asData[2]
            Send AssertSAreEqual "            Move iCount to iX"  asData[3]
            Send AssertSAreEqual "        Loop"                   asData[4]
            Send AssertSAreEqual "    End"                        asData[5]
            Send AssertSAreEqual "End_Procedure"                  asData[6]
        End_Procedure

    End_Object
