    Object oChangeReplaceCommandToFunction is a cTestFixture
        Set psFunctionName to "ChangeReplaceCommandToFunction"

        {Published = True}
        Procedure ChangeReplaceCommandToFunction_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '  Replace  "A"  In  sNameX  With "B" // End comment' to sLine
            Move '  Move (Replace("A",sNameX,"B")) to sNameX // End comment' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeReplaceCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeReplaceCommandToFunction_2
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '  Replace ".txt" In sVal1 With ("_" + (Trim(sVal2)))' to sLine
            Move '  Move (Replace(".txt",sVal1,("_" + (Trim(sVal2))))) to sVal1' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeReplaceCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Line with no Replace command must be returned unchanged and return False.
        {Published = True}
        Procedure ChangeReplaceCommandToFunction_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move x to y" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeReplaceCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "Move x to y" sLine
        End_Procedure

        // Variable arguments (not string literals); also verifies bChanged = True.
        {Published = True}
        Procedure ChangeReplaceCommandToFunction_VariableArgs
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Replace sOld in sText With sNew" to sLine
            Move "Move (Replace(sOld,sText,sNew)) to sText" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeReplaceCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

    End_Object
