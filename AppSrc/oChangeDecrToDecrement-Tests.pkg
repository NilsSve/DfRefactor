    Object oChangeDecrToDecrement is a cTestFixture
        Set psFunctionName to "ChangeDecrToDecrement"

        // Decr X -> Decrement X
        { Published = True }
        Procedure ChangeDecrToDecrement_BasicSwap
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Decr iCount' to sLine
            Move 'Decrement iCount' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeDecrToDecrement of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Leading indentation is preserved.
        { Published = True }
        Procedure ChangeDecrToDecrement_PreservesIndent
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Decr iCount' to sLine
            Move '    Decrement iCount' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeDecrToDecrement of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Code before the command (the "nose") is kept.
        { Published = True }
        Procedure ChangeDecrToDecrement_KeepsLineNose
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (bFlag) Decr iCount' to sLine
            Move 'If (bFlag) Decrement iCount' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeDecrToDecrement of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Already-modern Decrement is left untouched (no double-swap; whole-token guard).
        { Published = True }
        Procedure ChangeDecrToDecrement_AlreadyModern
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Decrement iCount' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeDecrToDecrement of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Decrement iCount' sLine
        End_Procedure

        // A variable that merely contains "Decr" is not the command -> unchanged.
        { Published = True }
        Procedure ChangeDecrToDecrement_NotASubstring
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move iDecrTotal to x' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeDecrToDecrement of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Move iDecrTotal to x' sLine
        End_Procedure

    End_Object
