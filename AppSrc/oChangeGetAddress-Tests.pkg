    Object oChangeGetAddress is a cTestFixture
        Set psFunctionName to "ChangeGetAddress"

        {Published = True}
        Procedure GetAddress_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    GetAddress of sString to pMyPointer" to sLine
            Move "    Move (AddressOf(sString)) to pMyPointer" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeGetAddress of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure GetAddress_2
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move " Function GetAddress Returns String" to sLine
            Move " Function GetAddress Returns String" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeGetAddress of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure GetAddress_3
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move " Entry_Item (GetAddress(oCustomer_DD))" to sLine
            Move " Entry_Item (GetAddress(oCustomer_DD))" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeGetAddress of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure GetAddress_4
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "String structBytesRead      //Actual bytes read - Should be integer but getAddress cannot find " to sLine
            Move "String structBytesRead      //Actual bytes read - Should be integer but getAddress cannot find " to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeGetAddress of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Regression (2026-06-10, cWinFunc.pkg): a GetAddress command INSIDE a Function
        // body must be converted. The old guard bailed on the lexer's sticky
        // bIsInFunction/bIsInProcedure scope flags - true for every line inside a method
        // body, i.e. exactly where GetAddress lives - so real files were never changed.
        // Single-line fixtures carry no scope, which is why the suite stayed green: this
        // test tokenizes the Function declaration FIRST so the in-body flag is genuinely
        // set when the GetAddress line is processed.
        {Published = True}
        Procedure GetAddress_InsideFunctionBody
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function MyFunc Returns Pointer" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Move "    GetAddress of sCharacter to pCharacter" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeGetAddress of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual "    Move (AddressOf(sCharacter)) to pCharacter" sLine
            Send ClearFuncLibProperties of ghoFuncLib
        End_Procedure

        // The no-"of" variant has no OfStatement - a rewrite would emit a broken
        // "Move (AddressOf())" - so it is deliberately left untouched.
        {Published = True}
        Procedure GetAddress_NoOfVariant_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    GetAddress sCharacter to pCharacter" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeGetAddress of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "    GetAddress sCharacter to pCharacter" sLine
        End_Procedure

    End_Object
