    // Unit tests for Win64WindowLongFunctions - the line-by-line (eStandardFunction)
    // refactor that modernizes the Win32 "long" calls that truncate pointers on 64-bit:
    //   GetWindowLong(x) -> GetWindowLongPtr(x)   SetWindowLong(x) -> SetWindowLongPtr(x)
    //   GetClassLong(x)  -> GetClassLongPtr(x)    SetClassLong(x)  -> SetClassLongPtr(x)
    // Each test sets one source line, tokenizes it (Get Tokenizer ... populates the
    // funclib's pTokenizer, which the function reads for the masked overstrike), then
    // calls the function and checks the result. It is whole-word + masked: an already-
    // converted *Ptr call, and a call inside a string literal, are left untouched.
    Object oWin64WindowLongFunctions is a cTestFixture
        Set psFunctionName to "Win64WindowLongFunctions"

        // GetWindowLong(x) -> GetWindowLongPtr(x)
        {Published = True}
        Procedure Win64WindowLongFunctions_GetWindowLong_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (GetWindowLong(hWnd, GWL_STYLE)) to iStyle" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64WindowLongFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Move (GetWindowLongPtr(hWnd, GWL_STYLE)) to iStyle" sLine
        End_Procedure

        // SetClassLong(x) -> SetClassLongPtr(x)
        {Published = True}
        Procedure Win64WindowLongFunctions_SetClassLong_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (SetClassLong(hWnd, GCL_HICON, hIcon)) to hOld" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64WindowLongFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Move (SetClassLongPtr(hWnd, GCL_HICON, hIcon)) to hOld" sLine
        End_Procedure

        // Idempotent: an already-converted *Ptr call must NOT be re-wrapped - the left
        // word-boundary plus the "Ptr" suffix stop "GetWindowLong" inside "GetWindowLongPtr"
        // from matching.
        {Published = True}
        Procedure Win64WindowLongFunctions_AlreadyConverted_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (GetWindowLongPtr(hWnd, GWL_STYLE)) to iStyle" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64WindowLongFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual "    Move (GetWindowLongPtr(hWnd, GWL_STYLE)) to iStyle" sLine
        End_Procedure

        // Masked: a GetWindowLong( inside a string literal must be left untouched.
        {Published = True}
        Procedure Win64WindowLongFunctions_InsideString_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move '    Move "see GetWindowLong(x) here" to sNote' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64WindowLongFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual '    Move "see GetWindowLong(x) here" to sNote' sLine
        End_Procedure

        // Multiple different calls on one line are all converted in one pass.
        {Published = True}
        Procedure Win64WindowLongFunctions_MultiplePerLine_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (GetWindowLong(hWnd, n) * GetClassLong(hWnd, m)) to iX" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64WindowLongFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Move (GetWindowLongPtr(hWnd, n) * GetClassLongPtr(hWnd, m)) to iX" sLine
        End_Procedure

    End_Object
