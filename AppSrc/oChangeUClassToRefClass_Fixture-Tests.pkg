    Object oChangeUClassToRefClass_Fixture is a cTestFixture
        Set psFunctionName to "ChangeUClassToRefClass"

        {Published = True}
        Procedure ChangeUClassToRefClass_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    Get Create U_Array to hArray" to sLine
            Move "    Get Create (RefClass(Array)) to hArray" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeUClassToRefClass of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeUClassToRefClass_2
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    Get    Create   U_Array    to     hArray" to sLine
            Move "    Get    Create   (RefClass(Array))    to     hArray" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeUClassToRefClass of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Line with no U_ class reference must be returned unchanged and return False.
        {Published = True}
        Procedure ChangeUClassToRefClass_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move x to y" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeUClassToRefClass of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "Move x to y" sLine
        End_Procedure

        // Different class name; also verifies bChanged = True.
        {Published = True}
        Procedure ChangeUClassToRefClass_DifferentClassName
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Get Create U_cObject to hObj" to sLine
            Move "Get Create (RefClass(cObject)) to hObj" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeUClassToRefClass of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // U_ inside a comment must not be converted.
        {Published = True}
        Procedure ChangeUClassToRefClass_InComment
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move 1 to i // Get Create U_Array to h" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeUClassToRefClass of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "Move 1 to i // Get Create U_Array to h" sLine
        End_Procedure

        // U_ inside a string literal must not be converted.
        {Published = True}
        Procedure ChangeUClassToRefClass_InString
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move "create U_Class" to sLine' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeUClassToRefClass of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Move "create U_Class" to sLine' sLine
        End_Procedure

    End_Object
