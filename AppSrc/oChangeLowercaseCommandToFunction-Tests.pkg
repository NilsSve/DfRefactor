    // Unit tests for ChangeLowercaseCommandToFunction - "Lowercase <arg> to <dest>" ->
    // "Move (Lowercase(<arg>)) to <dest>" (4531 obsolete-string-command family).
    Object oChangeLowercaseCommandToFunction is a cTestFixture
        Set psFunctionName to "ChangeLowercaseCommandToFunction"

        {Published = True}
        Procedure ChangeLowercaseCommandToFunction_InPlace
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Lowercase sVal to sVal" to sLine
            Move "Move (Lowercase(sVal)) to sVal" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLowercaseCommandToFunction of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // Real-world casing ("LowerCase") + indentation; the canonical "Lowercase" is emitted.
        Procedure ChangeLowercaseCommandToFunction_CamelCaseIndent
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    LowerCase sEmail to sEmail" to sLine
            Move "    Move (Lowercase(sEmail)) to sEmail" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLowercaseCommandToFunction of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // A table.field argument survives intact (position-based extraction, not a single-token grab).
        Procedure ChangeLowercaseCommandToFunction_TableField
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Lowercase USER.EMAIL to sMail" to sLine
            Move "Move (Lowercase(USER.EMAIL)) to sMail" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLowercaseCommandToFunction of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // An existing Lowercase() function CALL is left untouched (keyword not followed by whitespace).
        Procedure ChangeLowercaseCommandToFunction_CallUntouched
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move (Lowercase(sVal)) to sX" to sLine
            Move "Move (Lowercase(sVal)) to sX" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLowercaseCommandToFunction of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

    End_Object
