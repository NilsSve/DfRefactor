    Object oTypeToStructReport is a cTestFixture
        Set psFunctionName to "TypeToStructReport"

        // A simple Type with two Integer fields -> Struct with two Integer members.
        { Published = True }
        Procedure TypeToStructReport_BasicTwoFields
            String[] asBlock asResult
            Move 'Type tPoint'        to asBlock[0]
            Move 'Field x AS Integer' to asBlock[1]
            Move 'Field y AS Integer' to asBlock[2]
            Move 'End_Type'           to asBlock[3]
            Get _TypeDefToStruct of ghoFuncLib asBlock to asResult
            Send Assert (SizeOfArray(asResult) = 4)
            Send AssertSAreEqual 'Struct tPoint' asResult[0]
            Send AssertSAreEqual '    Integer iX' asResult[1]
            Send AssertSAreEqual '    Integer iY' asResult[2]
            Send AssertSAreEqual 'End_Struct'     asResult[3]
        End_Procedure

        // A sized String and an array field -> sized members: String 30 -> String[30],
        // Integer 5 -> Integer[5] (the byte layout is preserved).
        { Published = True }
        Procedure TypeToStructReport_SizedAndArrayFields
            String[] asBlock asResult
            Move 'Type tRec'                to asBlock[0]
            Move 'Field sName AS String 30' to asBlock[1]
            Move 'Field aVals AS Integer 5' to asBlock[2]
            Move 'End_Type'                 to asBlock[3]
            Get _TypeDefToStruct of ghoFuncLib asBlock to asResult
            Send Assert (SizeOfArray(asResult) = 4)
            Send AssertSAreEqual 'Struct tRec'         asResult[0]
            Send AssertSAreEqual '    String[30] sName' asResult[1]
            Send AssertSAreEqual '    Integer[5] iAVals' asResult[2]
            Send AssertSAreEqual 'End_Struct'          asResult[3]
        End_Procedure

        // Comments and other non-Type/Field/End_Type lines pass through unchanged, so the
        // worksheet keeps the author's notes and flags anything it could not parse.
        { Published = True }
        Procedure TypeToStructReport_PassesThroughComments
            String[] asBlock asResult
            Move 'Type tX'            to asBlock[0]
            Move '    // a note'      to asBlock[1]
            Move 'Field a AS Integer' to asBlock[2]
            Move 'End_Type'           to asBlock[3]
            Get _TypeDefToStruct of ghoFuncLib asBlock to asResult
            Send Assert (SizeOfArray(asResult) = 4)
            Send AssertSAreEqual 'Struct tX'     asResult[0]
            Send AssertSAreEqual '    // a note'  asResult[1]
            Send AssertSAreEqual '    Integer iA' asResult[2]
            Send AssertSAreEqual 'End_Struct'     asResult[3]
        End_Procedure

        // Finds every Type...End_Type definition in a file's lines (powers the package catalog).
        { Published = True }
        Procedure TypeToStructReport_CatalogsTypeDefs
            String[] asLines
            tTypeDef[] aDefs
            Move 'Use Foo.pkg'          to asLines[0]
            Move 'Type tA'              to asLines[1]
            Move 'Field x AS Integer'   to asLines[2]
            Move 'End_Type'             to asLines[3]
            Move 'Procedure Bar'        to asLines[4]
            Move 'Type tB'              to asLines[5]
            Move 'Field s AS String 10' to asLines[6]
            Move 'End_Type'             to asLines[7]
            Get _TypeDefsFromLines of ghoFuncLib asLines to aDefs
            Send Assert (SizeOfArray(aDefs) = 2)
            Send AssertSAreEqual 'tA' aDefs[0].sName
            Send Assert (SizeOfArray(aDefs[0].asBlock) = 3)
            Send AssertSAreEqual 'tB' aDefs[1].sName
        End_Procedure

        // Pulls the used Type names out of the accessors (ZeroType operand + At <type>.<field>),
        // de-duplicating repeats of the same type.
        { Published = True }
        Procedure TypeToStructReport_ExtractsUsedTypeNames
            String[] asLines asUsed
            Move 'ZeroType tTcItem to sTcItem'                 to asLines[0]
            Move 'Put TCIF_TEXT to sTcItem At tTcItem.mask'    to asLines[1]
            Move 'Put lpszText to sTcItem At tTcItem.pszText'  to asLines[2]
            Move 'Move 1 to x'                                 to asLines[3]
            Move 'Size_of_Field tOther fld to iSz'             to asLines[4]
            Get _UsedTypeNamesFromLines of ghoFuncLib asLines to asUsed
            Send Assert (SizeOfArray(asUsed) = 2)
            Send Assert (SearchArray("tTcItem", asUsed, Desktop, RefFunc(DFSTRICMP)) <> -1)
            Send Assert (SearchArray("tOther", asUsed, Desktop, RefFunc(DFSTRICMP)) <> -1)
        End_Procedure

        // PART 2 suggestion: a GetBuff field-read -> a direct Struct member Move, with the member
        // prefixed to match PART 1 (message -> iMessage, looked up in the catalog).
        { Published = True }
        Procedure TypeToStructReport_SuggestsGetBuffRead
            String[] asWords
            tTypeDef[] aCatalog
            String sSuggest
            Move 'tPrMsg' to aCatalog[0].sName
            Move 'Type tPrMsg'                         to aCatalog[0].asBlock[0]
            Move '    Field tPrMsg.message as Integer' to aCatalog[0].asBlock[1]
            Move 'End_Type'                            to aCatalog[0].asBlock[2]
            Get _SplitSourceWords of ghoFuncLib 'GetBuff from sMsg At tPrMsg.message to iPendingMessage' to asWords
            Get _SuggestStructLine of ghoFuncLib asWords aCatalog to sSuggest
            Send AssertSAreEqual 'Move TheData.iMessage to iPendingMessage' sSuggest
        End_Procedure

        // With the field's Type NOT in the catalog, the suggestion falls back to the bare field name.
        { Published = True }
        Procedure TypeToStructReport_SuggestFallsBackWithoutCatalog
            String[] asWords
            tTypeDef[] aCatalog
            String sSuggest
            Get _SplitSourceWords of ghoFuncLib 'GetBuff from sMsg At tPrMsg.message to iPendingMessage' to asWords
            Get _SuggestStructLine of ghoFuncLib asWords aCatalog to sSuggest
            Send AssertSAreEqual 'Move TheData.message to iPendingMessage' sSuggest
        End_Procedure

        // A Put field-write -> Move <src> to TheData.<prefixed field>.
        { Published = True }
        Procedure TypeToStructReport_SuggestsPutWrite
            String[] asWords
            tTypeDef[] aCatalog
            String sSuggest
            Move 'tTcItem' to aCatalog[0].sName
            Move 'Type tTcItem'                      to aCatalog[0].asBlock[0]
            Move '    Field tTcItem.mask as Integer' to aCatalog[0].asBlock[1]
            Move 'End_Type'                          to aCatalog[0].asBlock[2]
            Get _SplitSourceWords of ghoFuncLib 'Put TCIF_TEXT to sTcItem At tTcItem.mask' to asWords
            Get _SuggestStructLine of ghoFuncLib asWords aCatalog to sSuggest
            Send AssertSAreEqual 'Move TCIF_TEXT to TheData.iMask' sSuggest
        End_Procedure

        // ArrayPut <val> to <arr> At <Type>.<field> <idx> -> a Move into a Struct[] element, with the
        // field prefixed from the catalog (message -> iMessage).
        { Published = True }
        Procedure TypeToStructReport_SuggestsArrayPut
            String[] asWords
            tTypeDef[] aCatalog
            String sSuggest
            Move 'tPrMsg' to aCatalog[0].sName
            Move 'Type tPrMsg'                         to aCatalog[0].asBlock[0]
            Move '    Field tPrMsg.message as Integer' to aCatalog[0].asBlock[1]
            Move 'End_Type'                            to aCatalog[0].asBlock[2]
            Get _SplitSourceWords of ghoFuncLib 'ArrayPut iVal TO aMsg AT tPrMsg.message 3' to asWords
            Get _SuggestStructLine of ghoFuncLib asWords aCatalog to sSuggest
            Send Assert (sSuggest contains "Move iVal to TheData[i].iMessage")
        End_Procedure

        // ZeroType -> the buffer becomes a (zeroed) Struct local; the suggestion names Type + buffer.
        { Published = True }
        Procedure TypeToStructReport_SuggestsZeroTypeAsStructDecl
            String[] asWords
            tTypeDef[] aCatalog
            String sSuggest
            Get _SplitSourceWords of ghoFuncLib 'ZeroType tTcItem to sTcItem' to asWords
            Get _SuggestStructLine of ghoFuncLib asWords aCatalog to sSuggest
            Send Assert (sSuggest contains "tTcItem TheData")
            Send Assert (sSuggest contains "Struct local")
            Send Assert (sSuggest contains "sTcItem -> TheData")
        End_Procedure

        // A non-accessor line (or one with no <Type>.<field>) yields no suggestion.
        { Published = True }
        Procedure TypeToStructReport_NoSuggestionForNonAccessor
            String[] asWords
            tTypeDef[] aCatalog
            String sSuggest
            Get _SplitSourceWords of ghoFuncLib 'Move 1 to x' to asWords
            Get _SuggestStructLine of ghoFuncLib asWords aCatalog to sSuggest
            Send AssertSAreEqual '' sSuggest
        End_Procedure

        // _FieldAfterDot drops the Type prefix; a token with no dot yields "".
        { Published = True }
        Procedure TypeToStructReport_FieldAfterDot
            String sField
            Get _FieldAfterDot of ghoFuncLib 'tPrMsg.message' to sField
            Send AssertSAreEqual 'message' sField
            Get _FieldAfterDot of ghoFuncLib 'noDotHere' to sField
            Send AssertSAreEqual '' sField
        End_Procedure

        // Older type-first field syntax ("<datatype> <TypeName>.<field>", e.g. a Win32 MSG Type) ->
        // clean Struct members: the "<TypeName>." byte-offset prefix is stripped. Regression for the
        // tPrMsg report that came through as "Handle tPrMsg.hwnd".
        { Published = True }
        Procedure TypeToStructReport_OlderTypeFirstSyntax
            String[] asBlock asResult
            Move 'Type tPrMsg'               to asBlock[0]
            Move '    Handle tPrMsg.hwnd'     to asBlock[1]
            Move '    Integer tPrMsg.message' to asBlock[2]
            Move '    Pointer tPrMsg.pt'      to asBlock[3]
            Move 'End_Type'                  to asBlock[4]
            Get _TypeDefToStruct of ghoFuncLib asBlock to asResult
            Send Assert (SizeOfArray(asResult) = 5)
            Send AssertSAreEqual 'Struct tPrMsg'      asResult[0]
            Send AssertSAreEqual '    Handle hwnd'     asResult[1]
            Send AssertSAreEqual '    Integer iMessage' asResult[2]
            Send AssertSAreEqual '    Pointer pt'       asResult[3]
            Send AssertSAreEqual 'End_Struct'         asResult[4]
        End_Procedure

        // The "Field <TypeName>.<field> as <type>" form (the real tPrMsg syntax) -> clean Hungarian
        // members. Regression for "Handle tPrMsg.hwnd" coming through with the prefix.
        { Published = True }
        Procedure TypeToStructReport_FieldDottedSyntax
            String[] asBlock asResult
            Move 'Type tPrMsg'                         to asBlock[0]
            Move '    Field tPrMsg.hwnd    as Handle'  to asBlock[1]
            Move '    Field tPrMsg.message as Integer' to asBlock[2]
            Move '    Field tPrMsg.pt      as Pointer' to asBlock[3]
            Move 'End_Type'                           to asBlock[4]
            Get _TypeDefToStruct of ghoFuncLib asBlock to asResult
            Send Assert (SizeOfArray(asResult) = 5)
            Send AssertSAreEqual 'Struct tPrMsg'       asResult[0]
            Send AssertSAreEqual '    Handle hwnd'      asResult[1]
            Send AssertSAreEqual '    Integer iMessage' asResult[2]
            Send AssertSAreEqual '    Pointer pt'       asResult[3]
            Send AssertSAreEqual 'End_Struct'          asResult[4]
        End_Procedure

        // _HungarianMember: prefix by type with the first letter upper-cased; skip when already
        // prefixed; unmapped type -> bare name.
        { Published = True }
        Procedure TypeToStructReport_HungarianMember
            String s
            Get _HungarianMember of ghoFuncLib 'Integer' 'message' to s
            Send AssertSAreEqual 'iMessage' s
            Get _HungarianMember of ghoFuncLib 'Handle' 'hwnd' to s
            Send AssertSAreEqual 'hwnd' s
            Get _HungarianMember of ghoFuncLib 'DWord' 'Time' to s
            Send AssertSAreEqual 'dwTime' s
            Get _HungarianMember of ghoFuncLib 'NoSuchType' 'foo' to s
            Send AssertSAreEqual 'foo' s
        End_Procedure

        // _ParseTypeField: both legacy field forms parse to (bareName, dataType); a non-field -> False.
        { Published = True }
        Procedure TypeToStructReport_ParseTypeField
            String sBare sDt sCt
            Boolean b
            Get _ParseTypeField of ghoFuncLib 'Field tPrMsg.hwnd as Handle' (&sBare) (&sDt) (&sCt) to b
            Send Assert (b = True)
            Send AssertSAreEqual 'hwnd'   sBare
            Send AssertSAreEqual 'Handle' sDt
            Get _ParseTypeField of ghoFuncLib '    Integer tMsg.message' (&sBare) (&sDt) (&sCt) to b
            Send Assert (b = True)
            Send AssertSAreEqual 'message' sBare
            Send AssertSAreEqual 'Integer' sDt
            Get _ParseTypeField of ghoFuncLib '// just a comment' (&sBare) (&sDt) (&sCt) to b
            Send Assert (b = False)
        End_Procedure

        // A whole-line comment yields NO source words, so its prose is never harvested as a Type name
        // (the comment "...no rounding at all." had been mis-read as the Type "all"). Regression for
        // the false-positive "--- all (definition not found) ---" PART 1 row.
        { Published = True }
        Procedure TypeToStructReport_WholeLineCommentNotTokenized
            String[] asWords asLines asUsed
            Get _SplitSourceWords of ghoFuncLib '//   a value will perform no rounding at all.  A zero' to asWords
            Send Assert (SizeOfArray(asWords) = 0)
            Move '//   a value will perform no rounding at all.  A zero' to asLines[0]
            Get _UsedTypeNamesFromLines of ghoFuncLib asLines to asUsed
            Send Assert (SizeOfArray(asUsed) = 0)
        End_Procedure

    End_Object
