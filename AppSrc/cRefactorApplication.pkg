Class cRefactorApplication is a cRDCApplication

    Import_Class_Protocol cCompileMixin

    Procedure Construct_Object
        String sVal
        Forward Send Construct_Object

        Send Define_cCompileMixin

        Property Integer piBackupDaysOverwriteCycle 2

        // ProgressTick state. See ProgressTick / ProgressTickStart below.
        {Visibility=Private}
        Property Integer private.piTickThresholdMs 100
        {Visibility=Private}
        Property Integer private.piLastTickCount 0
        {Visibility=Private}
        Property Boolean private.pbCancelRequested False

        {Visibility=Private}
        Property String private.psFileCompareApp
        {Visibility=Private}
        Property String private.psStarZenSourceExplorer
        {Visibility=Private}
        Property Integer private.piToolbarIconSize 0
        {Visibility=Private}
        Property Integer private.peTabpagePosition xtpTabPositionLeft
        {Visibility=Private}
        Property String private.psGridRowBackgroundColor 0
        {Visibility=Private}
        Property Boolean private.pbWorkspaceMode True
        {Visibility=Private}
        Property Integer private.piActiveView -1
        {Visibility=Private}
        Property Handle private.phoActiveView -1     
        {Visibility=Private}
        Property tSCLanguage pSCLanguage
        {Visibility=Private}    
        Property String private_psHomePath ""
        
        {Visibility=Public}
        Property Handle phoFolderSelHeaDD
        {Visibility=Public}
        Property String psCompiler 
        {Visibility=Public}
        Property String psCompOpt CS_CompOptions
        {Visibility=Public}
        Property String psUserName ""
        {Visibility=Public}
        Property Handle phoEditorView 0
        {Visibility=Public}
        Property Handle phoRefactorView 0
        {Visibility=Public}
        Property Handle phoEditor 0
        {Visibility=Public}
        Property String psCurrentSourceFileName ""

        Property Boolean pbBatchMode False

        // Zero based. Note: If this is changed, the number of cCmdLnkButton's in the
        //                   SelectWorkspace.dg also needs to change.
        Property Integer piWorkspaceItems 9 
        Property String[] pasSelectedFolders
        
        // Workspace-state snapshots. Replace the older psOrg* / psStartup*
        // scalars; see tWorkspacePaths in RefactorConstants.h.pkg for fields.
        //   pOrgWS    - DFRefactor's OWN workspace at startup. Captured
        //               once in End_Construct_Object. Used by
        //               RestoreActiveFilelist and UpdateDFOpenPath to put
        //               state back the way it was after a target run.
        //   pTargetWS - The user-selected target workspace. Refreshed by
        //               UpdateDFOpenPath on every Set psSWSFile; all members
        //               are "" when no target is selected (the "no target"
        //               sentinel).
        // Target readers (Phase 2) must operate on the user-selected target;
        // do NOT migrate cCompileMixin or TestBench's own sample-compile
        // path to pTargetWS - those intentionally read from phoWorkspace.
        Property tWorkspacePaths pOrgWS
        Property tWorkspacePaths pTargetWS

        Property Handle phoWorkspaceSelector_Menuitem
        Property Handle phoSwsOpenDialog
        Property Handle phoOpenSourceFileDialog

        Object oSwsOpenDialog is an OpenDialog
            Set phoSwsOpenDialog to Self
            Set Dialog_Caption to CS_SelectWorkspaceFile
            Set Filter_String  to CS_WorkspaceFilterString
        End_Object

        Object oOpenSourceFileDialog is a OpenDialog
            Set Dialog_Caption to "Select a source file"
            Set phoOpenSourceFileDialog to Self
            Set Filter_String to (CS_SourceCodeFilters + "|All Files (*.*)|*.*")
        End_Object

        Set psVersion to C_DFVersion

    End_Procedure

    { MethodType=Property }
    Procedure Set psHomePath String sPath
        Set private_psHomePath to sPath
    End_Procedure
    
    Function psHomePath Returns String
        Function_Return (Private_psHomePath(Self))
    End_Function
        
    // The psUserName has already have been set, if the /c flag and the name of an ini-file
    // was specified on the command line.
    Procedure InitUserName
        String sName
        Get psUserName to sName
        If (sName = "") Begin  
            Get WindowsUserName to sName
//            Get_Environment "USERNAME" to sName
            Set psUserName to sName
        End
    End_Procedure         
                                  
    Procedure End_Construct_Object
        tWorkspacePaths OrgWS
        Forward Send End_Construct_Object

        Send InitUserName
        Open SysFile
        Open Functions
        Open FunctionsA
        Set private.psStarZenSourceExplorer to (Trim(SysFile.PathStarZen))
        Set piBackupDaysOverwriteCycle      to SysFile.iBackupDaysOverwriteCycle

        // Snapshot the program's own workspace state at startup. Used by:
        //   UpdateDFOpenPath      - restores DF_OPEN_PATH when target closes
        //   RestoreActiveFilelist - puts the filelist back after a target
        //                           refactor function redirected it
        //   cCompileMixin         - TestBench-side compile passes pOrgWS
        // SysFile / Functions / FunctionsA are already open above, so the
        // workspace properties read here reflect the program's own filelist.
        // If phoWorkspace isn't fully populated at this point (can happen
        // depending on .src startup ordering), the resulting struct can be
        // partly empty - subclasses that need a guaranteed-populated snapshot
        // can call CapturephoWorkspace again later (TestBench does this
        // from OnWorkspaceOpened, see TestBench.src).
        Get CapturephoWorkspace to OrgWS
        Set pOrgWS to OrgWS
    End_Procedure

    // Reads phoWorkspace into a tWorkspacePaths struct. Extracted from
    // End_Construct_Object so callers that need a fresh snapshot AFTER
    // the workspace data has been fully loaded (e.g. TestBench, which has
    // no target-workspace selector and seeds pTargetWS = self from
    // OnWorkspaceOpened so refactor functions find its own files) can
    // reuse the exact same capture logic.
    //
    // sAppSrc / sDDSrc / sAppHtml can be semicolon-delimited multi-path
    // lists; only the first entry is taken so callers can use WS.sAppSrc
    // directly without PathAtIndex. sSWSFile is derived from psHome +
    // CS_SWSFile (the hard-coded per-DF-version name) rather than read
    // from a property, because phoWorkspace doesn't expose it directly.
    Function CapturephoWorkspace Returns tWorkspacePaths
        tWorkspacePaths WS
        String sRaw

        Get_Attribute DF_OPEN_PATH     to WS.sOpenPath
        Get_Attribute DF_FILELIST_NAME to WS.sFilelistName

        // sWSFile  = Programs\*.ws  (DataFlex's psWorkspaceWSFile; legacy
        //            folder-paths config file).
        // sSWSFile = Home\<name>.sws (what Studio + the compiler use).
        Get psHome            of (phoWorkspace(Self))  to WS.sHome
        Get psWorkspaceWSFile of (phoWorkspace(Self))  to WS.sWSFile
        Move (vFolderFormat(WS.sHome) + CS_SWSFile)    to WS.sSWSFile

        Get psAppSrcPath  of (phoWorkspace(Self)) to sRaw
        Get PathAtIndex   of (phoWorkspace(Self)) sRaw 1 to WS.sAppSrc

        Get psDdSrcPath   of (phoWorkspace(Self)) to sRaw
        Get PathAtIndex   of (phoWorkspace(Self)) sRaw 1 to WS.sDDSrc

        Get psAppHtmlPath of (phoWorkspace(Self)) to sRaw
        Get PathAtIndex   of (phoWorkspace(Self)) sRaw 1 to WS.sAppHtml

        Get psBitmapPath  of (phoWorkspace(Self)) to WS.sBitmaps
        Get psDataPath    of (phoWorkspace(Self)) to WS.sData
        Get psFileList    of (phoWorkspace(Self)) to WS.sFileList
        Get psHelpPath    of (phoWorkspace(Self)) to WS.sHelp
        Get psProgramPath of (phoWorkspace(Self)) to WS.sPrograms
        Function_Return WS
    End_Function
    
    Function SourceFilePath Returns String
        String sFileName sPath

        Get psHomePath to sPath
        Get psCurrentSourceFileName to sFileName
        If (sFileName <> "") Begin
            Get ParseFolderName sFileName to sPath
        End
        Function_Return sPath
    End_Function

    { MethodType=Property }
    { EnumList="16, 24, 32" }
    Procedure Set piToolbarIconSize Integer iSize
        Send WriteInteger CS_Settings CS_ToolbarIconSize iSize
        Set private.piToolbarIconSize to iSize
    End_Procedure

    { MethodType=Property }
    Function piToolbarIconSize Returns Integer
        Integer iSize
        Get private.piToolbarIconSize to iSize
        If (iSize = 0) Begin
            Get ReadInteger CS_Settings CS_ToolbarIconSize 32 to iSize
            If (iSize = 0) Begin
                Move 32 to iSize
            End
            Set private.piToolbarIconSize to iSize
        End
        Function_Return iSize
    End_Function

