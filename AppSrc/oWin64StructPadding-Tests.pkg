    // Unit tests for Win64StructPadding (the cWin64StructPadding worker's AuditFile).
    // It is REPORT-ONLY - asCode is never modified - and walks each Struct...End_Struct
    // tracking a running byte offset (Integer/DWord/UInteger = 4; Pointer/Address/Handle/
    // Longptr/ULongptr = 8 on x64), flagging a pointer-sized member that does not land on
    // an 8-byte-aligned offset. An unsized member (String/Number/Date/array/...) makes the
    // rest of the struct indeterminate (a following pointer is reported "manual review"),
    // and a struct that already uses an Is$Win64 conditional is skipped.
    // Each test resets the lexer first (ClearFuncLibProperties, as the wrapper does per
    // file), creates the worker, runs the audit, and asserts the finding count.
    Object oWin64StructPadding is a cTestFixture
        Set psFunctionName to "Win64StructPadding"

        // Helper: reset the lexer, create the worker, audit one synthetic file,
        // return the finding count (asFindings comes back by reference).
        Function RunAudit String[] asCode String[] ByRef asFindings Returns Integer
            Handle  ho
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Get Create (RefClass(cWin64StructPadding)) to ho
            Get AuditFile of ho asCode (&asFindings) to iCount
            Send Destroy of ho
            Function_Return iCount
        End_Function

        // Integer then Pointer: the Pointer lands at offset 4 (not 8-aligned) - flagged.
        {Published = True}
        Procedure Win64StructPadding_IntThenPointer_Flagged
            String[] asCode asFindings
            Integer iCount
            Move "Struct tFoo"      to asCode[0]
            Move "    Integer iA"   to asCode[1]
            Move "    Pointer pB"   to asCode[2]
            Move "End_Struct"       to asCode[3]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 1)
        End_Procedure

        // Two Integers then Pointer: the Pointer lands at offset 8 (aligned) - NOT flagged.
        {Published = True}
        Procedure Win64StructPadding_TwoIntsThenPointer_NotFlagged
            String[] asCode asFindings
            Integer iCount
            Move "Struct tFoo"      to asCode[0]
            Move "    Integer iA"   to asCode[1]
            Move "    Integer iB"   to asCode[2]
            Move "    Pointer pC"   to asCode[3]
            Move "End_Struct"       to asCode[4]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 0)
        End_Procedure

        // Pointer as the first member: offset 0 is 8-aligned - NOT flagged.
        {Published = True}
        Procedure Win64StructPadding_PointerFirst_NotFlagged
            String[] asCode asFindings
            Integer iCount
            Move "Struct tFoo"      to asCode[0]
            Move "    Pointer pA"   to asCode[1]
            Move "    Integer iB"   to asCode[2]
            Move "End_Struct"       to asCode[3]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 0)
        End_Procedure

        // Handle is pointer-sized: Integer then Handle lands at offset 4 - flagged.
        {Published = True}
        Procedure Win64StructPadding_IntThenHandle_Flagged
            String[] asCode asFindings
            Integer iCount
            Move "Struct tFoo"      to asCode[0]
            Move "    Integer iA"   to asCode[1]
            Move "    Handle hB"    to asCode[2]
            Move "End_Struct"       to asCode[3]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 1)
        End_Procedure

        // A struct that already uses an Is$Win64 conditional is assumed handled and
        // skipped - even though Integer-then-Pointer would otherwise be flagged.
        {Published = True}
        Procedure Win64StructPadding_HasIsWin64_Suppressed
            String[] asCode asFindings
            Integer iCount
            Move "Struct tFoo"          to asCode[0]
            Move "    Integer iA"       to asCode[1]
            Move "    Pointer pB"       to asCode[2]
            Move "    #IFDEF Is$Win64"  to asCode[3]
            Move "    Integer iPad"     to asCode[4]
            Move "    #ENDIF"           to asCode[5]
            Move "End_Struct"           to asCode[6]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 0)
        End_Procedure

        // An unsized member (String) before a Pointer makes the offset indeterminate;
        // the Pointer is reported for manual review (1 finding).
        {Published = True}
        Procedure Win64StructPadding_IndeterminateBeforePointer_ManualReview
            String[] asCode asFindings
            Integer iCount
            Move "Struct tFoo"      to asCode[0]
            Move "    String sA"    to asCode[1]
            Move "    Pointer pB"   to asCode[2]
            Move "End_Struct"       to asCode[3]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 1)
        End_Procedure

        // No pointer-sized member: nothing to align, nothing reported - even with a
        // misaligning odd run of Integers.
        {Published = True}
        Procedure Win64StructPadding_NoPointer_NotFlagged
            String[] asCode asFindings
            Integer iCount
            Move "Struct tFoo"      to asCode[0]
            Move "    Integer iA"   to asCode[1]
            Move "    Integer iB"   to asCode[2]
            Move "    Integer iC"   to asCode[3]
            Move "End_Struct"       to asCode[4]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 0)
        End_Procedure

        // Code OUTSIDE any Struct...End_Struct is ignored - a misaligning-looking
        // declaration in a Procedure must NOT be flagged.
        {Published = True}
        Procedure Win64StructPadding_OutsideStruct_Ignored
            String[] asCode asFindings
            Integer iCount
            Move "Procedure Foo"    to asCode[0]
            Move "    Integer iA"   to asCode[1]
            Move "    Pointer pB"   to asCode[2]
            Move "End_Procedure"    to asCode[3]
            Get RunAudit asCode (&asFindings) to iCount
            Send Assert (iCount = 0)
        End_Procedure

    End_Object
