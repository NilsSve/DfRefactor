    // Unit tests for CommentOutArgumentSizeCommands - comments out the obsolete companion commands
    // Get_Argument_Size / Set_Argument_Size (legacy fixed string-buffer sizing, no-ops now; 4533).
    Object oCommentOutArgumentSizeCommands is a cTestFixture
        Set psFunctionName to "CommentOutArgumentSizeCommands"

        {Published = True}
        // Set_Argument_Size as the first/only statement -> whole line commented.
        Procedure CommentOutArgumentSize_SetFirstToken
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Set_Argument_Size 4096" to sLine
            Move "// Set_Argument_Size 4096" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get CommentOutArgumentSizeCommands of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // Get_Argument_Size (the save form) -> commented; indentation preserved.
        Procedure CommentOutArgumentSize_GetIndented
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    Get_Argument_Size to iArgumentSize" to sLine
            Move "    // Get_Argument_Size to iArgumentSize" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get CommentOutArgumentSizeCommands of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // Not the first token: an inline "If (cond) Set_Argument_Size n" - the whole line is commented.
        Procedure CommentOutArgumentSize_InlineIf
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "If (bResize) Set_Argument_Size 8192" to sLine
            Move "// If (bResize) Set_Argument_Size 8192" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get CommentOutArgumentSizeCommands of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // The restore form (Set_Argument_Size <var>) is commented like any other.
        Procedure CommentOutArgumentSize_RestoreVar
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "        Set_Argument_Size iArgSize" to sLine
            Move "        // Set_Argument_Size iArgSize" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get CommentOutArgumentSizeCommands of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send Assert bChanged
        End_Procedure

        {Published = True}
        // An already-commented line is left untouched (bLineIsReady gate - no double comment).
        Procedure CommentOutArgumentSize_AlreadyCommented
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "// Set_Argument_Size 4096" to sLine
            Move "// Set_Argument_Size 4096" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get CommentOutArgumentSizeCommands of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

        {Published = True}
        // An unrelated line is untouched.
        Procedure CommentOutArgumentSize_NonMatchUntouched
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move 4096 to iBuf" to sLine
            Move "Move 4096 to iBuf" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get CommentOutArgumentSizeCommands of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

        {Published = True}
        // The keyword inside a STRING literal must NOT trigger a comment-out (it's a distinct token).
        Procedure CommentOutArgumentSize_InStringUntouched
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move "Set_Argument_Size" to sName' to sLine
            Move 'Move "Set_Argument_Size" to sName' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get CommentOutArgumentSizeCommands of ghoFuncLib (&sLine) "" to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

    End_Object
