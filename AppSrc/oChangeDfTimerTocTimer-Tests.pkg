    Object oChangeDfTimerTocTimer is a cTestFixture
        Set psFunctionName to "ChangeDfTimerTocTimer"

        // Safe migration: Auto_Start_State=False, no Timer_Message, OnTimer params used only in the
        // Forward -> class swapped, Auto_*/Timer_object dropped, Timeout->piTimeout, OnTimer params
        // stripped, and the redundant "of (oTimer1(Self))" self-reference removed. sReason blank.
        { Published = True }
        Procedure ChangeDfTimerTocTimer_SafeMigration
            String[] asBlock asResult
            String sReason
            Move '    Object oTimer1 is a dfTimer'                   to asBlock[0]
            Move '        Set Auto_Start_State to False'             to asBlock[1]
            Move '        Set Auto_Stop_State to False'              to asBlock[2]
            Move '        Set Timer_object to (oTimer1(Self))'       to asBlock[3]
            Move '        Set Timeout of (oTimer1(Self)) to 10000'   to asBlock[4]
            Move '        Set pbEnabled of (oTimer1(Self)) to False' to asBlock[5]
            Move '        Procedure OnTimer Integer wParam Integer lParam' to asBlock[6]
            Move '            Send CheckForNewMessages'              to asBlock[7]
            Move '            Forward Send OnTimer wParam lParam'    to asBlock[8]
            Move '        End_Procedure'                             to asBlock[9]
            Move '    End_Object'                                    to asBlock[10]
            Get _MigrateDfTimerBlock of ghoFuncLib asBlock (&sReason) to asResult
            Send AssertSAreEqual '' sReason
            Send Assert (SizeOfArray(asResult) = 8)
            Send AssertSAreEqual '    Object oTimer1 is a cTimer'        asResult[0]
            Send AssertSAreEqual '        Set piTimeout to 10000'        asResult[1]
            Send AssertSAreEqual '        Set pbEnabled to False'        asResult[2]
            Send AssertSAreEqual '        Procedure OnTimer'             asResult[3]
            Send AssertSAreEqual '            Send CheckForNewMessages'  asResult[4]
            Send AssertSAreEqual '            Forward Send OnTimer'      asResult[5]
            Send AssertSAreEqual '        End_Procedure'                 asResult[6]
            Send AssertSAreEqual '    End_Object'                        asResult[7]
        End_Procedure

        // No "Set Auto_Start_State to False" -> relied on the default auto-start -> flagged, unchanged.
        { Published = True }
        Procedure ChangeDfTimerTocTimer_AutoStartReliance_Flagged
            String[] asBlock asResult
            String sReason
            Move '    Object oTimer1 is a dfTimer'                to asBlock[0]
            Move '        Set Timeout of (oTimer1(Self)) to 5000' to asBlock[1]
            Move '        Procedure OnTimer Integer w Integer l'  to asBlock[2]
            Move '            Forward Send OnTimer w l'           to asBlock[3]
            Move '        End_Procedure'                          to asBlock[4]
            Move '    End_Object'                                 to asBlock[5]
            Get _MigrateDfTimerBlock of ghoFuncLib asBlock (&sReason) to asResult
            Send Assert (sReason <> "")
            Send Assert (SizeOfArray(asResult) = 6)
            Send AssertSAreEqual '    Object oTimer1 is a dfTimer' asResult[0]
        End_Procedure

        // Timer_Message dispatch present -> flagged, unchanged (even though Auto_Start_State is False).
        { Published = True }
        Procedure ChangeDfTimerTocTimer_TimerMessage_Flagged
            String[] asBlock asResult
            String sReason
            Move '    Object oTimer1 is a dfTimer'           to asBlock[0]
            Move '        Set Auto_Start_State to False'     to asBlock[1]
            Move '        Set Timer_Message to msg_DoStuff'  to asBlock[2]
            Move '        Set Timeout to 5000'               to asBlock[3]
            Move '    End_Object'                            to asBlock[4]
            Get _MigrateDfTimerBlock of ghoFuncLib asBlock (&sReason) to asResult
            Send Assert (sReason <> "")
            Send Assert (SizeOfArray(asResult) = 5)
            Send AssertSAreEqual '    Object oTimer1 is a dfTimer' asResult[0]
        End_Procedure

        // OnTimer body references a param beyond the Forward -> flagged, unchanged.
        { Published = True }
        Procedure ChangeDfTimerTocTimer_ParamUsed_Flagged
            String[] asBlock asResult
            String sReason
            Move '    Object oTimer1 is a dfTimer'                  to asBlock[0]
            Move '        Set Auto_Start_State to False'            to asBlock[1]
            Move '        Procedure OnTimer Integer wParam Integer lParam' to asBlock[2]
            Move '            Showln wParam'                        to asBlock[3]
            Move '            Forward Send OnTimer wParam lParam'   to asBlock[4]
            Move '        End_Procedure'                            to asBlock[5]
            Move '    End_Object'                                   to asBlock[6]
            Get _MigrateDfTimerBlock of ghoFuncLib asBlock (&sReason) to asResult
            Send Assert (sReason <> "")
            Send Assert (SizeOfArray(asResult) = 7)
            Send AssertSAreEqual '    Object oTimer1 is a dfTimer' asResult[0]
        End_Procedure

        // Whole-file: a safe object migrates (count 1). Internal "of (oTimer1(Self))" self-references
        // are stripped; the external Timer_Active_State switch (in a view's Activate) is renamed
        // pbEnabled but keeps its "of oTimer1". Short param names (w/l) must NOT false-flag.
        { Published = True }
        Procedure ChangeDfTimerTocTimer_WholeFile_Migrates
            String[] asCode
            Integer iCount
            Move '    Object oTimer1 is a dfTimer'                        to asCode[0]
            Move '        Set Auto_Start_State to False'                  to asCode[1]
            Move '        Set Timeout of (oTimer1(Self)) to 10000'        to asCode[2]
            Move '        Set Timer_Active_State of (oTimer1(Self)) to False' to asCode[3]
            Move '        Procedure OnTimer Integer w Integer l'          to asCode[4]
            Move '            Forward Send OnTimer w l'                   to asCode[5]
            Move '        End_Procedure'                                  to asCode[6]
            Move '    End_Object'                                         to asCode[7]
            Move '    Procedure Activate'                                 to asCode[8]
            Move '        Set Timer_Active_State of oTimer1 to True'       to asCode[9]
            Move '    End_Procedure'                                      to asCode[10]
            Get ChangeDfTimerTocTimer of ghoFuncLib (&asCode) to iCount
            Send Assert (iCount = 1)
            Send Assert (SizeOfArray(asCode) = 10)
            Send AssertSAreEqual '    Object oTimer1 is a cTimer'        asCode[0]
            Send AssertSAreEqual '        Set piTimeout to 10000'        asCode[1]
            Send AssertSAreEqual '        Set pbEnabled to False'        asCode[2]
            Send AssertSAreEqual '        Procedure OnTimer'             asCode[3]
            Send AssertSAreEqual '        Set pbEnabled of oTimer1 to True' asCode[8]
        End_Procedure

        // Whole-file: an unsafe object (relied on auto-start) is left verbatim with a //TODO above it,
        // and nothing counts as migrated.
        { Published = True }
        Procedure ChangeDfTimerTocTimer_WholeFile_FlagsUnsafe
            String[] asCode
            Integer iCount
            Move '    Object oTimer2 is a dfTimer'                to asCode[0]
            Move '        Set Timeout of (oTimer2(Self)) to 3000' to asCode[1]
            Move '        Procedure OnTimer Integer wParam Integer lParam' to asCode[2]
            Move '            Forward Send OnTimer wParam lParam' to asCode[3]
            Move '        End_Procedure'                          to asCode[4]
            Move '    End_Object'                                 to asCode[5]
            Get ChangeDfTimerTocTimer of ghoFuncLib (&asCode) to iCount
            Send Assert (iCount = 0)
            Send Assert (SizeOfArray(asCode) = 7)
            Send Assert (Pos("//TODO dfTimer->cTimer", asCode[0]) > 0)
            Send AssertSAreEqual '    Object oTimer2 is a dfTimer' asCode[1]
        End_Procedure

    End_Object
