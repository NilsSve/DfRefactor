    Object oRemoveProjectObjectStructure is a cTestFixture
        Set psFunctionName to "RemoveProjectObjectStructure"

        // Blank line: bLineIsReady guard fires, line unchanged, return False.
        {Published = True}
        Procedure RemoveProjectObjectStructure_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '' to sLine
            Move '' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveProjectObjectStructure of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Regular code line outside any register section must be kept, return False.
        {Published = True}
        Procedure RemoveProjectObjectStructure_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move x to y" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveProjectObjectStructure of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "Move x to y" sLine
        End_Procedure

        // Register_Object line whose object name is in pasObjectNames must be removed.
        {Published = True}
        Procedure RemoveProjectObjectStructure_RegisterObjectRemoved
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            String[] asObjectNames
            Move "omainwindow" to asObjectNames[0]
            Set pasObjectNames of ghoFuncLib to asObjectNames
            Set pbRegisterAllObjectsStart of ghoFuncLib to True
            Move "Register_Object oMainWindow" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveProjectObjectStructure of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual "" sLine
        End_Procedure

        // Register_Object line whose object name is NOT in pasObjectNames must be kept.
        {Published = True}
        Procedure RemoveProjectObjectStructure_RegisterObjectKept
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            String[] asObjectNames
            Move "omainwindow" to asObjectNames[0]
            Set pasObjectNames of ghoFuncLib to asObjectNames
            Set pbRegisterAllObjectsStart of ghoFuncLib to True
            Move "Register_Object oUnknown" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveProjectObjectStructure of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "Register_Object oUnknown" sLine
        End_Procedure

    End_Object
