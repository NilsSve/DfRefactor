    Object oRemovePropertyPrivate is a cTestFixture
        Set psFunctionName to "RemovePropertyPrivate"

        {Published = True}
        Procedure RemovePropertyPrivate_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Property Boolean pbState Private' to sLine
            Move 'Property Boolean pbState' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemovePropertyPrivate of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Lowercase keyword is also removed.
        {Published = True}
        Procedure RemovePropertyPrivate_2
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Property Boolean pbState private' to sLine
            Move 'Property Boolean pbState' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemovePropertyPrivate of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Leading indentation is preserved.
        {Published = True}
        Procedure RemovePropertyPrivate_3
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Property String psName Private' to sLine
            Move '    Property String psName' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemovePropertyPrivate of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Non-property line -- bChanged must be False.
        {Published = True}
        Procedure RemovePropertyPrivate_4
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move sA to sB' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemovePropertyPrivate of ghoFuncLib (&sLine) to bChanged
            Send Assert (bChanged = False)
        End_Procedure

    End_Object
