    Object oEditorNormalizeCase is a cTestFixture
        Set psFunctionName to "EditorNormalizeCase"

        {Published = True}
        Procedure EditorNormalizeCase_1
            String sLine sExpected
            String[] asData
            Boolean bChanged bOK
            Handle hoEditor

            Get phoEditor of ghoFuncLib to hoEditor
            If (hoEditor = 0) Procedure_Return  // Console mode has no GUI Scintilla editor; skip this test.
            Move 'move iA TO iB' to asData[0]
            Move 'Move iA to iB' to sExpected
            Get WriteDataToEditor of hoEditor asData to bOK
            Get EditorNormalizeCase of ghoFuncLib (&asData) to bChanged

            If (bChanged = True) Begin
                // We need this because of an optimization in the cRefactoringEngine,
                // where we only want to call EditorDataAsStringArray once after all
                // calls to eEditor_Function type(s).
                Get EditorDataAsStringArray of hoEditor to asData
                Move asData[0] to sLine
            End
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Multi-keyword block: several keywords on separate lines, all normalised.
        {Published = True}
        Procedure EditorNormalizeCase_MultiKeyword
            Boolean bChanged bOK
            String[] asData
            Handle hoEditor

            Get phoEditor of ghoFuncLib to hoEditor
            If (hoEditor = 0) Procedure_Return  // Console mode has no GUI Scintilla editor; skip this test.
            Move 'PROCEDURE doSomething'       to asData[0]
            Move '    IF (bFound = TRUE) BEGIN' to asData[1]
            Move '        SEND doIt'           to asData[2]
            Move '    END'                     to asData[3]
            Move 'END_PROCEDURE'               to asData[4]
            Get WriteDataToEditor of hoEditor asData to bOK
            Get EditorNormalizeCase of ghoFuncLib (&asData) to bChanged
            Send Assert bChanged
            If (bChanged = True) Begin
                Get EditorDataAsStringArray of hoEditor to asData
            End
            Send AssertSAreEqual 'Procedure doSomething'      asData[0]
            Send AssertSAreEqual '    If (bFound = TRUE) Begin' asData[1]
            Send AssertSAreEqual '        Send doIt'          asData[2]
            Send AssertSAreEqual '    End'                    asData[3]
            Send AssertSAreEqual 'End_Procedure'              asData[4]
        End_Procedure

        // Mixed-case keywords: only the keyword tokens are corrected, identifiers untouched.
        {Published = True}
        Procedure EditorNormalizeCase_MixedCase
            Boolean bChanged bOK
            String[] asData
            Handle hoEditor

            Get phoEditor of ghoFuncLib to hoEditor
            If (hoEditor = 0) Procedure_Return  // Console mode has no GUI Scintilla editor; skip this test.
            Move 'function MyFunc RETURNS integer' to asData[0]
            Move '    function_return 0'           to asData[1]
            Move 'end_function'                    to asData[2]
            Get WriteDataToEditor of hoEditor asData to bOK
            Get EditorNormalizeCase of ghoFuncLib (&asData) to bChanged
            Send Assert bChanged
            If (bChanged = True) Begin
                Get EditorDataAsStringArray of hoEditor to asData
            End
            Send AssertSAreEqual 'Function MyFunc Returns Integer' asData[0]
            Send AssertSAreEqual '    Function_Return 0'           asData[1]
            Send AssertSAreEqual 'End_Function'                    asData[2]
        End_Procedure

    End_Object
