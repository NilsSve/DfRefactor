    { Published = True }
    { Description = """
        Removes "MS Sans Serif" font source lines.
        { MethodType = eRemoveFunction }
        { FnGroup = Cleanup }
        { SummaryText = Removed: 'MS Sans Serif' lines }
        """ }
    Function RemoveSansSerif String byref sLine Returns Boolean
        String sTest
        Boolean bWriteLine

        Move False to bWriteLine
        Move (Lowercase(Trim(sLine))) to sTest
        Move (Replaces(CS_S, sTest, ""))  to sTest
        Move (Replaces("'", sTest, "*")) to sTest
        Move (Replaces('"', sTest, "*")) to sTest
        If (sTest contains 'settypefaceto*mssansserif*') Begin
            Move True to bWriteLine
        End
        Function_Return bWriteLine
    End_Function

    { Published = True }
    { Description = """
        Removes old Studio generated comments lines.
        Examples:
        // fires when the button is clicked
        //OnChange is called on every changed character
        // Visual DataFlex xx.x Client Size Adjuster
        // Visual DataFlex xx.x Migration Utility
        ...and so on
        { MethodType = eRemoveFunction }
        { FnGroup = Cleanup }
        { SummaryText = Removed: Studio generated comments }
        """ }
    Function RemoveStudioGeneratedComments String ByRef sLine Returns Boolean
        String sText sComment sComment2
        Boolean bFound bChanged
        tTokenizer TokenizerData

        Get pTokenizer to TokenizerData
        Move False to bChanged
        Move (Trim(sLine)) to sText
        If (sText = "" or sText = CS_CommentSymbol or sText contains (CS_CommentSymbol + "AB") or TokenizerData.bIsComment = False) Begin
            Function_Return False
        End

        Move "fires when the button is clicked" to sComment
        Get IsStudioGeneratedComment sLine sComment to bFound
        If (bFound = True) Begin
            Move "" to sLine
            Function_Return True
        End

        Move "onchange is called on every changed character" to sComment
        Get IsStudioGeneratedComment sLine sComment to bFound
        If (bFound = True) Begin
            Move "" to sLine
            Function_Return True
        End

        Move "visual dataflex"      to sComment
        Move "client size adjuster" to sComment2
        Get IsStudioGeneratedComment sLine sComment sComment2 to bFound
        If (bFound = True) Begin
            Move "" to sLine
            Function_Return True
        End

        Move "visual dataflex"    to sComment
        Move "migration utility," to sComment2
        Get IsStudioGeneratedComment sLine sComment sComment2 to bFound
        If (bFound = True) Begin
            Move "" to sLine
            Function_Return True
        End

        Move "If you set Current_radio you must set this after the" to sComment
        Get IsStudioGeneratedComment sLine sComment to bFound
        If (bFound = True) Begin
            Move "" to sLine
            Function_Return True
        End

        Move "radio objects have been created AND after Notify_select_State has been" to sComment
        Get IsStudioGeneratedComment sLine sComment to bFound
        If (bFound = True) Begin
            Move "" to sLine
            Function_Return True
        End

        Move "created. i.e. Set in bottom-code at end!!" to sComment
        Get IsStudioGeneratedComment sLine sComment to bFound
        If (bFound = True) Begin
            Move "" to sLine
            Function_Return True
        End

        Function_Return bChanged
    End_Function

    { Published = True }
    { Description = """
        Removes spaces at the end of lines (trailing spaces).
        { MethodType = eStandardFunction }
        { SummaryText = Removed: Spaces at end of line }
        { FnGroup = Cleanup }
        """ }
    Function RemoveTrailingSpaces String ByRef sLine Returns Boolean
        Integer iBefore iAfter
        Boolean bChanged
        tTokenizer TokenizerData

        Move (Length(sLine))     to iBefore
        Move (RTrim(sLine))      to sLine
        Move (Length(sLine))     to iAfter
        Move (iBefore <> iAfter) to bChanged

        Function_Return bChanged
    End_Function

    { Published = True }
    { Description = """
        Removes variables from functions and procedures that aren't used.
        A limitation is that it does not remove unused *struct* variables.
        Pass a source file as a string array.
        Removes all unusad locally defined, in Procedures & Functions, for the
        passed string array. Returns number of removed unused local variables.
        { MethodType = eOtherFunction }
        { FnGroup = Cleanup }
        { SummaryText = Removed: Unused local variables }
        """ }
    Function RemoveUnusedLocals String[] ByRef asCode String sParameter Returns Integer
        Handle ho
        Integer iRetval

        Get Create (RefClass(cRemoveUnusedLocals)) to ho
        If (ho = 0) Begin
            Error "Could not create cRemoveUnusedLocals object."
            Function_Return 0
        End

        Set piNoOfUnusedLocalVariables of ho to 0
        Get RemoveUnusedLocals of ho (&asCode) to iRetval
        Send Destroy of ho

        Function_Return iRetval
    End_Function

    { Published = True }
    { Description = """
      The naming style of data-dictionaries *objects* over time has changed.
      The new style is:
        Object o<tablename>_DD is a c<TableName>Datadictionary
      They also have a switch so you can keep on using the legacy style name which is:
        Object o<tablename>_DD is a <tablename>_Datadictionary

      However before VDF12, this is how it looked:
        Object <tableName>_DD is a <tablename>_Datadictionary

      This caused tremendous headaches as due to the extra "o" we ended up with name clashes
      all over the place. Copying old code into new views/dialogs simply breaks and if your
      codebase has mixed styles then the compiler will not catch that.
      A code nightmare.

      Examples:
        <TableName>_DD - o<TableName>DD (eDDStudioStyle)
        <TableName>_DD - o<TableName>_dd (neDDNewStyle)
      { MethodType = eOtherFunctionAll }
      { FnGroup = Modernization }
      { SummaryText = Renamed DataDictionary objects }
      { EnumList = "eDDStudioStyle, eDDNewStyle, eDDOldStyle" }
      { InitialValue = eDDNewStyle }
      { ParamHelp = Valid values;
      \neDDStudioStyle - o<TableName>DD
      \neDDNewStyle - o<TableName>_dd
      \noDDOldStyle - <TableName>_DD }
      """ }
    Function RestyleDDOs String[] ByRef asFiles String sParameter Returns Integer
        String sHomePath
        Handle ho
        Boolean bIsStyle
        Integer iRetval iSize iCount eDDOStyle
        tRefactorSettings RefactorSettings
        tWorkspacePaths TargetWS OrgWS

        If (SizeOfArray(asFiles) <= 0) Begin
            Function_Return False
        End

        Get Create (RefClass(cDDOReStyler)) to ho
        If (ho = 0) Begin
            Error "Could not create cDDORestyler object (Function: RestyleDDOs)"
            Function_Return 0
        End

        // sParameter arrives as the enum NAME from the UI combo or as the numeric VALUE
        // from tests - resolve each member explicitly via _ParameterIsEnum (a bare Move
        // of the name into the Integer enum yields eDDUnknown; and NOTE the {EnumList}
        // display order differs from the Enum_List value order here, so positional
        // mapping would be wrong). Unmatched/blank keeps eDDUnknown, as before. NO
        // num_arguments guard - it is unreliable after nested sends/dynamic dispatch,
        // and an omitted parameter arrives as "" (no member matches).
        Get _ParameterIsEnum sParameter "eDDStudioStyle" eDDStudioStyle to bIsStyle
        If (bIsStyle = True) ;
            Move eDDStudioStyle to eDDOStyle
        Get _ParameterIsEnum sParameter "eDDNewStyle" eDDNewStyle to bIsStyle
        If (bIsStyle = True) ;
            Move eDDNewStyle to eDDOStyle
        Get _ParameterIsEnum sParameter "eDDOldStyle" eDDOldStyle to bIsStyle
        If (bIsStyle = True) ;
            Move eDDOldStyle to eDDOStyle

        // Path for the workspace we are refactoring: target if selected,
        // otherwise DFRefactor's own (defensive - RestyleDDOs is normally
        // invoked with a target workspace selected).
        Get pTargetWS of ghoApplication to TargetWS
        If (TargetWS.sHome <> "") Begin
            Move TargetWS.sHome to sHomePath
        End
        Else Begin
            Get pOrgWS of ghoApplication to OrgWS
            Move OrgWS.sHome to sHomePath
        End
        Set psHomePath  of ho to sHomePath
        Set peDDOStyle  of ho to eDDOStyle
        Set pasAllFiles of ho to asFiles
        Set pbStrict    of ho to False

        // StartDDORestyler briefly redirects the active filelist to the target
        // workspace for the one-time table enumeration only, then restores it
        // before the per-file processing - so DFRefactor's own error logging
        // stays intact even if the restyle raises errors.
        Get StartDDORestyler of ho to iRetval
        Send Destroy of ho

        Function_Return iRetval
    End_Function

    { Published = True }
    { Description = """
        Splits If/Else single lines to If/Else - Begin constructs.
        It does *not* split if the last word is = "Break", as that could
        change the program logic.
        The function accepts a parameter controlling the If/Else or Begin/End block constructs.
        Valid sParameters, See: EnumList;
        { MethodType = eStandardFunction }
        { FnGroup = Cleanup }
        { SummaryText = Split If/Else line }
        { EnumList = "eSplitBySpaceAndSemicolon, eSplitBySemicolon, eSplitToBeginEndBlock" }
        { InitialValue = eSplitToBeginEndBlock }
        { ParamHelp = Valid values;
        \neSplitBySpaceAndSemicolon - Split line with space and semicolon
        \neSplitBySemicolon - Split line with semicolon
        \neSplitToBeginEndBlock - Use a Begin/End block }
        """ }

    Function SplitInlineIfElseLine String ByRef sLine String sParameter Returns Boolean
        Boolean bStop bChanged bFound
        Integer iIndent eSplitBy iTabSize iItem
        String  sText sToken
        tTokenizer TokenizerData

        Get pTokenizer to TokenizerData
        If (TokenizerData.bLineIsReady = True or TokenizerData.bIsInCommand = True or ;
            TokenizerData.bIsInImage = True or TokenizerData.bIsVariableDeclaration = True) Begin
            Function_Return False
        End
        Move (SearchArray(CS_If, TokenizerData.asLineTokens, Desktop, RefFunc(DFSTRICMP))) to iItem
        If (iItem = -1) Begin
            Move (Trim(sLine)) to sText
            Move (Left(sText, 3)) to sText
            Move (Lowercase(sText) = Lowercase(CS_If)) to bFound
            If (bFound = False) Begin
                Function_Return False
            End
        End
        
        // Note: We do *not* change the line if it ends with a "Break", or if it contains
        //       a "Goto" or "Gosub", because wrapping those in a Begin/End block would
        //       change the logic of the program.
        Move TokenizerData.iTokenCount to iItem
        If (iItem = 0) ;
            Function_Return False
        Move TokenizerData.asLineTokens[iItem -1] to sToken
        If (Lowercase(sToken) = "break") Begin
            Function_Return False
        End
        Move (SearchArray("goto",  TokenizerData.asLineTokens, Desktop, RefFunc(DFSTRICMP))) to iItem
        If (iItem <> -1) ;
            Function_Return False
        Move (SearchArray("gosub", TokenizerData.asLineTokens, Desktop, RefFunc(DFSTRICMP))) to iItem
        If (iItem <> -1) ;
            Function_Return False
        
        Move False to bChanged
        // sParameter arrives as the enum NAME from the UI combo or as the numeric VALUE
        // from tests - resolve via _ParameterIsEnum (a bare Move of the name into the
        // Integer enum yielded eSplitUnknown from the UI). Default = the documented
        // {InitialValue}, eSplitToBeginEndBlock.
        Move eSplitToBeginEndBlock to eSplitBy
        Get _ParameterIsEnum sParameter "eSplitBySpaceAndSemicolon" eSplitBySpaceAndSemicolon to bFound
        If (bFound = True) ;
            Move eSplitBySpaceAndSemicolon to eSplitBy
        Get _ParameterIsEnum sParameter "eSplitBySemicolon" eSplitBySemicolon to bFound
        If (bFound = True) ;
            Move eSplitBySemicolon to eSplitBy
        Get piTabSize to iTabSize
        If (eSplitBy = eSplitToBeginEndBlock) Begin
            Move (SearchArray(CS_Begin, TokenizerData.asLineTokens, Desktop, RefFunc(DFSTRICMP))) to iItem
            If (iItem <> -1) ;
                Function_Return False
        End

        Move (LTrim(sLine))     to sText
        Move (Pos(sText,sLine) - 1) to iIndent
        Move (Left(sText, 3))   to sText
        Move (Lowercase(sText)) to sText
        If (sText = (Lowercase(CS_If) + CS_S)) Begin
            Get IsLineEndSemiColonOrBegin TokenizerData.sOverstrikeLine to bStop
            If (bStop = False) Begin
                // It's one of those single line if statements, break it up
                Move (Lowercase(sLine)) to sText
                Get BreakupCompoundStatement iIndent (&sLine) eSplitBy iTabSize to bChanged
            End
        End
        Else Begin
            Move (LTrim(sLine))     to sText
            Move (Left(sText, 5))   to sText
            Move (Lowercase(sText)) to sText
            If (sText = (Lowercase(CS_Else) + CS_S)) Begin
                Get IsLineEndSemiColonOrBegin TokenizerData.sOverstrikeLine to bStop
                If (bStop = False) Begin
                    Get BreakupCompoundStatement iIndent (&sLine) eSplitBy iTabSize to bChanged
                End
            End
        End
        Function_Return bChanged
    End_Function

    { Published = True }
    { Description = """
        Refactors legacy DbGrid objects to a CJ grid class with individual column objects.
        For each matching DbGrid object found across all selected files:
          - The scope is code within the legacy object, not the entire file.
          - Renames the class to the new grid class.
          - Converts the Begin_Row / Entry_Item list into individual column child objects.
          - Maps Set Form_Width Item N to W  ->  Set piWidth to W  on each column.
          - Maps Set Header_Label Item N to "L"  ->  Set psCaption to "L"  on each column.
          - Removes legacy-only grid properties: Main_File, Wrap_State, peResizeColumn, psColumnsID.
          - Removes the standard Entry_Display boilerplate procedure.
          - Preserves all other content (other Set properties, nested objects, etc.) unchanged.
        sParameter must be a comma-separated list of 2 or 3 class names:
          OldGridClass,NewGridClass[,NewColumnClass]
        Example: "cLangdbGrid,cDbCJGrid,cDbCJGridColumn"
        If sParameter is empty, any class ending in "dbgrid" is detected, and the
        standard DataFlex classes cDbCJGrid and cDbCJGridColumn are used as targets.
        Returns the total number of grid objects transformed across all files.
        { MethodType = eOtherFunctionAll }
        { FnGroup = Modernization }
        { EnumList = "ANY" }
        { InitialValue = DbGrid,cDbCJGrid,cDbCJGridColumn }
        { SummaryText = Refactored: DbGrid -> cDbCJGrid }
        { ModRecipe = 4537 | class: DBGRID }
        { ParamHelp = Three comma separated class names;
        \nMyDbGrid - Your subclass of DbGrid,
        \nMycDbCJGrid - Your subclass of cDbCJGrid,
        \nMycDbCJGridColumn - Your subclass of cDbCJGridColumn }
        """ }
    Function RefactorDbGridTocDbCJGrid String[] ByRef asFiles String sParameter Returns Integer
        Handle  ho
        Integer iRetval

        If (SizeOfArray(asFiles) = 0) Begin
            Function_Return 0
        End

        Get Create (RefClass(cDbGridTocDbCJGrid)) to ho
        If (ho = 0) Begin
            Error "Could not create cDbGridTocDbCJGrid object. (Function: RefactorDbGridTocDbCJGrid)"
            Function_Return 0
        End

        Get TransformDbGridTocDbCJGrid of ho asFiles sParameter to iRetval
        Send Destroy of ho
        Function_Return iRetval
    End_Function

//  These comments were moved here from the { Description } meta tag, as it 
//  seems that the DataFlex metatag buffer was overflowed(?), leading to an unsuccessful compilation.
//
//  - Translates known properties to their cCJGrid equivalents, e.g.:
//      Set peResizeColumn          ->  Set pbAllowColumnResize
//      Set Prompt_Button_Mode      ->  Set pbHeaderPrompts
//      Set Allow_Top_Add_State     ->  Set pbAllowAppendRow
//      Set Allow_Bottom_Add_State  ->  Set pbAllowAppendRow
//      Set Allow_Insert_Add_State  ->  Set pbAllowInsertRow
//      Set Auto_Save_State         ->  Set pbAutoSave
//      Set No_Create_State         ->  Set pbAllowAppendRow + Set pbAllowInsertRow (inverted)
//      Set No_Delete_State         ->  Set pbAllowDeleteRow (inverted)
//      Set Read_Only_State         ->  Set pbReadOnly
//      Set CurrentRowColor         ->  Set piHighlightBackColor
//      Set CurrentCellColor        ->  Set piFocusCellBackColor
//      Set CurrentRowTextColor     ->  Set piHighlightForeColor
//      Set CurrentCellTextColor    ->  Set piFocusCellForeColor
    { Published = True }
    { Description = """
        Refactors legacy non-data-aware Grid objects to a CJ grid class.
        For each matching Grid object found across all selected files:
          - The scope is code within the legacy object, not the entire file.
          - Translates known properties to their cCJGrid equivalents
          - Renames the class to the new grid class.
          - Removes legacy-only grid properties: Wrap_State, peResizeColumn, psColumnsID.
          - Comments out the Entry_Display procedure body; any color Set properties
            found inside Entry_Display are translated and placed above the commented block.
          - Comments out legacy-only grid methods with a TODO marker.
          - Column sub-objects are NOT generated -- the non-data-aware column structure
            varies per use case and must be completed manually after refactoring.
        sParameter must be a comma-separated list of 2 or 3 class names:
          OldGridClass,NewGridClass[,NewGridColumnClass]
        Example: "cMyGrid,cCJGrid,cCJGridColumn"
        If sParameter is empty, any class whose name ends in "grid" (but not "dbgrid") is
        detected, and the standard DataFlex classes cCJGrid and cCJGridColumn are used as the target.
        Returns the total number of grid objects transformed across all files.
        { MethodType = eOtherFunctionAll }
        { FnGroup = Modernization }
        { EnumList = "ANY" }
        { InitialValue = Grid,cCJGrid, cCJGridColumn }
        { SummaryText = Refactored: Grid -> cCJGrid }
        { ModRecipe = 4537 | class: GRID }
        { ParamHelp = Three comma separated class names;
        \nMyGrid - Your subclass of Grid,
        \nMycCJGrid - Your subclass of cCJGrid,
        \nMycCJGridColumn - Your subclass of cCJGridColumn }
        """ }
    Function RefactorGridToCJGrid String[] ByRef asFiles String sParameter Returns Integer
        Handle  ho
        Integer iRetval

        If (SizeOfArray(asFiles) = 0) Begin
            Function_Return 0
        End

        Get Create (RefClass(cGridToCJGrid)) to ho
        If (ho = 0) Begin
            Error "Could not create cGridToCJGrid object. (Function: RefactorGridToCJGrid)"
            Function_Return 0
        End

        Get TransformGridToCJGrid of ho asFiles sParameter to iRetval
        Send Destroy of ho
        Function_Return iRetval
    End_Function

