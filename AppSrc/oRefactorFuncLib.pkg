    { Published = True }
    { Description = """
        Converts legacy Begin_Constraints / End_Constraints blocks into a modern OnConstrain procedure.
        The ENTIRE block body (declarations, Get/If/Else and the Constrains they control, and any
        Report_* lines) moves verbatim and in order into 'Procedure OnConstrain' (opened with 'Forward
        Send OnConstrain') - nothing is reordered or moved out, since e.g. a Report_Index parameter can
        depend on logic earlier in the block. Comments are kept, blank lines dropped. A block with no
        matching End_Constraints is left untouched. Takes a whole source file as a string array.
        { MethodType = eOtherFunction }
        { FnGroup = Modernization }
        { SummaryText = Refactored: Begin_Constraints -> OnConstrain }
        { ModRecipe = 4533 | command: Begin_Constraint }
        { ModRecipe = 4533 | command: End_Constraint }
        """ }
    Function ChangeBeginEndConstraint String[] ByRef asCode String sParameter Returns Integer
        String[] asOut asBody asBlockRaw asEmpty
        Integer iCount iSize iBlocks i iMax iPos
        String sLine sTrim sFirst sLow sIndent
        Boolean bInBlock

        Move 0 to iBlocks
        Move False to bInBlock
        Move (SizeOfArray(asCode)) to iSize
        Decrement iSize
        For iCount from 0 to iSize
            Move asCode[iCount] to sLine
            Move (Trim(sLine)) to sTrim
            // First whitespace-delimited token of the trimmed line.
            Move (Pos(" ", sTrim)) to iPos
            If (iPos > 0) Begin
                Move (Trim(Left(sTrim, (iPos - 1)))) to sFirst
            End
            Else Begin
                Move sTrim to sFirst
            End
            Move (Lowercase(sFirst)) to sLow

            If (bInBlock = False) Begin
                If ((sLow = "begin_constraints") or (sLow = "begin_constraint")) Begin
                    // Open a block: remember the Begin_Constraints indentation, reset the buffers.
                    Move True to bInBlock
                    Move (Pos(sTrim, sLine)) to iPos
                    If (iPos > 1) Begin
                        Move (Left(sLine, (iPos - 1))) to sIndent
                    End
                    Else Begin
                        Move "" to sIndent
                    End
                    Move asEmpty to asBody
                    Move asEmpty to asBlockRaw
                    Move sLine to asBlockRaw[0]
                    Increment iBlocks
                End
                Else Begin
                    Move sLine to asOut[SizeOfArray(asOut)]
                End
            End
            Else Begin
                Move sLine to asBlockRaw[SizeOfArray(asBlockRaw)]
                If ((sLow = "end_constraints") or (sLow = "end_constraint")) Begin
                    // The ENTIRE block body moves verbatim and IN ORDER into OnConstrain - conditional
                    // constraints (If/Else around Constrain), declarations, AND any Report_* lines stay
                    // exactly where they were. A Report_Index parameter can be set by logic earlier in
                    // the block, so it must NOT be moved out.
                    Move (sIndent + "Procedure OnConstrain") to asOut[SizeOfArray(asOut)]
                    Move (sIndent + "    Forward Send OnConstrain") to asOut[SizeOfArray(asOut)]
                    Move (SizeOfArray(asBody) - 1) to iMax
                    For i from 0 to iMax
                        Move asBody[i] to asOut[SizeOfArray(asOut)]
                    Loop
                    Move (sIndent + "End_Procedure") to asOut[SizeOfArray(asOut)]
                    Move False to bInBlock
                End
                Else If (sTrim <> "") Begin
                    Move sLine to asBody[SizeOfArray(asBody)]
                End
            End
        Loop

        // Unterminated block (no End_Constraints): restore its raw lines unchanged so nothing breaks.
        If (bInBlock = True) Begin
            Move (SizeOfArray(asBlockRaw) - 1) to iMax
            For i from 0 to iMax
                Move asBlockRaw[i] to asOut[SizeOfArray(asOut)]
            Loop
            Move (iBlocks - 1) to iBlocks
        End

        Move asOut to asCode
        Function_Return iBlocks
    End_Function

    // ChangeDfTimerTocTimer - migrates safe dfTimer objects only. An object is left UNCHANGED with a
    // //TODO comment (human judgment needed) when it relied on auto-start (no 'Set Auto_Start_State to
    // False'), uses the Timer_Message dispatch, or uses its OnTimer params in the body. The per-object
    // rules live in _MigrateDfTimerBlock (cRefactorFuncLib); this function finds the objects, applies it,
    // and renames Timer_Active_State -> pbEnabled file-wide.
    { Published = True }
    { Description = """
        Migrates legacy 'Object ... is a dfTimer' objects to the modern cTimer: swaps the class, drops
        Auto_Start_State/Auto_Stop_State/Timer_object, renames Timeout -> piTimeout, strips the OnTimer
        params, and renames Timer_Active_State -> pbEnabled file-wide. Objects that need human judgment
        are left unchanged, each marked with a //TODO comment. Takes a whole source file as a string array.
        { MethodType = eOtherFunction }
        { SummaryText = Migrated: dfTimer -> cTimer }
        { ModRecipe = 4537 | class: DFTIMER }
        { FnGroup = Modernization }
        """ }
    Function ChangeDfTimerTocTimer String[] ByRef asCode String sParameter Returns Integer
        String[] asOut asBlock asMigrated asEmpty
        String sLine sLow sT0 sReason sIndent
        Integer iCount iSize iMigrated i iMax iDepth iPos iN iFound
        Boolean bInBlock
        tTokenizer TD

        Move 0 to iMigrated
        Move False to bInBlock
        Move 0 to iDepth
        Move (SizeOfArray(asCode)) to iSize
        Decrement iSize
        For iCount from 0 to iSize
            // Per-file progress: nudge the status panel's bar every ~20 lines so the current file shows
            // progress during this whole-file pass (no-op in batch mode / the test runner, where the
            // panel isn't active). Mirrors cUnicodePointerToString.
            If (Mod(iCount, 20) = 0 and (Active_State(ghoStatusPanel) = True)) Begin
                Send Update_StatusPanel of ghoStatusPanel ("Source line:" * String(iCount + 1) * "of:" * String(iSize + 1))
                Set piPosition of ghoProgressBar to (iCount + 1)
            End
            Move asCode[iCount] to sLine
            // Timer_Active_State -> pbEnabled, file-wide (DFTimer-specific external on/off switch, so
            // safe everywhere). Done first so refs inside a timer object are covered too.
            Move (Lowercase(sLine)) to sLow
            Move (Pos("timer_active_state", sLow)) to iPos
            If (iPos > 0) ;
                Move (Left(sLine, (iPos - 1)) + "pbEnabled" + Mid(sLine, Length(sLine), (iPos + 18))) to sLine
            Get Tokenizer of Self sLine to TD
            Move (SizeOfArray(TD.asLineTokens)) to iN
            Move "" to sT0
            If (iN > 0) ;
                Move (Lowercase(TD.asLineTokens[0])) to sT0

            If (bInBlock = False) Begin
                Move (SearchArray("dfTimer", TD.asLineTokens, Desktop, RefFunc(DFSTRICMP))) to iFound
                If ((sT0 = "object") and (iFound > -1)) Begin
                    // Open a dfTimer object; remember its indentation for any //TODO flag line.
                    Move True to bInBlock
                    Move 1 to iDepth
                    Move asEmpty to asBlock
                    Move sLine to asBlock[0]
                    Move (Pos(Trim(sLine), sLine)) to iPos
                    If (iPos > 1) ;
                        Move (Left(sLine, (iPos - 1))) to sIndent
                    Else ;
                        Move "" to sIndent
                End
                Else Begin
                    Move sLine to asOut[SizeOfArray(asOut)]
                End
            End
            Else Begin
                Move sLine to asBlock[SizeOfArray(asBlock)]
                If (sT0 = "object") ;
                    Increment iDepth
                If (sT0 = "end_object") Begin
                    Decrement iDepth
                    If (iDepth = 0) Begin
                        Get _MigrateDfTimerBlock of Self asBlock (&sReason) to asMigrated
                        If (sReason <> "") Begin
                            // Not safe to auto-migrate - leave the object verbatim, flag it for a human.
                            Move (sIndent + "//TODO dfTimer->cTimer (skipped): " + sReason) to asOut[SizeOfArray(asOut)]
                            Move (SizeOfArray(asBlock) - 1) to iMax
                            For i from 0 to iMax
                                Move asBlock[i] to asOut[SizeOfArray(asOut)]
                            Loop
                        End
                        Else Begin
                            Move (SizeOfArray(asMigrated) - 1) to iMax
                            For i from 0 to iMax
                                Move asMigrated[i] to asOut[SizeOfArray(asOut)]
                            Loop
                            Increment iMigrated
                        End
                        Move False to bInBlock
                    End
                End
            End
        Loop

        // Unterminated object (no matching End_Object): flush the buffered lines unchanged.
        If (bInBlock = True) Begin
            Move (SizeOfArray(asBlock) - 1) to iMax
            For i from 0 to iMax
                Move asBlock[i] to asOut[SizeOfArray(asOut)]
            Loop
        End

        Move asOut to asCode
        Function_Return iMigrated
    End_Function

    // ChangeSquareBracketsIndicators - limitation + extra examples (kept as // to keep the
    // {Description} under the meta-tag size limit):
    //   - Leaves the line unchanged if it contains a GROUP or ALL indicator directive.
    //   More examples:
    //   - While [Not Found]   -> e.g. While (Not(Found))
    //   - [Not Found] While   -> e.g. While (Not(Found))
    //   - If [Not Found] Reread hTable -> If (Not(Found)) Reread hTable
    //   - [~Found] Begin -> If (Not(Found)) Begin
    //   - [Found ~Found] Begin -> If (Found and Not(Found)) Begin
    { Published = True }
    { Description = """
        Changes legacy square brackets found indicators; [Found] [FindErr] to expressions; (Found) or (Not(Found))
        It does not change the 'Indicate' key word, only change square brackets to expressions.
        Paired with ChangeLegacyIndicators, which runs first but skips lines containing
        Find/Send/Constrain - THIS function sweeps those up, so reporting few or zero
        changed lines is NORMAL when both are selected.
        Sample Code:
          - [Found] and [FindErr] indicator statements to (Found) and (FindErr).
          - [Found| Command -> e.g. If (Found) Command
          - [FindErr] Send Rebuild_constraints of oDD -> If (FindErr) Send Rebuild_constraints of oDD
        { MethodType = eStandardFunction }
        { FnGroup = Modernization }
        { SummaryText = Changed: Square indicator expression [xxx] --> Paranthesis expression (xxx) }
        { EnumList = "eLeaveSelect, eModernizeSelect" }
        { InitialValue = eLeaveSelect }
        { ModRecipe = 4538 | without parentheses }
        { ParamHelp = eLeaveSelect keeps [SELECT] as-is (safe default). eModernizeSelect also needs AddUseOldFMACCommands selected (it defines the SELECT macro). }
        """ }
    Function ChangeSquareBracketsIndicators String ByRef sLine String sParameter Returns Boolean
        String sNewCode sVarName sExpression
        Boolean bFound bHasBracket bChanged
        Integer iStart iEnd iItem iLeftBracketNo iBracketTokenCount
        Boolean bSkip bModernizeSelect
        tTokenizer TokenizerData

        Get pTokenizer to TokenizerData
        If (TokenizerData.bLineIsReady = True or;
            TokenizerData.bIsInCommand = True or;
            TokenizerData.bIsInStruct  = True or;
            TokenizerData.bIsInImage   = True or;
            TokenizerData.bIsVariableDeclaration = True) Begin
            Function_Return False
        End
        Get HasBracket TokenizerData.BooleanIndicator to bHasBracket
        If (bHasBracket = False) Begin
            Function_Return False
        End

        // See ChangeLegacyIndicators: a LEADING bracket + If + Indicate 3-way compound cannot be safely
        // modernised on one line - converting the leading bracket here would yield "If (Found) If sCustCode
        // ne "" Indicate ..." (double-If garbage). Leave it unchanged. A leading bracket is token[0]; the
        // supported "If [bool] Indicate ..." (test 6) has token[0] = "If" and is untouched by this guard.
        If (SizeOfArray(TokenizerData.asLineTokens) > 0) Begin
            If (Left(TokenizerData.asLineTokens[0], 1) = "[" and ;
                TokenizerData.bHasIfCommand = True and ;
                (Lowercase(TokenizerData.sOverstrikeLine) contains (Lowercase(CS_Indicate) + CS_S))) ;
                Function_Return False
        End
        // We leave compound square bracket expessions combined withe keywords: "GROUP" and "ALL" alone:
        Move (SearchArray("GROUP", TokenizerData.asLineTokens, Desktop, RefFunc(DFSTRICMP))) to iItem
        If (iItem <> -1) Begin
            Function_Return False
        End
        Move (SearchArray("ALL", TokenizerData.asLineTokens, Desktop, RefFunc(DFSTRICMP))) to iItem
        If (iItem <> -1) Begin
            Function_Return False
        End

        // SELECT-handling gate. By default we respect CS_NonRefactorableIndicators and skip
        // lines whose bracket indicator has no valid modern bare form, leaving the harmless
        // [...] warning. The user opts in with eModernizeSelect when OldFMACCommands.pkg is
        // in the build, where bare Select compiles.
        // sParameter arrives as the enum NAME from the UI combo ("eModernizeSelect") or as
        // the numeric VALUE from tests - resolve via _ParameterIsEnum; a bare Move of the
        // name into the Integer enum left the gate at eLeaveSelect, so the opt-in never
        // worked from the UI (2026-06-10). NO num_arguments guard: it is unreliable here
        // (nested sends/dynamic engine dispatch can clobber it), and an omitted parameter
        // arrives as "" which _ParameterIsEnum already treats as no-match.
        Get _ParameterIsEnum sParameter "eModernizeSelect" eModernizeSelect to bModernizeSelect
        If (bModernizeSelect = False) Begin
            Get _IndicatorIsNonRefactorable TokenizerData to bSkip
            If (bSkip = True) ;
                Function_Return False
        End

        // Note: a bare-ified [Select] (eModernizeSelect) needs 'Use OldFMACCommands.pkg' added at the top
        // of the file - the companion AddUseOldFMACCommands (an eOtherFunction) does that by SCANNING the
        // rewritten file for the bare Select, so nothing needs to be flagged from here.

        // Count the genuine bracket indicator tokens in asLineTokens.
        // The tokeniser replaces parenthesised expressions with | pipes in asLineTokens,
        // so brackets that appear INSIDE a paren expression (e.g. an array index like
        // daPeriodDates[0]) are absent from asLineTokens.  Without this cap the while
        // loop below would use sOverstrikeLine — which does NOT mask paren content —
        // and would incorrectly treat array-index brackets as indicator brackets.
        Move 0 to iBracketTokenCount
        For iStart from 0 to (SizeOfArray(TokenizerData.asLineTokens) - 1)
            If (Left(TokenizerData.asLineTokens[iStart], 1) = "[") Begin
                Increment iBracketTokenCount
            End
        Loop

        Move TokenizerData.sOverstrikeLine to sNewCode
        Move 1 to iLeftBracketNo

        While (Pos("[", sNewCode) > 0 and iLeftBracketNo <= iBracketTokenCount)

            Move (Pos("[", sNewCode)) to iStart
            Move (Pos("]", sNewCode)) to iEnd
            Move (Mid(sNewCode, (iEnd - iStart -1), (iStart +1))) to sVarName
            // Convert bracketed indicators variables to an expression
            Get ConvertBracketIndicatorsToExpression iLeftBracketNo TokenizerData to sExpression
            Increment iLeftBracketNo

            // Handle negation cases
            If (sVarName <> "") Begin
                Move (Replace("[" + sVarName + "]", sNewCode, sExpression)) to sNewCode
            End
        Loop

        Get FixIndicatorsLoopRepeatCommand sNewCode to sNewCode
        // If the old expression started with a bracket, insert an "If" statement at start of line.
        If (Left(Trim(sNewCode), 1) = "(") Begin
            Move ("If" * String(sNewCode)) to sNewCode
        End

        Get RestoreOverstrikeLineValues sNewCode TokenizerData to sNewCode
        Get AssembleOutputLine sNewCode TokenizerData to sNewCode
        Move (sNewCode <> sLine) to bChanged
        Move sNewCode to sLine

        Function_Return bChanged
    End_Function

    // AddUseOldFMACCommands - the file-level companion to ChangeLegacyIndicators /
    // ChangeSquareBracketsIndicators. Those two (eStandardFunction, one line at a time) cannot add a
    // top-of-file definition themselves; under eModernizeSelect they bare-ify the legacy [Select] macro
    // indicator (e.g. [Select] -> (Select), Indicate Select as X -> Move (X) to Select). Bare SELECT only
    // compiles where the SELECT macro is defined.
    //
    // This eOtherFunction runs AFTER the line-by-line pass on the SAME file (see cRefactorEngine), so by
    // the time it sees asCode the legacy [Select] has ALREADY become the modern bare Select - there is no
    // [Select] left to look for. It therefore SCANS the rewritten code for a bare, boundary-aware
    // 'Select' token in real code and, when found, splices a guarded SELECT-macro definition near the top:
    //     #IFNDEF SELECT
    //         #Replace SELECT |!C
    //     #ENDIF
    // - the SAME definition the legacy REPORT command macro uses. It does NOT add 'Use OldFMACCommands.pkg':
    // that only makes the REPORT macro available, and OldFMACCommands.pkg defines SELECT ONLY if REPORT is
    // actually invoked - so a (Select) in a REPORT-less file would still fail to compile (the bug Nils hit).
    // The IFNDEF guard makes the shim idempotent AND conflict-free: a no-op in a file that already defines
    // SELECT (e.g. one that does use REPORT). The scan is the trigger - a per-file flag cannot be, because
    // the engine sends ClearFuncLibProperties before EVERY eOtherFunction (it would wipe any flag the
    // indicators raised during the line-by-line pass). Reading the final text also means it works when the
    // indicators were run in an earlier, separate run.
    //
    // String/comment safety: the scan reads the MASKED line (string literals overstruck) and skips
    // comment, blank, image and multi-line-string lines, so a SQL 'SELECT' inside a "..." literal or an
    // @SQL"""...""" / ; -continuation block can never trigger it; the word-boundary match also excludes
    // Selected / Select_State / Selection. Idempotent (skips a file that already has a #Replace SELECT),
    // and a no-op when no bare Select is present.
    { Published = True }
    { Description = """
        Defines the bare 'Select' macro indicator left behind when ChangeLegacyIndicators /
        ChangeSquareBracketsIndicators modernise a legacy [Select] under eModernizeSelect. Splices a guarded
        SELECT-macro definition near the top of the file (an IFNDEF-guarded Replace) - NOT a Use line, since
        OldFMACCommands.pkg defines SELECT only via the REPORT macro. Scans the rewritten code for a bare
        Select, string/comment-safe; run it with those two, or after. No-op when none is found or the
        definition is already present.
        { MethodType = eOtherFunction }
        { FnGroup = Modernization }
        { SummaryText = Defined: SELECT macro }
        { ModRecipe = 4345 | SELECT, MUST BE DEFINED }
        """ }
    Function AddUseOldFMACCommands String[] ByRef asCode String sParameter Returns Integer
        String[] asOut asShim
        String sLine sLC
        Integer iCount iSize iInsertAt iLastUse iFirstCode iSelectPos iShim
        Boolean bNeeds bAlreadyDefined bSeenCode bIsUseOrInc bInserted bSkipLine
        tTokenizer TD

        Move (SizeOfArray(asCode) - 1) to iSize
        If (iSize < 0) ;
            Function_Return 0

        Move False to bNeeds
        Move False to bAlreadyDefined
        Move False to bSeenCode
        Move -1 to iLastUse
        Move -1 to iFirstCode

        // ONE ordered pass (tokeniser is stateful, so top-to-bottom): detect the modernised bare Select
        // indicator (the reason to define the macro), note an existing '#Replace SELECT' definition, and
        // locate the top-of-file insertion point - after the leading Use/#include block, else before the
        // first real code line (so the macro precedes every use, and never lands inside a header comment).
        For iCount from 0 to iSize
            // Per-file progress nudge; no-op when no panel is active. Mirrors ChangeDfTimerTocTimer.
            If (Mod(iCount, 20) = 0 and (Active_State(ghoStatusPanel) = True)) Begin
                Send Update_StatusPanel of ghoStatusPanel ("Source line:" * String(iCount + 1) * "of:" * String(iSize + 1))
                Set piPosition of ghoProgressBar to (iCount + 1)
            End
            Move asCode[iCount] to sLine
            Get Tokenizer of Self sLine to TD

            // An existing '#Replace SELECT ...' directive (our prior shim, or a hand-written define) means
            // SELECT is already defined in-source -> nothing to add. A REPORT-using file has NO such line
            // in its source (REPORT defines SELECT inside the macro), so we still add the guarded shim,
            // which the IFNDEF then makes a no-op at compile time. (Note: 'Use OldFMACCommands.pkg' is NOT
            // a marker - it does not define SELECT on its own, so a file with only that line still needs us.)
            Move (Lowercase(Trim(sLine))) to sLC
            If ((Left(sLC, 8) = "#replace") and (sLC contains "select")) ;
                Move True to bAlreadyDefined

            // Detect the modernised bare Select indicator. Skip lines that are NOT real code - comment,
            // blank, image page, or part of a multi-line string (the latter is where a multi-line SQL
            // SELECT lives, per tTokenizer.bIsInDF23MultiLineString) - so such a 'SELECT' never triggers.
            // On the remaining code lines, search the MASKED line (indentation + overstrike, position-
            // aligned, with string literals blanked) boundary-aware: (Select) / Not(Select) / "to Select"
            // all match, while Selected / Select_State / Selection and a 'SELECT' inside a "..." literal
            // do not. Stop searching once found.
            Move (TD.bIsComment = True or TD.bIsBlank = True or TD.bIsInImage = True or TD.bIsInDF23MultiLineString = True) to bSkipLine
            If (bNeeds = False and bSkipLine = False) Begin
                Get _FindKeywordPos (TD.sIndentation + TD.sOverstrikeLine) CS_Select True 1 to iSelectPos
                If (iSelectPos > 0) ;
                    Move True to bNeeds
            End

            If (bSeenCode = False) Begin
                Get _IsUseOrIncludeLine sLine to bIsUseOrInc
                If (bIsUseOrInc = True) Begin
                    Move iCount to iLastUse
                End
                Else If (TD.bIsComment = False and TD.bIsBlank = False) Begin
                    Move iCount to iFirstCode
                    Move True to bSeenCode
                End
            End
        Loop

        // No bare Select anywhere -> nothing to do. Already defined -> idempotent no-op.
        If (bNeeds = False) ;
            Function_Return 0
        If (bAlreadyDefined = True) ;
            Function_Return 0

        // The guarded SELECT-macro shim to splice in: a // comment + the IFNDEF/Replace/ENDIF block. The
        // IFNDEF guard makes it idempotent and conflict-free (a no-op in a file that already defines SELECT,
        // e.g. one using REPORT). This REPLACES the old 'Use OldFMACCommands.pkg' line, which only made
        // REPORT available and did NOT define bare SELECT on its own. The #Replace line comes from
        // CS_SelectMacroDefineLine - its |!C is built from Character() codes because |!C is a compile-time
        // counter that a literal "|!C" in our source would evaluate here instead of emitting verbatim.
        Move "// SELECT macro defined by DFRefactor (OldFMACCommands.pkg defines it only via REPORT); IFNDEF-guarded, a no-op if already defined." to asShim[0]
        Move "#IFNDEF SELECT"        to asShim[1]
        Move CS_SelectMacroDefineLine to asShim[2]
        Move "#ENDIF"                to asShim[3]

        // Splice point: after the last leading Use/#include; else before the first code line; else top -
        // always before the first real code, so the #Replace precedes every (Select) use.
        If (iLastUse >= 0) ;
            Move (iLastUse + 1) to iInsertAt
        Else If (iFirstCode >= 0) ;
            Move iFirstCode to iInsertAt
        Else ;
            Move 0 to iInsertAt

        Move False to bInserted
        For iCount from 0 to iSize
            If (iCount = iInsertAt) Begin
                For iShim from 0 to (SizeOfArray(asShim) - 1)
                    Move asShim[iShim] to asOut[SizeOfArray(asOut)]
                Loop
                Move True to bInserted
            End
            Move asCode[iCount] to asOut[SizeOfArray(asOut)]
        Loop
        // Insertion point past the last line (all-preamble file): append the shim.
        If (bInserted = False) Begin
            For iShim from 0 to (SizeOfArray(asShim) - 1)
                Move asShim[iShim] to asOut[SizeOfArray(asOut)]
            Loop
        End

        Move asOut to asCode
        Function_Return 1
    End_Function

    { Published = True }
    { Description = """
        Changes legacy Sysdate4 command to Sysdate command.
        Example: Sysdate4 dDate -> Sysdate dDate
        { MethodType = eStandardFunction }
        { FnGroup = Modernization }
        { SummaryText = Changed: Sysdate4 command to Sysdate }
        { ModRecipe = 4533 | command: Sysdate4 }
        """ }
    Function ChangeSysdate4 String ByRef sLine String sParameter Returns Boolean
        Boolean bFound
        Integer iPos
        tTokenizer TokenizerData
        tToken Token

        Get pTokenizer to TokenizerData
        If (TokenizerData.bLineIsReady = True or TokenizerData.bIsInCommand = True or ;
            TokenizerData.bIsInImage = True or TokenizerData.bIsVariableDeclaration = True) Begin
            Function_Return False
        End

        Move TokenizerData.FirstLeftCommand to Token
        Move (Lowercase(Token.sCode) = Lowercase(CS_Sysdate4)) to bFound
        If (bFound = False) Begin
            Move TokenizerData.SecondLeftCommand to Token
            Move (Lowercase(Token.sCode) = Lowercase(CS_Sysdate4)) to bFound
            If (bFound = False) Begin
                Function_Return False
            End
        End

        // Remove the keyword's OWN trailing "4" positionally - a bare
        // Replace("4", ...) eats the FIRST "4" anywhere on the line (a "4"
        // in a variable or expression before the command; 2026-06-10 audit).
        // Locate the keyword boundary-aware on the MASKED line (position-
        // aligned with sLine) and splice that exact character out.
        Get _FindKeywordPos (TokenizerData.sIndentation + TokenizerData.sOverstrikeLine) CS_Sysdate4 True 1 to iPos
        If (iPos = 0) ;
            Function_Return False
        Move (Left(sLine, (iPos + Length(CS_Sysdate4) - 2)) + Mid(sLine, CI_EOL, (iPos + Length(CS_Sysdate4)))) to sLine
        Function_Return True
    End_Function

    { Published = True }
    { Description = """
        Changes lecacy Trim command with function Trim.
        Example: Trim sVal to sVal -> Move (Trim(sVal)) to sVal
        { MethodType = eStandardFunction }
        { FnGroup = Modernization }
        { SummaryText = Changed: Trim command to function Trim }
        { ModRecipe = 4531 | command: Trim }
        """ }
    Function ChangeTrimCommandToFunction String ByRef sLine String sParameter Returns Boolean
        Boolean bFound
        Integer iPos iStart iTrimPos iArgStart iArgEnd iToPos
        tTokenizer TokenizerData
        String sOverFull sCh

        Get pTokenizer to TokenizerData
        If (TokenizerData.bLineIsReady = True or TokenizerData.bIsInCommand = True or ;
            TokenizerData.bIsInImage = True or TokenizerData.bIsVariableDeclaration = True) Begin
            Function_Return False
        End

        Get IsKeywordInLine CS_Trim TokenizerData.asLineTokens to bFound
        If (bFound = False) Begin
            Function_Return False
        End

        // Work on the MASKED line (indentation + overstrike) - position-aligned with sLine,
        // with string content hidden, so a "Trim"/"to" inside a literal can never match.
        Move (TokenizerData.sIndentation + TokenizerData.sOverstrikeLine) to sOverFull

        // Locate the legacy Trim COMMAND: a boundary-aware "Trim" FOLLOWED BY WHITESPACE.
        // A "Trim(" function call has "(" right after the name, so it is never taken as the
        // command - that is what keeps a Trim(...) call on the same line untouched.
        Move 1 to iStart
        Move 0 to iTrimPos
        While (iTrimPos = 0)
            Get _FindKeywordPos sOverFull CS_Trim True iStart to iPos
            If (iPos = 0) ;
                Function_Return False
            Move (Mid(sOverFull, 1, (iPos + Length(CS_Trim)))) to sCh
            If (sCh = CS_S or sCh = Character(9)) ;
                Move iPos to iTrimPos
            Else ;
                Move (iPos + 1) to iStart
        Loop

        // Argument = the RAW text from the first non-blank after "Trim" up to the command
        // "to". Extracting by POSITION (not asLineTokens[next]) captures ANY argument shape -
        // a simple var, a table.field (USER.SPRAK), or a parenthesised expression
        // (Trim (Val(hDD,"X")) to y). The old single-token grab missed the paren form and
        // corrupted the dotted form into "Move (Trim(USER)).SPRAK" (Nils 2026-06-11).
        Move (iTrimPos + Length(CS_Trim)) to iArgStart
        While (iArgStart <= Length(sOverFull) and (Mid(sOverFull, 1, iArgStart) = CS_S or Mid(sOverFull, 1, iArgStart) = Character(9)))
            Increment iArgStart
        Loop

        Get _FindKeywordPos sOverFull CS_To True iArgStart to iToPos
        If (iToPos = 0 or iToPos <= iArgStart) ;
            Function_Return False

        // Last non-blank before "to" = the argument's end; the gap before "to" is kept verbatim.
        Move (iToPos - 1) to iArgEnd
        While (iArgEnd >= iArgStart and (Mid(sOverFull, 1, iArgEnd) = CS_S or Mid(sOverFull, 1, iArgEnd) = Character(9)))
            Decrement iArgEnd
        Loop
        If (iArgEnd < iArgStart) ;
            Function_Return False

        // Rebuild on the RAW line: <indent/nose> + Move (Trim(<arg>)) + <original gap> to <dest>.
        Move (Left(sLine, (iTrimPos - 1)) + CS_Move + " (" + CS_Trim + "(" + Mid(sLine, (iArgEnd - iArgStart + 1), iArgStart) + "))" + Mid(sLine, CI_EOL, (iArgEnd + 1))) to sLine
        Function_Return True
    End_Function

    // Generic "<Cmd> <arg> to <dest>" -> "Move (<Cmd>(<arg>)) to <dest>" rewrite for a single-argument
    // legacy string command (Uppercase, Lowercase, ...). Same robust approach as ChangeTrimCommandToFunction,
    // generalised by the keyword: the argument is extracted by POSITION (raw text from after the command
    // keyword up to the command "to"), so any shape survives - a simple var, a table.field (USER.SPRAK),
    // or a parenthesised expression. A "<Cmd>(" function CALL is left untouched (the keyword must be
    // FOLLOWED BY WHITESPACE, not "("). Requires an explicit "to <dest>".
    Function _SingleArgCommandToFunction String ByRef sLine String sKeyWord Returns Boolean
        Boolean bFound
        Integer iPos iStart iCmdPos iArgStart iArgEnd iToPos
        tTokenizer TokenizerData
        String sOverFull sCh

        Get pTokenizer to TokenizerData
        If (TokenizerData.bLineIsReady = True or TokenizerData.bIsInCommand = True or ;
            TokenizerData.bIsInImage = True or TokenizerData.bIsVariableDeclaration = True) Begin
            Function_Return False
        End

        Get IsKeywordInLine sKeyWord TokenizerData.asLineTokens to bFound
        If (bFound = False) Begin
            Function_Return False
        End

        // Work on the MASKED line (indentation + overstrike) - position-aligned with sLine, string
        // content hidden, so a keyword/"to" inside a literal can never match.
        Move (TokenizerData.sIndentation + TokenizerData.sOverstrikeLine) to sOverFull

        // Locate the legacy COMMAND: a boundary-aware keyword FOLLOWED BY WHITESPACE (a "<Cmd>(" call
        // has "(" right after the name, so it is never taken as the command - keeps a call untouched).
        Move 1 to iStart
        Move 0 to iCmdPos
        While (iCmdPos = 0)
            Get _FindKeywordPos sOverFull sKeyWord True iStart to iPos
            If (iPos = 0) ;
                Function_Return False
            Move (Mid(sOverFull, 1, (iPos + Length(sKeyWord)))) to sCh
            If (sCh = CS_S or sCh = Character(9)) ;
                Move iPos to iCmdPos
            Else ;
                Move (iPos + 1) to iStart
        Loop

        // Argument = RAW text from the first non-blank after the keyword up to the command "to".
        Move (iCmdPos + Length(sKeyWord)) to iArgStart
        While (iArgStart <= Length(sOverFull) and (Mid(sOverFull, 1, iArgStart) = CS_S or Mid(sOverFull, 1, iArgStart) = Character(9)))
            Increment iArgStart
        Loop

        Get _FindKeywordPos sOverFull CS_To True iArgStart to iToPos
        If (iToPos = 0 or iToPos <= iArgStart) ;
            Function_Return False

        // Last non-blank before "to" = the argument's end; the gap before "to" is kept verbatim.
        Move (iToPos - 1) to iArgEnd
        While (iArgEnd >= iArgStart and (Mid(sOverFull, 1, iArgEnd) = CS_S or Mid(sOverFull, 1, iArgEnd) = Character(9)))
            Decrement iArgEnd
        Loop
        If (iArgEnd < iArgStart) ;
            Function_Return False

        // Rebuild on the RAW line: <indent/nose> + Move (<Cmd>(<arg>)) + <original gap> to <dest>.
        Move (Left(sLine, (iCmdPos - 1)) + CS_Move + " (" + sKeyWord + "(" + Mid(sLine, (iArgEnd - iArgStart + 1), iArgStart) + "))" + Mid(sLine, CI_EOL, (iArgEnd + 1))) to sLine
        Function_Return True
    End_Function

    { Published = True }
    { Description = """
        Changes legacy Uppercase command to the Uppercase function.
        Example: Uppercase sVal to sVal -> Move (Uppercase(sVal)) to sVal
        { MethodType = eStandardFunction }
        { FnGroup = Modernization }
        { SummaryText = Changed: Uppercase command to function Uppercase }
        { ModRecipe = 4531 | command: Uppercase }
        """ }
    Function ChangeUppercaseCommandToFunction String ByRef sLine String sParameter Returns Boolean
        Boolean bChanged
        Get _SingleArgCommandToFunction (&sLine) CS_Uppercase to bChanged
        Function_Return bChanged
    End_Function

    { Published = True }
    { Description = """
        Changes legacy Lowercase command to the Lowercase function.
        Example: Lowercase sVal to sVal -> Move (Lowercase(sVal)) to sVal
        { MethodType = eStandardFunction }
        { FnGroup = Modernization }
        { SummaryText = Changed: Lowercase command to function Lowercase }
        { ModRecipe = 4531 | command: Lowercase }
        """ }
    Function ChangeLowercaseCommandToFunction String ByRef sLine String sParameter Returns Boolean
        Boolean bChanged
        Get _SingleArgCommandToFunction (&sLine) CS_Lowercase to bChanged
        Function_Return bChanged
    End_Function

    { Published = True }
    { Description = """
        Changes legacy Get Create U_Class to: Get Create (RefClass(Class))
        { MethodType = eStandardFunction }
        { FnGroup = Modernization }
        { SummaryText = Changed: 'Create U_Class' to 'Create (RefClass(Class))' }
        """ }
    Function ChangeUClassToRefClass String ByRef sLine String sParameter Returns Boolean
        Boolean bChanged bValid bIgnore
        String sTest sClassName sOldStyle sNewStyle
        Integer iPos
        tTokenizer TokenizerData

        Get pTokenizer to TokenizerData
        If (TokenizerData.bLineIsReady = True or TokenizerData.bIsInCommand = True or ;
            TokenizerData.bIsInImage = True or TokenizerData.bIsVariableDeclaration = True) Begin
            Function_Return False
        End
        Move False to bChanged
        Move "" to sClassName
        Move (Lowercase(sLine)) to sTest
        Move (Replaces(Character(9), sTest, CS_S)) to sTest // tab
        Get TrimInsideSpaces sTest to sTest
        // Two lines which are mostly for protection when running DfRefactor on the DfRefactor code itself
        Get _RemoveEndComment sTest to sTest                // Don't rewrite this in a comment
        Get RemoveStringsFromLine sTest to sTest            // If this is in a string then obviously leave it alone too
        If (Pos(" create u_", sTest)) Begin
            Move (Lowercase(sLine)) to sTest
            // Locate the U_ class token on the MASKED line (position-aligned
            // with sLine) with a LEFT boundary only - "u_" is a PREFIX, so
            // bWholeWord is False. A bare Pos could land inside an earlier
            // identifier ("hU_x") or a string literal and rewrite the wrong
            // text (2026-06-10 audit).
            Get _FindKeywordPos (TokenizerData.sIndentation + TokenizerData.sOverstrikeLine) "u_" False 1 to iPos
            Get IsValidClassCharacter sTest iPos to bValid
            While (bValid)
                Move (sClassName + Mid(sLine, 1, iPos)) to sClassName
                Increment iPos
                Get IsValidClassCharacter sTest iPos to bValid
            Loop
        End
        If (sClassName <> "") Begin
            Move True to bChanged
            Move sClassName to sOldStyle
            Move (Right(sClassName, Length(sClassName) - 2)) to sClassName // strip away the "U_"
            Move ("(RefClass(" + sClassName + "))") to sNewStyle
            Move (Replace(sOldStyle, sLine, sNewStyle)) to sLine
        End
        Function_Return bChanged
    End_Function

    { Published = True }
    { Description = """
        Changes legacy ZeroString command with function ZeroString.
        Example: ZeroString iLength to sParameter --> Move (ZeroString(iLength)) to sParameter
        { MethodType = eStandardFunction }
        { FnGroup = Modernization }
