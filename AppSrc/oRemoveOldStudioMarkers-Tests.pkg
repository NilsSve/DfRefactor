        End_Procedure

        // Regular code line: not a marker, bChanged must be False, line unchanged.
        {Published = True}
        Procedure RemoveOldStudioMarkers_NoChange
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move x to y' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveOldStudioMarkers of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Move x to y' sLine
        End_Procedure

    End_Object
