// oRefactorDbListTocDbCJGridPromptList-Tests.pkg
//
// Unit tests for cDbListTocDbCJGridPromptList.pkg
// (data-aware legacy dbList -> cDbCJGridPromptList subclass of cDbGridTocDbCJGrid).
// Included by oUnit_Tests.pkg inside the oRefactorFuncLib_Tests fixture object.
//
// Test groups:
//   oListClassDetection          - IsGridDeclaration (dblist pattern + exact match)
//   oListClassRename             - end-to-end class rename dbList -> cDbCJGridPromptList
//   oSelectionPropTranslation    - IsTranslatableGridProperty + TranslateGridProperty
//   oPromptCallbackHint          - one-time Prompt_Callback TODO header emission
//   oInheritedColumnConversion   - inherited Begin_Row/Entry_Item + Main_File handling

Use cDbListTocDbCJGridPromptList.pkg

Object oRefactorDbListTocDbCJGridPromptList is a cTestFixture
    Set psFunctionName to "RefactorDbListTocDbCJGridPromptList"

    // -----------------------------------------------------------------------
    // oListClassDetection - IsGridDeclaration
    // -----------------------------------------------------------------------
    Object oListClassDetection is a cTestFixture
        Set psFunctionName to "IsGridDeclaration (cDbListTocDbCJGridPromptList)"

        Object oWorker is a cDbListTocDbCJGridPromptList
        End_Object

        Procedure TearDown
            Boolean bOK
            Get ParseAndSetParameter of oWorker "" to bOK
            Send _InitializeFuncLib of ghoFuncLib
        End_Procedure

        {Published = True}
        { Description = "Bare 'dbList' class is detected by pattern" }
        Procedure DbList_DetectedByPattern
            Boolean bResult
            Get IsGridDeclaration of oWorker "object osel1 is a dblist" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "Any class ending in 'dblist' is detected by pattern" }
        Procedure CustomDbList_DetectedByPattern
            Boolean bResult
            Get IsGridDeclaration of oWorker "object osel1 is a cmydblist" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "A 'dbgrid' class is NOT detected by the dblist converter" }
        Procedure DbGrid_NotDetected
            Boolean bResult
            Get IsGridDeclaration of oWorker "object ogrid1 is a dbgrid" to bResult
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        { Description = "A non-list object is NOT detected" }
        Procedure NonList_NotDetected
            Boolean bResult
            Get IsGridDeclaration of oWorker "object oform1 is a cdbform" to bResult
            Send AssertFalse bResult
        End_Procedure

        {Published = True}
        { Description = "With explicit sParameter, exact class match is used (custom name)" }
        Procedure ExactMatch_CustomClass
            Boolean bResult bOK
            Get ParseAndSetParameter of oWorker "cMyList,cDbCJGridPromptList" to bOK
            Get IsGridDeclaration of oWorker "object o1 is a cmylist" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "With explicit sParameter, the 'dblist' pattern is NOT used" }
        Procedure ExactMatch_PatternDisabled
            Boolean bResult bOK
            Get ParseAndSetParameter of oWorker "cMyList,cDbCJGridPromptList" to bOK
            Get IsGridDeclaration of oWorker "object o1 is a dblist" to bResult
            Send AssertFalse bResult
        End_Procedure

    End_Object

    // -----------------------------------------------------------------------
    // oListClassRename - end-to-end class rename
    // -----------------------------------------------------------------------
    Object oListClassRename is a cTestFixture
        Set psFunctionName to "ClassRename (cDbListTocDbCJGridPromptList)"

        Object oWorker is a cDbListTocDbCJGridPromptList
        End_Object

        Procedure TearDown
            Boolean bOK
            Get ParseAndSetParameter of oWorker "" to bOK
            Send _InitializeFuncLib of ghoFuncLib
        End_Procedure

        Function RunTransform_as String[] asInput Returns String[]
            String[] asOutput
            Integer  iGrids
            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Get pasSource of oWorker to asOutput
            Function_Return asOutput
        End_Function

        {Published = True}
        { Description = "dbList class name is replaced with cDbCJGridPromptList" }
        Procedure ClassNameReplaced
            String[] asInput asOutput
            Integer  iGrids

            Move "Object oSelectCustomer is a dbList" to asInput[0]
            Move "End_Object"                          to asInput[1]

            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Get pasSource of oWorker to asOutput

            Send AssertIAreEqual 1 iGrids
            Send Assert (Lowercase(asOutput[0]) contains "is a cdbcjgridpromptlist")
        End_Procedure

        {Published = True}
        { Description = "Returns 0 and leaves source unchanged for non-list object" }
        Procedure NonList_Unchanged
            String[] asInput asOutput
            Integer  iGrids

            Move "Object oForm1 is a cDbForm" to asInput[0]
            Move "End_Object"                 to asInput[1]

            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Get pasSource of oWorker to asOutput

            Send AssertIAreEqual 0 iGrids
            Send AssertSAreEqual "Object oForm1 is a cDbForm" asOutput[0]
        End_Procedure

    End_Object

    // -----------------------------------------------------------------------
    // oSelectionPropTranslation - dbList selection-behaviour properties
    // -----------------------------------------------------------------------
    Object oSelectionPropTranslation is a cTestFixture
        Set psFunctionName to "SelectionPropTranslation (cDbListTocDbCJGridPromptList)"

        Object oWorker is a cDbListTocDbCJGridPromptList
        End_Object

        Procedure TearDown
            Boolean bOK
            Get ParseAndSetParameter of oWorker "" to bOK
            Send _InitializeFuncLib of ghoFuncLib
        End_Procedure

        // Wrap one Set line inside a minimal dbList and return the output.
        Function RunOneProp String sSetLine Returns String[]
            String[] asInput asOutput
            Integer  iGrids
            Move "Object oSel is a dbList" to asInput[0]
            Move ("    " + sSetLine)       to asInput[1]
            Move "End_Object"              to asInput[2]
            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Get pasSource of oWorker to asOutput
            Function_Return asOutput
        End_Function

        Function OutputContains String[] asOutput String sNeedle Returns Boolean
            Integer iIdx
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains sNeedle) Function_Return True
            Loop
            Function_Return False
        End_Function

        // --- IsTranslatableGridProperty direct unit tests ---

        {Published = True}
        { Description = "Auto_Server_State is recognised as translatable" }
        Procedure AutoServer_IsTranslatable
            Boolean bResult
            Get IsTranslatableGridProperty of oWorker "set auto_server_state to true" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "Auto_Index_State is recognised as translatable (intercepted before base removal)" }
        Procedure AutoIndex_IsTranslatable
            Boolean bResult
            Get IsTranslatableGridProperty of oWorker "set auto_index_state to true" to bResult
            Send Assert bResult
        End_Procedure

        {Published = True}
        { Description = "A non-dbList Set property still delegates to the base (highlight_row_state)" }
        Procedure BaseProp_StillTranslatable
            Boolean bResult
            Get IsTranslatableGridProperty of oWorker "set highlight_row_state to true" to bResult
            Send Assert bResult
        End_Procedure

        // --- End-to-end translation ---

        {Published = True}
        { Description = "Auto_Server_State True -> Set pbAutoServer to True" }
        Procedure AutoServer_Mapped
            String[] asOutput
            Boolean  bFound
            Get RunOneProp "Set Auto_Server_State to True" to asOutput
            Get OutputContains asOutput "Set pbAutoServer to True" to bFound
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Auto_Column_State False -> Set pbAutoColumn to False" }
        Procedure AutoColumn_Mapped
            String[] asOutput
            Boolean  bFound
            Get RunOneProp "Set Auto_Column_State to False" to asOutput
            Get OutputContains asOutput "Set pbAutoColumn to False" to bFound
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Popup_Search_State True -> Set pbAutoSearch to True" }
        Procedure PopupSearch_Mapped
            String[] asOutput
            Boolean  bFound
            Get RunOneProp "Set Popup_Search_State to True" to asOutput
            Get OutputContains asOutput "Set pbAutoSearch to True" to bFound
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Export_Item_State True -> Set peUpdateMode to umPromptValue + TODO" }
        Procedure ExportItem_MappedToUpdateMode
            String[] asOutput
            Boolean  bMode bTodo
            Get RunOneProp "Set Export_Item_State to True" to asOutput
            Get OutputContains asOutput "Set peUpdateMode to umPromptValue" to bMode
            Get OutputContains asOutput "// TODO: dbList Export_Item_State" to bTodo
            Send Assert (bMode and bTodo)
        End_Procedure

        {Published = True}
        { Description = "Auto_Index_State -> TODO comment only (no silent removal)" }
        Procedure AutoIndex_TodoOnly
            String[] asOutput
            Boolean  bFound
            Get RunOneProp "Set Auto_Index_State to True" to asOutput
            Get OutputContains asOutput "// TODO: dbList Auto_Index_State" to bFound
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Move_Value_Out_State -> TODO comment mentioning umPromptNonInvoking" }
        Procedure MoveValueOut_TodoOnly
            String[] asOutput
            Boolean  bFound
            Get RunOneProp "Set Move_Value_Out_State to False" to asOutput
            Get OutputContains asOutput "umPromptNonInvoking" to bFound
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Auto_Shadow_State -> TODO comment only" }
        Procedure AutoShadow_TodoOnly
            String[] asOutput
            Boolean  bFound
            Get RunOneProp "Set Auto_Shadow_State to True" to asOutput
            Get OutputContains asOutput "// TODO: dbList Auto_Shadow_State" to bFound
            Send Assert bFound
        End_Procedure

        {Published = True}
        { Description = "Auto_Label_State -> TODO comment only" }
        Procedure AutoLabel_TodoOnly
            String[] asOutput
            Boolean  bFound
            Get RunOneProp "Set Auto_Label_State to True" to asOutput
            Get OutputContains asOutput "// TODO: dbList Auto_Label_State" to bFound
            Send Assert bFound
        End_Procedure

    End_Object

    // -----------------------------------------------------------------------
    // oPromptCallbackHint - one-time Prompt_Callback TODO header
    // -----------------------------------------------------------------------
    Object oPromptCallbackHint is a cTestFixture
        Set psFunctionName to "PromptCallbackHint (cDbListTocDbCJGridPromptList)"

        Object oWorker is a cDbListTocDbCJGridPromptList
        End_Object

        Procedure TearDown
            Boolean bOK
            Get ParseAndSetParameter of oWorker "" to bOK
            Send _InitializeFuncLib of ghoFuncLib
        End_Procedure

        {Published = True}
        { Description = "A converted dbList emits the Prompt_Callback / peUpdateMode TODO header once" }
        Procedure PromptCallbackHint_Emitted
            String[] asInput asOutput
            Integer  iGrids iIdx iCallback iMode

            Move "Object oSel is a dbList"                to asInput[0]
            Move "    Set Main_File to Customer.File_Number" to asInput[1]
            Move "    Begin_Row"                           to asInput[2]
            Move "        Entry_Item Customer.Name"        to asInput[3]
            Move "    End_Row"                             to asInput[4]
            Move "End_Object"                              to asInput[5]

            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Get pasSource of oWorker to asOutput

            Move 0 to iCallback
            Move 0 to iMode
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains "Prompt_Callback") Increment iCallback
                If (asOutput[iIdx] contains "umPromptValue")   Increment iMode
            Loop
            // Emitted exactly once (one-time per converted list).
            Send AssertIAreEqual 1 iCallback
            Send Assert (iMode >= 1)
        End_Procedure

    End_Object

    // -----------------------------------------------------------------------
    // oInheritedColumnConversion - inherited dbGrid->cDbCJGrid machinery
    // -----------------------------------------------------------------------
    Object oInheritedColumnConversion is a cTestFixture
        Set psFunctionName to "InheritedColumnConversion (cDbListTocDbCJGridPromptList)"

        Object oWorker is a cDbListTocDbCJGridPromptList
        End_Object

        Procedure TearDown
            Boolean bOK
            Get ParseAndSetParameter of oWorker "" to bOK
            Send _InitializeFuncLib of ghoFuncLib
        End_Procedure

        Function OutputContains String[] asOutput String sNeedle Returns Boolean
            Integer iIdx
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (asOutput[iIdx] contains sNeedle) Function_Return True
            Loop
            Function_Return False
        End_Function

        {Published = True}
        { Description = "Entry_Item becomes a cDbCJGridColumn child object (inherited behaviour)" }
        Procedure EntryItem_BecomesColumnObject
            String[] asInput asOutput
            Integer  iGrids
            Boolean  bColObj bEntry

            Move "Object oSel is a dbList"            to asInput[0]
            Move "    Begin_Row"                       to asInput[1]
            Move "        Entry_Item Customer.Name"    to asInput[2]
            Move "    End_Row"                         to asInput[3]
            Move "End_Object"                          to asInput[4]

            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Get pasSource of oWorker to asOutput

            Send AssertIAreEqual 1 iGrids
            Get OutputContains asOutput "is a cDbCJGridColumn" to bColObj
            Get OutputContains asOutput "Entry_Item Customer.Name" to bEntry
            Send Assert (bColObj and bEntry)
        End_Procedure

        {Published = True}
        { Description = "Set Main_File is commented out with a Set Server hint (inherited behaviour)" }
        Procedure MainFile_CommentedWithServerHint
            String[] asInput asOutput
            Integer  iGrids iIdx
            Boolean  bMainCommented bServerHint

            Move "Object oSel is a dbList"                   to asInput[0]
            Move "    Set Main_File to Customer.File_Number"  to asInput[1]
            Move "    Begin_Row"                              to asInput[2]
            Move "        Entry_Item Customer.Name"           to asInput[3]
            Move "    End_Row"                                to asInput[4]
            Move "End_Object"                                 to asInput[5]

            Set pasSource of oWorker to asInput
            Get TransformSource of oWorker to iGrids
            Get pasSource of oWorker to asOutput

            Move False to bMainCommented
            Move False to bServerHint
            For iIdx from 0 to (SizeOfArray(asOutput) - 1)
                If (Lowercase(asOutput[iIdx]) contains "// set main_file") Move True to bMainCommented
                If (Lowercase(asOutput[iIdx]) contains "set server to ocustomer_dd") Move True to bServerHint
            Loop
            Send Assert (bMainCommented and bServerHint)
        End_Procedure

    End_Object

End_Object
