    Object oRemoveMultipleBlankLines is a cTestFixture
        Set psFunctionName to "RemoveMultipleBlankLines"

        {Published = True}
        Procedure RemoveMultipleBlankLines_1
            String sLine sExpected
            Boolean bChanged
            Integer iItem
            String[] asCode asExpected

            Move 0 to iItem
            Move "    Use SQL.pkg" to asCode[iItem]
            Increment iItem
            Move "    " to asCode[iItem]
            Increment iItem
            Move "    " to asCode[iItem]
            Increment iItem
            Move "    " to asCode[iItem]
            Increment iItem
            Move "    " to asCode[iItem]
            Increment iItem
            Move "    " to asCode[iItem]
            Increment iItem
            Move "    " to asCode[iItem]
            Increment iItem
            Move "    " to asCode[iItem]
            Increment iItem
            Move "    " to asCode[iItem]
            Increment iItem
            Move "Set Border_Style to Border_Thick" to asCode[iItem]

            Move 0 to iItem
            Move "    Use SQL.pkg" to asExpected[iItem]
            Increment iItem
            Move "" to asCode[iItem]
            Increment iItem
            Move "Set Border_Style to Border_Thick" to asExpected[iItem]

            Get RemoveMultipleBlankLines of ghoFuncLib (&asCode) 1 to bChanged
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

        // Already compliant: only 1 blank line with max=1 -- return value must be 0.
        {Published = True}
        Procedure RemoveMultipleBlankLines_NoChange
            Integer iResult
            String[] asCode asExpected

            Move "Use SQL.pkg" to asCode[0]
            Move ""            to asCode[1]
            Move "Set x to y"  to asCode[2]
            Move "Use SQL.pkg" to asExpected[0]
            Move ""            to asExpected[1]
            Move "Set x to y"  to asExpected[2]
            Get RemoveMultipleBlankLines of ghoFuncLib (&asCode) 1 to iResult
            Send AssertIAreEqual 0 iResult
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

        // Verifies the integer return value equals the number of lines removed.
        {Published = True}
        Procedure RemoveMultipleBlankLines_ReturnValue
            Integer iResult
            String[] asCode

            Move "Use SQL.pkg" to asCode[0]
            Move ""            to asCode[1]
            Move ""            to asCode[2]
            Move ""            to asCode[3]
            Move "Set x to y"  to asCode[4]
            Get RemoveMultipleBlankLines of ghoFuncLib (&asCode) 1 to iResult
            Send AssertIAreEqual 2 iResult
        End_Procedure

        // Max=2: two consecutive blank lines are kept; a third is removed.
        {Published = True}
        Procedure RemoveMultipleBlankLines_Max2
            Integer iResult
            String[] asCode asExpected

            Move "Line1" to asCode[0]
            Move ""       to asCode[1]
            Move ""       to asCode[2]
            Move ""       to asCode[3]
            Move "Line2"  to asCode[4]
            Move "Line1"  to asExpected[0]
            Move ""       to asExpected[1]
            Move ""       to asExpected[2]
            Move "Line2"  to asExpected[3]
            Get RemoveMultipleBlankLines of ghoFuncLib (&asCode) 2 to iResult
            Send AssertIAreEqual 1 iResult
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

        // No blank lines at all: return value must be 0 and array unchanged.
        {Published = True}
        Procedure RemoveMultipleBlankLines_NoBlanks
            Integer iResult
            String[] asCode asExpected

            Move "Use SQL.pkg" to asCode[0]
            Move "Set x to y"  to asCode[1]
            Move "Use SQL.pkg" to asExpected[0]
            Move "Set x to y"  to asExpected[1]
            Get RemoveMultipleBlankLines of ghoFuncLib (&asCode) 1 to iResult
            Send AssertIAreEqual 0 iResult
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

    End_Object
