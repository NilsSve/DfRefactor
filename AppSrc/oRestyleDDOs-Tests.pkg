    Object oRestyleDDOs is a cTestFixture
        Set psFunctionName to "RestyleDDOs"

        // Shared cDDOReStyler instance used by the in-memory tests below.
        // Tests that call methods on it set pasSource / peDDOStyle / pbCamelCaseTableName
        // explicitly before each assertion, so there is no state leakage between tests.
        Object oDDO is a cDDOReStyler
        End_Object

        {Published = True}
        Procedure RestyleDDOs_1
            String[] asFiles
            Boolean bChanged
            // Empty file array: function must return False (guard clause).
            Get RestyleDDOs of ghoFuncLib (&asFiles) eDDNewStyle to bChanged
            Send AssertFalse bChanged
        End_Procedure

        // ----- NewStyleName -----

        {Published = True}
        Procedure NewStyleName_OldStyle_WithCamelCase
            String sResult
            // CamelCase on: "customer" -> "Customer_DD" for eDDOldStyle.
            Set pbCamelCaseTableName of oDDO to True
            Get NewStyleName of oDDO "customer" eDDOldStyle to sResult
            Send AssertSAreEqual "Customer_DD" sResult
        End_Procedure

        {Published = True}
        Procedure NewStyleName_StudioStyle_WithCamelCase
            String sResult
            // CamelCase on: "customer" -> "oCustomer_DD" for eDDStudioStyle.
            Set pbCamelCaseTableName of oDDO to True
            Get NewStyleName of oDDO "customer" eDDStudioStyle to sResult
            Send AssertSAreEqual "oCustomer_DD" sResult
        End_Procedure

        {Published = True}
        Procedure NewStyleName_NewStyle_WithCamelCase
            String sResult
            // eDDNewStyle produces the same "o<Name>_DD" form as eDDStudioStyle.
            Set pbCamelCaseTableName of oDDO to True
            Get NewStyleName of oDDO "customer" eDDNewStyle to sResult
            Send AssertSAreEqual "oCustomer_DD" sResult
        End_Procedure

        {Published = True}
        Procedure NewStyleName_OldStyle_NoCamelCase
            String sResult
            // CamelCase off: table name case is preserved as-is.
            Set pbCamelCaseTableName of oDDO to False
            Get NewStyleName of oDDO "CUSTOMER" eDDOldStyle to sResult
            Send AssertSAreEqual "CUSTOMER_DD" sResult
        End_Procedure

        {Published = True}
        Procedure NewStyleName_StudioStyle_CamelCaseFoldsUppercase
            String sResult
            // CamelCase on: uppercase input is folded to lowercase then capitalised.
            Set pbCamelCaseTableName of oDDO to True
            Get NewStyleName of oDDO "CUSTOMER" eDDStudioStyle to sResult
            Send AssertSAreEqual "oCustomer_DD" sResult
        End_Procedure

        // ----- FindCurrentDDObjects -----

        {Published = True}
        Procedure FindDDObjects_DetectsOldStyleDeclaration
            String[] asSource
            tDDO[] DDObjects
            // Old-style: Object <Name>_DD is a <Name>_DataDictionary
            Move "    Object Customer_DD is a Customer_DataDictionary" to asSource[0]
            Set pasSource of oDDO to asSource
            Send FindCurrentDDObjects of oDDO
            Get pDDObjects of oDDO to DDObjects
            Send AssertIAreEqual 1 (SizeOfArray(DDObjects))
            Send AssertSAreEqual "Customer_DD" DDObjects[0].sDDO
        End_Procedure

        {Published = True}
        Procedure FindDDObjects_DetectsStudioStyleDeclaration
            String[] asSource
            tDDO[] DDObjects
            // Studio-style: Object o<Name>_DD is a <Name>_DataDictionary
            Move "    Object oCustomer_DD is a Customer_DataDictionary" to asSource[0]
            Set pasSource of oDDO to asSource
            Send FindCurrentDDObjects of oDDO
            Get pDDObjects of oDDO to DDObjects
            Send AssertIAreEqual 1 (SizeOfArray(DDObjects))
            Send AssertSAreEqual "oCustomer_DD" DDObjects[0].sDDO
        End_Procedure

        {Published = True}
        Procedure FindDDObjects_DetectsMultipleDDOs
            String[] asSource
            tDDO[] DDObjects
            // Two DDO declarations in the same source must both be detected.
            Move "    Object Customer_DD is a Customer_DataDictionary"   to asSource[0]
            Move "    Object oOrderHead_DD is a OrderHead_DataDictionary" to asSource[1]
            Set pasSource of oDDO to asSource
            Send FindCurrentDDObjects of oDDO
            Get pDDObjects of oDDO to DDObjects
            Send AssertIAreEqual 2 (SizeOfArray(DDObjects))
            Send AssertSAreEqual "Customer_DD"   DDObjects[0].sDDO
            Send AssertSAreEqual "oOrderHead_DD" DDObjects[1].sDDO
        End_Procedure

        {Published = True}
        Procedure FindDDObjects_IgnoresCommentedDeclaration
            String[] asSource
            tDDO[] DDObjects
            // Commented-out lines (starting with //) must not yield a DDO entry.
            Move "// Object Customer_DD is a Customer_DataDictionary" to asSource[0]
            Set pasSource of oDDO to asSource
            Send FindCurrentDDObjects of oDDO
            Get pDDObjects of oDDO to DDObjects
            Send AssertIAreEqual 0 (SizeOfArray(DDObjects))
        End_Procedure

        {Published = True}
        Procedure FindDDObjects_IgnoresNewStyleClassSyntax
            String[] asSource
            tDDO[] DDObjects
            // New-style class name (c<Name>DataDictionary, no underscore before
            // DataDictionary) is not detected by the scanner.
            Move "    Object oCustomer_DD is a cCustomerDataDictionary" to asSource[0]
            Set pasSource of oDDO to asSource
            Send FindCurrentDDObjects of oDDO
            Get pDDObjects of oDDO to DDObjects
            Send AssertIAreEqual 0 (SizeOfArray(DDObjects))
        End_Procedure

        {Published = True}
        Procedure FindDDObjects_EmptySource
            String[] asSource
            tDDO[] DDObjects
            // Empty source must produce an empty DDObjects array.
            Set pasSource of oDDO to asSource
            Send FindCurrentDDObjects of oDDO
            Get pDDObjects of oDDO to DDObjects
            Send AssertIAreEqual 0 (SizeOfArray(DDObjects))
        End_Procedure

        // ----- ApplyNewStyleForTable -----

        {Published = True}
        Procedure ApplyNewStyle_OldToStudio_ReplacesAllReferences
            String[] asSource asResult
            tDDO DDObject
            // Lines 0 and 1 contain Customer_DD references; line 2 must be unchanged.
            Move "    Set DDO_Server to Customer_DD"    to asSource[0]
            Move "    Open Customer_DD"                 to asSource[1]
            Move "    Set DDO_Server to OtherTable_DD"  to asSource[2]
            Set pasSource            of oDDO to asSource
            Set peDDOStyle           of oDDO to eDDStudioStyle
            Set pbCamelCaseTableName of oDDO to True
            Move "Customer_DD" to DDObject.sDDO
            Move "customer"    to DDObject.sTableName
            Move eDDOldStyle   to DDObject.eDDOStyle
            Send ApplyNewStyleForTable of oDDO DDObject
            Get pasSource of oDDO to asResult
            Send AssertSAreEqual "    Set DDO_Server to oCustomer_DD"   asResult[0]
            Send AssertSAreEqual "    Open oCustomer_DD"                asResult[1]
            Send AssertSAreEqual "    Set DDO_Server to OtherTable_DD"  asResult[2]
        End_Procedure

        {Published = True}
        Procedure ApplyNewStyle_OldToStudio_ReplacesInParentheses
            String[] asSource asResult
            tDDO DDObject
            // DDO reference inside parentheses must also be replaced.
            Move "    Get Value of (Customer_DD) MyField to sVal" to asSource[0]
            Set pasSource            of oDDO to asSource
            Set peDDOStyle           of oDDO to eDDStudioStyle
            Set pbCamelCaseTableName of oDDO to True
            Move "Customer_DD" to DDObject.sDDO
            Move "customer"    to DDObject.sTableName
            Move eDDOldStyle   to DDObject.eDDOStyle
            Send ApplyNewStyleForTable of oDDO DDObject
            Get pasSource of oDDO to asResult
            Send AssertSAreEqual "    Get Value of (oCustomer_DD) MyField to sVal" asResult[0]
        End_Procedure

        {Published = True}
        Procedure ApplyNewStyle_SameStyle_SourceUnchanged
            String[] asSource asResult
            tDDO DDObject
            // When DDO style already matches the target, source must be left intact.
            Move "    Set DDO_Server to Customer_DD" to asSource[0]
            Set pasSource  of oDDO to asSource
            Set peDDOStyle of oDDO to eDDOldStyle
            Move "Customer_DD" to DDObject.sDDO
            Move "customer"    to DDObject.sTableName
            Move eDDOldStyle   to DDObject.eDDOStyle
            Send ApplyNewStyleForTable of oDDO DDObject
            Get pasSource of oDDO to asResult
            Send AssertSAreEqual "    Set DDO_Server to Customer_DD" asResult[0]
        End_Procedure

    End_Object
