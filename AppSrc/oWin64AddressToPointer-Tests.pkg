    // Unit tests for Win64AddressToPointer - the line-by-line (eStandardFunction) refactor
    // that modernizes the legacy native-pointer TYPE in declarations:
    //   Address pFoo  -> Pointer pFoo      (local var / struct member)
    //   Property Address ... / Global_Variable Address ...
    // It renames ONLY the type slot: never AddressOf, a field (Customer.Address), a longer
    // identifier (sAddress), or a variable named "Address". Each test sets one line,
    // tokenizes it (Get Tokenizer ... populates pTokenizer), then calls the function.
    Object oWin64AddressToPointer is a cTestFixture
        Set psFunctionName to "Win64AddressToPointer"

        // Address pFoo (local var / struct member) -> Pointer pFoo
        {Published = True}
        Procedure Win64AddressToPointer_LocalVar_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Address pBuffer" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64AddressToPointer of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Pointer pBuffer" sLine
        End_Procedure

        // Array type Address[] -> Pointer[] (only the "Address" part is replaced)
        {Published = True}
        Procedure Win64AddressToPointer_ArrayType_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Address[] aBuffers" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64AddressToPointer of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Pointer[] aBuffers" sLine
        End_Procedure

        // Property Address pFoo -> Property Pointer pFoo (type is the 2nd token)
        {Published = True}
        Procedure Win64AddressToPointer_Property_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Property Address pHandle" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64AddressToPointer of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Property Pointer pHandle" sLine
        End_Procedure

        // Global_Variable Address gpBuf -> Global_Variable Pointer gpBuf (no indentation)
        {Published = True}
        Procedure Win64AddressToPointer_GlobalVariable_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Global_Variable Address gpBuffer" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64AddressToPointer of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "Global_Variable Pointer gpBuffer" sLine
        End_Procedure

        // AddressOf(...) must NOT be touched (whole-word right boundary, and not a type slot).
        {Published = True}
        Procedure Win64AddressToPointer_AddressOf_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (AddressOf(sData)) to pPtr" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64AddressToPointer of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual "    Move (AddressOf(sData)) to pPtr" sLine
        End_Procedure

        // A field reference (Customer.Address) must NOT be touched.
        {Published = True}
        Procedure Win64AddressToPointer_Field_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move Customer.Address to sStreet" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64AddressToPointer of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual "    Move Customer.Address to sStreet" sLine
        End_Procedure

        // A variable NAMED Address (the type is the first token) must NOT be touched.
        {Published = True}
        Procedure Win64AddressToPointer_VarNamedAddress_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Integer Address" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64AddressToPointer of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual "    Integer Address" sLine
        End_Procedure

        // Idempotent: an already-converted Pointer declaration is left alone.
        {Published = True}
        Procedure Win64AddressToPointer_AlreadyPointer_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Pointer pBuffer" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64AddressToPointer of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual "    Pointer pBuffer" sLine
        End_Procedure

        // Masked: "Address" inside a string literal is left untouched.
        {Published = True}
        Procedure Win64AddressToPointer_InsideString_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move '    Move "Address pFoo" to sNote' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get Win64AddressToPointer of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual '    Move "Address pFoo" to sNote' sLine
        End_Procedure

    End_Object
