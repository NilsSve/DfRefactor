    Object oChangeSquareBracketsIndicators is a cTestFixture
        Set psFunctionName to "ChangeSquareBracketsIndicators"

        { Published = True }
        Procedure ChangeSquareBracketsIndicators_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    [Found ~Found] Begin' to sLine
            Move '    If (Found and Not(Found)) Begin' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        { Published = True }
        Procedure ChangeSquareBracketsIndicators_2
            // Regression test: an array-index bracket [0] that appears inside a parenthesised
            // expression must NOT be treated as an indicator bracket.
            // Bug: the while loop operated on sOverstrikeLine which does not mask paren content,
            //      so [0] in daPeriodDates[0] was incorrectly converted to (select).
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '[select] Indicate select as (from_datum = daPeriodDates[0])' to sLine
            Move 'If (select) Indicate select as (from_datum = daPeriodDates[0])' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) eModernizeSelect to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Regression (2026-06-10): the UI parameter combo stores the enum NAME
        // ("eModernizeSelect") in Functions.Parameter and the engine passes it verbatim.
        // The old bare Move of that name into the Integer enum left the gate at
        // eLeaveSelect, so the opt-in never worked from the UI - only in tests, which
        // pass the numeric constant. _ParameterIsEnum accepts both forms; this is the
        // NAME-string twin of test _2.
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_SelectByParameterName
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '[select] Indicate select as (from_datum = daPeriodDates[0])' to sLine
            Move 'If (select) Indicate select as (from_datum = daPeriodDates[0])' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) "eModernizeSelect" to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Regression (2026-06-10): invoke EXACTLY the way cRefactorEngine does - a DYNAMIC
        // message id (Eval) with the parameter in a variable, not a direct compile-time
        // call. The direct-call tests were green while the engine run still ignored the
        // parameter; this pins the engine's dispatch style. (The fix: the gate no longer
        // consults num_arguments, which is unreliable across dispatch styles - "" simply
        // matches nothing.)
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_EngineStyleInvocation
            String sLine sExpected sParameter
            Boolean bChanged
            Integer iFunctionID
            tTokenizer TokenizerData
            Move '[select] Indicate select as (from_datum = daPeriodDates[0])' to sLine
            Move 'If (select) Indicate select as (from_datum = daPeriodDates[0])' to sExpected
            Move "eModernizeSelect" to sParameter
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Move (Eval("get_" - "ChangeSquareBracketsIndicators")) to iFunctionID
            Get iFunctionID of ghoFuncLib (&sLine) sParameter to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Line with no bracket indicator must be returned unchanged and return False.
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move x to y" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "Move x to y" sLine
        End_Procedure

        // Single indicator at start of line: "If" must be prepended; also verifies bChanged = True.
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_SimpleSingleIndicator
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "[Found]" to sLine
            Move "If (Found)" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Tilde (~) in isolation must produce Not() expression.
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_TildeNegation
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "[~bActive]" to sLine
            Move "If (Not(bActive))" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Lines containing GROUP must not be converted (guard returns False unchanged).
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_GroupGuard
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "[select] Group" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "[select] Group" sLine
        End_Procedure

        // Repeat keyword: indicator expression becomes the While condition.
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_RepeatToWhile
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "[bRunning] Repeat" to sLine
            Move "While (bRunning)" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Loop keyword: indicator expression is consumed; result is just "Loop".
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_LoopConsumesIndicator
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "[bRunning] Loop" to sLine
            Move "Loop" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Regression: with the default eLeaveSelect, the [select] bracket is left untouched
        // (SELECT is an old-FMAC macro with no valid modern bare form).
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_SelectLeftAloneByDefault
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '[select] Indicate select as (from_datum = daPeriodDates[0])' to sLine
            Move '[select] Indicate select as (from_datum = daPeriodDates[0])' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Regression: a LEADING bracket + If + Indicate compound must be left unchanged - converting the
        // leading bracket would yield "If (Found) If sCustCode ne "" Indicate ..." (double-If garbage).
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_LeadingBracketIfIndicateCompound
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '        [Found] If sCustCode ne "" Indicate Found as BillCust.Cust_Code eq sCustCode' to sLine
            Move '        [Found] If sCustCode ne "" Indicate Found as BillCust.Cust_Code eq sCustCode' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
            Send AssertFalse bChanged
        End_Procedure

        // Regression: a space right after "[" (e.g. "[ Found]") used to leave the line un-refactored - the
        // lone "[" token seeded an empty FirstBoolean and the bracket flag was lost. The tokenizer now merges
        // a lone "[" into the next token (mirrors the lone-"]" merge), so it parses like "[Found]".
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_SpaceAfterLeftBracket
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '[ Found] Begin' to sLine
            Move 'If (Found) Begin' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Regression twin: spaces on BOTH sides "[ Found ]" (lone "[" + lone "]") also normalize.
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_SpacesBothSidesBracket
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '[ Found ] Begin' to sLine
            Move 'If (Found) Begin' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

    End_Object
