    Object oChangeSquareBracketsIndicators is a cTestFixture
        Set psFunctionName to "ChangeSquareBracketsIndicators"

        { Published = True }
        Procedure ChangeSquareBracketsIndicators_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    [Found ~Found] Begin' to sLine
            Move '    If (Found and Not(Found)) Begin' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        { Published = True }
        Procedure ChangeSquareBracketsIndicators_2
            // Regression test: an array-index bracket [0] that appears inside a parenthesised
            // expression must NOT be treated as an indicator bracket.
            // Bug: the while loop operated on sOverstrikeLine which does not mask paren content,
            //      so [0] in daPeriodDates[0] was incorrectly converted to (select).
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '[select] Indicate select as (from_datum = daPeriodDates[0])' to sLine
            Move 'If (select) Indicate select as (from_datum = daPeriodDates[0])' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Line with no bracket indicator must be returned unchanged and return False.
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move x to y" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "Move x to y" sLine
        End_Procedure

        // Single indicator at start of line: "If" must be prepended; also verifies bChanged = True.
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_SimpleSingleIndicator
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "[Found]" to sLine
            Move "If (Found)" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Tilde (~) in isolation must produce Not() expression.
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_TildeNegation
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "[~bActive]" to sLine
            Move "If (Not(bActive))" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Lines containing GROUP must not be converted (guard returns False unchanged).
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_GroupGuard
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "[select] Group" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "[select] Group" sLine
        End_Procedure

        // Repeat keyword: indicator expression becomes the While condition.
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_RepeatToWhile
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "[bRunning] Repeat" to sLine
            Move "While (bRunning)" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Loop keyword: indicator expression is consumed; result is just "Loop".
        { Published = True }
        Procedure ChangeSquareBracketsIndicators_LoopConsumesIndicator
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "[bRunning] Loop" to sLine
            Move "Loop" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSquareBracketsIndicators of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

    End_Object
