    Object oSplitInlineIfElseLine is a cTestFixture
        Set psFunctionName to "SplitInlineIfElseLine"

        {Published = True}
        Procedure SplitInlineIfElseLine_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (WindowIndex = 0) Move "Go"   to sLabel' to sLine
            Move ('If (WindowIndex = 0) Begin' + CS_CRLF + '    Move "Go"   to sLabel' + CS_CRLF + 'End') to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get SplitInlineIfElseLine of ghoFuncLib (&sLine) eSplitToBeginEndBlock to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure SplitInlineIfElseLine_2
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (WindowIndex = 0) Move "Go"   to sLabel' to sLine
            Move ('If (WindowIndex = 0);' + CS_CRLF + '    Move "Go"   to sLabel') to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get SplitInlineIfElseLine of ghoFuncLib (&sLine) eSplitBySemicolon to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure SplitInlineIfElseLine_3
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (WindowIndex = 0) Move "Go"   to sLabel' to sLine
            Move ('If (WindowIndex = 0) ;' + CS_CRLF + '    Move "Go"   to sLabel') to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get SplitInlineIfElseLine of ghoFuncLib (&sLine) eSplitBySpaceAndSemicolon to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure SplitInlineIfElseLine_4
            // Regression: keywords inside the condition (e.g. "and") must not be used as the split point
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (bShouldSave and user.jobbhist = 0) Move False to bShouldSave' to sLine
            Move ('If (bShouldSave and user.jobbhist = 0) Begin' + CS_CRLF + '    Move False to bShouldSave' + CS_CRLF + 'End') to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get SplitInlineIfElseLine of ghoFuncLib (&sLine) eSplitToBeginEndBlock to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure SplitInlineIfElseLine_5
            // Regression: Goto must not be wrapped in a Begin/End block
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (RetVal =MBR_No) Goto forderreg_enter' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get SplitInlineIfElseLine of ghoFuncLib (&sLine) eSplitToBeginEndBlock to bChanged
            Send Assert (bChanged = False)
        End_Procedure

        {Published = True}
        Procedure SplitInlineIfElseLine_6
            // Regression: Gosub must not be wrapped in a Begin/End block
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (RetVal =MBR_No) Gosub forderreg_Cont' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get SplitInlineIfElseLine of ghoFuncLib (&sLine) eSplitToBeginEndBlock to bChanged
            Send Assert (bChanged = False)
        End_Procedure

        {Published = True}
        Procedure SplitInlineIfElseLine_7
            // Regression: unparenthesised condition must split at the command, not a condition keyword
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If user.ut_sdat ne 0 DFWritePos (_("Uppsagt den")) 14.0 (FONT_BOLD)' to sLine
            Move ('If user.ut_sdat ne 0 Begin' + CS_CRLF + '    DFWritePos (_("Uppsagt den")) 14.0 (FONT_BOLD)' + CS_CRLF + 'End') to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get SplitInlineIfElseLine of ghoFuncLib (&sLine) eSplitToBeginEndBlock to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure SplitInlineIfElseLine_8
            // Regression: IF NOT (expr) pattern -- NOT must not be treated as second command
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    IF NOT ('BIP' contains BALANCE_TYPE) MOVE 'I' TO BALANCE_TYPE" to sLine
            Move ("    IF NOT ('BIP' contains BALANCE_TYPE) Begin" + CS_CRLF + "        MOVE 'I' TO BALANCE_TYPE" + CS_CRLF + "    End") to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get SplitInlineIfElseLine of ghoFuncLib (&sLine) eSplitToBeginEndBlock to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

    End_Object
