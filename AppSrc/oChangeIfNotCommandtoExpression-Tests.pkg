    Object oChangeIfNotCommandtoExpression is a cTestFixture
        Set psFunctionName to "ChangeIfNotCommandToExpression"

        {Published = True}
        Procedure ChangeIfNotCommandToExpression_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    IFNOT Found Begin' to sLine
            Move '    If (Not(Found)) Begin' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIfNotCommandToExpression of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Line with no IFNOT must be returned unchanged and return False.
        {Published = True}
        Procedure ChangeIfNotCommandToExpression_NoIfNot
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move 1 to iCount" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIfNotCommandToExpression of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "Move 1 to iCount" sLine
        End_Procedure

        // Lowercase 'ifnot' is matched case-insensitively; bChanged must be True.
        {Published = True}
        Procedure ChangeIfNotCommandToExpression_Lowercase
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "    ifnot bFound begin" to sLine
            Move "    If (Not(bFound)) begin" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIfNotCommandToExpression of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // IFNOT with no trailing keyword -- result ends after the Not() expression.
        {Published = True}
        Procedure ChangeIfNotCommandToExpression_NoBegin
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "IFNOT bFlag" to sLine
            Move "If (Not(bFlag))" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeIfNotCommandToExpression of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

    End_Object
