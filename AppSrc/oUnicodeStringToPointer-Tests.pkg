    // Unit tests for the UnicodeStringToPointer refactoring function (the public
    // wrapper on ghoFuncLib, which drives the cUnicodeStringToPointer class).
    // It rewrites a bare  Move <String> to <Pointer/Address>  into
    //   Move (MemCopy(<ptr>, AddressOf(<str>), SizeOfString(<str>))) to iRFVoid
    // injecting the throwaway Integer once per method, and ONLY when both operand
    // types are known from the declarations OR the signature parameters.
    //
    // Each test feeds a small synthetic source file as a String array, resets the
    // lexer state first (ClearFuncLibProperties, as the engine does per file), then
    // checks the rewrite count and the affected lines (note the injected decl
    // shifts later indices down by one).
    Object oUnicodeStringToPointer is a cTestFixture
        Set psFunctionName to "UnicodeStringToPointer"

        // A declared String local -> Address local: rewritten, decl injected.
        {Published = True}
        Procedure UnicodeStringToPointer_StringToAddress_Wrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function Foo Global Returns Integer" to asCode[0]
            Move "    String sStr"          to asCode[1]
            Move "    Address aStr"         to asCode[2]
            Move "    Move sStr to aStr"    to asCode[3]
            Move "End_Function"             to asCode[4]
            Get UnicodeStringToPointer of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "    Integer iRFVoid" asCode[3]
            Send AssertSAreEqual "    Move (MemCopy(aStr, AddressOf(sStr), SizeOfString(sStr))) to iRFVoid" asCode[4]
        End_Procedure

        // A declared String local -> Pointer local: rewritten.
        {Published = True}
        Procedure UnicodeStringToPointer_StringToPointer_Wrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function Foo Global Returns Integer" to asCode[0]
            Move "    String sData"         to asCode[1]
            Move "    Pointer pData"        to asCode[2]
            Move "    Move sData to pData"  to asCode[3]
            Move "End_Function"             to asCode[4]
            Get UnicodeStringToPointer of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "    Integer iRFVoid" asCode[3]
            Send AssertSAreEqual "    Move (MemCopy(pData, AddressOf(sData), SizeOfString(sData))) to iRFVoid" asCode[4]
        End_Procedure

        // The real-world case: the String source is a PARAMETER, not a body local
        // (this is what cUnicodePointerToString does NOT handle). Both s and aDest
        // come from the signature.
        {Published = True}
        Procedure UnicodeStringToPointer_ParameterSource_Wrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Procedure ToBuffer String ByRef s Address ByRef aDest" to asCode[0]
            Move "    Move s to aDest"      to asCode[1]
            Move "End_Procedure"            to asCode[2]
            Get UnicodeStringToPointer of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "    Integer iRFVoid" asCode[1]
            Send AssertSAreEqual "    Move (MemCopy(aDest, AddressOf(s), SizeOfString(s))) to iRFVoid" asCode[2]
        End_Procedure

        // Integer -> Integer is untouched (count 0, line unchanged).
        {Published = True}
        Procedure UnicodeStringToPointer_IntegerMove_NotWrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function Foo Global Returns Integer" to asCode[0]
            Move "    Integer iA iB"        to asCode[1]
            Move "    Move iA to iB"        to asCode[2]
            Move "End_Function"             to asCode[3]
            Get UnicodeStringToPointer of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 0)
            Send AssertSAreEqual "    Move iA to iB" asCode[2]
        End_Procedure

        // Pointer -> String (the reverse direction) belongs to UnicodePointerToString,
        // NOT this function - it must leave it untouched.
        {Published = True}
        Procedure UnicodeStringToPointer_PointerToString_NotWrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function Foo Global Returns Integer" to asCode[0]
            Move "    String sStr"          to asCode[1]
            Move "    Address aPtr"         to asCode[2]
            Move "    Move aPtr to sStr"    to asCode[3]
            Move "End_Function"             to asCode[4]
            Get UnicodeStringToPointer of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 0)
            Send AssertSAreEqual "    Move aPtr to sStr" asCode[3]
        End_Procedure

        // Two conversions in one method: rewritten twice, but the throwaway Integer
        // is injected ONCE (asCode[5] is the second MemCopy, not a second decl).
        {Published = True}
        Procedure UnicodeStringToPointer_TwoMovesOneDecl_Wrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function Foo Global Returns Integer" to asCode[0]
            Move "    String sA sB"         to asCode[1]
            Move "    Address aA aB"        to asCode[2]
            Move "    Move sA to aA"        to asCode[3]
            Move "    Move sB to aB"        to asCode[4]
            Move "End_Function"             to asCode[5]
            Get UnicodeStringToPointer of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 2)
            Send AssertSAreEqual "    Integer iRFVoid" asCode[3]
            Send AssertSAreEqual "    Move (MemCopy(aA, AddressOf(sA), SizeOfString(sA))) to iRFVoid" asCode[4]
            Send AssertSAreEqual "    Move (MemCopy(aB, AddressOf(sB), SizeOfString(sB))) to iRFVoid" asCode[5]
        End_Procedure

        // Per-method scope: a String in method A must not license a Move in method B.
        {Published = True}
        Procedure UnicodeStringToPointer_ScopeIsolation_NotWrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function A Global Returns Integer" to asCode[0]
            Move "    String sX"            to asCode[1]
            Move "End_Function"             to asCode[2]
            Move "Function B Global Returns Integer" to asCode[3]
            Move "    Address aX"           to asCode[4]
            Move "    Move sX to aX"        to asCode[5]
            Move "End_Function"             to asCode[6]
            Get UnicodeStringToPointer of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 0)
            Send AssertSAreEqual "    Move sX to aX" asCode[5]
        End_Procedure

        // REGRESSION: a preceding Function closed with End_Procedure (DataFlex
        // tolerates the mismatch) leaves the lexer stuck in-method, so the OLD
        // transition-based detection skipped the next method's parameter collection
        // - exactly why cJSONParser._ToCharArray (param "String ByRef s") was
        // missed. With signature-line detection the parameter is collected and the
        // line wraps.
        {Published = True}
        Procedure UnicodeStringToPointer_AfterMismatchedEnd_Wrapped
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function PrecedingFn Returns Integer" to asCode[0]
            Move "    Function_Return 0"     to asCode[1]
            Move "End_Procedure"             to asCode[2]
            Move "Procedure ToBuffer String ByRef s Address ByRef aDest" to asCode[3]
            Move "    Move s to aDest"       to asCode[4]
            Move "End_Procedure"             to asCode[5]
            Get UnicodeStringToPointer of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "    Integer iRFVoid" asCode[4]
            Send AssertSAreEqual "    Move (MemCopy(aDest, AddressOf(s), SizeOfString(s))) to iRFVoid" asCode[5]
        End_Procedure

    End_Object
