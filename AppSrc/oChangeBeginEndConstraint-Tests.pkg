    Object oChangeBeginEndConstraint is a cTestFixture
        Set psFunctionName to "ChangeBeginEndConstraint"

        // A pure Begin_Constraints block -> OnConstrain procedure opened with Forward.
        { Published = True }
        Procedure ChangeBeginEndConstraint_PureBlock
            String[] asCode
            Integer iCount
            Move '        Begin_Constraints'                  to asCode[0]
            Move '            Constrain Vaktinst.mnr eq gMnr'  to asCode[1]
            Move '        End_Constraints'                    to asCode[2]
            Get ChangeBeginEndConstraint of ghoFuncLib (&asCode) to iCount
            Send Assert (iCount = 1)
            Send Assert (SizeOfArray(asCode) = 4)
            Send AssertSAreEqual '        Procedure OnConstrain'             asCode[0]
            Send AssertSAreEqual '            Forward Send OnConstrain'       asCode[1]
            Send AssertSAreEqual '            Constrain Vaktinst.mnr eq gMnr' asCode[2]
            Send AssertSAreEqual '        End_Procedure'                      asCode[3]
        End_Procedure

        // A mixed block: everything (Constrain + Report_Index) stays in order INSIDE OnConstrain;
        // Report_* is NOT moved out (its parameter may depend on earlier logic). Blank lines dropped.
        { Published = True }
        Procedure ChangeBeginEndConstraint_MixedBlock
            String[] asCode
            Integer iCount
            Move '        Begin_Constraints'                to asCode[0]
            Move '            Constrain Pas_utr.mnr Eq gMnr' to asCode[1]
            Move ''                                         to asCode[2]
            Move '            Report_Index by Index.2'       to asCode[3]
            Move ''                                         to asCode[4]
            Move '        End_Constraints'                  to asCode[5]
            Get ChangeBeginEndConstraint of ghoFuncLib (&asCode) to iCount
            Send Assert (iCount = 1)
            Send Assert (SizeOfArray(asCode) = 5)
            Send AssertSAreEqual '        Procedure OnConstrain'         asCode[0]
            Send AssertSAreEqual '            Forward Send OnConstrain'   asCode[1]
            Send AssertSAreEqual '            Constrain Pas_utr.mnr Eq gMnr' asCode[2]
            Send AssertSAreEqual '            Report_Index by Index.2'   asCode[3]
            Send AssertSAreEqual '        End_Procedure'                 asCode[4]
        End_Procedure

        // The critical fix: a CONDITIONAL constraint block keeps its declarations, Get/If/Else, the
        // Constrains they control, AND Report_* together and IN ORDER inside OnConstrain - never split.
        { Published = True }
        Procedure ChangeBeginEndConstraint_ConditionalPreserved
            String[] asCode
            Integer iCount
            Move '        Begin_Constraints'                    to asCode[0]
            Move '            String sStart'                    to asCode[1]
            Move '            Get pSelStart to sStart'          to asCode[2]
            Move '            If (sStart<>"") ;'                to asCode[3]
            Move '                Constrain tbl.fld ge sStart'  to asCode[4]
            Move '            Report_Index by Index.5'          to asCode[5]
            Move '        End_Constraints'                      to asCode[6]
            Get ChangeBeginEndConstraint of ghoFuncLib (&asCode) to iCount
            Send Assert (iCount = 1)
            Send Assert (SizeOfArray(asCode) = 8)
            Send AssertSAreEqual '        Procedure OnConstrain'           asCode[0]
            Send AssertSAreEqual '            Forward Send OnConstrain'     asCode[1]
            Send AssertSAreEqual '            String sStart'                asCode[2]
            Send AssertSAreEqual '            Get pSelStart to sStart'      asCode[3]
            Send AssertSAreEqual '            If (sStart<>"") ;'            asCode[4]
            Send AssertSAreEqual '                Constrain tbl.fld ge sStart' asCode[5]
            Send AssertSAreEqual '            Report_Index by Index.5'      asCode[6]
            Send AssertSAreEqual '        End_Procedure'                   asCode[7]
        End_Procedure

        // Code without a constraint block is returned unchanged (count 0).
        { Published = True }
        Procedure ChangeBeginEndConstraint_NoBlock
            String[] asCode
            Integer iCount
            Move '    Procedure Foo'   to asCode[0]
            Move '        Move 1 to x' to asCode[1]
            Move '    End_Procedure'   to asCode[2]
            Get ChangeBeginEndConstraint of ghoFuncLib (&asCode) to iCount
            Send Assert (iCount = 0)
            Send Assert (SizeOfArray(asCode) = 3)
            Send AssertSAreEqual '        Move 1 to x' asCode[1]
        End_Procedure

        // An unterminated block (no End_Constraints) is left fully untouched (count 0).
        { Published = True }
        Procedure ChangeBeginEndConstraint_Unterminated
            String[] asCode
            Integer iCount
            Move '        Begin_Constraints' to asCode[0]
            Move '            Constrain x eq y' to asCode[1]
            Get ChangeBeginEndConstraint of ghoFuncLib (&asCode) to iCount
            Send Assert (iCount = 0)
            Send Assert (SizeOfArray(asCode) = 2)
            Send AssertSAreEqual '        Begin_Constraints' asCode[0]
            Send AssertSAreEqual '            Constrain x eq y' asCode[1]
        End_Procedure

    End_Object
