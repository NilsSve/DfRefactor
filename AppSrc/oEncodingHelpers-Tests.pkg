    Object oEncodingHelpers is a cTestFixture
        Set psFunctionName to "EncodingHelpers"

        // ASCII round-trip: OEM encode then decode returns the original string.
        {Published = True}
        Procedure RFUtf8LineToOemBytes_AsciiRoundTrip
            String sInput sResult
            UChar[] ucaBytes
            Move "Hello, World!" to sInput
            Move (RFUtf8LineToOemBytes(sInput)) to ucaBytes
            Move (RFOemBytesToUtf8(ucaBytes)) to sResult
            Send AssertSAreEqual sInput sResult
        End_Procedure

        // One ASCII character = one OEM byte.
        {Published = True}
        Procedure RFUtf8LineToOemBytes_ByteCount
            UChar[] ucaBytes
            Move (RFUtf8LineToOemBytes("Hello")) to ucaBytes
            Send AssertIAreEqual 5 (SizeOfArray(ucaBytes))
        End_Procedure

        // Empty string returns a zero-length UChar[].
        {Published = True}
        Procedure RFUtf8LineToOemBytes_Empty
            UChar[] ucaBytes
            Move (RFUtf8LineToOemBytes("")) to ucaBytes
            Send AssertIAreEqual 0 (SizeOfArray(ucaBytes))
        End_Procedure

        // ASCII round-trip: UTF-8 encode then decode returns the original string.
        {Published = True}
        Procedure RFStringToUtf8Bytes_AsciiRoundTrip
            String sInput sResult
            UChar[] ucaBytes
            Move "DataFlex source" to sInput
            Move (RFStringToUtf8Bytes(sInput)) to ucaBytes
            Move (RFUtf8BytesToString(ucaBytes)) to sResult
            Send AssertSAreEqual sInput sResult
        End_Procedure

        // One ASCII character = one UTF-8 byte.
        {Published = True}
        Procedure RFStringToUtf8Bytes_ByteCount
            UChar[] ucaBytes
            Move (RFStringToUtf8Bytes("Hello")) to ucaBytes
            Send AssertIAreEqual 5 (SizeOfArray(ucaBytes))
        End_Procedure

        // Empty string returns a zero-length UChar[].
        {Published = True}
        Procedure RFStringToUtf8Bytes_Empty
            UChar[] ucaBytes
            Move (RFStringToUtf8Bytes("")) to ucaBytes
            Send AssertIAreEqual 0 (SizeOfArray(ucaBytes))
        End_Procedure

        // Empty UChar[] input returns an empty string.
        {Published = True}
        Procedure RFOemBytesToUtf8_Empty
            UChar[] ucaEmpty
            String sResult
            Move (RFOemBytesToUtf8(ucaEmpty)) to sResult
            Send AssertSAreEqual "" sResult
        End_Procedure

        // Empty UChar[] input returns an empty string.
        {Published = True}
        Procedure RFUtf8BytesToString_Empty
            UChar[] ucaEmpty
            String sResult
            Move (RFUtf8BytesToString(ucaEmpty)) to sResult
            Send AssertSAreEqual "" sResult
        End_Procedure

        // OEM file round-trip: write then read back; array must match exactly.
        {Published = True}
        Procedure WriteAndReadOem_RoundTrip
            Boolean bOk
            Integer iVoid
            String sDataPath sTempFile
            String[] asWrite asRead
            Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
            Move (sDataPath + "_EncTest.tmp") to sTempFile
            Move "Use SQL.pkg"   to asWrite[0]
            Move ""              to asWrite[1]
            Move "Set x to True" to asWrite[2]
            Move (RFWriteEncodedFileFromStringArray(asWrite, sTempFile, CS_CRLF, False)) to bOk
            Send Assert bOk
            Move (RFReadEncodedFileAsStringArray(sTempFile)) to asRead
            Send AssertArrayAreEqual asWrite asRead
            Move (RFDeleteFile(sTempFile)) to iVoid
        End_Procedure

        // UTF-8 file round-trip: write then read back; array must match exactly.
        {Published = True}
        Procedure WriteAndReadUtf8_RoundTrip
            Boolean bOk
            Integer iVoid
            String sDataPath sTempFile
            String[] asWrite asRead
            Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
            Move (sDataPath + "_EncTest.tmp") to sTempFile
            Move "Use SQL.pkg"   to asWrite[0]
            Move ""              to asWrite[1]
            Move "Set x to True" to asWrite[2]
            Move (RFWriteEncodedFileFromStringArray(asWrite, sTempFile, CS_CRLF, True)) to bOk
            Send Assert bOk
            Move (RFReadEncodedFileAsStringArray(sTempFile)) to asRead
            Send AssertArrayAreEqual asWrite asRead
            Move (RFDeleteFile(sTempFile)) to iVoid
        End_Procedure

        // UTF-8 write prepends the BOM -- RFFileHasBOM must return True.
        {Published = True}
        Procedure RFFileHasBOM_True
            Boolean bOk bResult
            Integer iVoid
            String sDataPath sTempFile
            String[] asLines
            Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
            Move (sDataPath + "_EncTest.tmp") to sTempFile
            Move "x" to asLines[0]
            Move (RFWriteEncodedFileFromStringArray(asLines, sTempFile, CS_CRLF, True)) to bOk
            Move (RFFileHasBOM(sTempFile)) to bResult
            Send Assert bResult
            Move (RFDeleteFile(sTempFile)) to iVoid
        End_Procedure

        // OEM write has no BOM -- RFFileHasBOM must return False.
        {Published = True}
        Procedure RFFileHasBOM_False
            Boolean bOk bResult
            Integer iVoid
            String sDataPath sTempFile
            String[] asLines
            Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
            Move (sDataPath + "_EncTest.tmp") to sTempFile
            Move "x" to asLines[0]
            Move (RFWriteEncodedFileFromStringArray(asLines, sTempFile, CS_CRLF, False)) to bOk
            Move (RFFileHasBOM(sTempFile)) to bResult
            Send AssertFalse bResult
            Move (RFDeleteFile(sTempFile)) to iVoid
        End_Procedure

        // A file shorter than 3 bytes cannot carry a BOM -- must return False.
        {Published = True}
        Procedure RFFileHasBOM_TooSmall
            Integer iChannel iVoid
            Boolean bResult
            String sDataPath sTempFile
            UChar[] ucaSmall
            Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
            Move (sDataPath + "_EncTest.tmp") to sTempFile
            Move 65 to ucaSmall[0]
            Move 66 to ucaSmall[1]
            Move (Seq_New_Channel()) to iChannel
            Direct_Output Channel iChannel ("binary:" + sTempFile)
            Write Channel iChannel ucaSmall
            Close_Output Channel iChannel
            Send Seq_Release_Channel iChannel
            Move (RFFileHasBOM(sTempFile)) to bResult
            Send AssertFalse bResult
            Move (RFDeleteFile(sTempFile)) to iVoid
        End_Procedure

    End_Object
