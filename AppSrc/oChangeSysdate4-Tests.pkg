    Object oChangeSysdate4 is a cTestFixture
        Set psFunctionName to "ChangeSysdate4"

        {Published = True}
        Procedure ChangeSysdate4_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Sysdate4 dToday' to sLine
            Move 'Sysdate dToday' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSysdate4 of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Comment line: bLineIsReady guard fires, line unchanged, return False.
        {Published = True}
        Procedure ChangeSysdate4_NoChange_Comment
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move '// Move Sysdate4 to dDate' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSysdate4 of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual '// Move Sysdate4 to dDate' sLine
        End_Procedure

        // Variable declaration: bIsVariableDeclaration guard fires, line unchanged.
        {Published = True}
        Procedure ChangeSysdate4_NoChange_VariableDecl
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Date Sysdate4' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSysdate4 of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Date Sysdate4' sLine
        End_Procedure

        // Leading indentation must be preserved.
        {Published = True}
        Procedure ChangeSysdate4_Indented
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Move Sysdate4 to dDate' to sLine
            Move '    Move Sysdate to dDate' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSysdate4 of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Regression (2026-06-10 audit): ONLY the keyword's own "4" may be removed.
        // The old Replace("4", sLine, "") ate the FIRST "4" anywhere on the line;
        // the positional splice must leave a "4" in other tokens untouched.
        {Published = True}
        Procedure ChangeSysdate4_OnlyKeywordFourRemoved
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move Sysdate4 to dDate4' to sLine
            Move 'Move Sysdate to dDate4' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSysdate4 of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Return value must be True when a match is found.
        {Published = True}
        Procedure ChangeSysdate4_ReturnValue
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move Sysdate4 to dToday' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSysdate4 of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
        End_Procedure

    End_Object
