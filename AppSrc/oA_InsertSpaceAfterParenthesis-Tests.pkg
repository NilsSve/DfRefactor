    Object oA_InsertSpaceAfterParenthesis is a cTestFixture
        Set psFunctionName to "A_InsertSpaceAfterParenthesis"

        {Published = True}
        Procedure A_InsertSpaceAfterParenthesis_1
            // ))Begin -> )) Begin
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    If ((Modrv.dolt Eq 0) Or (Modrv.dolt Eq 1))Begin    // active eller hiden' to sLine
            Move '    If ((Modrv.dolt Eq 0) Or (Modrv.dolt Eq 1)) Begin    // active eller hiden' to sExpected
            Get Tokenizer of ghoRefactorFuncLib sLine to TokenizerData
            Get A_InsertSpaceAfterParenthesis of ghoRefactorFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure A_InsertSpaceAfterParenthesis_2
            // )Move -> ) Move
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    If (bOk)Move iA to iB' to sLine
            Move '    If (bOk) Move iA to iB' to sExpected
            Get Tokenizer of ghoRefactorFuncLib sLine to TokenizerData
            Get A_InsertSpaceAfterParenthesis of ghoRefactorFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure A_InsertSpaceAfterParenthesis_3
            // No change needed — already has a space
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    If (bOk) Move iA to iB' to sLine
            Move '    If (bOk) Move iA to iB' to sExpected
            Get Tokenizer of ghoRefactorFuncLib sLine to TokenizerData
            Get A_InsertSpaceAfterParenthesis of ghoRefactorFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure A_InsertSpaceAfterParenthesis_4
            // )Send -> ) Send
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    If (iVal > 0)Send Info_Box "Yes"' to sLine
            Move '    If (iVal > 0) Send Info_Box "Yes"' to sExpected
            Get Tokenizer of ghoRefactorFuncLib sLine to TokenizerData
            Get A_InsertSpaceAfterParenthesis of ghoRefactorFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure A_InsertSpaceAfterParenthesis_5
            // Should not insert space between ) and a digit or operator
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Move (iA + iB) to iC' to sLine
            Move '    Move (iA + iB) to iC' to sExpected
            Get Tokenizer of ghoRefactorFuncLib sLine to TokenizerData
            Get A_InsertSpaceAfterParenthesis of ghoRefactorFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure A_InsertSpaceAfterParenthesis_6
            // )Send -> ) Send
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '            [Found  ]Set Field_Changed_Value Field Koffhuv.betvillkor_namn  to betvillk.namn' to sLine
            Move '            [Found  ] Set Field_Changed_Value Field Koffhuv.betvillkor_namn  to betvillk.namn' to sExpected
            Get Tokenizer of ghoRefactorFuncLib sLine to TokenizerData
            Get A_InsertSpaceAfterParenthesis of ghoRefactorFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual sExpected sLine
        End_Procedure

    End_Object
