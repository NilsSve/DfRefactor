    Object oChangeSubToSubtract is a cTestFixture
        Set psFunctionName to "ChangeSubToSubtract"

        // Sub X to Y -> Subtract X from Y (legacy "to" becomes "from")
        { Published = True }
        Procedure ChangeSubToSubtract_ToBecomesFrom
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Sub iAmount to iTotal' to sLine
            Move 'Subtract iAmount from iTotal' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSubToSubtract of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Sub X from Y -> Subtract X from Y (middle already "from")
        { Published = True }
        Procedure ChangeSubToSubtract_FromStays
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Sub 5 from Total' to sLine
            Move 'Subtract 5 from Total' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSubToSubtract of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Leading indentation is preserved.
        { Published = True }
        Procedure ChangeSubToSubtract_PreservesIndent
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Sub iX to iY' to sLine
            Move '    Subtract iX from iY' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSubToSubtract of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Code before the command (the "nose") is kept.
        { Published = True }
        Procedure ChangeSubToSubtract_KeepsLineNose
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (bFlag) Sub 1 to iCount' to sLine
            Move 'If (bFlag) Subtract 1 from iCount' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSubToSubtract of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Already-modern Subtract is left untouched (no double-convert; whole-token guard).
        { Published = True }
        Procedure ChangeSubToSubtract_AlreadyModern
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Subtract iAmount from iTotal' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSubToSubtract of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Subtract iAmount from iTotal' sLine
        End_Procedure

        // Regression (2026-06-10 audit): an identifier CONTAINING "sub" in the nose
        // must not hijack the splice point. The old bare Pos("sub", ...) matched
        // inside "bSubmitted" and produced "If (bSubtract 1 from iCount".
        { Published = True }
        Procedure ChangeSubToSubtract_NoseContainsSub
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (bSubmitted) Sub 1 to iCount' to sLine
            Move 'If (bSubmitted) Subtract 1 from iCount' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSubToSubtract of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // A line with no Sub command is unchanged and reports no change.
        { Published = True }
        Procedure ChangeSubToSubtract_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move x to y' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeSubToSubtract of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Move x to y' sLine
        End_Procedure

    End_Object
