    // Unit tests for AddUseOldFMACCommands (eOtherFunction). It DEFINES the bare 'Select' macro indicator
    // left behind when ChangeLegacyIndicators / ChangeSquareBracketsIndicators modernise a [Select] under
    // eModernizeSelect - by splicing a guarded '#IFNDEF SELECT / #Replace SELECT |!C / #ENDIF' shim near the
    // top (NOT a Use line: OldFMACCommands.pkg defines SELECT only via the REPORT macro). The trigger is the
    // FILE CONTENT - the function scans the rewritten code for a bare, boundary-aware Select token
    // (string/comment-safe). The insertion tests assert the macro block is present (SearchArray) at the right
    // spot rather than the exact comment text; the no-op tests assert the array is unchanged. ClearFuncLibProperties
    // is sent first (as the engine does before every eOtherFunction) so the stateful tokeniser starts clean.
    Object oAddUseOldFMACCommands is a cTestFixture
        Set psFunctionName to "AddUseOldFMACCommands"

        // Bare (Select) in code, a leading Use block present: the macro shim goes right after the last Use.
        {Published = True}
        Procedure AddUseOldFMACCommands_AfterUseBlock
            Integer iResult iPos
            String[] asCode

            Move "Use Windows.pkg"       to asCode[0]
            Move "Use cObject.pkg"       to asCode[1]
            Move ""                      to asCode[2]
            Move "Procedure Foo"         to asCode[3]
            Move "    If (Select) Begin" to asCode[4]
            Move "    End"               to asCode[5]
            Move "End_Procedure"        to asCode[6]

            Send ClearFuncLibProperties of ghoFuncLib
            Get AddUseOldFMACCommands of ghoFuncLib (&asCode) "" to iResult
            Send AssertIAreEqual 1 iResult
            // The guarded macro block was spliced in, intact + consecutive...
            Move (SearchArray("#IFNDEF SELECT", asCode)) to iPos
            Send Assert (iPos >= 0)
            Send Assert (asCode[iPos + 1] = CS_SelectMacroDefineLine)
            Send Assert (asCode[iPos + 2] = "#ENDIF")
            // ...after the leading Use block, before the first code line.
            Send Assert (iPos > (SearchArray("Use cObject.pkg", asCode)))
            Send Assert (iPos < (SearchArray("Procedure Foo", asCode)))
        End_Procedure

        // Bare (Select) in code, no Use statements, a header comment present: the macro goes after the
        // header, before the first code line (never inside the comment).
        {Published = True}
        Procedure AddUseOldFMACCommands_AfterHeaderComment
            Integer iResult iPos
            String[] asCode

            Move "// My report"                to asCode[0]
            Move "Object oReport is a cReport" to asCode[1]
            Move "    If (Select) Begin"       to asCode[2]
            Move "    End"                     to asCode[3]
            Move "End_Object"                  to asCode[4]

            Send ClearFuncLibProperties of ghoFuncLib
            Get AddUseOldFMACCommands of ghoFuncLib (&asCode) "" to iResult
            Send AssertIAreEqual 1 iResult
            Move (SearchArray("#IFNDEF SELECT", asCode)) to iPos
            Send Assert (iPos >= 0)
            Send Assert (asCode[iPos + 1] = CS_SelectMacroDefineLine)
            Send Assert (asCode[iPos + 2] = "#ENDIF")
            // After the header comment, before the first code line.
            Send Assert (iPos > (SearchArray("// My report", asCode)))
            Send Assert (iPos < (SearchArray("Object oReport is a cReport", asCode)))
        End_Procedure

        // Bare (Select) in code at the very top (no header, no Use): the macro goes first.
        {Published = True}
        Procedure AddUseOldFMACCommands_AtTop
            Integer iResult iPos
            String[] asCode

            Move "Object oFoo is a cBar"   to asCode[0]
            Move "    Move (Select) to bX" to asCode[1]
            Move "End_Object"              to asCode[2]

            Send ClearFuncLibProperties of ghoFuncLib
            Get AddUseOldFMACCommands of ghoFuncLib (&asCode) "" to iResult
            Send AssertIAreEqual 1 iResult
            Move (SearchArray("#IFNDEF SELECT", asCode)) to iPos
            Send Assert (iPos >= 0)
            Send Assert (asCode[iPos + 1] = CS_SelectMacroDefineLine)
            Send Assert (asCode[iPos + 2] = "#ENDIF")
            // Before the first code line.
            Send Assert (iPos < (SearchArray("Object oFoo is a cBar", asCode)))
        End_Procedure

        // Bare (Select) in code but the SELECT macro is already defined in-source (our shim present):
        // no change, returns 0. (A leftover 'Use OldFMACCommands.pkg' is NOT a definition - that case
        // still gets the shim - so the marker is the #Replace SELECT line, not a Use line.)
        {Published = True}
        Procedure AddUseOldFMACCommands_AlreadyPresent
            Integer iResult
            String[] asCode asExpected

            Move "#IFNDEF SELECT"          to asCode[0]
            Move CS_SelectMacroDefineLine to asCode[1]
            Move "#ENDIF"                  to asCode[2]
            Move "Procedure Foo"           to asCode[3]
            Move "    If (Select) Begin"   to asCode[4]
            Move "    End"                 to asCode[5]
            Move "End_Procedure"          to asCode[6]

            Move "#IFNDEF SELECT"          to asExpected[0]
            Move CS_SelectMacroDefineLine to asExpected[1]
            Move "#ENDIF"                  to asExpected[2]
            Move "Procedure Foo"           to asExpected[3]
            Move "    If (Select) Begin"   to asExpected[4]
            Move "    End"                 to asExpected[5]
            Move "End_Procedure"          to asExpected[6]

            Send ClearFuncLibProperties of ghoFuncLib
            Get AddUseOldFMACCommands of ghoFuncLib (&asCode) "" to iResult
            Send AssertArrayAreEqual asExpected asCode
            Send AssertIAreEqual 0 iResult
        End_Procedure

        // No bare Select anywhere - identifiers that merely CONTAIN "select" (bSelected, Select_State)
        // must not count. The function is a no-op, returns 0.
        {Published = True}
        Procedure AddUseOldFMACCommands_NoSelect_NoChange
            Integer iResult
            String[] asCode asExpected

            Move "Use Windows.pkg"                  to asCode[0]
            Move "Procedure Foo"                    to asCode[1]
            Move "    If (bSelected) Begin"         to asCode[2]
            Move "        Get Select_State to bX"   to asCode[3]
            Move "    End"                          to asCode[4]
            Move "End_Procedure"                   to asCode[5]

            Move "Use Windows.pkg"                  to asExpected[0]
            Move "Procedure Foo"                    to asExpected[1]
            Move "    If (bSelected) Begin"         to asExpected[2]
            Move "        Get Select_State to bX"   to asExpected[3]
            Move "    End"                          to asExpected[4]
            Move "End_Procedure"                   to asExpected[5]

            Send ClearFuncLibProperties of ghoFuncLib
            Get AddUseOldFMACCommands of ghoFuncLib (&asCode) "" to iResult
            Send AssertArrayAreEqual asExpected asCode
            Send AssertIAreEqual 0 iResult
        End_Procedure

        // A SQL 'SELECT' inside a normal "..." string literal is masked by the tokeniser (overstrike),
        // so it must not trigger the package. Returns 0.
        {Published = True}
        Procedure AddUseOldFMACCommands_SqlInStringLiteral_NoChange
            Integer iResult
            String[] asCode asExpected

            Move "Procedure Foo"                              to asCode[0]
            Move '    Move "SELECT * FROM Customer" to sSql'  to asCode[1]
            Move "End_Procedure"                             to asCode[2]

            Move "Procedure Foo"                              to asExpected[0]
            Move '    Move "SELECT * FROM Customer" to sSql'  to asExpected[1]
            Move "End_Procedure"                             to asExpected[2]

            Send ClearFuncLibProperties of ghoFuncLib
            Get AddUseOldFMACCommands of ghoFuncLib (&asCode) "" to iResult
            Send AssertArrayAreEqual asExpected asCode
            Send AssertIAreEqual 0 iResult
        End_Procedure

        // A multi-line SQL block (@SQL""" ... """) is flagged bIsInDF23MultiLineString and skipped, so a
        // 'SELECT' on its interior lines never triggers the package. Returns 0.
        {Published = True}
        Procedure AddUseOldFMACCommands_SqlMultiLine_NoChange
            Integer iResult
            String[] asCode asExpected

            Move "Procedure Foo"                   to asCode[0]
            Move '    Move (@SQL"""'               to asCode[1]
            Move "        SELECT * FROM Customer"  to asCode[2]
            Move "        WHERE ID = 5"            to asCode[3]
            Move '        """) to sResult'         to asCode[4]
            Move "End_Procedure"                  to asCode[5]

            Move "Procedure Foo"                   to asExpected[0]
            Move '    Move (@SQL"""'               to asExpected[1]
            Move "        SELECT * FROM Customer"  to asExpected[2]
            Move "        WHERE ID = 5"            to asExpected[3]
            Move '        """) to sResult'         to asExpected[4]
            Move "End_Procedure"                  to asExpected[5]

            Send ClearFuncLibProperties of ghoFuncLib
            Get AddUseOldFMACCommands of ghoFuncLib (&asCode) "" to iResult
            Send AssertArrayAreEqual asExpected asCode
            Send AssertIAreEqual 0 iResult
        End_Procedure

        // 'Select' mentioned only in a // comment is skipped (bIsComment), so no package is added. 0.
        {Published = True}
        Procedure AddUseOldFMACCommands_SelectInComment_NoChange
            Integer iResult
            String[] asCode asExpected

            Move "Procedure Foo"                        to asCode[0]
            Move "    // handle the (Select) indicator" to asCode[1]
            Move "    Move 1 to iX"                     to asCode[2]
            Move "End_Procedure"                       to asCode[3]

            Move "Procedure Foo"                        to asExpected[0]
            Move "    // handle the (Select) indicator" to asExpected[1]
            Move "    Move 1 to iX"                     to asExpected[2]
            Move "End_Procedure"                       to asExpected[3]

            Send ClearFuncLibProperties of ghoFuncLib
            Get AddUseOldFMACCommands of ghoFuncLib (&asCode) "" to iResult
            Send AssertArrayAreEqual asExpected asCode
            Send AssertIAreEqual 0 iResult
        End_Procedure

        // The 'Indicate Select as X' modernised form 'Move (X) to Select' ends with a bare Select - it must
        // trigger the macro. The shim goes after the leading Use. Returns 1.
        {Published = True}
        Procedure AddUseOldFMACCommands_BareSelectAfterTo
            Integer iResult iPos
            String[] asCode

            Move "Use Windows.pkg"            to asCode[0]
            Move "Procedure Foo"              to asCode[1]
            Move "    Move (Found) to Select" to asCode[2]
            Move "End_Procedure"             to asCode[3]

            Send ClearFuncLibProperties of ghoFuncLib
            Get AddUseOldFMACCommands of ghoFuncLib (&asCode) "" to iResult
            Send AssertIAreEqual 1 iResult
            Move (SearchArray("#IFNDEF SELECT", asCode)) to iPos
            Send Assert (iPos >= 0)
            Send Assert (asCode[iPos + 1] = CS_SelectMacroDefineLine)
            Send Assert (asCode[iPos + 2] = "#ENDIF")
            Send Assert (iPos > (SearchArray("Use Windows.pkg", asCode)))
            Send Assert (iPos < (SearchArray("Procedure Foo", asCode)))
        End_Procedure

    End_Object
