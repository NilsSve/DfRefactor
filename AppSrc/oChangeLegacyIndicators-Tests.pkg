        {Published = True}
        // Regression test: trailing ')' from outer scope must not cause placeholder leak.
        // Bug: last line of compound If "((iSdagnr Eq 4) and (MASK1.SERVICEDAG4 eq iServicedag))) Begin"
        // was becoming "||||...||||) Begin" because SearchArray couldn't find the placeholder with trailing ')'.
        Procedure ChangeLegacyIndicators_55
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    ((iSdagnr Eq 4) and (MASK1.SERVICEDAG4 eq iServicedag))) Begin' to sLine
            Move '    ((iSdagnr Eq 4) and (MASK1.SERVICEDAG4 eq iServicedag))) Begin' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLegacyIndicators of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
