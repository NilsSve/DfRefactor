        {Published = True}
        { Description = """
            Guards the UTF-8 -> OEM -> UTF-8 round-trip for a legacy Swedish
            source line. Catches regressions of the Utf8ToOem bug where
            PointerToString re-decoded OEM bytes as UTF-8 and lopped
            characters off the tail of the line on write-back.
            """ }
        Procedure ChangeLegacyIndicators_48
            String  sOriginal sRoundTripped
            UChar[] ucaOemBytes
            Integer iIdx iCountA iExpectedBytes

            Move 'Set Label to "Create log file with booking, ÅÅÅÅMMDD-Order.txt"' to sOriginal

            // Step 1: Unicode line -> CP850 bytes, via the byte-safe encoder
            //         (does NOT route OEM bytes through PointerToString).
            Move (Utf8LineToOemBytes(sOriginal)) to ucaOemBytes

            // Step 2: byte-count sanity check.
            //         The line has 61 characters; 4 of them (Å) are non-ASCII.
            //         In CP850 each character is exactly 1 byte, so we expect
            //         the OEM buffer to be exactly the same length as the
            //         character count -- 61 bytes, not more, not less.
            Move (Length(sOriginal)) to iExpectedBytes
            Send AssertIAreEqual iExpectedBytes (SizeOfArray(ucaOemBytes)) ;
                "OEM byte count must match character count for CP850 input"

            // Step 3: spot-check that every 'Å' was encoded as 0x8F (143) in CP850.
            //         The source line contains 4 of them.
            Move 0 to iCountA
            For iIdx From 0 To (SizeOfArray(ucaOemBytes) - 1)
                If (ucaOemBytes[iIdx] = 143) Increment iCountA
            Loop
            Send AssertIAreEqual 4 iCountA ;
                "Expected 4 occurrences of CP850 0x8F ('Å') in the encoded bytes"

            // Step 4: full round-trip -- OEM bytes back to a Unicode String.
            //         Every character, including those at the tail, must be
            //         preserved exactly. This is the regression guard for the
            //         'two characters chopped off the end' symptom.
            Move (OemBytesToUtf8(ucaOemBytes)) to sRoundTripped
            Send AssertSAreEqual sOriginal sRoundTripped ;
                "UTF-8 -> OEM -> UTF-8 round-trip must preserve the full line"
        End_Procedure

