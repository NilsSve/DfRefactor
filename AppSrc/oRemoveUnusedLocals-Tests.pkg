    Object oRemoveUnusedLocals is a cTestFixture
        Set psFunctionName to "RemoveUnusedLocals"

        {Published = True}
        // Not sure how we should test this?
        Procedure RemoveUnusedLocals_1
            String[] asCode asExpected
            Boolean bChanged
            Integer iItem

            Move 0 to iItem
            Move "Procedure Test"                       to asCode[iItem]
            Increment iItem
            Move     "Date dToday"                      to asCode[iItem]
            Increment iItem
            Move     "String sVal"                      to asCode[iItem]
            Increment iItem
            Move     "Integer iVal"                     to asCode[iItem]
            Increment iItem
            Move     "Sysdate4 dToday"                  to asCode[iItem]
            Increment iItem
            Move     "Move (dToday + 23) to dToday"     to asCode[iItem]
            Increment iItem
            Move "End_Procedure"                        to asCode[iItem]

            Move 0 to iItem
            Move "Procedure Test"                       to asExpected[iItem]
            Increment iItem
            Move     "Date dToday"                      to asExpected[iItem]
            Increment iItem
            Move     "Sysdate4 dToday"                  to asExpected[iItem]
            Increment iItem
            Move     "Move (dToday + 23) to dToday"     to asExpected[iItem]
            Increment iItem
            Move "End_Procedure"                        to asExpected[iItem]

            Get RemoveUnusedLocals of ghoFuncLib (&asCode) to bChanged
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

        // All declared variables are used -- code array must be unchanged and return 0.
        {Published = True}
        Procedure RemoveUnusedLocals_AllUsed
            String[] asCode asExpected
            Integer iResult

            Move "Procedure Test"          to asCode[0]
            Move "String sName"            to asCode[1]
            Move "Integer iCount"          to asCode[2]
            Move "Move x to sName"         to asCode[3]
            Move "Move 1 to iCount"        to asCode[4]
            Move "End_Procedure"           to asCode[5]

            Move "Procedure Test"          to asExpected[0]
            Move "String sName"            to asExpected[1]
            Move "Integer iCount"          to asExpected[2]
            Move "Move x to sName"         to asExpected[3]
            Move "Move 1 to iCount"        to asExpected[4]
            Move "End_Procedure"           to asExpected[5]

            Get RemoveUnusedLocals of ghoFuncLib (&asCode) to iResult
            Send AssertIAreEqual 0 iResult
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

        // Two unused variables each on their own declaration line -- both lines are removed.
        // Return value equals the number of unused variables removed (2).
        {Published = True}
        Procedure RemoveUnusedLocals_MultipleUnused
            String[] asCode asExpected
            Integer iResult

            Move "Procedure Test"          to asCode[0]
            Move "String sA"               to asCode[1]
            Move "String sB"               to asCode[2]
            Move "String sC"               to asCode[3]
            Move "Move x to sC"            to asCode[4]
            Move "End_Procedure"           to asCode[5]

            Move "Procedure Test"          to asExpected[0]
            Move "String sC"               to asExpected[1]
            Move "Move x to sC"            to asExpected[2]
            Move "End_Procedure"           to asExpected[3]

            Get RemoveUnusedLocals of ghoFuncLib (&asCode) to iResult
            Send AssertIAreEqual 2 iResult
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

        // Two variables declared on the same line; only one is unused.
        // The unused name is removed from the declaration line -- the line itself stays.
        {Published = True}
        Procedure RemoveUnusedLocals_PartialLineRemoval
            String[] asCode asExpected
            Integer iResult

            Move "Procedure Test"          to asCode[0]
            Move "String sUsed sUnused"    to asCode[1]
            Move "Move x to sUsed"         to asCode[2]
            Move "End_Procedure"           to asCode[3]

            Move "Procedure Test"          to asExpected[0]
            Move "String sUsed"            to asExpected[1]
            Move "Move x to sUsed"         to asExpected[2]
            Move "End_Procedure"           to asExpected[3]

            Get RemoveUnusedLocals of ghoFuncLib (&asCode) to iResult
            Send AssertIAreEqual 1 iResult
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

        // Unused variable inside a Function block (not just Procedure) is removed.
        {Published = True}
        Procedure RemoveUnusedLocals_FunctionBlock
            String[] asCode asExpected
            Integer iResult

            Move "Function ComputeVal Integer iA Returns Integer" to asCode[0]
            Move "Integer iResult"                                to asCode[1]
            Move "Integer iTemp"                                  to asCode[2]
            Move "Move iA to iResult"                             to asCode[3]
            Move "Function_Return iResult"                        to asCode[4]
            Move "End_Function"                                   to asCode[5]

            Move "Function ComputeVal Integer iA Returns Integer" to asExpected[0]
            Move "Integer iResult"                                to asExpected[1]
            Move "Move iA to iResult"                             to asExpected[2]
            Move "Function_Return iResult"                        to asExpected[3]
            Move "End_Function"                                   to asExpected[4]

            Get RemoveUnusedLocals of ghoFuncLib (&asCode) to iResult
            Send AssertIAreEqual 1 iResult
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

        // Variable declared with the 'Local' keyword and never used -- the entire line is removed.
        {Published = True}
        Procedure RemoveUnusedLocals_LocalKeyword
            String[] asCode asExpected
            Integer iResult

            Move "Procedure Test"          to asCode[0]
            Move "Local String sUnused"    to asCode[1]
            Move "Integer iCount"          to asCode[2]
            Move "Move 1 to iCount"        to asCode[3]
            Move "End_Procedure"           to asCode[4]

            Move "Procedure Test"          to asExpected[0]
            Move "Integer iCount"          to asExpected[1]
            Move "Move 1 to iCount"        to asExpected[2]
            Move "End_Procedure"           to asExpected[3]

            Get RemoveUnusedLocals of ghoFuncLib (&asCode) to iResult
            Send AssertIAreEqual 1 iResult
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

        // Regression: a local used only on a ;-continued line must NOT be removed.
        // The lexer previously wholesale-overstruck ;-continued non-DF23 lines,
        // hiding sSERVICEDAG2/3/4 from the usage scan so they were wrongly deleted.
        {Published = True}
        Procedure RemoveUnusedLocals_SemiColonContinuation
            String[] asCode asExpected
            Integer iResult iItem iMax

            Move 0 to iItem
            Move "Procedure Test"                                                  to asCode[iItem]
            Increment iItem
            Move "Integer isDagnr iServiceDag"                                     to asCode[iItem]
            Increment iItem
            Move "String sSERVICEDAG sSERVICEDAG2 sSERVICEDAG3 sSERVICEDAG4"        to asCode[iItem]
            Increment iItem
            Move "If (((isDagnr Eq 1) and (sSERVICEDAG eq iServiceDag)) ;"          to asCode[iItem]
            Increment iItem
            Move "    or ((isDagnr Eq 2) and (sSERVICEDAG2 eq iServiceDag)) ;"      to asCode[iItem]
            Increment iItem
            Move "    or ((isDagnr Eq 3) and (sSERVICEDAG3 eq iServiceDag)) ;"      to asCode[iItem]
            Increment iItem
            Move "    or ((isDagnr Eq 4) and (sSERVICEDAG4 eq iServiceDag))) Begin" to asCode[iItem]
            Increment iItem
            Move "    Send None"                                                   to asCode[iItem]
            Increment iItem
            Move "End"                                                             to asCode[iItem]
            Increment iItem
            Move "End_Procedure"                                                   to asCode[iItem]

            Move (SizeOfArray(asCode)) to iMax
            Decrement iMax
            For iItem from 0 to iMax
                Move asCode[iItem] to asExpected[iItem]
            Loop

            Get RemoveUnusedLocals of ghoFuncLib (&asCode) to iResult
            Send AssertIAreEqual 0 iResult
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

        // Regression: a local used only AFTER the closing quote of an old-school
        // ;-continued multi-line string ("..." spanning physical lines, each
        // continued line ending with ;) must NOT be removed. The lexer must keep
        // string content overstruck but resume scanning real code (` to sTest`)
        // once the closing quote is found. A leading /* */ block comment that
        // contains a look-alike declaration must be left untouched.
        {Published = True}
        Procedure RemoveUnusedLocals_OldSchoolMultiLineString
            String[] asCode asExpected
            Integer iResult iItem iMax

            Move 0 to iItem
            Move "Procedure TestSemiColons"                                          to asCode[iItem]
            Increment iItem
            Move "    /*"                                                            to asCode[iItem]
            Increment iItem
            Move "    String sTest1"                                                 to asCode[iItem]
            Increment iItem
            Move "    */"                                                            to asCode[iItem]
            Increment iItem
            Move "    String sTest"                                                  to asCode[iItem]
            Increment iItem
            Move '    Move "This is a test string on multiple lines;'                 to asCode[iItem]
            Increment iItem
            Move "    using the 'old school' DataFlex multi-line string version.;"    to asCode[iItem]
            Increment iItem
            Move "    in contrast the new DF23 string style doesn't;"                 to asCode[iItem]
            Increment iItem
            Move '    need a semicolon at the end of line." to sTest'                 to asCode[iItem]
            Increment iItem
            Move "End_Procedure"                                                     to asCode[iItem]

            Move (SizeOfArray(asCode)) to iMax
            Decrement iMax
            For iItem from 0 to iMax
                Move asCode[iItem] to asExpected[iItem]
            Loop

            Get RemoveUnusedLocals of ghoFuncLib (&asCode) to iResult
            Send AssertIAreEqual 0 iResult
            Send AssertArrayAreEqual asExpected asCode
        End_Procedure

    End_Object
