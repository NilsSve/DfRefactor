    Object oRemoveTrailingSpaces is a cTestFixture
        Set psFunctionName to "RemoveTrailingSpaces"

        {Published = True}
        Procedure RemoveTrailingSpaces_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move True to Seqeof     ' to sLine
            Move 'Move True to Seqeof' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveTrailingSpaces of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // No trailing spaces -- bChanged must be False.
        {Published = True}
        Procedure RemoveTrailingSpaces_2
            String sLine
            Boolean bChanged
            Move 'Move True to Seqeof' to sLine
            Get RemoveTrailingSpaces of ghoFuncLib (&sLine) to bChanged
            Send Assert (bChanged = False)
        End_Procedure

        // A line of only spaces is reduced to an empty string.
        {Published = True}
        Procedure RemoveTrailingSpaces_3
            String sLine sExpected
            Boolean bChanged
            Move '     ' to sLine
            Move '' to sExpected
            Get RemoveTrailingSpaces of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Leading indentation is preserved; only trailing spaces are removed.
        {Published = True}
        Procedure RemoveTrailingSpaces_4
            String sLine sExpected
            Boolean bChanged
            Move '    Move True to Seqeof   ' to sLine
            Move '    Move True to Seqeof' to sExpected
            Get RemoveTrailingSpaces of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Return value must be True when trailing spaces are removed.
        {Published = True}
        Procedure RemoveTrailingSpaces_ReturnValue
            String sLine
            Boolean bChanged
            Move 'Move x to y   ' to sLine
            Get RemoveTrailingSpaces of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
        End_Procedure

    End_Object
