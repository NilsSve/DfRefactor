            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Kalle Oskar' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send AssertFalse (TokenizerData.bIsVariableDeclaration = True)
        End_Procedure

        {Published = True}
        Procedure Tokenizer_63
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If code# eq 0 If tmp# ge 0 Begin' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (SizeOfArray(TokenizerData.aExpressions) = 2)
        End_Procedure

        {Published = True}
        Procedure Tokenizer_64
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If code# eq 0 If tmp# ge 0 Begin' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            If (SizeOfArray(TokenizerData.aExpressions) = 1) Begin
                Send AssertSAreEqual (TokenizerData.aExpressions[0].sExpression <> "(code# eq 0)")
            End
            Else Begin
                Send AssertSAreEqual (TokenizerData.aExpressions[0].sExpression <> "(code# eq 0)" or TokenizerData.aExpressions[1].sExpression <> "(tmp# ge 0)")
            End
        End_Procedure

        // Interior lines of a @SQL""" multi-line block must have bLineIsReady=True
        // and asLineTokens must be empty (no overstrike chars like "^^^^^^" present).
        {Published = True}
        Procedure Tokenizer_65
            String sLine
            tTokenizer TokenizerData
            // Simulate entering a @SQL""" block
            Set piMultiLineStringType of ghoFuncLib to MLS_SQLTripleQuote
            Move '        SELECT' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bLineIsReady = True)
            Send Assert (TokenizerData.bIsInDF23MultiLineString = True)
            Send Assert (SizeOfArray(TokenizerData.asLineTokens) = 0)
            Set piMultiLineStringType of ghoFuncLib to MLS_None
        End_Procedure

        // iTokenCount must equal SizeOfArray(asLineTokens).
        // For "IF NOT ('BIP' contains BALANCE_TYPE) MOVE 'I' TO BALANCE_TYPE" the
        // parenthesis expression is one token, so the total must be 7, not 9 (raw split count).
        {Published = True}
        Procedure Tokenizer_66
            String sLine
            tTokenizer TokenizerData
            Move "    IF NOT ('BIP' contains BALANCE_TYPE) MOVE 'I' TO BALANCE_TYPE" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.iTokenCount = 7)
            Send Assert (TokenizerData.iTokenCount = SizeOfArray(TokenizerData.asLineTokens))
            Send AssertSAreEqual "('BIP' contains BALANCE_TYPE)" TokenizerData.asLineTokens[2]
        End_Procedure

        // Property declaration line is detected (bIsPropertyDeclaration = True).
        {Published = True}
        Procedure Tokenizer_67
            String sLine
            tTokenizer TokenizerData
            Move 'Property Integer piMyValue 0' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsPropertyDeclaration = True)
        End_Procedure

        // "Property ..." inside a string literal is NOT detected as a property declaration.
        {Published = True}
        Procedure Tokenizer_68
            String sLine
            tTokenizer TokenizerData
            Move 'Move "Property Integer piMyValue" to sLine' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsPropertyDeclaration = False)
        End_Procedure

        // End_Function when inside a function resets bIsInFunction and sets bLineIsReady.
        {Published = True}
        Procedure Tokenizer_69
            String sLine
            tTokenizer TokenizerData
            Set pbInFunction of ghoFuncLib to True
            Move 'End_Function' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsInFunction = False)
            Send Assert (TokenizerData.bLineIsReady = True)
        End_Procedure

        // End_Procedure when inside a procedure resets bIsInProcedure and sets bLineIsReady.
        {Published = True}
        Procedure Tokenizer_70
            String sLine
            tTokenizer TokenizerData
            Set pbInProcedure of ghoFuncLib to True
            Move 'End_Procedure' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsInProcedure = False)
            Send Assert (TokenizerData.bLineIsReady = True)
        End_Procedure

        // End_Object when inside an object resets bIsInObject and sets bLineIsReady.
        {Published = True}
        Procedure Tokenizer_71
            String sLine
            tTokenizer TokenizerData
            Set pbInObject of ghoFuncLib to True
            Move 'End_Object' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsInObject = False)
            Send Assert (TokenizerData.bLineIsReady = True)
        End_Procedure

        // End_Class when inside a class resets bIsInClass and sets bLineIsReady.
        {Published = True}
        Procedure Tokenizer_72
            String sLine
            tTokenizer TokenizerData
            Set pbInClass of ghoFuncLib to True
            Move 'End_Class' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsInClass = False)
            Send Assert (TokenizerData.bLineIsReady = True)
        End_Procedure

        // End_Struct when inside a struct resets bIsInStruct and sets bLineIsReady.
        {Published = True}
        Procedure Tokenizer_73
            String sLine
            tTokenizer TokenizerData
            Set pbInStruct of ghoFuncLib to True
            Move 'End_Struct' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsInStruct = False)
            Send Assert (TokenizerData.bLineIsReady = True)
        End_Procedure

        // #ENDCOMMAND when inside a command block resets bIsInCommand and sets bLineIsReady.
        {Published = True}
        Procedure Tokenizer_74
            String sLine
            tTokenizer TokenizerData
            Set pbInCommand of ghoFuncLib to True
            Move '#ENDCOMMAND' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsInCommand = False)
            Send Assert (TokenizerData.bLineIsReady = True)
        End_Procedure

        // A line with three double-quoted strings has all three collected in asStringConstant.
        {Published = True}
        Procedure Tokenizer_75
            String sLine
            tTokenizer TokenizerData
            Move 'Move (Trim("Hello") + " " + Trim("World")) to sMsg' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (SizeOfArray(TokenizerData.asStringConstant) = 3)
        End_Procedure

        // A line mixing double-quoted and single-quoted strings has both collected in asStringConstant.
        {Published = True}
        Procedure Tokenizer_76
            String sLine
            tTokenizer TokenizerData
            Move ('If (sA = "foo" and sB = ' + "'" + 'bar' + "'" + ') Move True to bMatch') to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (SizeOfArray(TokenizerData.asStringConstant) = 2)
        End_Procedure

        // sFirstToken is the first non-whitespace token of the line, regardless of indentation.
        {Published = True}
        Procedure Tokenizer_77
            String sLine
            tTokenizer TokenizerData
            Move '    Get psMyProp of ghoApp to sVal' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send AssertSAreEqual "Get" TokenizerData.sFirstToken
        End_Procedure

        // bIsSetStatement is True when the first token is "Set".
        {Published = True}
        Procedure Tokenizer_78
            String sLine
            tTokenizer TokenizerData
            Move 'Set pbVisible of oMyPanel to True' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsSetStatement = True)
            Send Assert (TokenizerData.bIsGetStatement = False)
        End_Procedure

        // bIsBeginStatement is True and bIsEndStatement is False for a Begin-only line.
        {Published = True}
        Procedure Tokenizer_79
            String sLine
            tTokenizer TokenizerData
            Move '    Begin' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsBeginStatement = True)
            Send Assert (TokenizerData.bIsEndStatement = False)
        End_Procedure

        // bIsEndStatement is True and bIsBeginStatement is False for a standalone End line.
        {Published = True}
        Procedure Tokenizer_80
            String sLine
            tTokenizer TokenizerData
            Move '    End' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsEndStatement = True)
            Send Assert (TokenizerData.bIsBeginStatement = False)
        End_Procedure

        // iTokenCount equals 4 for a simple four-token Move statement.
        {Published = True}
        Procedure Tokenizer_81
            String sLine
            tTokenizer TokenizerData
            Move 'Move sA to sB' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.iTokenCount = 4)
        End_Procedure

        // sEndComment captures the full end comment even when it contains "//".
        {Published = True}
        Procedure Tokenizer_82
            String sLine sExpected
            tTokenizer TokenizerData
            Move 'Move sA to sB // See: http://example.com/path' to sLine
            Move '// See: http://example.com/path' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send AssertSAreEqual sExpected TokenizerData.sEndComment
        End_Procedure

        // "//" inside a string constant must not be mistaken for the end-comment delimiter.
        {Published = True}
        Procedure Tokenizer_83
            String sLine sExpected
            tTokenizer TokenizerData
            Move 'Move "http://example.com/path" to sLine // Some end comment.' to sLine
            Move '// Some end comment.' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send AssertSAreEqual sExpected TokenizerData.sEndComment
        End_Procedure

        // Single-line at-quoted SQL string: "//" inside @"..." must not be captured as end comment.
        {Published = True}
        Procedure Tokenizer_84
            String sLine sExpected
            tTokenizer TokenizerData
            Move 'Move @"http://example.com" to sUrl // DF comment' to sLine
            Move '// DF comment' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send AssertSAreEqual sExpected TokenizerData.sEndComment
        End_Procedure

        // Single-line triple-quote string: "//" inside """...""" must not be captured as end comment.
        {Published = True}
        Procedure Tokenizer_85
            String sLine sExpected
            tTokenizer TokenizerData
            Move 'Move """http://example.com""" to sUrl // DF comment' to sLine
            Move '// DF comment' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send AssertSAreEqual sExpected TokenizerData.sEndComment
        End_Procedure

        // Multi-line SQL string continuation with "//" in SQL content: line must be flagged
        // as bLineIsReady so refactoring functions never process it.
        {Published = True}
        Procedure Tokenizer_86
            String sLine
            tTokenizer TokenizerData
            Move '    WHERE url = "http://example.com" AND active = 1' to sLine
            Set piMultiLineStringType of ghoFuncLib to MLS_SQLDoubleQuote
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsInDF23MultiLineString = True)
            Send Assert (TokenizerData.bLineIsReady = True)
        End_Procedure

        // Multi-line triple-quote string continuation with "//" in content: same guarantee.
        {Published = True}
        Procedure Tokenizer_87
            String sLine
            tTokenizer TokenizerData
            Move '    http://example.com/path' to sLine
            Set piMultiLineStringType of ghoFuncLib to MLS_TripleQuote
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Send Assert (TokenizerData.bIsInDF23MultiLineString = True)
            Send Assert (TokenizerData.bLineIsReady = True)
        End_Procedure

    End_Object
