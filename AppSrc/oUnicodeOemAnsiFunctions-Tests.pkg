    // Unit tests for UnicodeOemAnsiFunctions - the line-by-line (eStandardFunction)
    // refactor that modernizes the legacy OEM/ANSI string-conversion calls:
    //   ToOEM(x)  -> Utf8ToOem(x)
    //   ToANSI(x) -> Utf8ToAnsi(x)
    // Each test sets one source line, tokenizes it (Get Tokenizer ... populates the
    // funclib's pTokenizer, which the function reads for the masked overstrike), then
    // calls the function and checks the result. It is whole-word + masked: an already-
    // converted call, and a call inside a string literal, are left untouched.
    Object oUnicodeOemAnsiFunctions is a cTestFixture
        Set psFunctionName to "UnicodeOemAnsiFunctions"

        // ToOEM(x) -> Utf8ToOem(x)
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_ToOEM_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (ToOEM(sData)) to sBuffer" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Move (Utf8ToOem(sData)) to sBuffer" sLine
        End_Procedure

        // ToANSI(x) -> Utf8ToAnsi(x)
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_ToANSI_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (ToANSI(sData)) to sBuffer" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Move (Utf8ToAnsi(sData)) to sBuffer" sLine
        End_Procedure

        // Idempotent: an already-converted call (Utf8ToOem) must NOT be re-wrapped -
        // the left word-boundary stops "ToOem" inside "Utf8ToOem" from matching.
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_AlreadyConverted_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (Utf8ToOem(sData)) to sBuffer" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual "    Move (Utf8ToOem(sData)) to sBuffer" sLine
        End_Procedure

        // Masked: a ToOEM( inside a string literal must be left untouched.
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_InsideString_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move '    Move "use ToOEM(x) here" to sBuffer' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual '    Move "use ToOEM(x) here" to sBuffer' sLine
        End_Procedure

        // Multiple calls (both kinds) on one line are all converted in one pass.
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_MultiplePerLine_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (ToOEM(sA) * ToANSI(sB)) to sC" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Move (Utf8ToOem(sA) * Utf8ToAnsi(sB)) to sC" sLine
        End_Procedure

        // A ToOEM nested inside another call - the shape ChangeTrimCommandToFunction produces from
        // "Trim (ToOEM(x)) to x". Only ToOEM is renamed; the outer Trim and the parens stay intact.
        // Regression: when ChangeTrim ran first in the same line-by-line pass WITHOUT a re-tokenize,
        // the stale masked line skewed the splice and produced "Move (Utf8ToOem(ToOEM(x))))" (Trim
        // clobbered, ToOEM left, extra paren). Fixed by the engine re-tokenizing between functions.
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_NestedInTrim_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (Trim(ToOEM(event.UserId))) to event.UserId" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Move (Trim(Utf8ToOem(event.UserId))) to event.UserId" sLine
        End_Procedure

        // A space between the name and the "(" is valid DataFlex - "ToOEM (sPath)" is a
        // call. Regression (Nils, 2026-06-10, real source line): _RenameMaskedCalls
        // required the "(" to be ADJACENT, so spaced calls were silently skipped.
        // Only the name is replaced; the original spacing must survive.
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_SpaceBeforeParen_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "            Move (ToOEM (sPath)) to sPath" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "            Move (Utf8ToOem (sPath)) to sPath" sLine
        End_Procedure

        // The second real-world miss from the same report: a spaced ToAnsi nested inside
        // another spaced call. Only ToAnsi is renamed; FileDateTime and all spacing stay.
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_SpacedNestedCall_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "                        Move (FileDateTime (ToAnsi (sPath))) to FileInfo" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "                        Move (FileDateTime (Utf8ToAnsi (sPath))) to FileInfo" sLine
        End_Procedure

        // Idempotence must also hold for the spaced form: an already-converted
        // "Utf8ToOem (x)" is left alone (left word-boundary, as in the adjacent case).
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_SpacedAlreadyConverted_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (Utf8ToOem (sData)) to sBuffer" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual "    Move (Utf8ToOem (sData)) to sBuffer" sLine
        End_Procedure

    End_Object
