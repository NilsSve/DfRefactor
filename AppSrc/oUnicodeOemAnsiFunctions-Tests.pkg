    // Unit tests for UnicodeOemAnsiFunctions - the line-by-line (eStandardFunction)
    // refactor that modernizes the legacy OEM/ANSI string-conversion calls:
    //   ToOEM(x)  -> Utf8ToOem(x)
    //   ToANSI(x) -> Utf8ToAnsi(x)
    // Each test sets one source line, tokenizes it (Get Tokenizer ... populates the
    // funclib's pTokenizer, which the function reads for the masked overstrike), then
    // calls the function and checks the result. It is whole-word + masked: an already-
    // converted call, and a call inside a string literal, are left untouched.
    Object oUnicodeOemAnsiFunctions is a cTestFixture
        Set psFunctionName to "UnicodeOemAnsiFunctions"

        // ToOEM(x) -> Utf8ToOem(x)
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_ToOEM_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (ToOEM(sData)) to sBuffer" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Move (Utf8ToOem(sData)) to sBuffer" sLine
        End_Procedure

        // ToANSI(x) -> Utf8ToAnsi(x)
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_ToANSI_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (ToANSI(sData)) to sBuffer" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Move (Utf8ToAnsi(sData)) to sBuffer" sLine
        End_Procedure

        // Idempotent: an already-converted call (Utf8ToOem) must NOT be re-wrapped -
        // the left word-boundary stops "ToOem" inside "Utf8ToOem" from matching.
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_AlreadyConverted_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (Utf8ToOem(sData)) to sBuffer" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual "    Move (Utf8ToOem(sData)) to sBuffer" sLine
        End_Procedure

        // Masked: a ToOEM( inside a string literal must be left untouched.
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_InsideString_NotChanged
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move '    Move "use ToOEM(x) here" to sBuffer' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = False)
            Send AssertSAreEqual '    Move "use ToOEM(x) here" to sBuffer' sLine
        End_Procedure

        // Multiple calls (both kinds) on one line are all converted in one pass.
        {Published = True}
        Procedure UnicodeOemAnsiFunctions_MultiplePerLine_Renamed
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Send ClearFuncLibProperties of ghoFuncLib
            Move "    Move (ToOEM(sA) * ToANSI(sB)) to sC" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get UnicodeOemAnsiFunctions of ghoFuncLib (&sLine) "" to bChanged
            Send Assert (bChanged = True)
            Send AssertSAreEqual "    Move (Utf8ToOem(sA) * Utf8ToAnsi(sB)) to sC" sLine
        End_Procedure

    End_Object
