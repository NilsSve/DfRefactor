    Object oChangePadCommandToFunction is a cTestFixture
        Set psFunctionName to "ChangePadCommandToFunction"

        // Pad {source} to {dest} {length} -> Move (Pad(source, length)) to dest
        { Published = True }
        Procedure ChangePadCommandToFunction_VariableArgs
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Pad sVar to sResult 20' to sLine
            Move 'Move (Pad(sVar, 20)) to sResult' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangePadCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // A File.Field source stays intact as a single token.
        { Published = True }
        Procedure ChangePadCommandToFunction_FileFieldSource
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Pad MASKINER.RV1ART to ARTNR 20' to sLine
            Move 'Move (Pad(MASKINER.RV1ART, 20)) to ARTNR' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangePadCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Leading indentation is preserved.
        { Published = True }
        Procedure ChangePadCommandToFunction_PreservesIndent
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Pad sName to sPadded 30' to sLine
            Move '    Move (Pad(sName, 30)) to sPadded' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangePadCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // A line with no Pad command is unchanged and reports no change.
        { Published = True }
        Procedure ChangePadCommandToFunction_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move x to y' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangePadCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Move x to y' sLine
        End_Procedure

    End_Object
