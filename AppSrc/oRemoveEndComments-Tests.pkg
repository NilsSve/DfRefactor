    Object oRemoveEndComments is a cTestFixture
        Set psFunctionName to "RemoveEndComments"

        {Published = True}
        Procedure RemoveEndComments_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'End_Procedure   // This is a bla bla procedure' to sLine
            Move 'End_Procedure' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveEndComments of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure RemoveEndComments_2
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'End_Function   // This is an end function' to sLine
            Move 'End_Function' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveEndComments of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure RemoveEndComments_3
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'End_Class   // This class does bla bla bla' to sLine
            Move 'End_Class' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveEndComments of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure RemoveEndComments_4
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'End_Object   // This object does bla bla bla' to sLine
            Move 'End_Object' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveEndComments of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Plain End_Procedure with no comment: bChanged must be False, line unchanged.
        {Published = True}
        Procedure RemoveEndComments_NoChange
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'End_Procedure' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveEndComments of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'End_Procedure' sLine
        End_Procedure

        // Blank line: bLineIsReady guard fires, bChanged must be False.
        {Published = True}
        Procedure RemoveEndComments_BlankLine
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move '' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get RemoveEndComments of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
        End_Procedure

    End_Object
