    Object oAddUseFileExtension is a cTestFixture
        Set psFunctionName to "AddUseFileExtension"

        // Use cMyClass -> Use cMyClass.pkg
        { Published = True }
        Procedure AddUseFileExtension_AddsPkg
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Use cMyClass' to sLine
            Move 'Use cMyClass.pkg' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get AddUseFileExtension of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Already has the .pkg extension -> unchanged, reports no change.
        { Published = True }
        Procedure AddUseFileExtension_AlreadyPkg
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Use cMyClass.pkg' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get AddUseFileExtension of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Use cMyClass.pkg' sLine
        End_Procedure

        // A non-.pkg extension (.vw etc.) is left untouched.
        { Published = True }
        Procedure AddUseFileExtension_OtherExtension
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Use MyView.vw' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get AddUseFileExtension of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Use MyView.vw' sLine
        End_Procedure

        // Leading indentation and a trailing comment are preserved.
        { Published = True }
        Procedure AddUseFileExtension_PreservesIndentAndComment
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Use cBar  // grid base' to sLine
            Move '    Use cBar.pkg  // grid base' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get AddUseFileExtension of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // A non-Use line is returned unchanged and reports no change.
        { Published = True }
        Procedure AddUseFileExtension_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move x to y' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get AddUseFileExtension of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual 'Move x to y' sLine
        End_Procedure

    End_Object
