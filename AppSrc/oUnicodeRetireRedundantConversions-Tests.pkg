    // Unit tests for UnicodeRetireRedundantConversions (the eOtherFunction wrapper on ghoFuncLib).
    // It comments out a file's OWN global OEM/ANSI/UTF-8 conversion functions that now duplicate the
    // DataFlex (CharTranslate.pkg) built-ins - the duplicate-global 4390 fix. Reversible (comment, not
    // delete), only GLOBAL (top-level) definitions; a 2-line marker is inserted before each retired block
    // (so a retired def at input index 0 lands at output index 2).
    // Each test feeds a small synthetic source file as a String array and checks the count + an affected line.
    Object oUnicodeRetireRedundantConversions is a cTestFixture
        Set psFunctionName to "UnicodeRetireRedundantConversions"

        // A global OemToUtf8 definition is commented out (markers at 0..1, commented def at 2).
        {Published = True}
        Procedure URRC_OemToUtf8_Retired
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function OemToUtf8 Global String sValue Returns String" to asCode[0]
            Move "    String sResult"          to asCode[1]
            Move "    Function_Return sResult" to asCode[2]
            Move "End_Function"                to asCode[3]
            Get UnicodeRetireRedundantConversions of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "// Function OemToUtf8 Global String sValue Returns String" asCode[2]
        End_Procedure

        // A global Utf8ToOem definition is commented out too.
        {Published = True}
        Procedure URRC_Utf8ToOem_Retired
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function Utf8ToOem Global String sValue Returns String" to asCode[0]
            Move "    Function_Return sValue" to asCode[1]
            Move "End_Function"               to asCode[2]
            Get UnicodeRetireRedundantConversions of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 1)
            Send AssertSAreEqual "// Function Utf8ToOem Global String sValue Returns String" asCode[2]
        End_Procedure

        // Two conversion globals in one file -> both retired (count 2).
        {Published = True}
        Procedure URRC_MultipleInFile_Retired
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function OemToUtf8 Global String sValue Returns String" to asCode[0]
            Move "    Function_Return sValue" to asCode[1]
            Move "End_Function"               to asCode[2]
            Move "Function Utf8ToOem Global String sValue Returns String" to asCode[3]
            Move "    Function_Return sValue" to asCode[4]
            Move "End_Function"               to asCode[5]
            Get UnicodeRetireRedundantConversions of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 2)
        End_Procedure

        // A buffer-family global (MultiToWideBuffer) is in the retire set too.
        {Published = True}
        Procedure URRC_BufferFunction_Retired
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function MultiToWideBuffer Global DWord dw Pointer p Integer i Pointer pp Returns Integer" to asCode[0]
            Move "    Function_Return 0" to asCode[1]
            Move "End_Function"          to asCode[2]
            Get UnicodeRetireRedundantConversions of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 1)
        End_Procedure

        // NEGATIVE: a same-named METHOD inside a class is NOT global -> left untouched (count 0, line intact).
        {Published = True}
        Procedure URRC_MethodInClass_NotRetired
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Class cFoo is a cObject" to asCode[0]
            Move "    Function OemToUtf8 String sValue Returns String" to asCode[1]
            Move "        Function_Return sValue" to asCode[2]
            Move "    End_Function"       to asCode[3]
            Move "End_Class"              to asCode[4]
            Get UnicodeRetireRedundantConversions of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 0)
            Send AssertSAreEqual "    Function OemToUtf8 String sValue Returns String" asCode[1]
        End_Procedure

        // NEGATIVE: an unrelated global function is left untouched.
        {Published = True}
        Procedure URRC_UnrelatedGlobal_NotRetired
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "Function MyHelper Global String s Returns String" to asCode[0]
            Move "    Function_Return s" to asCode[1]
            Move "End_Function"          to asCode[2]
            Get UnicodeRetireRedundantConversions of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 0)
            Send AssertSAreEqual "Function MyHelper Global String s Returns String" asCode[0]
        End_Procedure

        // IDEMPOTENT: an already-commented block no longer starts with Function -> skipped (count 0).
        {Published = True}
        Procedure URRC_AlreadyCommented_Noop
            String[] asCode
            Integer iCount
            Send ClearFuncLibProperties of ghoFuncLib
            Move "// Function OemToUtf8 Global String sValue Returns String" to asCode[0]
            Move "//     Function_Return sValue" to asCode[1]
            Move "// End_Function"          to asCode[2]
            Get UnicodeRetireRedundantConversions of ghoFuncLib (&asCode) "" to iCount
            Send Assert (iCount = 0)
            Send AssertSAreEqual "// Function OemToUtf8 Global String sValue Returns String" asCode[0]
        End_Procedure

    End_Object
