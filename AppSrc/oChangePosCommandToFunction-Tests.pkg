    Object oChangePosCommandToFunction is a cTestFixture
        Set psFunctionName to "ChangePosCommandToFunction"

        {Published = True}
        Procedure ChangePosCommandToFunction_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Pos "-"  in sIns to iPos' to sLine
            Move 'Move (Pos("-",sIns)) to iPos' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangePosCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangePosCommandToFunction_2
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '   If (iA <> iB) Pos "   "  in sIns to iPos // End comment' to sLine
            Move '   If (iA <> iB) Move (Pos("   ",sIns)) to iPos // End comment' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangePosCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Line with no Pos command must be returned unchanged and return False.
        {Published = True}
        Procedure ChangePosCommandToFunction_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move x to y" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangePosCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "Move x to y" sLine
        End_Procedure

        // Variable arguments (not string literals); also verifies bChanged = True.
        {Published = True}
        Procedure ChangePosCommandToFunction_VariableArgs
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Pos sDelim in sValue to iPos" to sLine
            Move "Move (Pos(sDelim,sValue)) to iPos" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangePosCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

    End_Object
