        {Published = True}
        // Regression test: semicolon (line-continuation char) must stay outside the expression.
        // Bug: "Else If sStart gt "";" was becoming "Else If (sStart > "";)" -- semicolon trapped inside.
        Procedure ChangeLegacyOperators_24
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '           Else If sStart gt "";' to sLine
            Move '           Else If (sStart > "");' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLegacyOperators of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        {Published = True}
        Procedure ChangeLegacyOperators_25
            // Regression test: semicolon after a numeric literal must stay outside the parentheses.
            // Bug: "If (Length(sMin)) eq 1;" was becoming "If ((Length(sMin)) = 1;)" -- semicolon trapped inside.
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '        If (Length(sMin)) eq 1;' to sLine
            Move '        If ((Length(sMin)) = 1);' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLegacyOperators of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
