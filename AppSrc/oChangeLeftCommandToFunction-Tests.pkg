    Object oChangeLeftCommandToFunction is a cTestFixture
        Set psFunctionName to "ChangeLeftCommandToFunction"

        {Published = True}
        Procedure ChangeLeftCommandToFunction_1
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Left sPath  to sDir (iSepPos - 1)' to sLine
            Move 'Move (Left(sPath, (iSepPos - 1))) to sDir' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLeftCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Literal integer length parameter.
        {Published = True}
        Procedure ChangeLeftCommandToFunction_2
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Left sText to sResult 5' to sLine
            Move 'Move (Left(sText, 5)) to sResult' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLeftCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Leading indentation is preserved.
        {Published = True}
        Procedure ChangeLeftCommandToFunction_3
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move '    Left sPath to sDir (iSepPos - 1)' to sLine
            Move '    Move (Left(sPath, (iSepPos - 1))) to sDir' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLeftCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // No Left command present -- bChanged must be False.
        {Published = True}
        Procedure ChangeLeftCommandToFunction_4
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'Move sA to sB' to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLeftCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send Assert (bChanged = False)
        End_Procedure

        // Proper no-match guard: line unchanged and bChanged = False.
        {Published = True}
        Procedure ChangeLeftCommandToFunction_NoMatch
            String sLine
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Move x to y" to sLine
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLeftCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send AssertFalse bChanged
            Send AssertSAreEqual "Move x to y" sLine
        End_Procedure

        // Regression (2026-06-10 audit): an identifier CONTAINING the keyword in the
        // nose must not hijack the splice point. The old bare Pos("left", ...)
        // matched inside "iLeftMargin" and split the line there. (Single space
        // before "Move": the "*" concatenation normalizes the nose's trailing
        // space - verified by the DFUnit run.)
        {Published = True}
        Procedure ChangeLeftCommandToFunction_NoseContainsLeft
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move 'If (iLeftMargin > 0) Left sText to sX 5' to sLine
            Move 'If (iLeftMargin > 0) Move (Left(sText, 5)) to sX' to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLeftCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

        // Variable length argument; also verifies bChanged = True.
        {Published = True}
        Procedure ChangeLeftCommandToFunction_bChanged
            String sLine sExpected
            Boolean bChanged
            tTokenizer TokenizerData
            Move "Left sText to sResult iLen" to sLine
            Move "Move (Left(sText, iLen)) to sResult" to sExpected
            Get Tokenizer of ghoFuncLib sLine to TokenizerData
            Get ChangeLeftCommandToFunction of ghoFuncLib (&sLine) to bChanged
            Send Assert bChanged
            Send AssertSAreEqual sExpected sLine
        End_Procedure

    End_Object
